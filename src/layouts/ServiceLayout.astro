---
import BaseLayout from './BaseLayout.astro';
import Hero from '../components/Hero.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import ReviewStrip from '../components/ReviewStrip.astro';
import ThreeStep from '../components/ThreeStep.astro';
import AreaGrid from '../components/AreaGrid.astro';
import ContactFormSection from '../components/ContactFormSection.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Schema from '../components/Schema.astro';
import { SITE } from '../lib/site';
import { getAllPosts } from '../lib/blog';
const BLOG_POSTS = await getAllPosts();

interface Props {
  slug: string;
  title: string;          // SEO title
  description: string;    // meta description
  h1: string;
  eyebrow?: string;
  subtitle?: string;
  heroImage?: string;
  serviceName: string;    // schema service name
  serviceType?: string;   // schema service type (optional)
  faqs: { q: string; a: string }[];
  related?: { href: string; label: string }[];
  enhanced?: boolean;     // opt-in richer sidebar (review + GBP map + expandable links)
}
const {
  slug, title, description, h1, eyebrow, subtitle, heroImage,
  serviceName, serviceType = 'HVAC Service', faqs, related = [], enhanced = false,
} = Astro.props;

const breadcrumbs = [
  { name: 'Home', url: `${SITE.url}/` },
  { name: 'Services', url: `${SITE.url}/services/` },
  { name: serviceName, url: `${SITE.url}/services/${slug}/` },
];

const serviceSchema = {
  name: serviceName,
  serviceType,
  areaServed: SITE.serviceAreas.map(a => ({ '@type': /county/i.test(a.name) ? 'AdministrativeArea' : 'City', name: a.name, containedInPlace: { '@type': 'State', name: 'Florida' } })),
  description,
  url: `${SITE.url}/services/${slug}/`,
  inLanguage: 'en-US',
  offers: { '@type': 'Offer', availability: 'https://schema.org/InStock', areaServed: SITE.serviceAreas.map(a => a.name) },
  // aggregateRating intentionally NOT set here - it lives only on the HVACBusiness
  // @graph entity. Two aggregateRatings on one page triggers GSC's "Review has
  // multiple aggregate ratings" error (Service block + global business).
  brand: { '@type': 'Brand', name: SITE.name },
  speakable: {
    '@type': 'SpeakableSpecification',
    xpath: ['/html/head/title', '/html/body//h1', '/html/body//h2[1]', '/html/body//p[1]'],
  },
};
const relatedGuides = BLOG_POSTS
  .filter((post) => {
    const haystack = `${post.title} ${post.description} ${post.primaryService.label}`.toLowerCase();
    return serviceName.toLowerCase().split(' ').some((word) => word.length > 4 && haystack.includes(word));
  })
  .slice(0, 3);
const guides = relatedGuides.length ? relatedGuides : BLOG_POSTS.slice(0, 3);

// --- Enhanced sidebar data ---
const gbpUrl = SITE.socials.google;
const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(`${SITE.address.street} ${SITE.address.city} ${SITE.address.region} ${SITE.address.postalCode}`)}&z=11&output=embed`;
const sidebarReview = { t: 'Look no further for reliable and reasonable pricing on AC equipment and repair. The tech was outstanding. Owner Tim is the real deal - a customer-focused owner.', a: 'John Shackelford' };
const otherServices = SITE.services.filter((s) => s.slug !== slug);
---
<BaseLayout title={title} description={description} breadcrumbs={breadcrumbs}>
  <Hero
    eyebrow={eyebrow || serviceName}
    title={h1}
    subtitle={subtitle || description}
    image={heroImage}
    showForm={true}
    ctaLabel="Book This Service"
    ctaHref={SITE.bookUrl}
  />

  <section class="py-14 md:py-20">
    <div class="container-site grid lg:grid-cols-12 gap-10">
      <article class="lg:col-span-8 prose-icac">
        <div class="not-prose flex items-center gap-3 mb-6 pb-4 border-b border-slate-100">
          <img src="/images/Tim%20Hawk%20(ICAC%20Owner).webp" alt={`${SITE.owner}, Owner`} title={`${SITE.owner}, Owner - I Care Air Care`} class="w-10 h-10 rounded-full ring-2 ring-brand-100 object-cover object-top shrink-0" width="40" height="40" loading="lazy" />
          <div class="text-[13px] text-slate-600 leading-snug">
            <span>Reviewed by <a href="/tim-hawk/" class="font-semibold text-navy-700 hover:text-brand-700">{SITE.owner}</a> · Florida License <strong class="text-navy-700">{SITE.license}</strong> · EPA 608 Universal</span>
          </div>
        </div>
        <slot />
      </article>
      <aside class="lg:col-span-4 space-y-6">
        <div class="rounded-xl bg-brand-500 text-white p-6 shadow-[var(--shadow-soft)]">
          <h3 class="text-white font-bold text-lg">Need help now?</h3>
          <p class="mt-2 text-blue-50 text-sm leading-relaxed">Call our Wesley Chapel team for same-day {serviceName.toLowerCase()} when the schedule allows. We'll give you the earliest available arrival window before dispatch.</p>
          <a href={SITE.phoneHref} class="mt-4 inline-flex w-full justify-center items-center gap-2 rounded-md bg-accent-500 hover:bg-accent-600 text-white font-bold px-4 py-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.21 11.36 11.36 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.58 1 1 0 01-.21 1.11l-2.2 2.1z"/></svg>
            {SITE.phone}
          </a>
          <a href={SITE.bookUrl} target="_blank" rel="noopener" class="mt-2 inline-flex w-full justify-center items-center gap-2 rounded-md bg-white/10 border border-white/30 hover:bg-white/20 text-white font-semibold px-4 py-3">Book Online</a>
          <ul class="mt-5 space-y-2 text-sm text-blue-50">
            <li>✓ Licensed & insured · CAC1816515</li>
            <li>✓ 1-year repair warranty</li>
            <li>✓ Upfront flat-rate pricing</li>
            <li>✓ 4.9★ · {SITE.rating.count}+ Google reviews</li>
          </ul>
        </div>

        {enhanced && (
          <div class="rounded-xl bg-white ring-1 ring-slate-200 p-6 shadow-[var(--shadow-card)]">
            <div class="flex items-center justify-between">
              <div class="inline-flex gap-0.5" role="img" aria-label="5 out of 5 stars">
                {[0,1,2,3,4].map(() => (
                  <svg width="15" height="15" viewBox="0 0 24 24" aria-hidden="true"><path fill="#fbbc04" d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01z"/></svg>
                ))}
              </div>
              <span class="text-[11px] font-bold text-slate-500 uppercase tracking-wide">{SITE.rating.value}★ · {SITE.rating.count}+ reviews</span>
            </div>
            <p class="mt-3 text-[14.5px] text-slate-700 leading-relaxed italic">“{sidebarReview.t}”</p>
            <div class="mt-2 text-[13px] font-bold text-navy-700">- {sidebarReview.a}</div>
            <a href={gbpUrl} target="_blank" rel="noopener" class="mt-3 inline-flex items-center gap-1 text-brand-700 font-semibold hover:text-brand-800 text-[14px]">Read all {SITE.rating.count}+ reviews on Google →</a>
          </div>
        )}

        {enhanced && (
          <div class="rounded-xl bg-white ring-1 ring-slate-200 overflow-hidden shadow-[var(--shadow-card)]">
            <div class="aspect-[4/3] bg-slate-100">
              <iframe data-lazy-src={mapSrc} title={`${SITE.name} location - Wesley Chapel, FL`} class="w-full h-full border-0" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
            <div class="p-5">
              <h3 class="font-bold text-navy-700 text-lg">Visit us on Google</h3>
              <p class="mt-1 text-[14px] text-slate-600">{SITE.address.street}, {SITE.address.city}, {SITE.address.region} {SITE.address.postalCode}</p>
              <a href={gbpUrl} target="_blank" rel="noopener" class="mt-3 inline-flex items-center gap-1.5 rounded-md bg-white ring-1 ring-slate-200 hover:ring-brand-300 px-3 py-2 text-[14px] font-semibold text-navy-700">
                <svg width="15" height="15" viewBox="0 0 24 24" aria-hidden="true"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09A6.6 6.6 0 015.49 12c0-.73.13-1.43.35-2.09V7.07H2.18A10.96 10.96 0 001 12c0 1.77.42 3.45 1.18 4.93z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                View our Google Business Profile →
              </a>
            </div>
          </div>
        )}

        {enhanced ? (
          <details open class="iac-disclose rounded-xl bg-surface ring-1 ring-slate-200 p-6">
            <summary class="flex items-center justify-between cursor-pointer list-none font-bold text-navy-700 text-lg">
              Related services
              <svg class="iac-disclose__chev w-5 h-5 text-slate-400 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <ul class="mt-4 space-y-2 text-[14.5px]">
              {otherServices.map((s) => (
                <li><a class="text-brand-700 hover:text-brand-800 underline underline-offset-2" href={`/services/${s.slug}/`}>{s.name}</a></li>
              ))}
            </ul>
          </details>
        ) : (related.length > 0 && (
          <div class="rounded-xl bg-surface ring-1 ring-slate-200 p-6">
            <h3 class="font-bold text-navy-700 text-lg">Related services</h3>
            <ul class="mt-3 space-y-2 text-[15px]">
              {related.map(r => (
                <li><a class="text-brand-700 hover:text-brand-800 underline underline-offset-2" href={r.href}>{r.label}</a></li>
              ))}
            </ul>
          </div>
        ))}

        {enhanced ? (
          <details open class="iac-disclose rounded-xl bg-surface ring-1 ring-slate-200 p-6">
            <summary class="flex items-center justify-between cursor-pointer list-none font-bold text-navy-700 text-lg">
              Service area
              <svg class="iac-disclose__chev w-5 h-5 text-slate-400 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <ul class="mt-4 grid grid-cols-2 gap-x-4 gap-y-2 text-[14.5px]">
              {SITE.serviceAreas.map((a) => (
                <li><a class="text-brand-700 hover:text-brand-800 underline underline-offset-2" href={`/service-areas/${a.slug}/`}>{a.name}</a></li>
              ))}
            </ul>
            <a href="/service-areas/" class="mt-4 inline-flex items-center gap-1 text-brand-700 font-semibold hover:text-brand-800">See all areas →</a>
          </details>
        ) : (
          <div class="rounded-xl bg-surface ring-1 ring-slate-200 p-6">
            <h3 class="font-bold text-navy-700 text-lg">Service area</h3>
            <p class="mt-2 text-[14.5px] text-slate-600">Wesley Chapel · Tampa · Land O' Lakes · New Tampa · Lutz · Odessa · Zephyrhills · Pasco · Hillsborough · Polk County.</p>
            <a href="/service-areas/" class="mt-3 inline-flex items-center gap-1 text-brand-700 font-semibold hover:text-brand-800">See all areas →</a>
          </div>
        )}
      </aside>
    </div>
  </section>

  <section class="py-12 bg-surface">
    <div class="container-site">
      <div class="max-w-3xl">
        <span class="inline-flex rounded-md bg-white ring-1 ring-slate-200 text-brand-700 text-xs font-semibold px-2.5 py-1">Helpful guides</span>
        <h2 class="mt-3 text-2xl md:text-3xl">Homeowner guides related to {serviceName}</h2>
      </div>
      <div class="mt-6 grid md:grid-cols-3 gap-4">
        {guides.map((post) => (
          <a href={`/blogs/${post.slug}/`} class="group rounded-xl bg-white ring-1 ring-slate-200 p-5 hover:shadow-[var(--shadow-card)] transition">
            <div class="text-xs font-semibold text-brand-700">{post.tag}</div>
            <h3 class="mt-2 text-lg font-bold text-navy-700 group-hover:text-brand-700 leading-snug">{post.title}</h3>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">{post.description}</p>
            <span class="mt-4 inline-flex text-sm font-semibold text-accent-500">Read guide →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <WhyChooseUs />
  <ThreeStep />
  <ReviewStrip />
  <AreaGrid />
  <FAQ title={`${serviceName} FAQs`} items={faqs} />
  <FinalCTA />
  <ContactFormSection />

  <Schema type="Service" data={serviceSchema} />
  <Schema type="FAQPage" faqs={faqs.map(f => ({ q: f.q, a: f.a.replace(/<[^>]*>/g,'') }))} />
</BaseLayout>

<style is:global>
  .iac-disclose summary::-webkit-details-marker { display: none; }
  .iac-disclose summary::marker { content: ''; }
  .iac-disclose[open] .iac-disclose__chev { transform: rotate(180deg); }
</style>
