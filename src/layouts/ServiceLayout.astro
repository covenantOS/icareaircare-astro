---
import BaseLayout from './BaseLayout.astro';
import Hero from '../components/Hero.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import ReviewStrip from '../components/ReviewStrip.astro';
import ThreeStep from '../components/ThreeStep.astro';
import AreaGrid from '../components/AreaGrid.astro';
import ContactFormSection from '../components/ContactFormSection.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Schema from '../components/Schema.astro';
import { SITE, formatToday } from '../lib/site';
import { BLOG_POSTS } from '../lib/blog';

interface Props {
  slug: string;
  title: string;          // SEO title
  description: string;    // meta description
  h1: string;
  eyebrow?: string;
  subtitle?: string;
  heroImage?: string;
  serviceName: string;    // schema service name
  serviceType?: string;   // schema service type (optional)
  faqs: { q: string; a: string }[];
  related?: { href: string; label: string }[];
  /** Optional schema price range like "$150-$3200" */
  priceRange?: string;
  /** Featured area pages to deep-link from this service page */
  areaLinks?: { href: string; label: string; note?: string }[];
}
const {
  slug, title, description, h1, eyebrow, subtitle, heroImage,
  serviceName, serviceType = 'HVAC Service', faqs, related = [],
  priceRange, areaLinks,
} = Astro.props;

const breadcrumbs = [
  { name: 'Home', url: `${SITE.url}/` },
  { name: 'Services', url: `${SITE.url}/services/` },
  { name: serviceName, url: `${SITE.url}/services/${slug}/` },
];

const serviceSchema: Record<string, any> = {
  name: serviceName,
  serviceType,
  areaServed: SITE.serviceAreas.map(a => ({ '@type': 'City', name: a.name, containedInPlace: { '@type': 'State', name: 'Florida' } })),
  description,
  url: `${SITE.url}/services/${slug}/`,
};
if (priceRange) serviceSchema.priceRange = priceRange;

const relatedGuides = BLOG_POSTS
  .filter((post) => {
    const haystack = `${post.title} ${post.description} ${post.primaryService.label}`.toLowerCase();
    return serviceName.toLowerCase().split(' ').some((word) => word.length > 4 && haystack.includes(word));
  })
  .slice(0, 3);
const guides = relatedGuides.length ? relatedGuides : BLOG_POSTS.slice(0, 3);

// Default contextual area links per service page if none passed.
const defaultAreaLinks = [
  { href: '/service-areas/wesley-chapel-ac-repair/', label: `${serviceName} in Wesley Chapel`, note: 'Foamflower Blvd HQ' },
  { href: '/service-areas/new-tampa-heating-and-cooling/', label: `${serviceName} in New Tampa`, note: 'Tampa Palms · K-Bar Ranch' },
  { href: '/service-areas/land-o-lakes-hvac-services/', label: `${serviceName} in Land O' Lakes`, note: 'Bexley · Connerton' },
];
const areas = areaLinks && areaLinks.length ? areaLinks : defaultAreaLinks;

const today = formatToday();
---
<BaseLayout title={title} description={description} breadcrumbs={breadcrumbs} heroPreload={heroImage}>
  <Hero
    eyebrow={eyebrow || serviceName}
    title={h1}
    subtitle={subtitle || description}
    image={heroImage}
    showForm={true}
    ctaLabel="Book This Service"
  />

  <section class="py-14 md:py-20">
    <div class="container-site grid lg:grid-cols-12 gap-10">
      <article class="lg:col-span-8 prose-icac">
        <div class="not-prose flex flex-wrap items-center gap-3 text-sm text-slate-500 mb-6 border-b border-slate-100 pb-4">
          <span class="inline-flex items-center gap-2">
            <img src="/images/tim-hawk-owner.webp" alt="Tim Hawk, Owner of I Care Air Care" class="w-7 h-7 rounded-full object-cover ring-1 ring-slate-200" width="28" height="28" loading="lazy" />
            <span><span class="text-slate-400">Reviewed by</span> <a class="text-navy-700 font-semibold hover:text-brand-600" href="/about-us/#tim-hawk">Tim Hawk</a> <span class="text-slate-400">— Owner & Master HVAC Tech, FL {SITE.license}</span></span>
          </span>
          <span class="text-slate-300">·</span>
          <span><span class="text-slate-400">Updated</span> {today}</span>
        </div>
        <slot />
        <p class="not-prose mt-12 text-sm text-slate-500 italic">Page reviewed and updated {today} by Tim Hawk, owner of I Care Air Care, Florida HVAC license {SITE.license}.</p>
      </article>
      <aside class="lg:col-span-4 space-y-6">
        <div class="rounded-xl bg-brand-500 text-white p-6 shadow-[var(--shadow-soft)]">
          <h3 class="text-white font-bold text-lg">Need help now?</h3>
          <p class="mt-2 text-blue-50 text-sm leading-relaxed">Call our Wesley Chapel team for same-day {serviceName.toLowerCase()} when the schedule allows. We'll give you the earliest available arrival window before dispatch.</p>
          <a href={SITE.phoneHref} class="mt-4 inline-flex w-full justify-center items-center gap-2 rounded-md bg-accent-500 hover:bg-accent-600 text-white font-bold px-4 py-3" aria-label={`Call our Wesley Chapel ${serviceName.toLowerCase()} team — ${SITE.phone}`}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.21 11.36 11.36 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.58 1 1 0 01-.21 1.11l-2.2 2.1z"/></svg>
            Talk to a tech · {SITE.phone}
          </a>
          <a href={SITE.bookPath} class="mt-2 inline-flex w-full justify-center items-center gap-2 rounded-md bg-white/10 border border-white/30 hover:bg-white/20 text-white font-semibold px-4 py-3">Book Online</a>
          <ul class="mt-5 space-y-2 text-sm text-blue-50">
            <li>✓ Licensed & insured · CAC1816515</li>
            <li>✓ 1-year repair warranty</li>
            <li>✓ Upfront flat-rate pricing</li>
            <li>✓ 4.9★ · {SITE.rating.count}+ Google reviews</li>
          </ul>
        </div>

        {related.length > 0 && (
          <div class="rounded-xl bg-surface ring-1 ring-slate-200 p-6">
            <h3 class="font-bold text-navy-700 text-lg">Related services</h3>
            <ul class="mt-3 space-y-2 text-[15px]">
              {related.map(r => (
                <li><a class="text-brand-600 hover:text-brand-700 underline underline-offset-2" href={r.href}>{r.label}</a></li>
              ))}
            </ul>
          </div>
        )}

        <div class="rounded-xl bg-surface ring-1 ring-slate-200 p-6">
          <h3 class="font-bold text-navy-700 text-lg">{serviceName} in your neighborhood</h3>
          <ul class="mt-3 space-y-2 text-[15px]">
            {areas.map(a => (
              <li>
                <a class="text-brand-600 hover:text-brand-700 underline underline-offset-2 font-semibold" href={a.href}>{a.label}</a>
                {a.note && <div class="text-xs text-slate-500 mt-0.5">{a.note}</div>}
              </li>
            ))}
          </ul>
          <a href="/service-areas/" class="mt-4 inline-flex items-center gap-1 text-brand-600 font-semibold hover:text-brand-700">See all 9 service areas →</a>
        </div>
      </aside>
    </div>
  </section>

  <section class="py-12 bg-surface">
    <div class="container-site">
      <div class="max-w-3xl">
        <span class="inline-flex rounded-md bg-white ring-1 ring-slate-200 text-brand-700 text-xs font-semibold px-2.5 py-1">Helpful guides</span>
        <h2 class="mt-3 text-2xl md:text-3xl">Homeowner guides related to {serviceName}</h2>
      </div>
      <div class="mt-6 grid md:grid-cols-3 gap-4">
        {guides.map((post) => (
          <a href={`/${post.slug}/`} class="group rounded-xl bg-white ring-1 ring-slate-200 p-5 hover:shadow-[var(--shadow-card)] transition">
            <div class="text-xs font-semibold text-brand-600">{post.tag}</div>
            <h3 class="mt-2 text-lg font-bold text-navy-700 group-hover:text-brand-600 leading-snug">{post.title}</h3>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">{post.description}</p>
            <span class="mt-4 inline-flex text-sm font-semibold text-accent-500">Read guide →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <WhyChooseUs />
  <ThreeStep />
  <ReviewStrip />
  <AreaGrid />
  <FAQ title={`${serviceName} FAQs`} items={faqs} />
  <FinalCTA />
  <ContactFormSection />

  <Schema type="Service" data={serviceSchema} />
  <Schema type="FAQPage" faqs={faqs.map(f => ({ q: f.q, a: f.a.replace(/<[^>]*>/g,'') }))} />
  <slot name="extraSchema" />
</BaseLayout>
