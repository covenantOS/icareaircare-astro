---
import BaseLayout from './BaseLayout.astro';
import Hero from '../components/Hero.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import ReviewStrip from '../components/ReviewStrip.astro';
import ThreeStep from '../components/ThreeStep.astro';
import AreaGrid from '../components/AreaGrid.astro';
import ContactFormSection from '../components/ContactFormSection.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Schema from '../components/Schema.astro';
import { SITE } from '../lib/site';
import { getAllPosts } from '../lib/blog';
const BLOG_POSTS = await getAllPosts();

interface Props {
  slug: string;
  title: string;          // SEO title
  description: string;    // meta description
  h1: string;
  eyebrow?: string;
  subtitle?: string;
  heroImage?: string;
  serviceName: string;    // schema service name
  serviceType?: string;   // schema service type (optional)
  faqs: { q: string; a: string }[];
  related?: { href: string; label: string }[];
}
const {
  slug, title, description, h1, eyebrow, subtitle, heroImage,
  serviceName, serviceType = 'HVAC Service', faqs, related = [],
} = Astro.props;

const breadcrumbs = [
  { name: 'Home', url: `${SITE.url}/` },
  { name: 'Services', url: `${SITE.url}/services/` },
  { name: serviceName, url: `${SITE.url}/services/${slug}/` },
];

const serviceSchema = {
  name: serviceName,
  serviceType,
  areaServed: SITE.serviceAreas.map(a => ({ '@type': 'City', name: a.name, containedInPlace: { '@type': 'State', name: 'Florida' } })),
  description,
  url: `${SITE.url}/services/${slug}/`,
  inLanguage: 'en-US',
  offers: { '@type': 'Offer', availability: 'https://schema.org/InStock', areaServed: SITE.serviceAreas.map(a => a.name) },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: SITE.rating.value,
    reviewCount: SITE.rating.count,
    bestRating: 5,
  },
  brand: { '@type': 'Brand', name: SITE.name },
  speakable: {
    '@type': 'SpeakableSpecification',
    xpath: ['/html/head/title', '/html/body//h1', '/html/body//h2[1]', '/html/body//p[1]'],
  },
};
const relatedGuides = BLOG_POSTS
  .filter((post) => {
    const haystack = `${post.title} ${post.description} ${post.primaryService.label}`.toLowerCase();
    return serviceName.toLowerCase().split(' ').some((word) => word.length > 4 && haystack.includes(word));
  })
  .slice(0, 3);
const guides = relatedGuides.length ? relatedGuides : BLOG_POSTS.slice(0, 3);
---
<BaseLayout title={title} description={description} breadcrumbs={breadcrumbs}>
  <Hero
    eyebrow={eyebrow || serviceName}
    title={h1}
    subtitle={subtitle || description}
    image={heroImage}
    showForm={true}
    ctaLabel="Book This Service"
    ctaHref={SITE.bookUrl}
  />

  <section class="py-14 md:py-20">
    <div class="container-site grid lg:grid-cols-12 gap-10">
      <article class="lg:col-span-8 prose-icac">
        <div class="not-prose flex items-center gap-3 mb-6 pb-4 border-b border-slate-100">
          <img src="/images/Tim%20Hawk%20(ICAC%20Owner).webp" alt={`${SITE.owner}, Owner`} class="w-10 h-10 rounded-full ring-2 ring-brand-100 object-cover object-top shrink-0" width="40" height="40" loading="lazy" />
          <div class="text-[13px] text-slate-600 leading-snug">
            <span>Reviewed by <a href="/tim-hawk/" class="font-semibold text-navy-700 hover:text-brand-700">{SITE.owner}</a> · Florida License <strong class="text-navy-700">{SITE.license}</strong> · EPA 608 Universal</span>
            <span class="block text-[11.5px] text-slate-500 mt-0.5">Updated {new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</span>
          </div>
        </div>
        <slot />
      </article>
      <aside class="lg:col-span-4 space-y-6">
        <div class="rounded-xl bg-brand-500 text-white p-6 shadow-[var(--shadow-soft)]">
          <h3 class="text-white font-bold text-lg">Need help now?</h3>
          <p class="mt-2 text-blue-50 text-sm leading-relaxed">Call our Wesley Chapel team for same-day {serviceName.toLowerCase()} when the schedule allows. We'll give you the earliest available arrival window before dispatch.</p>
          <a href={SITE.phoneHref} class="mt-4 inline-flex w-full justify-center items-center gap-2 rounded-md bg-accent-500 hover:bg-accent-600 text-white font-bold px-4 py-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.21 11.36 11.36 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.58 1 1 0 01-.21 1.11l-2.2 2.1z"/></svg>
            {SITE.phone}
          </a>
          <a href={SITE.bookUrl} target="_blank" rel="noopener" class="mt-2 inline-flex w-full justify-center items-center gap-2 rounded-md bg-white/10 border border-white/30 hover:bg-white/20 text-white font-semibold px-4 py-3">Book Online</a>
          <ul class="mt-5 space-y-2 text-sm text-blue-50">
            <li>✓ Licensed & insured · CAC1816515</li>
            <li>✓ 1-year repair warranty</li>
            <li>✓ Upfront flat-rate pricing</li>
            <li>✓ 4.9★ · {SITE.rating.count}+ Google reviews</li>
          </ul>
        </div>

        {related.length > 0 && (
          <div class="rounded-xl bg-surface ring-1 ring-slate-200 p-6">
            <h3 class="font-bold text-navy-700 text-lg">Related services</h3>
            <ul class="mt-3 space-y-2 text-[15px]">
              {related.map(r => (
                <li><a class="text-brand-700 hover:text-brand-800 underline underline-offset-2" href={r.href}>{r.label}</a></li>
              ))}
            </ul>
          </div>
        )}

        <div class="rounded-xl bg-surface ring-1 ring-slate-200 p-6">
          <h3 class="font-bold text-navy-700 text-lg">Service area</h3>
          <p class="mt-2 text-[14.5px] text-slate-600">Wesley Chapel · Tampa · Land O' Lakes · New Tampa · Lutz · Odessa · Zephyrhills · Pasco · Hillsborough · Polk County.</p>
          <a href="/service-areas/" class="mt-3 inline-flex items-center gap-1 text-brand-700 font-semibold hover:text-brand-800">See all areas →</a>
        </div>
      </aside>
    </div>
  </section>

  <section class="py-12 bg-surface">
    <div class="container-site">
      <div class="max-w-3xl">
        <span class="inline-flex rounded-md bg-white ring-1 ring-slate-200 text-brand-700 text-xs font-semibold px-2.5 py-1">Helpful guides</span>
        <h2 class="mt-3 text-2xl md:text-3xl">Homeowner guides related to {serviceName}</h2>
      </div>
      <div class="mt-6 grid md:grid-cols-3 gap-4">
        {guides.map((post) => (
          <a href={`/blogs/${post.slug}/`} class="group rounded-xl bg-white ring-1 ring-slate-200 p-5 hover:shadow-[var(--shadow-card)] transition">
            <div class="text-xs font-semibold text-brand-700">{post.tag}</div>
            <h3 class="mt-2 text-lg font-bold text-navy-700 group-hover:text-brand-700 leading-snug">{post.title}</h3>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">{post.description}</p>
            <span class="mt-4 inline-flex text-sm font-semibold text-accent-500">Read guide →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <WhyChooseUs />
  <ThreeStep />
  <ReviewStrip />
  <AreaGrid />
  <FAQ title={`${serviceName} FAQs`} items={faqs} />
  <FinalCTA />
  <ContactFormSection />

  <Schema type="Service" data={serviceSchema} />
  <Schema type="FAQPage" faqs={faqs.map(f => ({ q: f.q, a: f.a.replace(/<[^>]*>/g,'') }))} />
</BaseLayout>
