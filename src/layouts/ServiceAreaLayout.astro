---
import BaseLayout from './BaseLayout.astro';
import Hero from '../components/Hero.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import ReviewStrip from '../components/ReviewStrip.astro';
import ThreeStep from '../components/ThreeStep.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import ContactFormSection from '../components/ContactFormSection.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Schema from '../components/Schema.astro';
import { SITE, formatToday } from '../lib/site';

interface LocalReview { name: string; neighborhood?: string; body: string; rating?: number; }
interface Landmark { name: string; note?: string; }
interface Stat { label: string; value: string; }

interface Props {
  slug: string;
  title: string;
  description: string;
  h1: string;
  eyebrow?: string;
  subtitle?: string;
  cityName: string;
  heroImage?: string;
  faqs: { q: string; a: string }[];
  neighborhoods?: string[];
  landmarks?: Landmark[];
  climateNote?: string;
  stats?: Stat[];
  reviews?: LocalReview[];
  responseWindow?: string;
  driveTime?: string;
  zipCodes?: string[];
  geo?: { lat: number; lng: number };
  mapEmbed?: string;
  schoolsOrHoas?: string[];
  relatedAreas?: { slug: string; name: string; note?: string }[];
}
const {
  slug, title, description, h1, eyebrow, subtitle, cityName, heroImage,
  faqs, neighborhoods = [], landmarks = [], climateNote, stats = [],
  reviews = [], responseWindow = 'Call for current ETA', driveTime,
  zipCodes = [], geo, mapEmbed, schoolsOrHoas = [], relatedAreas = [],
} = Astro.props;

const breadcrumbs = [
  { name: 'Home', url: `${SITE.url}/` },
  { name: 'Service Areas', url: `${SITE.url}/service-areas/` },
  { name: cityName, url: `${SITE.url}/service-areas/${slug}/` },
];

const defaultMap = geo
  ? `https://www.google.com/maps?q=${geo.lat},${geo.lng}&z=12&output=embed`
  : `https://www.google.com/maps?q=${encodeURIComponent(cityName + ', FL')}&z=12&output=embed`;
const embedSrc = mapEmbed || defaultMap;

const areaSchema: any = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'HVAC Services',
  provider: { '@id': `${SITE.url}/#business` },
  areaServed: {
    '@type': 'City',
    name: cityName,
    containedInPlace: { '@type': 'State', name: 'Florida' },
    ...(geo ? { geo: { '@type': 'GeoCoordinates', latitude: geo.lat, longitude: geo.lng } } : {}),
  },
  name: `HVAC Services in ${cityName}, FL`,
  description,
  url: `${SITE.url}/service-areas/${slug}/`,
  offers: {
    '@type': 'Offer',
    priceCurrency: 'USD',
    priceRange: '$89-$14500',
    availability: 'https://schema.org/InStock',
    availableChannel: {
      '@type': 'ServiceChannel',
      servicePhone: SITE.phone,
      serviceUrl: `${SITE.url}${SITE.bookPath}`,
    },
  },
};

const today = formatToday();
---
<BaseLayout title={title} description={description} breadcrumbs={breadcrumbs} heroPreload={heroImage}>
  <Hero
    eyebrow={eyebrow || `${cityName}, FL`}
    title={h1}
    subtitle={subtitle || description}
    image={heroImage}
    showForm={true}
    ctaLabel={`Get Help in ${cityName}`}
  />

  <!-- Local quick-facts bar -->
  <section class="bg-white border-b border-slate-100">
    <div class="container-site py-6 grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="flex items-start gap-3">
        <div class="shrink-0 w-10 h-10 rounded-lg bg-brand-50 text-brand-600 flex items-center justify-center">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a7 7 0 00-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 00-7-7zm0 10a3 3 0 110-6 3 3 0 010 6z"/></svg>
        </div>
        <div>
          <div class="text-[11px] uppercase tracking-[0.14em] text-slate-500">Dispatch from</div>
          <div class="font-bold text-navy-700 text-sm">Wesley Chapel HQ</div>
          <div class="text-xs text-slate-500">Foamflower Blvd.{driveTime && ` · ${driveTime}`}</div>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <div class="shrink-0 w-10 h-10 rounded-lg bg-brand-50 text-brand-600 flex items-center justify-center">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 100 20 10 10 0 000-20zm1 11h-6v-2h4V6h2v7z"/></svg>
        </div>
        <div>
          <div class="text-[11px] uppercase tracking-[0.14em] text-slate-500">Scheduling</div>
          <div class="font-bold text-navy-700 text-sm">{responseWindow}</div>
          <div class="text-xs text-slate-500">Same-day when available</div>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <div class="shrink-0 w-10 h-10 rounded-lg bg-brand-50 text-brand-600 flex items-center justify-center">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6 4.4 2.3 7.4L12 16.9l-6.3 4.3L8 13.8 2 9.4h7.6z"/></svg>
        </div>
        <div>
          <div class="text-[11px] uppercase tracking-[0.14em] text-slate-500">Google rating</div>
          <div class="font-bold text-navy-700 text-sm">{SITE.rating.value}★ · {SITE.rating.count}+ reviews</div>
          <div class="text-xs text-slate-500">Tampa Bay area</div>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <div class="shrink-0 w-10 h-10 rounded-lg bg-brand-50 text-brand-600 flex items-center justify-center">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l8 3v6c0 5-3.4 9.6-8 11-4.6-1.4-8-6-8-11V5l8-3z"/></svg>
        </div>
        <div>
          <div class="text-[11px] uppercase tracking-[0.14em] text-slate-500">License</div>
          <div class="font-bold text-navy-700 text-sm">FL {SITE.license}</div>
          <div class="text-xs text-slate-500">Bonded & insured</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Main content + sidebar -->
  <section class="py-14 md:py-20 bg-surface">
    <div class="container-site grid lg:grid-cols-12 gap-10">
      <article class="lg:col-span-8 prose-icac bg-white rounded-2xl ring-1 ring-slate-200 p-6 md:p-8 shadow-[var(--shadow-card)]">
        <div class="not-prose flex flex-wrap items-center gap-3 text-sm text-slate-500 mb-6 border-b border-slate-100 pb-4">
          <span class="inline-flex items-center gap-2">
            <img src="/images/tim-hawk-owner.webp" alt="Tim Hawk, Owner of I Care Air Care" class="w-7 h-7 rounded-full object-cover ring-1 ring-slate-200" width="28" height="28" loading="lazy" />
            <span><span class="text-slate-400">Reviewed by</span> <a class="text-navy-700 font-semibold hover:text-brand-600" href="/about-us/#tim-hawk">Tim Hawk</a> <span class="text-slate-400">— Owner & Master HVAC Tech, FL {SITE.license}</span></span>
          </span>
          <span class="text-slate-300">·</span>
          <span><span class="text-slate-400">Updated</span> {today}</span>
        </div>
        <slot />
        <p class="not-prose mt-12 text-sm text-slate-500 italic">Page reviewed and updated {today} by Tim Hawk, owner of I Care Air Care, Florida HVAC license {SITE.license}.</p>
      </article>
      <aside class="lg:col-span-4 space-y-6">
        <div class="rounded-2xl bg-gradient-to-br from-brand-600 to-brand-800 text-white p-6 shadow-[var(--shadow-soft)]">
          <h3 class="text-white font-bold text-lg">Service in {cityName}</h3>
          <p class="mt-2 text-blue-50 text-sm leading-relaxed">Call our Wesley Chapel team for the earliest available {cityName} appointment and a realistic arrival window before dispatch.</p>
          <a href={SITE.phoneHref} class="mt-4 inline-flex w-full justify-center items-center gap-2 rounded-md bg-accent-500 hover:bg-accent-600 text-white font-bold px-4 py-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.21 11.36 11.36 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.58 1 1 0 01-.21 1.11l-2.2 2.1z"/></svg>
            {SITE.phone}
          </a>
          <a href={SITE.bookPath} class="mt-2 inline-flex w-full justify-center items-center gap-2 rounded-md bg-white/10 border border-white/30 hover:bg-white/20 text-white font-semibold px-4 py-3">Book Online</a>
          <ul class="mt-5 space-y-2 text-sm text-blue-50">
            <li class="flex items-center gap-2"><span class="text-accent-400">✓</span> Licensed · CAC1816515</li>
            <li class="flex items-center gap-2"><span class="text-accent-400">✓</span> 1-year repair warranty</li>
            <li class="flex items-center gap-2"><span class="text-accent-400">✓</span> Upfront flat-rate pricing</li>
            <li class="flex items-center gap-2"><span class="text-accent-400">✓</span> 4.9★ · {SITE.rating.count}+ reviews</li>
          </ul>
        </div>

        <!-- Map -->
        <div class="rounded-2xl overflow-hidden ring-1 ring-slate-200 shadow-[var(--shadow-card)] bg-white">
          <div class="aspect-[4/3] bg-slate-100">
            <iframe src={embedSrc} width="100%" height="100%" style="border:0" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title={`Service area map for ${cityName}, FL`}></iframe>
          </div>
          <div class="p-4 text-[13px] text-slate-600">
            <div class="font-bold text-navy-700 mb-1">Serving {cityName}, FL</div>
            {zipCodes.length > 0 && <div><span class="font-semibold text-navy-700">ZIP codes:</span> {zipCodes.join(', ')}</div>}
          </div>
        </div>

        {neighborhoods.length > 0 && (
          <div class="rounded-2xl bg-white ring-1 ring-slate-200 p-6">
            <h3 class="font-bold text-navy-700 text-lg">Neighborhoods we serve</h3>
            <ul class="mt-3 grid grid-cols-2 gap-1 text-[14.5px]">
              {neighborhoods.map(n => <li class="text-slate-600 flex items-center gap-1.5"><span class="text-accent-500">›</span>{n}</li>)}
            </ul>
          </div>
        )}

        <div class="rounded-2xl bg-white ring-1 ring-slate-200 p-6">
          <h3 class="font-bold text-navy-700 text-lg">All HVAC services in {cityName}</h3>
          <ul class="mt-3 space-y-2 text-[15px]">
            {SITE.services.map(s => (
              <li><a class="text-brand-600 hover:text-brand-700 underline underline-offset-2" href={`/services/${s.slug}/`}>{s.name}</a></li>
            ))}
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <!-- Landmarks + climate -->
  {(landmarks.length > 0 || climateNote) && (
    <section class="py-14 md:py-18 bg-surface">
      <div class="container-site grid lg:grid-cols-12 gap-10 items-start">
        {landmarks.length > 0 && (
          <div class="lg:col-span-7">
            <span class="inline-flex items-center rounded-full bg-white ring-1 ring-slate-200 text-brand-700 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em]">Around {cityName}</span>
            <h2 class="mt-3 text-3xl md:text-4xl">Local landmarks & communities we serve around</h2>
            <p class="mt-3 text-slate-600">We've worked on homes and businesses near every major {cityName} landmark — here are a few you might know.</p>
            <ul class="mt-6 grid sm:grid-cols-2 gap-3">
              {landmarks.map(l => (
                <li class="flex items-start gap-3 rounded-xl bg-white ring-1 ring-slate-200 p-4">
                  <div class="shrink-0 w-9 h-9 rounded-md bg-accent-50 text-accent-600 flex items-center justify-center">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a7 7 0 00-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 00-7-7z"/></svg>
                  </div>
                  <div>
                    <div class="font-bold text-navy-700 text-[15px]">{l.name}</div>
                    {l.note && <div class="text-slate-500 text-[13px] mt-0.5">{l.note}</div>}
                  </div>
                </li>
              ))}
            </ul>
          </div>
        )}
        {climateNote && (
          <div class="lg:col-span-5">
            <div class="rounded-2xl bg-navy-700 text-white p-6 md:p-7 shadow-[var(--shadow-soft)]">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-accent-400"><path d="M6 19a6 6 0 01.2-12 7 7 0 0113.4 2A5 5 0 0118 19H6z"/></svg>
                </div>
                <div>
                  <div class="text-[11px] uppercase tracking-[0.14em] text-blue-100">Climate</div>
                  <div class="font-bold text-white text-lg">HVAC concerns specific to {cityName}</div>
                </div>
              </div>
              <p class="mt-5 text-blue-50 leading-relaxed text-[15px]" set:html={climateNote}></p>
            </div>
          </div>
        )}
      </div>
    </section>
  )}

  <ServiceGrid />
  <WhyChooseUs />
  <ThreeStep />
  <ReviewStrip reviews={reviews.length > 0 ? reviews.map(r => ({ author: r.name, body: r.body, rating: r.rating ?? 5, neighborhood: r.neighborhood })) : undefined} />
  <FAQ title={`${cityName} HVAC FAQs`} items={faqs} />

  <!-- Related areas -->
  {relatedAreas.length > 0 && (
    <section class="py-14 bg-white">
      <div class="container-site">
        <div class="max-w-3xl">
          <span class="inline-flex items-center rounded-full bg-brand-50 text-brand-700 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em]">Nearby service areas</span>
          <h2 class="mt-3 text-2xl md:text-3xl">We also serve these communities near {cityName}</h2>
        </div>
        <div class="mt-8 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {relatedAreas.map(r => (
            <a href={`/service-areas/${r.slug}/`} class="group rounded-xl bg-surface ring-1 ring-slate-200 hover:ring-brand-300 hover:shadow-[var(--shadow-card)] p-5 transition">
              <div class="flex items-center gap-2 text-brand-600">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a7 7 0 00-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 00-7-7z"/></svg>
                <span class="text-[11px] uppercase tracking-[0.14em] font-bold">Service area</span>
              </div>
              <div class="mt-2 font-bold text-navy-700 group-hover:text-brand-700">{r.name}</div>
              {r.note && <div class="mt-1 text-[13px] text-slate-500">{r.note}</div>}
              <div class="mt-3 text-sm text-accent-500 font-semibold">View page →</div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <FinalCTA />
  <ContactFormSection />

  <script type="application/ld+json" set:html={JSON.stringify(areaSchema)} />
  <Schema type="FAQPage" faqs={faqs.map(f => ({ q: f.q, a: f.a.replace(/<[^>]*>/g,'') }))} />
</BaseLayout>
