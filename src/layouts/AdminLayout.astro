---
// Minimal layout for /admin/* pages — no public Header/Footer, no SEO bloat.
// Brand tokens come from src/styles/global.css.
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Internal — I Care Air Care KPI dashboard' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <meta name="description" content={description} />
    <title>{title} · I Care Air Care</title>
    <link rel="icon" href="/favicon-bear.png" />
    <style is:global>
      @import "../styles/global.css";

      /* Font-size bump (Tim feedback 2026-05-09 — easier reading without glasses). */
      body { background: var(--color-surface); font-size: 16px; }
      .admin-shell { min-height: 100vh; }

      .card {
        background: #fff;
        border: 1px solid var(--color-line);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-card);
        padding: 1.35rem;
      }
      .card-quiet {
        background: #fff;
        border: 1px solid var(--color-line);
        border-radius: var(--radius-lg);
        padding: 1.1rem;
      }
      .stat-label {
        font-size: 0.875rem;       /* was 0.78 */
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--color-muted);
      }
      .stat-value {
        font-size: 2.5rem;          /* was 2.25 */
        font-weight: 700;
        line-height: 1.05;
        color: var(--color-navy-700);
        letter-spacing: -0.02em;
      }
      .stat-sub {
        font-size: 1rem;            /* was 0.875 */
        color: var(--color-ink-soft);
        margin-top: 0.35rem;
      }
      .pill {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.2rem 0.6rem;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 600;
      }
      .pill-ok    { background: #e0f5e9; color: #15803d; }
      .pill-warn  { background: #fef3c7; color: #92400e; }
      .pill-err   { background: #fee2e2; color: #991b1b; }
      .pill-info  { background: var(--color-brand-50); color: var(--color-brand-800); }
      .btn-admin {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.55rem 1rem;
        background: var(--color-accent-500);
        color: #fff;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.875rem;
        border: none;
        cursor: pointer;
        transition: background 0.15s;
      }
      .btn-admin:hover { background: var(--color-accent-600); }
      .btn-admin[disabled] { background: #cbd5e1; cursor: not-allowed; }
      .btn-ghost-admin {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.5rem 0.85rem;
        background: transparent;
        color: var(--color-navy-700);
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.875rem;
        border: 1px solid var(--color-line);
        cursor: pointer;
      }
      .btn-ghost-admin:hover { background: var(--color-surface-2); }
      .tab {
        padding: 0.45rem 0.95rem;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 600;
        cursor: pointer;
        border: 1px solid var(--color-line);
        background: #fff;
        color: var(--color-navy-700);
      }
      .tab[aria-pressed="true"] {
        background: var(--color-navy-700);
        color: #fff;
        border-color: var(--color-navy-700);
      }
      table.kpi-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.95rem;        /* was 0.875 */
      }
      table.kpi-table th, table.kpi-table td {
        text-align: left;
        padding: 0.7rem 0.85rem;   /* taller rows for readability */
        border-bottom: 1px solid var(--color-line);
      }
      table.kpi-table th {
        font-weight: 600;
        color: var(--color-muted);
        font-size: 0.8rem;          /* was 0.72 */
        text-transform: uppercase;
        letter-spacing: 0.05em;
        background: var(--color-surface);
      }
      table.kpi-table tr:last-child td { border-bottom: none; }
      .num { font-variant-numeric: tabular-nums; }
      .progress {
        height: 8px;
        background: var(--color-line);
        border-radius: 999px;
        overflow: hidden;
      }
      .progress > span {
        display: block;
        height: 100%;
        background: var(--color-accent-500);
        border-radius: 999px;
      }
      .skeleton {
        background: linear-gradient(90deg, #eef3f6, #f8fafb, #eef3f6);
        background-size: 200% 100%;
        animation: shimmer 1.4s infinite;
        border-radius: 6px;
      }
      @keyframes shimmer {
        0%   { background-position: 200% 0; }
        100% { background-position: -200% 0; }
      }
      /* Smooth fade+slide entrance for cards / sections */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .fade-up { animation: fadeUp 360ms cubic-bezier(.22,1,.36,1) both; }
      /* Stagger by setting --i: 0,1,2,3 on each element */
      .fade-up[style*="--i"] { animation-delay: calc(var(--i) * 60ms); }
      /* Subtle lift on hoverable rows / interactive cards */
      .hover-lift { transition: transform 180ms ease, box-shadow 180ms ease; }
      .hover-lift:hover { transform: translateY(-1px); box-shadow: var(--shadow-soft); }
      /* Soft pulse for live-ish elements */
      @keyframes softPulse {
        0%, 100% { opacity: 0.85; }
        50%      { opacity: 1; }
      }
      .pulse-soft { animation: softPulse 2.4s ease-in-out infinite; }
      /* AI briefing tone tints */
      .tone-good  { background: linear-gradient(135deg, #ecfdf5, #d1fae5); border-left: 3px solid #10b981; }
      .tone-warn  { background: linear-gradient(135deg, #fffbeb, #fef3c7); border-left: 3px solid #f59e0b; }
      .tone-bad   { background: linear-gradient(135deg, #fef2f2, #fee2e2); border-left: 3px solid #ef4444; }
      .tone-neutral { background: linear-gradient(135deg, #f8fafc, #f1f5f9); border-left: 3px solid #64748b; }
      .chip { display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; border-radius: 999px; font-size: 11px; font-weight: 600; }
      .chip-good { background: #d1fae5; color: #065f46; }
      .chip-warn { background: #fef3c7; color: #92400e; }
      .chip-bad  { background: #fee2e2; color: #991b1b; }
      .chip-info { background: var(--color-brand-50); color: var(--color-brand-800); }
      /* Counter animation target — opacity comes up smoothly */
      .stat-value, .num-anim { transition: opacity 200ms ease; }
      /* Rounded section badges with icon */
      .section-icon {
        display: inline-flex; align-items: center; justify-content: center;
        width: 28px; height: 28px; border-radius: 8px; font-size: 14px;
      }
      .login-card {
        max-width: 420px;
        margin: 4rem auto;
        padding: 2rem;
      }
      .login-card input {
        width: 100%;
        padding: 0.7rem 0.85rem;
        border: 1px solid var(--color-line);
        border-radius: 8px;
        font-size: 0.95rem;
        font-family: inherit;
      }
      .login-card input:focus {
        outline: 2px solid var(--color-brand-400);
        border-color: var(--color-brand-500);
      }
      /* Sticky control-nav pills */
      .nav-pill {
        display: inline-flex;
        align-items: center;
        padding: 0.3rem 0.7rem;
        border-radius: 999px;
        color: var(--color-ink-soft);
        text-decoration: none;
        transition: background 0.15s, color 0.15s;
      }
      .nav-pill:hover { background: var(--color-surface-2); color: var(--color-navy-700); }
      .nav-pill.is-active {
        background: var(--color-navy-700);
        color: #fff;
      }
      /* ── Sidebar workspace layout (2026-06-03 — replaced the long scroll) ── */
      .dash-layout {
        display: flex;
        gap: 1.25rem;
        align-items: flex-start;
        padding-top: 1rem;
        padding-bottom: 1.5rem;
      }
      .dash-sidebar { flex-shrink: 0; width: 196px; position: sticky; top: 96px; }
      .dash-nav { display: flex; flex-direction: column; gap: 3px; }
      .dash-nav-item {
        display: flex; align-items: center; gap: 0.6rem;
        width: 100%; text-align: left;
        padding: 0.6rem 0.8rem; border-radius: 9px;
        font-weight: 600; font-size: 0.92rem;
        color: var(--color-ink-soft); background: transparent;
        border: none; cursor: pointer; transition: background 0.12s, color 0.12s;
      }
      .dash-nav-item:hover { background: var(--color-surface-2); color: var(--color-navy-700); }
      .dash-nav-item.is-active {
        background: var(--color-navy-700); color: #fff;
        box-shadow: var(--shadow-soft);
      }
      .dash-nav-ico { font-size: 1.05rem; width: 1.35rem; text-align: center; flex-shrink: 0; }
      /* min-width:0 lets the wide leaderboard table scroll inside the content
         column instead of forcing the whole page wider than the viewport. */
      .dash-main { flex: 1 1 0; min-width: 0; }

      @media (max-width: 1023px) {
        .dash-layout { flex-direction: column; gap: 0.5rem; padding-top: 0.5rem; }
        .dash-sidebar { position: static; width: 100%; }
        /* Horizontal icon+label strip on mobile (sticky just under the top bar). */
        .dash-nav {
          flex-direction: row; overflow-x: auto; gap: 6px;
          padding: 4px 0; -webkit-overflow-scrolling: touch;
        }
        .dash-nav-item {
          flex-direction: column; gap: 2px;
          padding: 0.45rem 0.8rem; font-size: 0.68rem;
          white-space: nowrap; border-radius: 10px;
          border: 1px solid var(--color-line);
        }
        .dash-nav-item.is-active { border-color: var(--color-navy-700); }
        .dash-nav-ico { font-size: 1.2rem; width: auto; }
      }
      /* Goal-progress bars */
      .goal-bar {
        position: relative;
        height: 10px;
        background: #eef3f6;
        border-radius: 999px;
        overflow: hidden;
      }
      .goal-bar > .goal-fill {
        position: absolute; top: 0; left: 0; bottom: 0;
        background: linear-gradient(90deg, var(--color-brand-500), var(--color-brand-700));
        border-radius: 999px;
        transition: width 700ms cubic-bezier(.22,1,.36,1);
      }
      .goal-bar.is-good > .goal-fill   { background: linear-gradient(90deg, #10b981, #15803d); }
      .goal-bar.is-warn > .goal-fill   { background: linear-gradient(90deg, #f59e0b, #b45309); }
      .goal-bar.is-bad > .goal-fill    { background: linear-gradient(90deg, #ef4444, #991b1b); }
      .goal-bar > .goal-target {
        position: absolute; top: -2px; bottom: -2px;
        width: 2px; background: var(--color-navy-700); opacity: 0.6;
      }
      .goal-row { padding: 0.6rem 0; border-bottom: 1px dashed var(--color-line); }
      .goal-row:last-child { border-bottom: none; }
      .goal-card {
        background: #fff;
        border: 1px solid var(--color-line);
        border-radius: var(--radius-lg);
        padding: 0.85rem 1rem;
      }
      .goal-card.goal-card-shop {
        background: linear-gradient(135deg, #fffbeb, #fff);
        border-color: #fcd34d;
      }
      /* Section anchors — leave room for the sticky control nav so the section
         heading isn't hidden under it when a pill is clicked. */
      #sec-insights, #sec-kpis, #sec-leaderboard, #sec-goals,
      #sec-segments, #sec-reviews, #sec-callbacks { scroll-margin-top: 80px; }

      /* Chat */
      #chat-panel { display: none; flex-direction: column; }
      #chat-panel.is-open { display: flex; }
      .chat-msg { padding: 0.65rem 0.85rem; border-radius: 12px; max-width: 92%; }
      .chat-bot { background: #fff; border: 1px solid var(--color-line); align-self: flex-start; }
      .chat-user { background: var(--color-brand-500); color: #fff; align-self: flex-end; margin-left: auto; }
      .chat-suggest {
        background: var(--color-brand-50);
        color: var(--color-brand-800);
        border: 1px solid var(--color-brand-100, #cfe5ec);
        padding: 0.4rem 0.65rem;
        border-radius: 8px;
        cursor: pointer;
      }
      .chat-suggest:hover { background: var(--color-brand-100, #cfe5ec); }
      .chat-thinking { display: inline-flex; gap: 3px; align-items: center; }
      .chat-thinking span { width: 6px; height: 6px; border-radius: 999px; background: var(--color-brand-500); animation: chatDot 1s infinite ease-in-out; }
      .chat-thinking span:nth-child(2) { animation-delay: 0.15s; }
      .chat-thinking span:nth-child(3) { animation-delay: 0.3s; }
      @keyframes chatDot {
        0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
        40% { opacity: 1; transform: scale(1); }
      }
    </style>
  </head>
  <body class="admin-shell">
    <slot />
    <footer class="container-site py-4 text-center text-[11px] text-slate-500 border-t border-line mt-6">
      <span>Built by</span>
      <a href="https://servicelinepro.com" target="_blank" rel="noopener" class="font-semibold text-brand-700 hover:text-accent-600 transition-colors">
        ServiceLine&nbsp;Pro
      </a>
      <span class="opacity-60">·</span>
      <span>Custom KPI dashboards for home-services companies</span>
    </footer>
  </body>
</html>
