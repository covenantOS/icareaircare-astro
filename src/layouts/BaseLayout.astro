---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';
import Schema from '../components/Schema.astro';
import { SITE } from '../lib/site';

interface Props {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
  breadcrumbs?: { name: string; url: string }[];
}
const {
  title,
  description,
  image = `${SITE.url}/images/I-Care-Air-Care-%E2%80%93-Blue-Background-Banner.webp`,
  noindex = false,
  breadcrumbs,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, SITE.url).href;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />


    {import.meta.env.PUBLIC_GA_ID && (
      <Fragment>
        <script type="text/partytown" src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_ID}`} />
        <script type="text/partytown" set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${import.meta.env.PUBLIC_GA_ID}');`} />
      </Fragment>
    )}
    <Schema type="LocalBusiness" />
    {breadcrumbs && <Schema type="BreadcrumbList" breadcrumbs={breadcrumbs} />}
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col pb-20 lg:pb-0">
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main" class="flex-1"><slot /></main>
    <Footer />
    <StickyMobileCTA />
  </body>
</html>
