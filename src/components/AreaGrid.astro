---
import { SITE } from '../lib/site';
const mapEmbed = 'https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d113137.91!2d-82.45!3d28.22!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e0!3m2!1sen!2sus!4v1713600000000';
---
<section class="relative py-16 md:py-20 bg-wave overflow-hidden">
  <div class="container-site">
    <h2 class="text-center text-3xl md:text-4xl title-accent mb-10">Proudly Serving Wesley Chapel &amp; Surrounding Areas</h2>
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
      <div class="rounded-xl overflow-hidden shadow-[var(--shadow-soft)] ring-1 ring-white">
        <iframe
          src={mapEmbed}
          width="100%"
          height="380"
          style="border:0"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="I Care Air Care service area map"></iframe>
      </div>
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.15em] text-accent-500">/ Areas We Serve</p>
        <p class="mt-3 text-slate-600 leading-relaxed">
          Whether you need <a href="/service-areas/wesley-chapel-ac-repair/" class="text-brand-600 underline underline-offset-2 hover:text-brand-700">AC repair in Wesley Chapel</a>, a trusted HVAC contractor near me in <a href="/service-areas/land-o-lakes-hvac-services/" class="text-brand-600 underline underline-offset-2 hover:text-brand-700">Land O' Lakes</a>, or fast heating and cooling service in <a href="/service-areas/new-tampa-heating-and-cooling/" class="text-brand-600 underline underline-offset-2 hover:text-brand-700">New Tampa</a> — I Care Air Care has you covered across the entire Tampa Bay region.
        </p>
        <ul class="mt-5 grid grid-cols-2 gap-y-2 gap-x-6 text-[15px]">
          {SITE.serviceAreas.map(a => (
            <li>
              <a href={`/service-areas/${a.slug}/`} class="inline-flex items-center gap-2 text-navy-700 hover:text-brand-600">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-accent-500"><path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg>
                {a.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    <div class="mt-10 text-center">
      <a href={SITE.bookUrl} target="_blank" rel="noopener" class="btn-primary btn-lg">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Book Now
      </a>
    </div>
  </div>
</section>
