---
import { SITE } from '../lib/site';
---
<section class="py-16 md:py-20">
  <div class="container-site">
    <div class="grid md:grid-cols-2 gap-10 items-center">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.18em] text-brand-600">Service area</p>
        <h2 class="mt-2 text-3xl md:text-4xl font-bold">Proudly serving Tampa Bay & beyond</h2>
        <p class="mt-4 text-slate-600 leading-relaxed">Based in Wesley Chapel, we dispatch local technicians across Pasco, Hillsborough and Polk counties. Whether you live on a quiet cul-de-sac or in a new-construction neighborhood, we\u2019re a short drive away.</p>
        <a href="/service-areas/" class="mt-6 inline-flex items-center gap-2 text-brand-700 font-semibold hover:text-brand-800">See all service areas →</a>
      </div>
      <div class="grid grid-cols-2 gap-3">
        {SITE.serviceAreas.map(a => (
          <a href={`/service-areas/${a.slug}/`} class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-brand-800 hover:border-brand-500 hover:text-brand-600 transition">
            📍 {a.name}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
