---
import { SITE } from '../lib/site';
const mapEmbed = 'https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d113137.91!2d-82.45!3d28.22!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e0!3m2!1sen!2sus!4v1713600000000';
---
<section class="py-16 md:py-20 bg-surface">
  <div class="container-site">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="text-3xl md:text-4xl title-accent">Proudly Serving Wesley Chapel &amp; Surrounding Areas</h2>
      <p class="mt-4 text-slate-600 leading-relaxed">
        Based in Wesley Chapel, we cover all of Pasco, Hillsborough &amp; Polk counties — from New Tampa to Zephyrhills.
      </p>
    </div>

    <!-- Pill area buttons -->
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      {SITE.serviceAreas.map(a => (
        <a
          href={`/service-areas/${a.slug}/`}
          class="inline-flex items-center gap-1.5 rounded-full bg-white border border-brand-200 hover:border-brand-500 hover:text-brand-700 text-navy-700 font-medium px-5 py-2.5 text-sm shadow-sm transition-all"
        >
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" class="text-accent-500 shrink-0" aria-hidden="true"><path d="M12 2a7 7 0 00-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 00-7-7zm0 10a3 3 0 110-6 3 3 0 010 6z"/></svg>
          {a.name}
        </a>
      ))}
    </div>

    <!-- Map below pill buttons -->
    <div class="mt-10 rounded-xl overflow-hidden shadow-[var(--shadow-soft)] ring-1 ring-slate-200">
      <iframe
        src={mapEmbed}
        width="100%"
        height="420"
        style="border:0;display:block;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="I Care Air Care service area map"></iframe>
    </div>

    <div class="mt-8 text-center">
      <a href="/service-areas/" class="btn-primary btn-lg">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a7 7 0 00-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 00-7-7zm0 10a3 3 0 110-6 3 3 0 010 6z"/></svg>
        See All Service Areas
      </a>
    </div>
  </div>
</section>
