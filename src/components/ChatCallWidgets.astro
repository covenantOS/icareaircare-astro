---
// ChatCallWidgets — two floating widgets:
//   • bottom-RIGHT: a chat-style lead capture (phone + message) that submits
//     to /api/lead → LeadConnector webhook (same backend as the regular forms)
//     and confirms with a "team will be in contact" message.
//   • bottom-LEFT: a one-tap call button (real human, real number).
// Both push GTM dataLayer events so the existing GTM container can route
// them to GA4 / Ads / Clarity / wherever.
//
// Mobile: hidden — the StickyMobileCTA already covers this real estate.
// Tablet+: both visible.
import { SITE } from '../lib/site';
---
<!-- Wrapper is `hidden md:block` so we don't double up with StickyMobileCTA -->
<div class="hidden md:block" id="cc-widgets" data-cc-phone={SITE.phone} data-cc-tel-href={SITE.phoneHref}>

  <!-- ============== Left: Real-human Call button ============== -->
  <a
    id="cc-call-btn"
    href={SITE.phoneHref}
    aria-label={`Call ${SITE.name} now at ${SITE.phone}`}
    class="fixed left-5 bottom-5 z-[60] inline-flex items-center gap-2.5 rounded-full bg-accent-500 hover:bg-accent-600 active:bg-accent-700 text-white font-bold pl-3 pr-5 py-3 shadow-[0_10px_30px_-8px_rgba(0,0,0,0.45)] ring-2 ring-white/40 transition-transform hover:scale-105"
  >
    <span class="inline-flex w-9 h-9 items-center justify-center rounded-full bg-white/15">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.21 11.36 11.36 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.58 1 1 0 01-.21 1.11l-2.2 2.1z"/>
      </svg>
    </span>
    <span class="leading-tight text-left">
      <span class="block text-[10.5px] font-semibold uppercase tracking-[0.12em] text-white/85">Call a real human</span>
      <span class="block text-sm">{SITE.phone}</span>
    </span>
  </a>

  <!-- ============== Right: Chat-style callback widget ============== -->
  <!-- Collapsed launcher -->
  <button
    id="cc-chat-launcher"
    type="button"
    aria-expanded="false"
    aria-controls="cc-chat-panel"
    aria-label="Open chat — request a callback"
    class="fixed right-5 bottom-5 z-[60] inline-flex items-center gap-2.5 rounded-full bg-brand-600 hover:bg-brand-700 active:bg-brand-800 text-white font-bold pl-3 pr-5 py-3 shadow-[0_10px_30px_-8px_rgba(0,0,0,0.45)] ring-2 ring-white/40 transition-transform hover:scale-105"
  >
    <span class="inline-flex w-9 h-9 items-center justify-center rounded-full bg-white/15">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M4 4h16c1.1 0 2 .9 2 2v10c0 1.1-.9 2-2 2H6l-4 4V6c0-1.1.9-2 2-2zm2 4v2h12V8H6zm0 4v2h8v-2H6z"/>
      </svg>
    </span>
    <span class="leading-tight text-left">
      <span class="block text-[10.5px] font-semibold uppercase tracking-[0.12em] text-white/85">Chat with us</span>
      <span class="block text-sm">Get a quick callback</span>
    </span>
  </button>

  <!-- Expanded chat panel -->
  <div
    id="cc-chat-panel"
    role="dialog"
    aria-modal="false"
    aria-labelledby="cc-chat-title"
    class="hidden fixed right-5 bottom-5 z-[61] w-[min(360px,calc(100vw-2.5rem))] rounded-2xl bg-white ring-1 ring-slate-200 shadow-[0_24px_60px_-16px_rgba(15,26,41,0.55)] overflow-hidden"
  >
    <!-- Header -->
    <div class="bg-brand-600 text-white px-4 py-3 flex items-center justify-between">
      <div>
        <div id="cc-chat-title" class="font-bold text-sm">Quick callback</div>
        <div class="text-[11.5px] text-blue-100 leading-tight">Tim's team replies same business day</div>
      </div>
      <button id="cc-chat-close" type="button" aria-label="Close chat" class="w-8 h-8 rounded-full hover:bg-white/15 inline-flex items-center justify-center">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M19 6.4L17.6 5 12 10.6 6.4 5 5 6.4 10.6 12 5 17.6 6.4 19 12 13.4 17.6 19 19 17.6 13.4 12z"/>
        </svg>
      </button>
    </div>

    <!-- Form (default state) -->
    <form
      id="cc-chat-form"
      action="/api/lead"
      method="POST"
      class="px-4 pt-4 pb-4 space-y-3"
    >
      <input type="hidden" name="_form_type" value="chat_widget" />
      <input type="hidden" name="_next" value="/thank-you/?ref=chat_widget" />
      <input type="text" name="_honey" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

      <!-- Faux conversation bubble — sets expectation, not a real chat -->
      <div class="rounded-xl bg-slate-50 ring-1 ring-slate-200 p-3 text-[13.5px] text-slate-700 leading-relaxed">
        Hi! Drop your number and what you need help with. Our Wesley Chapel team will text/call back fast.
      </div>

      <label class="block">
        <span class="sr-only">Your name (optional)</span>
        <input
          name="name"
          type="text"
          placeholder="Your name (optional)"
          autocomplete="name"
          class="w-full rounded-md border border-slate-200 bg-white px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 placeholder:text-slate-400"
        />
      </label>
      <label class="block">
        <span class="sr-only">Phone number</span>
        <input
          name="phone"
          type="tel"
          required
          placeholder="Phone number *"
          autocomplete="tel"
          class="w-full rounded-md border border-slate-200 bg-white px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 placeholder:text-slate-400"
        />
      </label>
      <label class="block">
        <span class="sr-only">What do you need help with?</span>
        <textarea
          name="message"
          required
          rows="3"
          placeholder="What's going on? (e.g. AC blowing warm, capacitor replacement quote, tune-up...)"
          class="w-full rounded-md border border-slate-200 bg-white px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 placeholder:text-slate-400 resize-none"
        ></textarea>
      </label>
      <button
        type="submit"
        class="w-full inline-flex items-center justify-center gap-2 rounded-md bg-accent-500 hover:bg-accent-600 text-white font-bold px-4 py-3 transition"
      >
        <span class="cc-submit-label">Request callback</span>
        <svg class="cc-submit-spinner hidden animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="3" stroke-opacity="0.25"/>
          <path d="M21 12a9 9 0 00-9-9" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
        </svg>
      </button>
      <p class="text-[10.5px] text-center text-slate-500">By submitting, you agree to be contacted at the number provided. No spam.</p>
    </form>

    <!-- Success state -->
    <div id="cc-chat-success" class="hidden px-4 pt-5 pb-4">
      <div class="flex items-center gap-3">
        <div class="shrink-0 w-12 h-12 rounded-full bg-green-100 text-green-600 inline-flex items-center justify-center">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
          </svg>
        </div>
        <div>
          <div class="font-bold text-navy-700">Got it — we're on it.</div>
          <div class="text-[13px] text-slate-600">Tim's team will be in contact shortly.</div>
        </div>
      </div>
      <p class="mt-4 text-[13.5px] text-slate-700 leading-relaxed">
        Need help right now? Tap below to call our Wesley Chapel team — same-day no-cool service often available.
      </p>
      <a id="cc-chat-call-now" href={SITE.phoneHref} class="mt-3 w-full inline-flex items-center justify-center gap-2 rounded-md bg-accent-500 hover:bg-accent-600 text-white font-bold px-4 py-3">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.21 11.36 11.36 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.58 1 1 0 01-.21 1.11l-2.2 2.1z"/>
        </svg>
        Call {SITE.phone} now
      </a>
    </div>

    <!-- Error state -->
    <div id="cc-chat-error" class="hidden px-4 pt-5 pb-4">
      <div class="rounded-md bg-red-50 ring-1 ring-red-200 text-red-700 text-[13.5px] p-3">
        Something went wrong sending that. Please call us directly so we don't miss you.
      </div>
      <a href={SITE.phoneHref} class="mt-3 w-full inline-flex items-center justify-center gap-2 rounded-md bg-accent-500 hover:bg-accent-600 text-white font-bold px-4 py-3">
        Call {SITE.phone}
      </a>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var wrap = document.getElementById('cc-widgets');
    if (!wrap) return;
    var launcher = document.getElementById('cc-chat-launcher');
    var panel = document.getElementById('cc-chat-panel');
    var closeBtn = document.getElementById('cc-chat-close');
    var form = document.getElementById('cc-chat-form');
    var successEl = document.getElementById('cc-chat-success');
    var errorEl = document.getElementById('cc-chat-error');
    var callBtn = document.getElementById('cc-call-btn');
    var callNow = document.getElementById('cc-chat-call-now');
    var spinner = form && form.querySelector('.cc-submit-spinner');
    var submitLabel = form && form.querySelector('.cc-submit-label');

    function gtm(event, extra) {
      try {
        window.dataLayer = window.dataLayer || [];
        var payload = { event: event, widget: 'cc_widgets' };
        if (extra) for (var k in extra) payload[k] = extra[k];
        window.dataLayer.push(payload);
      } catch (e) { /* swallow — never block UX on analytics */ }
    }

    function openPanel() {
      if (!panel || !launcher) return;
      panel.classList.remove('hidden');
      launcher.classList.add('hidden');
      launcher.setAttribute('aria-expanded', 'true');
      // focus first interactive element
      var firstInput = panel.querySelector('input[name="phone"]');
      if (firstInput) try { firstInput.focus(); } catch (e) {}
      gtm('chat_widget_open');
    }
    function closePanel() {
      if (!panel || !launcher) return;
      panel.classList.add('hidden');
      launcher.classList.remove('hidden');
      launcher.setAttribute('aria-expanded', 'false');
      gtm('chat_widget_close');
    }
    function showSuccess() {
      if (form) form.classList.add('hidden');
      if (errorEl) errorEl.classList.add('hidden');
      if (successEl) successEl.classList.remove('hidden');
    }
    function showError() {
      if (errorEl) errorEl.classList.remove('hidden');
      if (spinner) spinner.classList.add('hidden');
      if (submitLabel) submitLabel.textContent = 'Request callback';
      var btn = form && form.querySelector('button[type="submit"]');
      if (btn) btn.disabled = false;
    }

    if (launcher) launcher.addEventListener('click', openPanel);
    if (closeBtn) closeBtn.addEventListener('click', closePanel);
    if (callBtn) {
      callBtn.addEventListener('click', function () {
        gtm('call_widget_click', { source: 'left_call_button' });
      });
    }
    if (callNow) {
      callNow.addEventListener('click', function () {
        gtm('call_widget_click', { source: 'chat_success_state' });
      });
    }

    // ESC key closes
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && panel && !panel.classList.contains('hidden')) {
        closePanel();
      }
    });

    // Submit handler — POST to /api/lead via fetch so we keep the chat
    // panel open and show inline success rather than navigating away.
    if (form) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var btn = form.querySelector('button[type="submit"]');
        if (btn) btn.disabled = true;
        if (submitLabel) submitLabel.textContent = 'Sending...';
        if (spinner) spinner.classList.remove('hidden');

        var fd = new FormData(form);
        // Pull values for the dataLayer event without leaking PII verbatim
        var phoneVal = String(fd.get('phone') || '').replace(/\D/g, '');
        var hasMessage = !!String(fd.get('message') || '').trim();

        gtm('chat_widget_submit', {
          phone_provided: phoneVal.length >= 10,
          message_provided: hasMessage,
        });

        fetch('/api/lead', {
          method: 'POST',
          body: fd,
          redirect: 'manual',
        })
        .then(function (res) {
          // /api/lead returns a 303 redirect on success. With redirect:'manual'
          // the response is opaqueredirect; we treat any non-error as success.
          if (res.type === 'opaqueredirect' || res.ok || res.status === 0) {
            showSuccess();
          } else {
            showError();
          }
        })
        .catch(function () {
          showError();
        });
      });
    }
  })();
</script>
