---
// Reusable inline Google review card. Use only real, verifiable reviews from
// the Google Business Profile (same set used in ServiceAreaLayout schema).
interface Props { body: string; name: string; location?: string; }
const { body, name, location } = Astro.props;
---
<figure class="not-prose my-8 rounded-2xl bg-white ring-1 ring-slate-200 shadow-[var(--shadow-card)] p-6 md:p-7">
  <div class="flex items-center justify-between">
    <div class="inline-flex gap-0.5" role="img" aria-label="5 out of 5 stars">
      {[0, 1, 2, 3, 4].map(() => (
        <svg width="17" height="17" viewBox="0 0 24 24" aria-hidden="true"><path fill="#fbbc04" d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01z"/></svg>
      ))}
    </div>
    <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" title="Google review">
      <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
      <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
      <path fill="#FBBC05" d="M5.84 14.09A6.6 6.6 0 015.49 12c0-.73.13-1.43.35-2.09V7.07H2.18A10.96 10.96 0 001 12c0 1.77.42 3.45 1.18 4.93z"/>
      <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
    </svg>
  </div>
  <blockquote class="mt-3 text-[15.5px] text-slate-700 leading-relaxed italic">“{body}”</blockquote>
  <figcaption class="mt-3 text-[13.5px] font-bold text-navy-700">
    {name}<span class="font-normal text-slate-500">{location ? ` · ${location}` : ''} · Verified Google review</span>
  </figcaption>
</figure>
