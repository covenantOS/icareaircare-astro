---
import { SITE } from '../lib/site';
interface Props {
  type?: 'LocalBusiness' | 'Service' | 'FAQPage' | 'BreadcrumbList' | 'Article' | 'HowTo' | 'FinancialProduct';
  data?: Record<string, any>;
  faqs?: { q: string; a: string }[];
  breadcrumbs?: { name: string; url: string }[];
  steps?: string[];
}
const { type = 'LocalBusiness', data = {}, faqs, breadcrumbs, steps } = Astro.props;

// Named Person entity for Tim — powers E-E-A-T across the site.
// Referenced by @id from Article schema on blog posts and Person reference in LocalBusiness.
const tim = {
  '@type': 'Person',
  '@id': `${SITE.url}/#tim-hawk`,
  name: SITE.owner,
  jobTitle: 'Owner · Master HVAC Technician',
  worksFor: { '@id': `${SITE.url}/#business` },
  image: `${SITE.url}/images/Tim%20Hawk%20(ICAC%20Owner).webp`,
  url: `${SITE.url}/about-us/#team`,
  description: `Founded I Care Air Care in 2010 after 30+ years in the Tampa Bay HVAC trade. Florida licensed master contractor ${SITE.license}. EPA Section 608 Universal certified.`,
  knowsAbout: [
    'HVAC installation',
    'AC repair',
    'Florida heat pump service',
    'Air duct cleaning',
    'Commercial refrigeration',
    'Residential AC maintenance',
    'Manual-J load calculation',
    'Indoor air quality',
  ],
  hasCredential: [
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'license',
      name: `Florida HVAC License ${SITE.license}`,
      recognizedBy: {
        '@type': 'GovernmentOrganization',
        name: 'Florida Department of Business and Professional Regulation',
        url: 'https://www2.myfloridalicense.com/',
      },
      url: SITE.licenseVerificationUrl,
    },
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'certification',
      name: 'EPA Section 608 Universal',
      recognizedBy: {
        '@type': 'GovernmentOrganization',
        name: 'United States Environmental Protection Agency',
        url: 'https://www.epa.gov/section608',
      },
    },
  ],
  sameAs: SITE.founderProfiles,
};

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'HVACBusiness',
  '@id': `${SITE.url}/#business`,
  name: SITE.name,
  legalName: SITE.legalName,
  image: `${SITE.url}/images/ICAC%20Full%20Logo.webp`,
  logo: `${SITE.url}/images/ICAC%20Full%20Logo.webp`,
  url: SITE.url,
  telephone: SITE.phone,
  email: SITE.email,
  priceRange: '$$',
  foundingDate: '2010',
  slogan: SITE.tagline,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    addressRegion: SITE.address.region,
    postalCode: SITE.address.postalCode,
    addressCountry: SITE.address.country,
  },
  geo: { '@type': 'GeoCoordinates', latitude: SITE.geo.latitude, longitude: SITE.geo.longitude },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: SITE.rating.value,
    reviewCount: SITE.rating.count,
    bestRating: 5,
  },
  areaServed: SITE.serviceAreas.map(a => ({
    '@type': /county/i.test(a.name) ? 'AdministrativeArea' : 'City',
    name: a.name,
    containedInPlace: { '@type': 'State', name: 'Florida' },
  })),
  sameAs: SITE.externalProfiles,
  founder: { '@id': `${SITE.url}/#tim-hawk` },
  employee: { '@id': `${SITE.url}/#tim-hawk` },
  makesOffer: SITE.services.map(s => ({
    '@type': 'Offer',
    itemOffered: {
      '@type': 'Service',
      name: s.name,
      url: `${SITE.url}/services/${s.slug}/`,
    },
  })),
  hasCredential: { '@type': 'EducationalOccupationalCredential', credentialCategory: 'license', name: `Florida HVAC License ${SITE.license}` },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '08:00',
      closes: '18:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Saturday'],
      opens: '10:00',
      closes: '16:00',
    },
  ],
};

let json: any = localBusiness;
if (type === 'LocalBusiness') {
  // WebSite entity — powers sitelinks, RSS discovery, and gives AI crawlers a
  // clean top-level description of the site (vs. just the business entity).
  const website = {
    '@type': 'WebSite',
    '@id': `${SITE.url}/#website`,
    url: SITE.url,
    name: SITE.name,
    inLanguage: 'en-US',
    publisher: { '@id': `${SITE.url}/#business` },
    description: `${SITE.name} — ${SITE.tagline}`,
  };
  // Emit LocalBusiness + Person + WebSite via @graph so all three are linked entities
  json = {
    '@context': 'https://schema.org',
    '@graph': [localBusiness, tim, website],
  };
}
if (type === 'Service') json = { '@context': 'https://schema.org', '@type': 'Service', provider: { '@id': `${SITE.url}/#business` }, ...data };
if (type === 'Article') json = { '@context': 'https://schema.org', '@type': 'Article', ...data };
if (type === 'HowTo') {
  json = {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    ...data,
    step: (steps || []).map((s, i) => ({
      '@type': 'HowToStep',
      position: i + 1,
      text: s,
    })),
  };
}
if (type === 'FinancialProduct') json = { '@context': 'https://schema.org', '@type': 'FinancialProduct', provider: { '@id': `${SITE.url}/#business` }, ...data };
if (type === 'FAQPage' && faqs) json = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
if (type === 'BreadcrumbList' && breadcrumbs) json = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((b, i) => ({ '@type': 'ListItem', position: i + 1, name: b.name, item: b.url })),
};
---
<script type="application/ld+json" set:html={JSON.stringify(json)} />
