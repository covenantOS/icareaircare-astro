---
const brands = ['Carrier', 'Trane', 'Lennox', 'Rheem', 'Goodman', 'American Standard', 'Bryant', 'Mitsubishi Electric'];
// Duplicate list for seamless infinite loop
const track = [...brands, ...brands];
---
<section class="py-8 border-y border-slate-100 bg-white overflow-hidden">
  <div class="container-site mb-5 text-center">
    <p class="text-xs font-bold uppercase tracking-[0.18em] text-brand-700">We service every major brand</p>
    <p class="mt-1 text-sm text-slate-600">Factory-trained on residential & light-commercial equipment</p>
  </div>
  <div class="relative overflow-hidden" aria-hidden="true">
    <!-- Fade edges -->
    <div class="absolute left-0 top-0 bottom-0 w-16 z-10 pointer-events-none" style="background:linear-gradient(to right,#fff,transparent)"></div>
    <div class="absolute right-0 top-0 bottom-0 w-16 z-10 pointer-events-none" style="background:linear-gradient(to left,#fff,transparent)"></div>
    <!-- Scrolling track -->
    <div class="brand-marquee flex items-center gap-10 w-max py-1">
      {track.map(b => (
        <div class="shrink-0 flex items-center justify-center px-4 py-2 rounded-lg border border-slate-100 bg-white shadow-sm min-w-[140px]">
          <span class="text-[15px] font-bold text-slate-600 tracking-tight whitespace-nowrap">{b}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .brand-marquee {
    animation: brand-scroll 28s linear infinite;
    will-change: transform;
  }
  .brand-marquee:hover {
    animation-play-state: paused;
  }
  @keyframes brand-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>
