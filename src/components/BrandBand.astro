---
const brands = ['Carrier', 'Trane', 'Lennox', 'Rheem', 'Goodman', 'American Standard', 'Bryant', 'Mitsubishi'];
---
<section class="py-10 border-y border-slate-100 bg-white">
  <div class="container-site">
    <div class="flex flex-col md:flex-row md:items-center gap-6 md:gap-10">
      <div class="shrink-0">
        <p class="text-xs font-bold uppercase tracking-[0.18em] text-brand-600">We service every major brand</p>
        <p class="mt-1 text-sm text-slate-600">Factory-trained on residential & light-commercial</p>
      </div>
      <ul class="flex-1 flex flex-wrap gap-x-6 gap-y-2 text-navy-700 font-semibold">
        {brands.map(b => (
          <li class="flex items-center gap-2">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-accent-500"></span>
            {b}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
