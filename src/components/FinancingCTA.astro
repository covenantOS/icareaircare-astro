---
// Reusable financing band. Surfaces the 0% Synchrony option mid-content so a
// big repair or replacement does not scare the homeowner off the page.
import { SITE } from '../lib/site';
---
<div class="not-prose my-10 overflow-hidden rounded-2xl bg-gradient-to-br from-brand-700 to-navy-800 text-white shadow-[var(--shadow-soft)]">
  <div class="md:flex md:items-stretch">
    <div class="p-6 md:p-8 md:flex-1">
      <span class="inline-flex items-center gap-1.5 rounded-full bg-white/15 px-3 py-1 text-[11px] font-bold uppercase tracking-wide">0% APR available · Synchrony</span>
      <h3 class="mt-3 text-white text-xl md:text-2xl font-bold leading-snug">A surprise repair should not wreck your budget</h3>
      <p class="mt-2 text-white/85 text-[15px] leading-relaxed max-w-lg">Qualified homeowners can spread repairs and replacements into low monthly payments with 0% financing through Synchrony. Apply in minutes and decide with zero pressure.</p>
      <div class="mt-5 flex flex-col sm:flex-row gap-3">
        <a href="/financing/" class="inline-flex items-center justify-center gap-2 rounded-lg bg-accent-500 hover:bg-accent-600 text-white font-bold px-6 py-3.5 transition">See financing options</a>
        <a href={SITE.phoneHref} class="inline-flex items-center justify-center gap-2 rounded-lg bg-white/10 ring-1 ring-white/40 hover:bg-white/20 text-white font-semibold px-6 py-3.5 transition">Call {SITE.phone}</a>
      </div>
    </div>
    <div class="hidden md:flex md:w-56 items-center justify-center bg-white p-5">
      <img src="/images/Synchrony-Financing-Partner-%E2%80%93-I-Care-Air-Care.webp" alt="Synchrony financing partner, I Care Air Care HVAC payment options" title="0% HVAC financing through Synchrony" width="200" height="160" loading="lazy" class="max-h-40 w-auto object-contain" />
    </div>
  </div>
</div>
