---
import { SITE } from '../lib/site';
const cards = [
  {
    icon: 'family',
    title: 'Local, Family-Owned Service',
    body: `We're a Wesley Chapel–based, family-owned <a href="/about-us/" class="text-brand-800 underline underline-offset-2 hover:text-brand-800">HVAC contractor</a> that treats every customer like a neighbor. When you search <em>"HVAC contractor near me"</em> in Wesley Chapel, Land O' Lakes or New Tampa — we're the local team that actually shows up with personal attention on every call.`,
  },
  {
    icon: 'shield',
    title: 'Proven Expertise & Licensed Technicians',
    body: `With over <strong>60 combined years of experience</strong>, our licensed and insured Wesley Chapel team delivers expert <a href="/services/ac-repair-tampa/" class="text-brand-800 underline underline-offset-2 hover:text-brand-800">AC repair</a>, <a href="/services/ac-maintenance-tampa/" class="text-brand-800 underline underline-offset-2 hover:text-brand-800">AC tune-ups</a>, and complete <a href="/services/heating-services-tampa/" class="text-brand-800 underline underline-offset-2 hover:text-brand-800">heating and cooling</a> solutions. No matter the brand or issue — we fix it right the first time.`,
  },
  {
    icon: 'star',
    title: 'Honest, 5-Star Reputation',
    body: `Homeowners across Wesley Chapel and the Tampa Bay area trust us for upfront pricing, a one-year repair warranty, and fast <a href="/services/emergency-ac-repair-tampa/" class="text-brand-800 underline underline-offset-2 hover:text-brand-800">urgent air conditioning service near me</a>. 700+ five-star Google reviews and counting.`,
  },
];
---
<section class="py-14 md:py-20">
  <div class="container-site">
    <div class="text-center max-w-2xl mx-auto mb-10 md:mb-14">
      <h2 class="text-3xl md:text-4xl">Why Choose Us</h2>
      <p class="mt-3 text-sm font-semibold uppercase tracking-[0.15em] text-brand-800">The #1 Trusted HVAC Contractor in Wesley Chapel &amp; Tampa Bay</p>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {cards.map(c => (
        <div class="text-center px-6 py-8 rounded-xl bg-white ring-1 ring-slate-100 shadow-[var(--shadow-card)]">
          <div class="mx-auto w-20 h-20 flex items-center justify-center">
            {c.icon === 'family' && (
              <svg viewBox="0 0 64 64" class="w-16 h-16 text-brand-500" fill="currentColor"><path d="M18 22a7 7 0 100-14 7 7 0 000 14zm28 0a7 7 0 100-14 7 7 0 000 14zM18 26c-7 0-12 3-12 9v5h24v-5c0-6-5-9-12-9zm28 0c-1 0-2 0-3 .2 2 2 3 5 3 8.8V40h15v-5c0-6-7-9-15-9zM32 30a6 6 0 100-12 6 6 0 000 12zm0 4c-6 0-10 3-10 7v5h20v-5c0-4-4-7-10-7z"/></svg>
            )}
            {c.icon === 'shield' && (
              <svg viewBox="0 0 64 64" class="w-16 h-16 text-brand-500" fill="currentColor"><path d="M32 4L8 14v14c0 14 10 26 24 32 14-6 24-18 24-32V14L32 4zm0 9l17 7v8c0 11-7 20-17 24-10-4-17-13-17-24v-8l17-7z"/></svg>
            )}
            {c.icon === 'star' && (
              <svg viewBox="0 0 64 64" class="w-16 h-16 text-brand-500" fill="currentColor"><path d="M32 4l8.2 16.6L58 23l-13 12.6 3 17.9L32 45l-16 8.5 3-17.9L6 23l17.8-2.4L32 4z"/></svg>
            )}
          </div>
          <h3 class="mt-4 text-xl font-bold text-navy-700">{c.title}</h3>
          <p class="mt-3 text-slate-600 leading-relaxed text-[15px]" set:html={c.body}></p>
        </div>
      ))}
    </div>
    <div class="mt-10 text-center">
      <a href={SITE.phoneHref} class="btn-primary btn-lg">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.21 11.36 11.36 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.58 1 1 0 01-.21 1.11l-2.2 2.1z"/></svg>
        Call Us Now
      </a>
    </div>
  </div>
</section>
