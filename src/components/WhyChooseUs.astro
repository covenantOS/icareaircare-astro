---
import { SITE } from '../lib/site';
const cards = [
  {
    icon: 'truck',
    title: 'Trucks dispatch from 27022 Foamflower Blvd',
    body: `Our service vans roll out of <strong>Wesley Chapel every weekday morning</strong> — minutes from Seven Oaks, Meadow Pointe, Wiregrass, Epperson, Mirada, Land O' Lakes and New Tampa. Closest neighborhoods get the earliest available appointments. Call <a href="${SITE.phoneHref}" class="text-brand-800 underline underline-offset-2 hover:text-brand-800">${SITE.phone}</a> and you reach a Wesley Chapel landline, not an out-of-state dispatcher.`,
  },
  {
    icon: 'pen',
    title: 'Tim signs off on every install personally',
    body: `Owner <strong>${SITE.owner}</strong> walks every replacement before the job is closed — Manual-J load calc, duct static-pressure check, refrigerant verification, permit closeout. Florida license <strong>${SITE.license}</strong>, EPA Section 608 Universal. Same licensed team works every job from Wesley Chapel to Lakeland — no franchise rotations, no out-of-state subs.`,
  },
  {
    icon: 'shield',
    title: 'Flat-rate quotes before any work starts',
    body: `Every repair is <strong>quoted in writing before we touch a screw</strong>. Diagnostic visit is credited toward the repair if you move forward. Every workmanship repair carries a <strong>1-year parts-and-labor warranty</strong> stacked on top of the manufacturer's coverage. <a href="/services/ac-repair-tampa/" class="text-brand-800 underline underline-offset-2 hover:text-brand-800">See AC repair pricing</a>.`,
  },
];
---
<section class="py-14 md:py-20">
  <div class="container-site">
    <div class="text-center max-w-2xl mx-auto mb-10 md:mb-14">
      <h2 class="text-3xl md:text-4xl">Three reasons Wesley Chapel keeps recommending us</h2>
      <p class="mt-3 text-sm font-semibold uppercase tracking-[0.15em] text-brand-800">Local · Licensed · Family-run since 2010</p>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {cards.map(c => (
        <div class="text-center px-6 py-8 rounded-xl bg-white ring-1 ring-slate-100 shadow-[var(--shadow-card)]">
          <div class="mx-auto w-20 h-20 flex items-center justify-center">
            {c.icon === 'truck' && (
              <svg viewBox="0 0 64 64" class="w-16 h-16 text-brand-500" fill="currentColor" aria-hidden="true"><path d="M4 18h28v22h-4a4 4 0 11-8 0H12a4 4 0 11-8 0V18zm32 6h12l8 10v6h-4a4 4 0 11-8 0h-8V24zM16 40a2 2 0 100 4 2 2 0 000-4zm32 0a2 2 0 100 4 2 2 0 000-4z"/></svg>
            )}
            {c.icon === 'pen' && (
              <svg viewBox="0 0 64 64" class="w-16 h-16 text-brand-500" fill="currentColor" aria-hidden="true"><path d="M14 8h28l8 8v40H14V8zm26 4v8h8l-8-8zM20 28h24v3H20zm0 8h24v3H20zm0 8h16v3H20z"/></svg>
            )}
            {c.icon === 'shield' && (
              <svg viewBox="0 0 64 64" class="w-16 h-16 text-brand-500" fill="currentColor" aria-hidden="true"><path d="M32 4L8 14v14c0 14 10 26 24 32 14-6 24-18 24-32V14L32 4zm-3 36l-9-9 3-3 6 6 14-14 3 3-17 17z"/></svg>
            )}
          </div>
          <h3 class="mt-4 text-xl font-bold text-navy-700">{c.title}</h3>
          <p class="mt-3 text-slate-600 leading-relaxed text-[15px] text-left" set:html={c.body}></p>
        </div>
      ))}
    </div>
    <div class="mt-10 text-center">
      <a href={SITE.phoneHref} class="btn-primary btn-lg">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.21 11.36 11.36 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.58 1 1 0 01-.21 1.11l-2.2 2.1z"/></svg>
        Talk to Tim's team
      </a>
    </div>
  </div>
</section>
