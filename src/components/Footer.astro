---
import { SITE } from '../lib/site';
const mapEmbed = 'https://www.google.com/maps?q=27022+Foamflower+Blvd+Wesley+Chapel+FL+33544&output=embed';
---
<footer>
  <!-- Contact block -->
  <section class="bg-brand-500 pt-10 pb-12">
    <div class="container-site">
      <div class="rounded-xl bg-white shadow-[var(--shadow-soft)] p-6 md:p-8 grid md:grid-cols-2 gap-6 items-stretch">
        <div>
          <h2 class="text-2xl md:text-3xl text-navy-700">Contact Us Now</h2>
          <p class="mt-2 text-slate-600">Have a question or need HVAC help?</p>
          <p class="mt-4 text-slate-700"><strong class="text-navy-700">Contact us today!</strong> Our team is ready to assist you with honest answers and fast service.</p>
          <dl class="mt-6 space-y-2 text-[15px]">
            <div class="flex gap-3"><dt class="w-20 text-navy-700 font-semibold">Email:</dt><dd><a class="text-brand-600 hover:text-brand-700 underline underline-offset-2" href={`mailto:${SITE.email}`}>{SITE.email}</a></dd></div>
            <div class="flex gap-3"><dt class="w-20 text-navy-700 font-semibold">Phone:</dt><dd><a class="text-brand-600 hover:text-brand-700 underline underline-offset-2" href={SITE.phoneHref}>{SITE.phone}</a></dd></div>
            <div class="flex gap-3"><dt class="w-20 text-navy-700 font-semibold">Address:</dt><dd class="text-slate-700">{SITE.address.street}, {SITE.address.city}, {SITE.address.region} {SITE.address.postalCode}, United States</dd></div>
          </dl>
        </div>
        <div class="rounded-lg overflow-hidden ring-1 ring-slate-200 min-h-[260px]">
          <iframe src={mapEmbed} width="100%" height="100%" style="border:0" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="I Care Air Care location"></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- Main footer -->
  <section class="bg-brand-400">
    <div class="container-site py-10 grid md:grid-cols-4 gap-8">
      <div>
        <img src="/images/ICAC%20Full%20Logo.webp" alt={SITE.name} class="h-12 w-auto" width="200" height="56" loading="lazy" />
        <div class="mt-5 flex gap-2">
          <a aria-label="Google Business Profile" href={SITE.socials.google} target="_blank" rel="noopener" class="w-9 h-9 rounded-md bg-white/20 hover:bg-white/30 flex items-center justify-center text-white">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21.35 11.1h-9.17v2.73h6.51c-.33 3.81-3.5 5.44-6.5 5.44C8.36 19.27 5 16.25 5 12c0-4.1 3.2-7.27 7.2-7.27 3.09 0 4.9 1.97 4.9 1.97L19 4.72S16.56 2 12.1 2C6.42 2 2.03 6.8 2.03 12c0 5.05 4.13 10 10.22 10 5.35 0 9.25-3.67 9.25-9.09 0-1.15-.15-1.81-.15-1.81z"/></svg>
          </a>
          <a aria-label="Subscribe to HVAC Library RSS feed" href="/rss.xml" class="w-9 h-9 rounded-md bg-white/20 hover:bg-white/30 flex items-center justify-center text-white">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795.001 3.251 1.454 3.251 3.248zM0 8.72v4.47c6.261 0 11.344 5.073 11.344 11.326h4.478c0-8.733-7.09-15.796-15.822-15.796zm0-8.72v4.615C10.79 4.615 19.385 13.187 19.385 24h4.615C24 10.746 13.254 0 0 0z"/></svg>
          </a>
        </div>
        <a href="/financing/" class="mt-6 inline-flex items-center gap-2 text-white font-semibold">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-accent-400"><path d="M12 2L1 21h22L12 2z"/></svg>
          CHECK OUR FINANCING PLANS
        </a>
      </div>

      <div>
        <h4 class="text-white font-bold uppercase tracking-wide text-sm">Call Us Now</h4>
        <p class="mt-3"><a href={SITE.phoneHref} class="text-white font-bold text-xl hover:underline">{SITE.phone}</a></p>
        <p class="mt-2 text-white/90 text-sm">Fully Licensed</p>
        <p class="mt-1 text-white/90 text-sm">License #: {SITE.license}</p>
      </div>

      <div>
        <h4 class="text-white font-bold uppercase tracking-wide text-sm">Hours</h4>
        <ul class="mt-3 space-y-1 text-white/90 text-sm">
          <li>Mon – Fri: 8 AM – 6 PM</li>
          <li>Saturday: 10 AM – 4 PM</li>
          <li>Sunday: Closed</li>
          <li class="pt-1 text-xs">Same-day service may be available.</li>
        </ul>
      </div>

      <div class="grid grid-cols-2 gap-4 text-sm">
        <div>
          <h4 class="text-white font-bold uppercase tracking-wide text-sm mb-3">Services</h4>
          <ul class="space-y-1.5">
            {SITE.services.map(s => <li><a class="text-white/90 hover:text-white" href={`/services/${s.slug}/`}>{s.name}</a></li>)}
          </ul>
        </div>
        <div>
          <h4 class="text-white font-bold uppercase tracking-wide text-sm mb-3">Areas</h4>
          <ul class="space-y-1.5">
            {SITE.serviceAreas.slice(0,6).map(a => <li><a class="text-white/90 hover:text-white" href={`/service-areas/${a.slug}/`}>{a.name}</a></li>)}
          </ul>
        </div>
      </div>
    </div>

    <!-- Company / secondary nav strip -->
    <div class="border-t border-white/20">
      <div class="container-site py-5 flex flex-wrap items-center justify-center md:justify-between gap-x-6 gap-y-2 text-[13px]">
        <span class="text-white/90 font-semibold uppercase tracking-wide">Company</span>
        <nav class="flex flex-wrap gap-x-5 gap-y-1 text-white/90" aria-label="Company links">
          <a href="/about-us/" class="hover:text-white">About Us</a>
          <a href="/about-us/#team" class="hover:text-white">Meet the Team</a>
          <a href="/reviews/" class="hover:text-white">Reviews</a>
          <a href="/financing/" class="hover:text-white">Financing</a>
          <a href="/blogs/" class="hover:text-white">Blog &amp; HVAC Tips</a>
          <a href="/careers/" class="hover:text-white">Careers</a>
          <a href="/contact/" class="hover:text-white">Contact</a>
          <a href={SITE.bookUrl} target="_blank" rel="noopener" class="hover:text-white">Book Online</a>
          <a href="/rss.xml" class="hover:text-white">RSS</a>
          <a href="/sitemap-index.xml" class="hover:text-white">Sitemap</a>
        </nav>
      </div>
    </div>

    <div class="border-t border-white/20">
      <div class="container-site py-5 flex flex-col md:flex-row items-center justify-between gap-2 text-xs text-white/90">
        <p>© {new Date().getFullYear()} All Rights Reserved by I Care Air Care</p>
        <p class="flex items-center gap-5">
          <a href="/privacy-policy/" class="hover:text-white">Privacy Policy</a>
          <a href="/terms-of-use/" class="hover:text-white">Terms of Use</a>
        </p>
      </div>
    </div>
  </section>
</footer>
