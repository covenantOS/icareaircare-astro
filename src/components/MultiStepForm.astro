---
import { SITE } from '../lib/site';

const services = [
  { label: 'AC Repair',      icon: 'M9 3v2H7v14h2v2h6v-2h2V5h-2V3H9zm0 4h6v10H9V7z' },
  { label: 'Maintenance',    icon: 'M12 2a6 6 0 00-3 11.17V18a3 3 0 006 0v-4.83A6 6 0 0012 2zm0 14a1 1 0 110-2 1 1 0 010 2z' },
  { label: 'Installation',   icon: 'M3 7h18v10H3V7zm2 2v6h14V9H5zm7-7l-5 5h10l-5-5z' },
  { label: 'Heating',        icon: 'M12 2c-1 4 3 4 3 8s-4 4-3 8c-3-4 1-8 0-12-2 0-3-2-3-4h3z' },
  { label: 'Duct Cleaning',  icon: 'M4 4h16v4H4V4zm0 6h16v4H4v-4zm0 6h16v4H4v-4z' },
  { label: 'Emergency',      icon: 'M12 2L1 21h22L12 2zm0 6l7 12H5l7-12zm-1 4h2v4h-2v-4zm0 5h2v2h-2v-2z' },
  { label: 'Other / Not Sure', icon: 'M12 22a10 10 0 110-20 10 10 0 010 20zm0-7a1 1 0 110-2 1 1 0 010 2zm1-2h-2v-5h2v5z' },
];

const fieldClass = 'w-full rounded-lg border border-slate-200 bg-slate-50 focus:bg-white px-3.5 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 text-navy-900 placeholder:text-slate-400 transition';
---

<div class="msform-wrap rounded-2xl overflow-hidden shadow-[0_24px_60px_-16px_rgba(15,26,41,0.55)] ring-1 ring-white/15">

  <!-- Dark header -->
  <div class="bg-navy-900 px-6 pt-5 pb-4">
    <h3 class="text-white font-bold text-xl leading-tight">Get Your Free Estimate</h3>
    <p class="text-slate-400 text-sm mt-0.5">Takes less than 60 seconds</p>
    <div class="mt-4 grid grid-cols-2 gap-2">
      <div class="msform-bar-1 h-1 rounded-full" style="background-color:var(--color-accent-500)"></div>
      <div class="msform-bar-2 h-1 rounded-full" style="background-color:rgba(255,255,255,0.18)"></div>
    </div>
    <p class="msform-step-label text-[11px] text-slate-400 mt-1.5">Step 1 of 2 — Choose a service</p>
  </div>

  <!-- Step 1: Service selection -->
  <div class="msform-step-1 bg-navy-800 px-5 pt-4 pb-5">
    <div class="grid grid-cols-2 gap-2">
      {services.map((s, i) => (
        <button
          type="button"
          class={`service-btn flex items-center gap-2.5 rounded-xl bg-white/10 border border-white/15 hover:bg-accent-500 hover:border-accent-400 px-3.5 py-3 text-sm font-semibold text-white text-left transition-all${i === services.length - 1 ? ' col-span-2' : ''}`}
          data-service={s.label}
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" class="shrink-0 opacity-75" aria-hidden="true"><path d={s.icon} /></svg>
          {s.label}
        </button>
      ))}
    </div>
  </div>

  <!-- Step 2: Contact info (hidden initially) -->
  <form
    class="msform-step-2 hidden bg-white px-5 pt-4 pb-5 space-y-3"
    action="https://formsubmit.co/tim@icareaircare.com"
    method="POST"
  >
    <input type="hidden" name="_subject" value="New lead from icareaircare.com" />
    <input type="hidden" name="_next" value="https://www.icareaircare.com/contact/#thanks" />
    <input type="hidden" name="_captcha" value="true" />
    <input type="text" name="_honey" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
    <input type="hidden" name="service" class="msform-service-input" />

    <div class="flex items-center gap-3 pb-1">
      <button type="button" class="msform-back inline-flex items-center gap-1 text-sm text-brand-600 hover:text-brand-700 font-medium transition">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Back
      </button>
      <span class="text-sm text-slate-500">Service: <strong class="msform-service-display text-navy-700"></strong></span>
    </div>

    <input name="name" type="text" placeholder="Your Name *" required class={fieldClass} />
    <input name="email" type="email" placeholder="Email Address *" required class={fieldClass} />
    <input name="phone" type="tel" placeholder="Phone Number *" required class={fieldClass} />
    <input name="address" type="text" placeholder="Address (optional)" class={fieldClass} />

    <button
      type="submit"
      class="w-full inline-flex items-center justify-center gap-2 rounded-lg bg-accent-500 hover:bg-accent-600 text-white font-bold px-6 py-3.5 shadow-sm transition text-[15px]"
    >
      Get My Free Quote
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
    </button>
    <p class="text-[11px] text-center text-slate-500">We reply same business day · No spam, ever</p>
  </form>

</div>

<script is:inline>
  (function () {
    function initMSForm(wrap) {
      var step1 = wrap.querySelector('.msform-step-1');
      var step2 = wrap.querySelector('.msform-step-2');
      var bar2 = wrap.querySelector('.msform-bar-2');
      var label = wrap.querySelector('.msform-step-label');
      var svcInput = wrap.querySelector('.msform-service-input');
      var svcDisplay = wrap.querySelector('.msform-service-display');
      var backBtn = wrap.querySelector('.msform-back');

      wrap.querySelectorAll('.service-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          if (svcInput) svcInput.value = btn.dataset.service || '';
          if (svcDisplay) svcDisplay.textContent = btn.dataset.service || '';
          step1.classList.add('hidden');
          step2.classList.remove('hidden');
          if (bar2) bar2.style.backgroundColor = 'var(--color-accent-500)';
          if (label) label.textContent = 'Step 2 of 2 — Your contact info';
        });
      });

      if (backBtn) {
        backBtn.addEventListener('click', function () {
          step2.classList.add('hidden');
          step1.classList.remove('hidden');
          if (bar2) bar2.style.backgroundColor = 'rgba(255,255,255,0.18)';
          if (label) label.textContent = 'Step 1 of 2 — Choose a service';
        });
      }
    }

    function ready(fn) {
      if (document.readyState !== 'loading') { fn(); }
      else { document.addEventListener('DOMContentLoaded', fn); }
    }

    ready(function () {
      document.querySelectorAll('.msform-wrap').forEach(function (wrap) {
        if (!wrap.dataset.msInit) {
          wrap.dataset.msInit = '1';
          initMSForm(wrap);
        }
      });
    });
  })();
</script>
