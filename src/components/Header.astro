---
import { SITE } from '../lib/site';
---
<header class="sticky top-0 z-40 bg-white/95 backdrop-blur border-b border-slate-200">
  <div class="container-site flex items-center justify-between h-16 md:h-20">
    <a href="/" class="flex items-center gap-2" aria-label={`${SITE.name} home`}>
      <img src="/images/ICAC%20Full%20Logo.webp" alt={SITE.name} class="h-9 md:h-11 w-auto" width="200" height="44" />
    </a>
    <nav class="hidden lg:flex items-center gap-7 text-[15px] font-medium text-slate-700" aria-label="Primary">
      <a href="/services/" class="hover:text-brand-600">Services</a>
      <a href="/service-areas/" class="hover:text-brand-600">Service Areas</a>
      <a href="/about-us/" class="hover:text-brand-600">About</a>
      <a href="/reviews/" class="hover:text-brand-600">Reviews</a>
      <a href="/financing/" class="hover:text-brand-600">Financing</a>
      <a href="/blogs/" class="hover:text-brand-600">Blog</a>
      <a href="/contact/" class="hover:text-brand-600">Contact</a>
    </nav>
    <div class="flex items-center gap-3">
      <a href={SITE.phoneHref} class="hidden sm:inline-flex items-center gap-2 text-sm font-semibold text-brand-700">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {SITE.phone}
      </a>
      <a href={SITE.phoneHref} class="inline-flex items-center rounded-full bg-brand-600 hover:bg-brand-700 text-white text-sm font-semibold px-4 py-2 shadow-sm transition">
        Call Now
      </a>
    </div>
  </div>
</header>
