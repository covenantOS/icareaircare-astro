---
import { SITE } from '../lib/site';
---
<header class="relative z-40">
  <!-- Top utility bar -->
  <div class="bg-white border-b border-slate-100">
    <div class="container-site flex items-center justify-between h-16 md:h-20 gap-4">
      <a href="/" class="flex items-center" aria-label={`${SITE.name} home`}>
        <img src="/images/ICAC%20Full%20Logo.webp" alt={SITE.name} class="h-10 md:h-12 w-auto" width="200" height="48" loading="eager" />
      </a>
      <a href="/financing/" class="hidden md:inline-flex items-center gap-3 group">
        <span class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-accent-500 text-white">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 100 20 10 10 0 000-20zm1 15h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 10.9 13 11.5 13 13h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26A2 2 0 1010 7H8a4 4 0 117.07 2.25z"/></svg>
        </span>
        <span class="font-semibold text-navy-700 group-hover:text-accent-600">CHECK OUR NEW DEALS!</span>
      </a>
      <div class="flex items-center gap-3">
        <div class="hidden md:flex flex-col items-end">
          <span class="text-[11px] font-bold uppercase tracking-[0.16em] text-navy-700">Call for a Free Quote</span>
          <a href={SITE.phoneHref} class="text-accent-500 font-bold text-xl md:text-2xl hover:text-accent-600 flex items-center gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-accent-500"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.21 11.36 11.36 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.58 1 1 0 01-.21 1.11l-2.2 2.1z"/></svg>
            {SITE.phone}
          </a>
        </div>
        <a href={SITE.phoneHref} class="md:hidden inline-flex items-center rounded-md bg-accent-500 hover:bg-accent-600 text-white text-sm font-semibold px-3.5 py-2">
          Call Now
        </a>
      </div>
    </div>
  </div>

  <!-- Primary nav bar (teal) -->
  <div class="bg-brand-500 text-white shadow-sm">
    <div class="container-site flex items-center justify-between h-14">
      <a href="/" class="flex items-center" aria-label={`${SITE.name} home`}>
        <img src="/images/ICAC%20Logo.png" alt="" aria-hidden="true" class="h-9 w-auto" width="40" height="40" />
      </a>
      <nav class="hidden lg:flex items-center gap-7 text-[15px] font-medium" aria-label="Primary">
        <a href="/services/" class="hover:text-accent-100">Services</a>
        <a href="/service-areas/" class="hover:text-accent-100">Areas Served</a>
        <a href="/blogs/" class="hover:text-accent-100">Blogs</a>
        <a href="/financing/" class="hover:text-accent-100">Financing</a>
        <a href="/reviews/" class="hover:text-accent-100">Reviews</a>
        <a href="/about-us/" class="hover:text-accent-100">About Us</a>
        <a href="/contact/" class="hover:text-accent-100">Contact</a>
      </nav>
      <a href={SITE.phoneHref} class="hidden md:inline-flex items-center gap-3 font-semibold">
        <span class="text-sm">Call Us Now →</span>
        <span class="inline-flex items-center gap-2 bg-white/15 rounded-md px-3 py-1.5 hover:bg-white/25">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.21 11.36 11.36 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.58 1 1 0 01-.21 1.11l-2.2 2.1z"/></svg>
          {SITE.phone}
        </span>
      </a>
      <!-- Mobile menu toggle -->
      <details class="lg:hidden relative">
        <summary class="list-none cursor-pointer p-2 -mr-2" aria-label="Open menu">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </summary>
        <div class="absolute right-0 top-full mt-2 w-64 rounded-lg bg-white text-navy-700 shadow-lg ring-1 ring-slate-200 p-2">
          <a href="/services/" class="block rounded-md px-3 py-2 hover:bg-surface">Services</a>
          <a href="/service-areas/" class="block rounded-md px-3 py-2 hover:bg-surface">Areas Served</a>
          <a href="/blogs/" class="block rounded-md px-3 py-2 hover:bg-surface">Blogs</a>
          <a href="/financing/" class="block rounded-md px-3 py-2 hover:bg-surface">Financing</a>
          <a href="/reviews/" class="block rounded-md px-3 py-2 hover:bg-surface">Reviews</a>
          <a href="/about-us/" class="block rounded-md px-3 py-2 hover:bg-surface">About Us</a>
          <a href="/contact/" class="block rounded-md px-3 py-2 hover:bg-surface">Contact</a>
        </div>
      </details>
    </div>
  </div>
</header>
