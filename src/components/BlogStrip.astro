---
const posts = [
  {
    href: '/air-conditioning-not-cooling-in-tampa-fl-heres-how-to-fix-it-fast/',
    title: 'AC Not Cooling in Tampa? Here\u2019s How to Fix It Fast',
    tags: 'AC Maintenance, AC Repair, Cooling',
    img: '/images/air-conditioning-not-cooling-tampa-fl-mini-split-outdoor-condenser-unit-wall-mounted.webp',
  },
  {
    href: '/ac-blowing-warm-air-in-tampa-heres-how-to-fix-it-fast/',
    title: 'AC Blowing Warm Air in Tampa? 8 Common Causes',
    tags: 'AC Repair, Cooling',
    img: '/images/ac-blowing-warm-air-tampa-woman-relaxing-cool-comfort-mini-split-living-room.png',
  },
  {
    href: '/new-construction-hvac-guide-for-epperson-mirada-homeowners/',
    title: 'New Construction HVAC Guide for Epperson & Mirada',
    tags: 'Heating, Installation',
    img: '/images/HVAC-Installation-Tampa-Bay-%E2%80%93-Outdoor-Unit-Setup-and-Connection.webp',
  },
];
---
<section class="relative py-16 md:py-20 overflow-hidden">
  <div class="absolute inset-0 bg-brand-600"></div>
  <div class="relative container-site">
    <div class="text-center max-w-2xl mx-auto text-white">
      <h2 class="text-white text-3xl md:text-4xl title-accent">The I Care Air Care HVAC Library</h2>
      <p class="mt-6 text-blue-50">
        Explore expert tips, <a class="underline underline-offset-2 text-accent-400 hover:text-white" href="/services/ac-maintenance-tampa/">AC maintenance guides</a>, and answers to common heating and cooling questions — all designed to help Tampa and Wesley Chapel homeowners stay comfortable and energy-efficient year-round.
      </p>
    </div>
    <div class="mt-10 grid md:grid-cols-3 gap-5">
      {posts.map(p => (
        <a href={p.href} class="group relative block rounded-xl overflow-hidden aspect-[4/5] shadow-[var(--shadow-soft)]">
          <img src={p.img} alt={p.title} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition duration-500" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-navy-800/85 via-navy-800/25 to-transparent"></div>
          <div class="absolute top-4 left-4 inline-flex rounded-md bg-brand-700/90 text-white text-xs font-semibold px-2.5 py-1">{p.tags}</div>
          <div class="absolute bottom-0 inset-x-0 p-5">
            <h3 class="text-white font-bold text-lg md:text-xl leading-snug">{p.title}</h3>
            <span class="mt-2 inline-flex items-center gap-1 text-sm font-semibold text-accent-400">Read article →</span>
          </div>
        </a>
      ))}
    </div>
    <div class="mt-10 text-center">
      <a href="/blogs/" class="btn-primary btn-lg">Visit The Library</a>
    </div>
  </div>
</section>
