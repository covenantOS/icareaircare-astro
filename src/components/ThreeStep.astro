---
import { SITE } from '../lib/site';
const steps = [
  { n: 1, title: 'You Call', icon: 'phone', body: 'Fast scheduling, same-day slots' },
  { n: 2, title: 'We Diagnose', icon: 'team', body: 'On-time, clear upfront pricing' },
  { n: 3, title: 'We Fix It', icon: 'check', body: 'Quality parts, 1-year warranty' },
];
---
<section class="relative py-16 md:py-24 overflow-hidden">
  <div class="absolute inset-0">
    <img src="/images/ICAC%20Team%281%29.webp" alt="" aria-hidden="true" class="w-full h-full object-cover" loading="lazy" width="960" height="720" decoding="async" />
    <div class="absolute inset-0 bg-gradient-to-br from-navy-900/90 via-brand-800/88 to-navy-800/92"></div>
  </div>
  <div class="relative container-site text-center text-white">
    <h2 class="text-3xl md:text-4xl text-white title-accent">Our Simple 3-Step Process</h2>
    <p class="mt-5 max-w-2xl mx-auto text-blue-100">
      Getting <a class="underline underline-offset-2 hover:text-white" href="/services/ac-repair-tampa/">AC repair</a> or HVAC service near you has never been easier — fast, transparent, stress-free.
    </p>
    <div class="mt-12 grid md:grid-cols-3 gap-8 md:gap-10">
      {steps.map(s => (
        <div class="flex flex-col items-center">
          <div class="w-24 h-24 md:w-28 md:h-28 rounded-full bg-white/15 ring-1 ring-white/30 flex items-center justify-center">
            {s.icon === 'phone' && <svg width="42" height="42" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.21 11.36 11.36 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.58 1 1 0 01-.21 1.11l-2.2 2.1z"/></svg>}
            {s.icon === 'team' && <svg width="42" height="42" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 12a5 5 0 100-10 5 5 0 000 10zm-8 8a8 8 0 0116 0H4zm14-8a4 4 0 100-8 4 4 0 000 8z"/></svg>}
            {s.icon === 'check' && <svg width="46" height="46" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>}
          </div>
          <div class="mt-2 w-8 h-8 rounded-full bg-accent-500 flex items-center justify-center text-white font-bold text-sm -mt-4 relative z-10 ring-2 ring-white/30">{s.n}</div>
          <h3 class="mt-3 text-xl font-bold text-white">{s.title}</h3>
          <p class="mt-2 text-blue-100 text-sm max-w-[180px]">{s.body}</p>
        </div>
      ))}
    </div>
    <div class="mt-12">
      <a href={SITE.phoneHref} class="btn-primary btn-lg">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.21 11.36 11.36 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.58 1 1 0 01-.21 1.11l-2.2 2.1z"/></svg>
        Call {SITE.phone}
      </a>
    </div>
  </div>
</section>
