---
import { SITE } from '../lib/site';
const steps = [
  { n: 1, title: 'You Call', icon: 'phone', body: 'Book online or call for fast air conditioning service near me. Whether it\u2019s routine AC maintenance or an emergency AC repair — we confirm your appointment quickly.' },
  { n: 2, title: 'We Diagnose', icon: 'team', body: 'A licensed HVAC contractor arrives on time, diagnoses your issue, and explains your options clearly — no surprises, no pressure.' },
  { n: 3, title: 'We Fix It', icon: 'check', body: 'We repair your system efficiently using quality parts — from AC tune-ups to full heating and cooling repairs. Backed by a one-year warranty.' },
];
---
<section class="relative py-16 md:py-24 overflow-hidden">
  <div class="absolute inset-0">
    <img src="/images/ICAC%20Team%281%29.webp" alt="" aria-hidden="true" class="w-full h-full object-cover" loading="lazy" />
    <div class="absolute inset-0 bg-gradient-to-br from-navy-900/90 via-brand-800/88 to-navy-800/92"></div>
  </div>
  <div class="relative container-site text-center text-white">
    <h2 class="text-3xl md:text-4xl text-white title-accent">Our Simple 3-Step Process</h2>
    <p class="mt-5 max-w-2xl mx-auto text-blue-100">
      Getting <a class="underline underline-offset-2 hover:text-white" href="/services/ac-repair-tampa/">AC repair</a> or HVAC service near you has never been easier — we make the process fast, transparent, and stress-free.
    </p>
    <div class="mt-12 grid md:grid-cols-3 gap-8 md:gap-10">
      {steps.map(s => (
        <div class="flex flex-col items-center">
          <div class="w-28 h-28 md:w-32 md:h-32 rounded-full bg-white/15 ring-1 ring-white/30 flex items-center justify-center">
            {s.icon === 'phone' && <svg width="48" height="48" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.21 11.36 11.36 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.58 1 1 0 01-.21 1.11l-2.2 2.1z"/></svg>}
            {s.icon === 'team' && <svg width="48" height="48" viewBox="0 0 24 24" fill="currentColor"><path d="M12 12a5 5 0 100-10 5 5 0 000 10zm-8 8a8 8 0 0116 0H4zm14-8a4 4 0 100-8 4 4 0 000 8z"/></svg>}
            {s.icon === 'check' && <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>}
          </div>
          <h3 class="mt-5 text-2xl font-bold text-white">{s.title}</h3>
          <p class="mt-3 text-blue-100 leading-relaxed max-w-xs">{s.body}</p>
        </div>
      ))}
    </div>
    <div class="mt-12">
      <a href={SITE.bookUrl} target="_blank" rel="noopener" class="btn-primary btn-lg">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Book Now
      </a>
    </div>
  </div>
</section>
