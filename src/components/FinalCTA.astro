---
import { SITE } from '../lib/site';
---
<section class="py-16 md:py-20">
  <div class="container-site">
    <div class="grid md:grid-cols-2 gap-10 items-center">
      <div class="rounded-2xl overflow-hidden shadow-[var(--shadow-soft)] bg-surface">
        <img
          src="/images/Tim%20Hawk%20(ICAC%20Owner).webp"
          alt="Tim Hawk, owner of I Care Air Care, smiling at his desk in Wesley Chapel, FL"
          class="w-full h-auto block"
          width="900"
          height="675"
          loading="lazy"
        />
      </div>
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.15em] text-accent-500">
          With {SITE.yearsInBusiness}+ years of experience and a five-star reputation
        </p>
        <h2 class="mt-3 text-3xl md:text-4xl">Ready for Reliable HVAC Service in Wesley Chapel?</h2>
        <p class="mt-5 text-slate-600 leading-relaxed">
          We're more than just an <a href="/services/ac-repair-tampa/" class="text-brand-600 underline underline-offset-2 hover:text-brand-700">HVAC contractor</a> — we're your Wesley Chapel neighbors. From routine <a href="/services/ac-maintenance-tampa/" class="text-brand-600 underline underline-offset-2 hover:text-brand-700">AC maintenance</a> to <a href="/services/emergency-ac-repair-tampa/" class="text-brand-600 underline underline-offset-2 hover:text-brand-700">emergency air conditioner repair</a>, our local team delivers honest service and real peace of mind for every homeowner in Wesley Chapel, New Tampa, Land O' Lakes and beyond.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href={SITE.bookUrl} target="_blank" rel="noopener" class="btn-primary btn-lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Book With Us Now
          </a>
          <a href={SITE.phoneHref} class="btn-ghost btn-lg">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.21 11.36 11.36 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.58 1 1 0 01-.21 1.11l-2.2 2.1z"/></svg>
            {SITE.phone}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
