---
import { SITE } from '../lib/site';
const reviews = [
  {
    label: 'Clear Communication',
    text: 'Customers often mention that the team explains the issue, the repair path, and the price before work begins.',
  },
  {
    label: 'Respectful Service',
    text: 'Homeowners call out clean work, marked trucks, friendly technicians, and service that feels local instead of rushed.',
  },
  {
    label: 'Practical Repairs',
    text: 'The recurring theme is honest diagnosis: fix what can be fixed, explain when replacement makes more sense, and put it in writing.',
  },
];
---
<section class="py-14 md:py-18 bg-paper">
  <div class="container-site">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="text-3xl md:text-4xl title-accent">Our Great Customer Experience</h2>
      <p class="mt-5 text-slate-600 leading-relaxed">
        Common themes from homeowners who needed <a class="text-brand-600 underline underline-offset-2 hover:text-brand-700" href="/services/ac-repair-tampa/">AC repair</a>, <a class="text-brand-600 underline underline-offset-2 hover:text-brand-700" href="/services/emergency-ac-repair-tampa/">urgent air conditioner repair</a>, and HVAC services across Wesley Chapel and Tampa.
      </p>
    </div>

    <div class="mt-8 rounded-2xl bg-white shadow-[var(--shadow-soft)] ring-1 ring-slate-100 p-6 md:p-8">
      <div class="flex items-start justify-between gap-4 flex-wrap mb-6">
        <h3 class="text-navy-700 font-bold text-lg">What our clients say about us</h3>
        <div class="text-right">
          <div class="text-3xl font-bold text-navy-700">{SITE.rating.value.toFixed(2)}</div>
          <div class="text-accent-500 tracking-tight">★★★★★</div>
          <div class="text-xs text-slate-500">{SITE.rating.count}+ reviews</div>
        </div>
      </div>

      <!-- Carousel container -->
      <div class="relative overflow-hidden" style="min-height:140px">
        {reviews.map((r, i) => (
          <div
            class="review-slide absolute inset-0 transition-opacity duration-700"
            style={i === 0 ? 'opacity:1;z-index:1' : 'opacity:0;z-index:0'}
            data-idx={i}
          >
            <figure class="rounded-xl bg-surface p-5 h-full">
              <div class="flex items-center justify-between">
                <div class="text-accent-500">★★★★★</div>
                <span class="text-xs text-slate-500">Google feedback</span>
              </div>
              <p class="mt-3 text-[14.5px] text-slate-700 leading-relaxed">{r.text}</p>
              <figcaption class="mt-4 flex items-center justify-between">
                <span class="text-sm font-semibold text-navy-700">{r.label}</span>
                <span class="text-[11px] font-semibold text-slate-500">G · Google</span>
              </figcaption>
            </figure>
          </div>
        ))}
      </div>

      <!-- Dot navigation -->
      <div class="flex justify-center gap-2 mt-5">
        {reviews.map((_, i) => (
          <button
            class="review-dot w-2.5 h-2.5 rounded-full transition-colors"
            style={i === 0 ? 'background-color:var(--color-accent-500)' : 'background-color:var(--color-line)'}
            data-idx={i}
            aria-label={`View review ${i + 1}`}
          ></button>
        ))}
      </div>
    </div>

    <div class="mt-8 text-center">
      <a href="/reviews/" class="btn-primary btn-lg">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14 2 9.27l6.91-1.01z"/></svg>
        See All Reviews
      </a>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    function initCarousel(section) {
      var slides = section.querySelectorAll('.review-slide');
      var dots = section.querySelectorAll('.review-dot');
      if (!slides.length) return;
      var current = 0;
      var ACCENT = 'var(--color-accent-500)';
      var LINE = 'var(--color-line)';

      function goTo(n) {
        slides[current].style.opacity = '0';
        slides[current].style.zIndex = '0';
        dots[current].style.backgroundColor = LINE;
        current = n % slides.length;
        slides[current].style.opacity = '1';
        slides[current].style.zIndex = '1';
        dots[current].style.backgroundColor = ACCENT;
      }

      dots.forEach(function (dot, i) {
        dot.addEventListener('click', function () { goTo(i); clearInterval(timer); timer = setInterval(advance, 4500); });
      });

      function advance() { goTo((current + 1) % slides.length); }
      var timer = setInterval(advance, 4500);
    }

    function ready(fn) {
      if (document.readyState !== 'loading') fn(); else document.addEventListener('DOMContentLoaded', fn);
    }
    ready(function () {
      document.querySelectorAll('.review-slide').length && initCarousel(document.querySelector('.review-slide').closest('section'));
    });
  })();
</script>
