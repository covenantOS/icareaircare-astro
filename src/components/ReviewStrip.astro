---
import { SITE } from '../lib/site';
const reviews = [
  {
    name: 'Tim Ravis',
    date: 'Jan 02, 2026',
    text: 'Efficient care and friendly reliable service. Tim and Kleiner installed my system 3 years ago and keep it running like a top. Professional, honest, and on time every visit.',
  },
  {
    name: 'Carol Bartlett',
    date: 'Jan 07, 2026',
    text: 'Technician was very helpful and supportive us getting our system back up and running. Clear communication on the repair and the price was exactly what they quoted.',
  },
  {
    name: 'Douglas Manzano',
    date: 'Jan 10, 2026',
    text: 'Thank you to Tim for outstanding service. Came out same-day for an emergency AC repair in Wesley Chapel and had us cold again in under an hour. Highly recommend.',
  },
];
---
<section class="py-16 md:py-20 bg-paper">
  <div class="container-site">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="text-3xl md:text-4xl title-accent">Our Great Customer Experience</h2>
      <p class="mt-6 text-slate-600 leading-relaxed">
        Real reviews from homeowners who needed <a class="text-brand-600 underline underline-offset-2 hover:text-brand-700" href="/services/ac-repair-tampa/">AC repair</a>, <a class="text-brand-600 underline underline-offset-2 hover:text-brand-700" href="/services/emergency-ac-repair-tampa/">emergency air conditioner repair</a>, and HVAC services across Wesley Chapel and Tampa — and chose to trust us.
      </p>
    </div>

    <div class="mt-10 rounded-2xl bg-white shadow-[var(--shadow-soft)] ring-1 ring-slate-100 p-6 md:p-8">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <h3 class="text-navy-700 font-bold text-lg">What our clients say about us</h3>
        <div class="text-right">
          <div class="text-3xl font-bold text-navy-700">{SITE.rating.value.toFixed(2)}</div>
          <div class="text-accent-500 tracking-tight">★★★★★</div>
          <div class="text-xs text-slate-500">{SITE.rating.count}+ reviews</div>
        </div>
      </div>
      <div class="mt-6 grid md:grid-cols-3 gap-5">
        {reviews.map(r => (
          <figure class="rounded-xl bg-surface p-5">
            <div class="flex items-center justify-between">
              <div class="text-accent-500">★★★★★</div>
              <time class="text-xs text-slate-500">{r.date}</time>
            </div>
            <blockquote class="mt-3 text-[14.5px] text-slate-700 leading-relaxed">{r.text}</blockquote>
            <figcaption class="mt-4 flex items-center justify-between">
              <span class="text-sm font-semibold text-navy-700">{r.name}</span>
              <span class="text-[11px] font-semibold text-slate-500">G · Google</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>

    <div class="mt-8 text-center">
      <a href="/reviews/" class="btn-primary btn-lg">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14 2 9.27l6.91-1.01z"/></svg>
        See All Reviews
      </a>
    </div>
  </div>
</section>
