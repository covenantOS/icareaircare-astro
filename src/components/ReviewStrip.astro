---
import { SITE, formatToday } from '../lib/site';
import Schema from './Schema.astro';

interface Props {
  /** Override the default themed-feedback set with real authored reviews — render with Review schema. */
  reviews?: { author: string; body: string; rating?: number; date?: string; neighborhood?: string }[];
}
const { reviews } = Astro.props;

// Default themed-feedback cards (no Review schema — these summarize patterns, not specific reviews).
const themed = [
  { label: 'Clear Communication', text: 'Customers often mention that the team explains the issue, the repair path, and the price before work begins.' },
  { label: 'Respectful Service', text: 'Homeowners call out clean work, marked trucks, friendly technicians, and service that feels local instead of rushed.' },
  { label: 'Practical Repairs', text: 'The recurring theme is honest diagnosis: fix what can be fixed, explain when replacement makes more sense, and put it in writing.' },
];

const useReal = Array.isArray(reviews) && reviews.length > 0;
const today = formatToday();
---
<section class="py-16 md:py-20 bg-paper">
  <div class="container-site">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="text-3xl md:text-4xl title-accent">Our Great Customer Experience</h2>
      <p class="mt-6 text-slate-600 leading-relaxed">
        Common themes from homeowners who needed <a class="text-brand-600 underline underline-offset-2 hover:text-brand-700" href="/services/ac-repair-tampa/">a no-cool unit fixed</a>, <a class="text-brand-600 underline underline-offset-2 hover:text-brand-700" href="/services/emergency-ac-repair-tampa/">priority same-day dispatch</a>, and full HVAC service across Wesley Chapel and the Tampa Bay area.
      </p>
    </div>

    <div class="mt-10 rounded-2xl bg-white shadow-[var(--shadow-soft)] ring-1 ring-slate-100 p-6 md:p-8">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
          <h3 class="text-navy-700 font-bold text-lg">What our clients say about us</h3>
          <p class="mt-1 text-xs text-slate-500">As of {today}</p>
        </div>
        <div class="text-right">
          <div class="text-3xl font-bold text-navy-700">{SITE.rating.value.toFixed(2)}</div>
          <div class="text-accent-500 tracking-tight">★★★★★</div>
          <div class="text-xs text-slate-500">{SITE.rating.count}+ reviews</div>
        </div>
      </div>
      <div class="mt-6 grid md:grid-cols-3 gap-5">
        {useReal && reviews!.map(r => (
          <figure class="rounded-xl bg-surface p-5">
            <div class="flex items-center justify-between">
              <div class="text-accent-500">{'★'.repeat(r.rating ?? 5)}</div>
              <span class="text-xs text-slate-500">Verified Google review</span>
            </div>
            <p class="mt-3 text-[14.5px] text-slate-700 leading-relaxed">{r.body}</p>
            <figcaption class="mt-4 flex items-center justify-between">
              <span class="text-sm font-semibold text-navy-700">{r.author}{r.neighborhood ? ` · ${r.neighborhood}` : ''}</span>
              <span class="text-[11px] font-semibold text-slate-500">G · Google</span>
            </figcaption>
          </figure>
        ))}
        {!useReal && themed.map(r => (
          <figure class="rounded-xl bg-surface p-5">
            <div class="flex items-center justify-between">
              <div class="text-accent-500">★★★★★</div>
              <span class="text-xs text-slate-500">Google feedback</span>
            </div>
            <p class="mt-3 text-[14.5px] text-slate-700 leading-relaxed">{r.text}</p>
            <figcaption class="mt-4 flex items-center justify-between">
              <span class="text-sm font-semibold text-navy-700">{r.label}</span>
              <span class="text-[11px] font-semibold text-slate-500">G · Google</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>

    <div class="mt-8 text-center">
      <a href="/reviews/" class="btn-primary btn-lg">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14 2 9.27l6.91-1.01z"/></svg>
        See All Reviews
      </a>
    </div>
  </div>
  {useReal && <Schema type="Reviews" reviews={reviews} />}
</section>
