---
import LeadForm from './LeadForm.astro';
---
<section class="relative py-16 md:py-20 overflow-hidden" id="quote">
  <div class="absolute inset-0 bg-gradient-to-br from-brand-600 via-brand-500 to-brand-700"></div>
  <img src="/images/I-Care-Air-Care-%E2%80%93-Blue-Background-Banner-lines.webp" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover mix-blend-overlay opacity-25" />
  <div class="relative container-site max-w-5xl">
    <div class="grid lg:grid-cols-5 gap-8 lg:gap-12 items-center">
      <div class="lg:col-span-2 text-white">
        <h2 class="text-white text-3xl md:text-4xl title-accent text-left">Contact Us for a Free Quote</h2>
        <p class="mt-6 text-blue-50 leading-relaxed">
          Tell us a little about your HVAC need and we'll reach out with next steps and a free quote — usually within the same business day.
        </p>
        <ul class="mt-6 space-y-2 text-blue-50 text-sm">
          <li class="flex items-center gap-2"><span class="text-accent-400">✓</span> Upfront, flat-rate pricing</li>
          <li class="flex items-center gap-2"><span class="text-accent-400">✓</span> Licensed · CAC1816515</li>
          <li class="flex items-center gap-2"><span class="text-accent-400">✓</span> 700+ five-star Google reviews</li>
          <li class="flex items-center gap-2"><span class="text-accent-400">✓</span> Serving Wesley Chapel, New Tampa, Land O' Lakes &amp; all Tampa Bay</li>
        </ul>
      </div>
      <div class="lg:col-span-3">
        <LeadForm title="Request a Free Quote" variant="card" />
      </div>
    </div>
  </div>
</section>
<style>
  .title-accent.text-left::after { margin-left: 0; }
</style>
