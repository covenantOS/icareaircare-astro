---
import { SITE } from '../lib/site';

interface Props {
  // 'compact' = small horizontal row for footer / contact / reviews.
  // 'card' = larger card-style row for tim-hawk page or anywhere needing more presence.
  variant?: 'compact' | 'card';
  // 'light' = badges look right on light/surface bg, 'dark' = on navy/brand bg.
  theme?: 'light' | 'dark';
  // Tighter wrap for footer
  align?: 'center' | 'start';
}
const {
  variant = 'compact',
  theme = 'light',
  align = 'center',
} = Astro.props;

const badges = [
  {
    label: 'Google',
    sub: `${SITE.rating.value}★ · ${SITE.rating.count}+ reviews`,
    href: 'https://maps.app.goo.gl/2iCjuu1yf3GAbvSS8',
    icon: 'google',
  },
  {
    label: `FL ${SITE.license}`,
    sub: 'Verify on DBPR',
    href: SITE.licenseVerificationUrl,
    icon: 'shield',
  },
  {
    label: 'BBB',
    sub: 'Wesley Chapel profile',
    href: 'https://www.bbb.org/us/fl/wesley-chapel/profile/air-conditioning-contractor/i-care-air-care-llc-0653-90109276',
    icon: 'bbb',
  },
  {
    label: 'Rheem',
    sub: 'Pro Partner',
    href: 'https://icareaircare.rheempropartner.com/',
    icon: 'rheem',
  },
];

const wrapJustify = align === 'center' ? 'justify-center' : 'justify-start';
---
{variant === 'compact' && (
  <div class={`flex flex-wrap ${wrapJustify} items-stretch gap-2 md:gap-3`}>
    {badges.map(b => (
      <a
        href={b.href}
        target="_blank"
        rel="noopener"
        class={`group inline-flex items-center gap-2.5 rounded-lg px-3 py-2 transition ${theme === 'dark' ? 'bg-white/10 ring-1 ring-white/20 hover:bg-white/15 hover:ring-white/40 text-white' : 'bg-white ring-1 ring-slate-200 hover:ring-brand-400 hover:shadow-[var(--shadow-card)] text-navy-700'}`}
        aria-label={`${b.label} — ${b.sub}`}
      >
        <span class="shrink-0 w-7 h-7 rounded-md flex items-center justify-center" aria-hidden="true">
          {b.icon === 'google' && (
            <svg width="18" height="18" viewBox="0 0 48 48">
              <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
              <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
              <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
              <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
            </svg>
          )}
          {b.icon === 'shield' && (
            <svg width="18" height="18" viewBox="0 0 24 24" class={theme === 'dark' ? 'text-accent-400' : 'text-brand-700'} fill="currentColor">
              <path d="M12 2l8 3v6c0 5-3.4 9.6-8 11-4.6-1.4-8-6-8-11V5l8-3zm-1 13l5-5-1.4-1.4L11 12.2l-2.6-2.6L7 11l4 4z"/>
            </svg>
          )}
          {b.icon === 'bbb' && (
            <span class="inline-flex w-7 h-7 rounded-md bg-[#005a87] text-white text-[10px] font-bold items-center justify-center tracking-tight">BBB</span>
          )}
          {b.icon === 'rheem' && (
            <span class="inline-flex w-7 h-[18px] rounded bg-[#cf112d] text-white text-[8px] font-bold items-center justify-center tracking-[0.04em] px-1">RHEEM</span>
          )}
        </span>
        <span class="leading-tight">
          <span class={`block text-[12px] font-bold ${theme === 'dark' ? 'text-white' : 'text-navy-700'} group-hover:text-brand-700`}>{b.label}</span>
          <span class={`block text-[10px] ${theme === 'dark' ? 'text-blue-100' : 'text-slate-500'}`}>{b.sub}</span>
        </span>
      </a>
    ))}
  </div>
)}

{variant === 'card' && (
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
    {badges.map(b => (
      <a
        href={b.href}
        target="_blank"
        rel="noopener"
        class="group rounded-2xl bg-white ring-1 ring-slate-200 hover:ring-brand-400 hover:shadow-[var(--shadow-card)] p-4 transition flex items-center gap-3"
      >
        <span class="shrink-0 w-10 h-10 rounded-xl flex items-center justify-center bg-white ring-1 ring-slate-100" aria-hidden="true">
          {b.icon === 'google' && (
            <svg width="22" height="22" viewBox="0 0 48 48">
              <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
              <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
              <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
              <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
            </svg>
          )}
          {b.icon === 'shield' && (
            <svg width="22" height="22" viewBox="0 0 24 24" class="text-brand-700" fill="currentColor">
              <path d="M12 2l8 3v6c0 5-3.4 9.6-8 11-4.6-1.4-8-6-8-11V5l8-3zm-1 13l5-5-1.4-1.4L11 12.2l-2.6-2.6L7 11l4 4z"/>
            </svg>
          )}
          {b.icon === 'bbb' && (
            <span class="inline-flex w-9 h-9 rounded-lg bg-[#005a87] text-white text-xs font-bold items-center justify-center tracking-tight">BBB</span>
          )}
          {b.icon === 'rheem' && (
            <span class="inline-flex w-9 h-6 rounded bg-[#cf112d] text-white text-[9px] font-bold items-center justify-center tracking-[0.04em]">RHEEM</span>
          )}
        </span>
        <span class="min-w-0 leading-tight">
          <span class="block text-[11px] uppercase tracking-[0.12em] text-slate-500">{b.label}</span>
          <span class="block text-[13px] font-bold text-navy-700 group-hover:text-brand-700 truncate">{b.sub}</span>
        </span>
      </a>
    ))}
  </div>
)}
