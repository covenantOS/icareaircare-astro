---
import { SITE } from '../lib/site';
interface Props { compact?: boolean; title?: string; variant?: 'hero' | 'section' | 'card'; }
const { compact = false, title = 'Request your free quote', variant = 'hero' } = Astro.props;

const wrapClass = variant === 'hero'
  ? 'rounded-2xl bg-brand-500/90 backdrop-blur ring-1 ring-white/30 shadow-[0_20px_50px_-20px_rgba(15,26,41,0.6)] p-6 md:p-7'
  : variant === 'card'
  ? 'rounded-xl bg-white ring-1 ring-slate-200 shadow-[var(--shadow-soft)] p-6 md:p-7'
  : 'rounded-2xl bg-white/95 ring-1 ring-white/50 shadow-[var(--shadow-soft)] p-6 md:p-7';

const fieldClass = variant === 'card'
  ? 'w-full rounded-md border border-slate-200 bg-slate-50 focus:bg-white px-3.5 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 text-ink placeholder:text-slate-500'
  : 'w-full rounded-md border border-transparent bg-white focus:bg-white px-3.5 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-accent-400 text-ink placeholder:text-slate-500';
---
<form
  class={wrapClass}
  action="https://formsubmit.co/tim@icareaircare.com"
  method="POST"
>
  <input type="hidden" name="_subject" value="New lead from icareaircare.com" />
  <input type="hidden" name="_next" value="https://www.icareaircare.com/contact/#thanks" />
  <input type="hidden" name="_captcha" value="true" />
  <input type="text" name="_honey" tabindex="-1" autocomplete="off" class="hidden" />

  {title && (
    <h3 class={`${variant === 'hero' ? 'text-white' : 'text-navy-700'} font-bold text-lg md:text-xl mb-4`}>
      {title}
    </h3>
  )}

  <div class="space-y-3">
    <label class="block">
      <span class="sr-only">Name</span>
      <input name="name" type="text" placeholder="Name*" required class={fieldClass} />
    </label>
    <label class="block">
      <span class="sr-only">Email Address</span>
      <input name="email" type="email" placeholder="Email Address" required class={fieldClass} />
    </label>
    <label class="block">
      <span class="sr-only">Phone</span>
      <div class="relative">
        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-base select-none" aria-hidden="true">🇺🇸</span>
        <input name="phone" type="tel" placeholder="Phone Number*" required class={`${fieldClass} pl-9`} />
      </div>
    </label>
    <label class="block">
      <span class="sr-only">Street address</span>
      <input name="address" type="text" placeholder="Street address (optional)" class={fieldClass} />
    </label>
    <div class="grid grid-cols-2 gap-3">
      <label class="block">
        <span class="sr-only">City</span>
        <input name="city" type="text" placeholder="City" class={fieldClass} />
      </label>
      <label class="block">
        <span class="sr-only">State</span>
        <input name="state" type="text" placeholder="State" value="FL" class={fieldClass} />
      </label>
    </div>
    <label class="block">
      <span class="sr-only">Zip Code</span>
      <input name="zip" type="text" placeholder="Postal Code" class={fieldClass} />
    </label>
  </div>

  <button type="submit" class="mt-4 w-full inline-flex items-center justify-center gap-2 rounded-md bg-accent-500 hover:bg-accent-600 text-white font-bold px-6 py-3.5 shadow-sm transition">
    Get Quote
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
  </button>
  <p class={`mt-3 text-[11px] text-center ${variant === 'hero' ? 'text-blue-50' : 'text-slate-500'}`}>We'll never sell your info. Reply STOP anytime.</p>
</form>
