---
interface Props {
  variant?: 'full' | 'compact';
  showCta?: boolean;
}
const { variant = 'full', showCta = true } = Astro.props;
---
{variant === 'full' ? (
  <section class="py-14 md:py-18 bg-white">
    <div class="container-site">
      <div class="grid lg:grid-cols-12 gap-10 items-center">

        <div class="lg:col-span-6 relative">
          <div class="relative rounded-2xl overflow-hidden ring-1 ring-slate-200 shadow-[var(--shadow-soft)] bg-white">
            <img
              src="/images/gen/rheem-lifestyle-w480.webp"
              srcset="/images/gen/rheem-lifestyle-w480.webp 480w, /images/gen/rheem-lifestyle-w800.webp 800w"
              sizes="(min-width: 1024px) 520px, 100vw"
              alt='Rheem — "The new degree of comfort" family lifestyle image'
              width="580"
              height="400"
              class="w-full h-auto block"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="absolute -bottom-4 -left-4 rounded-xl bg-white p-3 shadow-[0_12px_32px_-12px_rgb(21_35_56_/_0.2)] ring-1 ring-slate-200 flex items-center gap-3">
            <img src="/images/gen/rheem-logo-w104.webp"
                 srcset="/images/gen/rheem-logo-w104.webp 1x, /images/gen/rheem-logo-w208.webp 2x"
                 alt="Rheem logo" width="52" height="52" class="w-13 h-13" loading="lazy" />
            <div class="text-[13px] leading-tight">
              <div class="font-bold text-navy-700">Rheem®</div>
              <div class="text-slate-600 text-[11px]">The new degree of comfort.™</div>
            </div>
          </div>
        </div>

        <div class="lg:col-span-6">
          <span class="inline-flex items-center rounded-full bg-red-50 ring-1 ring-red-200 text-red-700 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em]">Rheem® Pro Partner</span>
          <h2 class="mt-3 text-3xl md:text-4xl title-accent">A factory-authorized Rheem Pro Partner in Wesley Chapel.</h2>
          <p class="mt-5 text-slate-600 leading-relaxed text-[17px]">We install and service every major HVAC brand — Carrier, Trane, Lennox, Rheem, Goodman, American Standard, Bryant, Mitsubishi. Rheem is the one we know inside and out. Our installers are factory-trained on Rheem's current product lines, we warranty-register every Rheem system we install, and we carry the Rheem-specific parts that keep our service trucks rolling on same-day repair calls.</p>

          <div class="mt-7 grid sm:grid-cols-2 gap-4 text-[14.5px]">
            <div class="flex gap-3">
              <div class="mt-0.5 w-9 h-9 rounded-lg bg-red-50 text-red-600 flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2L2 7v10l10 5 10-5V7L12 2zm0 2.2L19.5 8 12 11.8 4.5 8 12 4.2z"/></svg>
              </div>
              <div>
                <div class="font-bold text-navy-700">Factory-trained installers</div>
                <div class="text-slate-600 text-[13px]">Current Rheem product lines, commissioning protocols, A2L refrigerant handling.</div>
              </div>
            </div>
            <div class="flex gap-3">
              <div class="mt-0.5 w-9 h-9 rounded-lg bg-red-50 text-red-600 flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.4 4.8L20 8l-4 3.9.9 5.5L12 14.8 7.1 17.4 8 11.9 4 8l5.6-1.2z"/></svg>
              </div>
              <div>
                <div class="font-bold text-navy-700">Warranty registration</div>
                <div class="text-slate-600 text-[13px]">We register every Rheem install so parts and labor coverage doesn't expire quietly.</div>
              </div>
            </div>
            <div class="flex gap-3">
              <div class="mt-0.5 w-9 h-9 rounded-lg bg-red-50 text-red-600 flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4 6h16v12H4z" fill="none"/><path d="M3 5h18v14H3V5zm2 2v10h14V7H5zm2 2h10v2H7V9zm0 4h6v2H7v-2z"/></svg>
              </div>
              <div>
                <div class="font-bold text-navy-700">Rheem parts on the truck</div>
                <div class="text-slate-600 text-[13px]">Capacitors, contactors, motors, and board-level components specific to Rheem equipment.</div>
              </div>
            </div>
            <div class="flex gap-3">
              <div class="mt-0.5 w-9 h-9 rounded-lg bg-red-50 text-red-600 flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 3a6 6 0 00-3 11.2V18a3 3 0 006 0v-3.8A6 6 0 0012 3z"/></svg>
              </div>
              <div>
                <div class="font-bold text-navy-700">Matched system design</div>
                <div class="text-slate-600 text-[13px]">Manual-J sized, matched condenser + air handler for real Florida latent-load removal.</div>
              </div>
            </div>
          </div>

          {showCta && (
            <div class="mt-7 flex flex-wrap gap-3">
              <a href="/services/hvac-installation-tampa/" class="btn-primary">See HVAC Installation</a>
              <a href="tel:+18133952324" class="btn-ghost">Call (813) 395-2324</a>
            </div>
          )}
        </div>

      </div>
    </div>
  </section>
) : (
  <section class="py-10 bg-white border-y border-slate-100">
    <div class="container-site flex flex-col sm:flex-row items-center gap-6 justify-between">
      <div class="flex items-center gap-4">
        <img src="/images/gen/rheem-logo-w104.webp"
             srcset="/images/gen/rheem-logo-w104.webp 1x, /images/gen/rheem-logo-w208.webp 2x"
             alt="Rheem logo" width="48" height="48" class="w-12 h-12" loading="lazy" />
        <div>
          <div class="inline-flex items-center rounded-full bg-red-50 text-red-700 px-2.5 py-0.5 text-[10.5px] font-bold uppercase tracking-[0.14em] ring-1 ring-red-200">Rheem® Pro Partner</div>
          <div class="mt-1 font-bold text-navy-700 text-[15.5px]">Factory-authorized Rheem installer in Wesley Chapel.</div>
          <div class="text-slate-600 text-[13px]">Also fully service Carrier, Trane, Lennox, Goodman &amp; every major brand.</div>
        </div>
      </div>
      {showCta && (
        <a href="/services/hvac-installation-tampa/" class="inline-flex items-center gap-1.5 text-sm font-bold text-brand-700 hover:text-brand-800">
          See HVAC installation
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      )}
    </div>
  </section>
)}
