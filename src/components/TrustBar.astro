---
import { SITE } from '../lib/site';
---
<div class="bg-brand-700 text-white text-[13px]">
  <div class="container-site flex flex-wrap items-center justify-between gap-y-2 py-2">
    <div class="flex items-center gap-4">
      <span class="inline-flex items-center gap-1.5">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-amber-300"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {SITE.rating.value}★ • {SITE.rating.count}+ Google Reviews
      </span>
      <span class="hidden sm:inline">Licensed & Insured · CAC1816515</span>
      <span class="hidden md:inline">Urgent No-Cool Help</span>
    </div>
    <a href={SITE.phoneHref} class="font-semibold hover:underline">{SITE.phone}</a>
  </div>
</div>
