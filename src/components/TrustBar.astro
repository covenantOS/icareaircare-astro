---
// Reusable E-E-A-T / trust-signal row. Drop under the intro of any service
// page. Presentational only - pulls live numbers from SITE so every page
// stays in sync. Wrapped in not-prose so it is safe inside .prose-icac.
import { SITE } from '../lib/site';

const items = [
  { t: `${SITE.rating.value}★ · ${SITE.rating.count}+ Google reviews`, d: 'M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01z', gold: true },
  { t: `Licensed · ${SITE.license}`, d: 'M12 2l8 4v6c0 5-3.4 8.5-8 10-4.6-1.5-8-5-8-10V6l8-4z' },
  { t: 'EPA 608 Universal Certified', d: 'M12 2a10 10 0 100 20 10 10 0 000-20zm-1 14l-4-4 1.4-1.4L11 13.2l5.6-5.6L18 9l-7 7z' },
  { t: `${SITE.yearsInBusiness} years serving Tampa Bay`, d: 'M12 2a10 10 0 100 20 10 10 0 000-20zm1 5h-2v6l5 3 1-1.7-4-2.3V7z' },
  { t: `${SITE.customersServed} homes served`, d: 'M12 3l9 8h-3v9h-5v-6h-2v6H6v-9H3l9-8z' },
  { t: '1-year workmanship warranty', d: 'M9 16.2l-3.5-3.5L4 14.2 9 19.2 20 8.2 18.6 6.8z' },
];
---
<div class="not-prose my-8 rounded-xl bg-gradient-to-br from-brand-50 to-surface ring-1 ring-brand-100 px-5 py-4">
  <ul class="flex flex-wrap gap-x-5 gap-y-3 items-center">
    {items.map((i) => (
      <li class="inline-flex items-center gap-2 text-[13.5px] font-semibold text-navy-700">
        <svg width="18" height="18" viewBox="0 0 24 24" class="shrink-0 text-brand-600" aria-hidden="true"><path d={i.d} fill={i.gold ? '#fbbc04' : 'currentColor'} /></svg>
        {i.t}
      </li>
    ))}
  </ul>
</div>
