---
interface Item { q: string; a: string; }
interface Props { title?: string; items: Item[]; columns?: 1 | 2; variant?: 'teal' | 'white'; }
const { title = 'Frequently Asked Questions', items, columns = 2, variant = 'teal' } = Astro.props;

const cardClass = variant === 'white'
  ? 'group rounded-xl bg-white border border-brand-100 hover:border-brand-300 transition open:border-brand-300 open:shadow-sm'
  : 'group rounded-md bg-brand-500/85 text-white hover:bg-brand-600 transition open:bg-brand-600';

const summaryClass = variant === 'white'
  ? 'flex items-start justify-between gap-4 cursor-pointer list-none px-5 py-4 font-semibold text-navy-700'
  : 'flex items-start justify-between gap-4 cursor-pointer list-none px-5 py-4 font-semibold';

const chevronClass = variant === 'white'
  ? 'text-2xl leading-none text-accent-500 transition-transform group-open:rotate-45 shrink-0'
  : 'text-2xl leading-none text-accent-400 transition-transform group-open:rotate-45 shrink-0';

const bodyClass = variant === 'white'
  ? 'px-5 pb-5 -mt-1 text-[15px] text-slate-600 leading-relaxed'
  : 'px-5 pb-5 -mt-1 text-[15px] text-blue-50 leading-relaxed';
---
<section class="py-16 md:py-20 bg-paper">
  <div class="container-site">
    <h2 class="text-center text-3xl md:text-4xl title-accent">{title}</h2>
    <div class={`mt-10 grid ${columns === 2 ? 'md:grid-cols-2' : ''} gap-3 md:gap-4`}>
      {items.map(item => (
        <details class={cardClass}>
          <summary class={summaryClass}>
            <span set:html={item.q}></span>
            <span class={chevronClass}>+</span>
          </summary>
          <div class={bodyClass} set:html={item.a}></div>
        </details>
      ))}
    </div>
    <p class="mt-8 text-center text-slate-600">
      Still have questions? <a href="/contact/" class="text-accent-500 font-semibold underline underline-offset-2 hover:text-accent-600">Call us today</a> or send us a message — our team is here to help.
    </p>
  </div>
</section>
