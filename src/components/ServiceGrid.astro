---
import { SITE } from '../lib/site';

const cards = [
  { slug: 'ac-repair-tampa', name: 'AC Repair', img: '/images/HVAC-Services-in-Tampa-FL-%E2%80%93-Outdoor-AC-Unit-Repair-Man.webp' },
  { slug: 'ac-maintenance-tampa', name: 'AC Maintenance', img: '/images/HVAC-Services-in-Tampa-FL-%E2%80%93-AC-Refrigerant-Pressure-Testing.webp' },
  { slug: 'hvac-installation-tampa', name: 'HVAC Installation', img: '/images/HVAC-Installation-Tampa-Bay-%E2%80%93-New-Outdoor-Condenser-Installation.webp' },
  { slug: 'air-duct-cleaning-tampa', name: 'Air Duct Cleaning', img: '/images/air-duct-cleaning-wesley-chapel-metal-ductwork-supply-vent-register.webp' },
  { slug: 'refrigeration-repair-tampa', name: 'Refrigeration Services', img: '/images/HVAC-Services-in-Tampa-FL-%E2%80%93-Commercial-AC-Condenser-Systems.webp' },
  { slug: 'heating-services-tampa', name: 'Heating Services', img: '/images/Heating-Services-ICAC.webp' },
  { slug: 'thermostat-installation-tampa', name: 'Thermostat Installation', img: '/images/smart-thermostat-installation-tampa-honeywell.webp' },
  { slug: 'emergency-ac-repair-tampa', name: 'Emergency HVAC', img: '/images/Outdoor-AC-Condenser-Installation-HVAC-Contractor-Near-Me.webp' },
];

// Derive srcset variants generated by scripts/resize-images.mjs
// e.g. /images/Foo.webp -> /images/gen/Foo-w320.webp + /images/gen/Foo-w520.webp
function variants(src: string) {
  const m = src.match(/^(\/images\/)(.+)\.(webp|jpg|png)$/);
  if (!m) return { small: src, large: src };
  const base = `/images/gen/${m[2]}`;
  return { small: `${base}-w320.webp`, large: `${base}-w520.webp` };
}

const icons: Record<string, string> = {
  'ac-repair-tampa': 'M9 3v2H7v14h2v2h6v-2h2V5h-2V3H9zm0 4h6v10H9V7z',
  'ac-maintenance-tampa': 'M22 9l-3-3 1.5-1.5L22 6l2.5-2.5L26 5l-4 4zM3 13l4 4H3v-4zm9-7a5 5 0 00-5 5v1h10v-1a5 5 0 00-5-5z',
  'hvac-installation-tampa': 'M3 7h18v10H3V7zm2 2v6h14V9H5z',
  'air-duct-cleaning-tampa': 'M4 4h16v4H4V4zm0 6h16v4H4v-4zm0 6h16v4H4v-4z',
  'refrigeration-repair-tampa': 'M6 2h12v20H6V2zm2 2v7h8V4H8zm0 9v7h8v-7H8z',
  'heating-services-tampa': 'M12 2c-1 4 3 4 3 8s-4 4-3 8c-3-4 1-8 0-12-2 0-3-2-3-4h3z',
  'thermostat-installation-tampa': 'M12 2a6 6 0 00-3 11.17V18a3 3 0 006 0v-4.83A6 6 0 0012 2zm0 14a1 1 0 110-2 1 1 0 010 2z',
  'emergency-ac-repair-tampa': 'M12 2L1 21h22L12 2zm0 6l7 12H5l7-12zm-1 4h2v4h-2v-4zm0 5h2v2h-2v-2z',
};
---
<section class="py-14 md:py-20 bg-wave">
  <div class="container-site">
    <div class="text-center mb-10 md:mb-14">
      <h2 class="text-3xl md:text-4xl title-accent">Our Expert HVAC Services</h2>
      <p class="mt-6 max-w-2xl mx-auto text-slate-600 leading-relaxed">
        From emergency <a href="/services/ac-repair-tampa/" class="text-brand-800 hover:text-brand-900 underline underline-offset-2">AC repair</a> to full system replacements, our licensed Wesley Chapel technicians cover every HVAC need across Pasco, Hillsborough and Polk counties.
      </p>
    </div>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5">
      {cards.map(c => {
        const v = variants(c.img);
        return (
        <a href={`/services/${c.slug}/`} class="group relative block overflow-hidden rounded-xl aspect-[4/5] shadow-[var(--shadow-card)] hover:shadow-[var(--shadow-soft)] transition">
          <img src={v.large}
               srcset={`${v.small} 320w, ${v.large} 520w`}
               sizes="(min-width: 1024px) 232px, 48vw"
               alt={c.name} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition duration-500" loading="lazy" width="400" height="500" />
          <div class="absolute inset-0 bg-gradient-to-t from-navy-800/85 via-navy-800/35 to-navy-800/10"></div>
          <div class="absolute inset-0 bg-navy-900/0 group-hover:bg-navy-900/30 transition-colors duration-500"></div>
          <div class="absolute top-3 left-3 inline-flex items-center justify-center w-10 h-10 rounded-md bg-brand-500/90 text-white">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d={icons[c.slug]} /></svg>
          </div>
          <div class="absolute bottom-0 inset-x-0 p-4 md:p-5">
            <h3 class="text-white font-bold text-lg md:text-xl leading-snug">{c.name}</h3>
            <span class="mt-1 inline-flex items-center gap-1 text-sm font-semibold text-accent-400">
              Learn more
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
        );
      })}
    </div>
  </div>
</section>
