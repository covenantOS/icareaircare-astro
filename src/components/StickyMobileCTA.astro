---
import { SITE } from '../lib/site';
---
<div class="lg:hidden fixed bottom-0 inset-x-0 z-40 bg-white/95 backdrop-blur border-t border-slate-200 px-4 py-3 flex gap-2 shadow-lg">
  <a href={SITE.phoneHref} class="flex-1 inline-flex items-center justify-center rounded-full bg-brand-600 text-white font-semibold text-sm px-4 py-3">
    Call {SITE.phone}
  </a>
  <a href={SITE.bookUrl} target="_blank" rel="noopener" class="inline-flex items-center justify-center rounded-full border border-brand-600 text-brand-700 font-semibold text-sm px-4 py-3">
    Book
  </a>
</div>
