---
import { SITE } from '../lib/site';
---
<div
  id="sticky-mobile-cta"
  class="md:hidden fixed bottom-0 inset-x-0 z-40 bg-white border-t border-slate-200 px-4 py-3 flex gap-3 shadow-[0_-4px_16px_rgba(0,0,0,0.08)]"
  style="transform:translateY(100%);transition:transform 360ms cubic-bezier(.4,0,.2,1);"
  aria-label="Quick contact"
>
  <a href={SITE.phoneHref} class="flex-1 inline-flex items-center justify-center gap-2 rounded-full bg-accent-500 hover:bg-accent-600 text-white font-bold text-[14px] px-4 py-3 transition-colors">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.21 11.36 11.36 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.58 1 1 0 01-.21 1.11l-2.2 2.1z"/></svg>
    Call Now
  </a>
  <a href="/contact/" class="flex-1 inline-flex items-center justify-center gap-2 rounded-full border-2 border-accent-500 text-accent-600 hover:bg-accent-50 font-bold text-[14px] px-4 py-3 transition-colors">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    Book Online
  </a>
</div>

<script is:inline>
  (function () {
    var bar = document.getElementById('sticky-mobile-cta');
    if (!bar) return;
    var visible = false;
    var ticking = false;
    var THRESHOLD = 200;
    function update() {
      var show = window.scrollY > THRESHOLD;
      if (show !== visible) {
        visible = show;
        bar.style.transform = show ? 'translateY(0)' : 'translateY(100%)';
      }
      ticking = false;
    }
    window.addEventListener('scroll', function () {
      if (!ticking) { ticking = true; requestAnimationFrame(update); }
    }, { passive: true });
    update();
  })();
</script>
