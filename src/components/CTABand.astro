---
import { SITE } from '../lib/site';
interface Props { title?: string; subtitle?: string; }
const {
  title = 'AC trouble? We can usually be there today.',
  subtitle = 'Call now or book online and a local technician will be on the way.',
} = Astro.props;
---
<section class="py-14 md:py-16 bg-gradient-to-r from-brand-800 to-brand-700">
  <div class="container-site text-center text-white">
    <h2 class="text-3xl md:text-4xl font-bold text-white">{title}</h2>
    <p class="mt-3 text-white max-w-2xl mx-auto">{subtitle}</p>
    <div class="mt-7 flex flex-wrap justify-center gap-3">
      <a href={SITE.phoneHref} class="inline-flex items-center rounded-full bg-accent-500 hover:bg-accent-600 text-navy-900 font-bold px-6 py-3 shadow-lg">
        Call {SITE.phone}
      </a>
      <a href="/contact/" class="inline-flex items-center rounded-full bg-white/15 border border-white/60 hover:bg-white/25 text-white font-semibold px-6 py-3">
        Book online
      </a>
    </div>
  </div>
</section>
