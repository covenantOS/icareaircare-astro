---
import { SITE } from '../lib/site';
import LeadForm from './LeadForm.astro';
interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  showForm?: boolean;
  variant?: 'home' | 'page';
  ctaLabel?: string;
  ctaHref?: string;
}
const {
  eyebrow = `${SITE.yearsInBusiness}+ Years of Service`,
  title = "Tampa's #1 Air Conditioning Contractor",
  subtitle,
  image = '/images/ICAC%20Team.webp',
  imageAlt = 'I Care Air Care team in Wesley Chapel, FL',
  showForm = false,
  variant = 'page',
  ctaLabel = 'Book Now',
  ctaHref = '/contact/',
} = Astro.props;
---
<section class="relative overflow-hidden">
  <!-- Image layer -->
  <div class="absolute inset-0">
    <img src={image} alt="" aria-hidden="true" class="w-full h-full object-cover" width="1600" height="900" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-700/85 via-navy-700/72 to-brand-700/55"></div>
  </div>

  <div class={`relative container-site grid lg:grid-cols-12 gap-10 ${showForm ? 'py-12 md:py-16 lg:py-20' : 'py-16 md:py-24'} items-center`}>
    <div class={`${showForm ? 'lg:col-span-7' : 'lg:col-span-8'} text-white`}>
      {eyebrow && (
        <span class="inline-flex items-center gap-2 rounded-full bg-white/10 ring-1 ring-white/20 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.18em] text-accent-400">
          {eyebrow}
        </span>
      )}
      <h1 class="mt-4 text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-[1.05]">
        <span set:html={title} />
      </h1>
      {subtitle && <p class="mt-5 text-lg text-blue-100 max-w-xl leading-relaxed" set:html={subtitle} />}

      <div class="mt-7 flex flex-wrap gap-3">
        <a href={ctaHref} class="btn-primary btn-lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          {ctaLabel}
        </a>
        {variant === 'home' && (
          <a href="/service-areas/" class="btn-outline btn-lg">
            See Our Service Areas →
          </a>
        )}
      </div>

      {variant === 'home' && (
        <div class="mt-8 flex flex-wrap gap-x-8 gap-y-3 text-sm text-blue-50">
          <span class="inline-flex items-center gap-2">
            <span class="text-accent-400 tracking-tight">★★★★★</span>
            <span>Rated {SITE.rating.value}/5 &nbsp;|&nbsp; {SITE.rating.count}+ Happy Homeowners</span>
          </span>
          <span class="inline-flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-accent-400"><path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg>
            Licensed & Insured · CAC1816515
          </span>
          <span class="inline-flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-accent-400"><path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg>
            1-Year Repair Warranty
          </span>
        </div>
      )}
    </div>

    {showForm && (
      <div class="lg:col-span-5">
        <LeadForm title="Request a free quote" />
      </div>
    )}
  </div>

  <!-- Subtle bottom wave -->
  <svg aria-hidden="true" viewBox="0 0 1440 80" preserveAspectRatio="none" class="block w-full h-12 text-white"><path fill="currentColor" d="M0 40 C240 80 480 0 720 40 C960 80 1200 0 1440 40 L1440 80 L0 80 Z"/></svg>
</section>
