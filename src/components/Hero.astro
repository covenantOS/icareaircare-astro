---
import { SITE } from '../lib/site';
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  ctaLabel?: string;
  ctaHref?: string;
}
const {
  eyebrow,
  title,
  subtitle,
  image = '/images/Air-Conditioning-Cool-Photo-May-13-2025-scaled-1.webp',
  imageAlt = 'I Care Air Care HVAC technician in Wesley Chapel, FL',
  ctaLabel = 'Schedule Service',
  ctaHref = '/contact/',
} = Astro.props;
---
<section class="relative overflow-hidden bg-gradient-to-br from-brand-800 via-brand-700 to-brand-600 text-white">
  <div class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_30%_20%,white,transparent_40%)]"></div>
  <div class="container-site relative grid lg:grid-cols-2 gap-10 py-16 md:py-24 items-center">
    <div>
      {eyebrow && <p class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider">{eyebrow}</p>}
      <h1 class="mt-4 text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-[1.05]">{title}</h1>
      {subtitle && <p class="mt-5 text-lg text-blue-100 max-w-xl leading-relaxed">{subtitle}</p>}
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={SITE.phoneHref} class="inline-flex items-center gap-2 rounded-full bg-accent-500 hover:bg-accent-600 text-brand-900 font-semibold px-6 py-3 shadow-lg transition">
          Call {SITE.phone}
        </a>
        <a href={ctaHref} class="inline-flex items-center gap-2 rounded-full bg-white/10 hover:bg-white/20 border border-white/30 text-white font-semibold px-6 py-3 transition">
          {ctaLabel}
        </a>
      </div>
      <div class="mt-8 flex items-center gap-5 text-sm text-blue-100">
        <span class="inline-flex items-center gap-1.5">⭐ {SITE.rating.value} Google Rating</span>
        <span class="inline-flex items-center gap-1.5">✓ 30+ Years Experience</span>
        <span class="hidden sm:inline-flex items-center gap-1.5">✓ Same-Day Service</span>
      </div>
    </div>
    <div class="relative">
      <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-2xl ring-1 ring-white/10">
        <img src={image} alt={imageAlt} class="w-full h-full object-cover" width="800" height="600" loading="eager" />
      </div>
    </div>
  </div>
</section>
