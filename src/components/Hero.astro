---
import { SITE } from '../lib/site';
import LeadForm from './LeadForm.astro';
interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  showForm?: boolean;
  variant?: 'home' | 'page';
  ctaLabel?: string;
  ctaHref?: string;
}
const {
  eyebrow = `${SITE.yearsInBusiness}+ Years of Service`,
  title = "Tampa's #1 Air Conditioning Contractor",
  subtitle,
  image = '/images/ICAC%20Team%281%29.webp',
  imageAlt = 'I Care Air Care team in Wesley Chapel, FL with service vans',
  showForm = false,
  variant = 'page',
  ctaLabel = 'Book Now',
  ctaHref,
} = Astro.props;
---
<section class="relative overflow-hidden">
  <!-- Image layer -->
  <div class="absolute inset-0">
    <img src={image} alt="" aria-hidden="true" class="w-full h-full object-cover object-center" width="1600" height="900" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-900/92 via-navy-800/82 to-brand-800/60"></div>
  </div>

  <div class={`relative container-site grid lg:grid-cols-12 gap-8 lg:gap-10 ${showForm ? 'py-12 md:py-16 lg:py-20' : 'py-16 md:py-24'} items-center`}>
    <div class={`${showForm ? 'lg:col-span-7' : 'lg:col-span-8'} text-white`}>
      {eyebrow && (
        <span class="inline-flex items-center rounded-full bg-white text-brand-700 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.14em] shadow-sm">
          {eyebrow}
        </span>
      )}
      <h1 class="mt-5 text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-[1.05] drop-shadow-[0_2px_12px_rgba(15,26,41,0.4)]">
        <span set:html={title} />
      </h1>
      {subtitle && <p class="mt-5 text-lg text-blue-50 max-w-xl leading-relaxed drop-shadow-[0_1px_6px_rgba(15,26,41,0.35)]" set:html={subtitle} />}

      <div class="mt-7 flex flex-wrap gap-3">
        <a href={ctaHref || SITE.bookUrl} target={ctaHref ? undefined : '_blank'} rel={ctaHref ? undefined : 'noopener'} class="btn-primary btn-lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          {ctaLabel}
        </a>
        {variant === 'home' && (
          <a href="/service-areas/" class="btn-outline btn-lg">
            See Our Service Areas →
          </a>
        )}
      </div>

      {variant === 'home' && (
        <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-white">
          <div class="flex items-center gap-2">
            <span class="inline-flex items-center rounded-md bg-white px-2 py-1 shadow-sm">
              <svg viewBox="0 0 48 48" width="18" height="18" aria-hidden="true"><path fill="#4285F4" d="M45.1 24.5c0-1.6-.1-2.7-.3-3.9H24v7.1h12.1c-.3 1.8-1.6 4.6-4.5 6.5l-.04.3 6.5 5 .5.05c4.1-3.8 6.5-9.4 6.5-15.1z"/><path fill="#34A853" d="M24 46c5.9 0 10.8-1.9 14.4-5.3l-6.9-5.3c-1.8 1.3-4.3 2.2-7.5 2.2-5.7 0-10.5-3.8-12.2-9h-.3l-6.7 5.2-.1.3C8.3 40.9 15.5 46 24 46z"/><path fill="#FBBC05" d="M11.8 28.6c-.4-1.3-.7-2.7-.7-4.1s.3-2.8.7-4.1l-.02-.3-6.8-5.3-.2.1C3.4 17.9 2.5 20.8 2.5 24s.9 6.1 2.3 9l7-5.4z"/><path fill="#EB4335" d="M24 10.5c4 0 6.7 1.7 8.3 3.2l6-5.9C34.7 4.3 29.9 2 24 2 15.5 2 8.3 7.1 4.8 15l7 5.4c1.7-5.2 6.5-9 12.2-9z"/></svg>
            </span>
            <span class="text-accent-400">★★★★★</span>
            <span>Rated {SITE.rating.value}/5 · {SITE.rating.count}+ Happy Homeowners</span>
          </div>
          <span class="inline-flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-accent-400"><path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg>
            Licensed & Insured · CAC1816515
          </span>
          <span class="inline-flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-accent-400"><path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg>
            1-Year Repair Warranty
          </span>
        </div>
      )}
    </div>

    {showForm && (
      <div class="lg:col-span-5">
        <LeadForm title="Request a Free Quote" />
      </div>
    )}
  </div>

  <!-- Subtle bottom wave to ease into next section -->
  <svg aria-hidden="true" viewBox="0 0 1440 80" preserveAspectRatio="none" class="block w-full h-12 text-[color:var(--color-surface)]"><path fill="currentColor" d="M0 40 C240 80 480 0 720 40 C960 80 1200 0 1440 40 L1440 80 L0 80 Z"/></svg>
</section>
