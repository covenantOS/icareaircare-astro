---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import BlogStrip from '../components/BlogStrip.astro';
import FinalCTA from '../components/FinalCTA.astro';
import ContactFormSection from '../components/ContactFormSection.astro';

const allPosts = [
  { href: '/air-conditioning-not-cooling-in-tampa-fl-heres-how-to-fix-it-fast/', title: 'AC Not Cooling in Tampa? How to Fix It Fast', tag: 'AC Repair', date: 'Apr 12', read: '11 min' },
  { href: '/ac-blowing-warm-air-in-tampa-heres-how-to-fix-it-fast/', title: 'AC Blowing Warm Air in Tampa? 8 Common Causes', tag: 'AC Repair', date: 'Apr 10', read: '8 min' },
  { href: '/new-construction-hvac-guide-for-epperson-mirada-homeowners/', title: 'New Construction HVAC Guide for Epperson & Mirada', tag: 'Installation', date: 'Mar 28', read: '8 min' },
  { href: '/ac-not-cooling-wesley-chapel/', title: 'AC Not Cooling in Wesley Chapel? Troubleshooting', tag: 'AC Repair', date: 'Mar 23', read: '12 min' },
  { href: '/air-duct-cleaning-wesley-chapel/', title: 'Air Duct Cleaning in Wesley Chapel — What You Need', tag: 'IAQ', date: 'Mar 20', read: '10 min' },
  { href: '/ac-maintenance-wesley-chapel/', title: 'AC Maintenance in Wesley Chapel', tag: 'Maintenance', date: 'Mar 15', read: '9 min' },
  { href: '/air-conditioning-installation-wesley-chapel/', title: 'Air Conditioning Installation in Wesley Chapel', tag: 'Installation', date: 'Mar 10', read: '11 min' },
  { href: '/emergency-ac-repair-wesley-chapel/', title: 'Emergency AC Repair in Wesley Chapel', tag: 'Emergency', date: 'Mar 5', read: '7 min' },
  { href: '/hvac-installation-in-tampa-bay-complete-guide-for-homeowners/', title: 'HVAC Installation in Tampa Bay — Complete Guide', tag: 'Installation', date: 'Feb 28', read: '14 min' },
];
---
<BaseLayout
  title="HVAC Blog | I Care Air Care Wesley Chapel"
  description="Expert HVAC tips, repair guides, and maintenance advice from I Care Air Care's licensed Wesley Chapel team. AC not cooling? Ducts dirty? Start here."
  breadcrumbs={[{name:'Home',url:'https://www.icareaircare.com/'},{name:'Blog',url:'https://www.icareaircare.com/blogs/'}]}
>
  <Hero
    eyebrow="HVAC Library"
    title="The I Care Air Care HVAC Library"
    subtitle="Real answers from licensed technicians. AC troubleshooting, maintenance guides, new-construction tips, and everything Wesley Chapel homeowners need to stay comfortable."
    image="/images/HVAC-installation-Tampa-Bay-technician-installing-a-ceiling-air-vent-register-in-a-home.webp"
  />
  <section class="py-16">
    <div class="container-site">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {allPosts.map(p => (
          <a href={p.href} class="group block rounded-2xl bg-white ring-1 ring-slate-100 shadow-[var(--shadow-card)] p-6 hover:shadow-[var(--shadow-soft)] hover:-translate-y-0.5 transition">
            <div class="inline-flex rounded-md bg-brand-50 text-brand-700 text-xs font-semibold px-2.5 py-1">{p.tag}</div>
            <h3 class="mt-3 text-lg font-bold text-navy-700 group-hover:text-brand-600 leading-snug">{p.title}</h3>
            <div class="mt-3 text-xs text-slate-500 flex items-center gap-3">
              <span>{p.date}</span>
              <span>•</span>
              <span>{p.read} read</span>
            </div>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-accent-500">Read article →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
  <BlogStrip />
  <FinalCTA />
  <ContactFormSection />
</BaseLayout>
