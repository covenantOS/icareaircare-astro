  { q: 'Do you service both AC and heating emergencies?', a: 'Yes — we handle heat pump failures, furnace lockouts, and air handler problems year-round. Cold snaps in January are almost as busy for us as July heat.' },
];

const related = [
  { href: '/services/ac-repair-tampa/', label: 'Standard AC Repair' },
  { href: '/services/ac-maintenance-tampa/', label: 'AC Maintenance (Prevent the Emergency)' },
