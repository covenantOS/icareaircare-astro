---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ServiceGrid from '../../components/ServiceGrid.astro';
import WhyChooseUs from '../../components/WhyChooseUs.astro';
import ReviewStrip from '../../components/ReviewStrip.astro';
import AreaGrid from '../../components/AreaGrid.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import ContactFormSection from '../../components/ContactFormSection.astro';
import FAQ from '../../components/FAQ.astro';

const faqs = [
  { q: 'What HVAC services do you provide in Tampa?', a: 'AC repair, emergency AC repair, AC maintenance & tune-ups, new HVAC installation, air duct cleaning, heating services (heat pumps, heat strips, furnaces), thermostat installation, and commercial refrigeration repair.' },
  { q: 'Are you licensed and insured in Florida?', a: 'Yes — Florida CAC1816515, bonded and insured. We send trained, uniformed technicians in marked service vehicles.' },
  { q: 'Do you offer same-day service?', a: 'Most standard service calls are handled same-day. Emergency calls during business hours are prioritized ahead of routine maintenance.' },
  { q: 'What areas do you serve?', a: 'All of Pasco, Hillsborough, and Polk counties — including Wesley Chapel, Tampa, New Tampa, Land O\' Lakes, Lutz, Odessa, and Zephyrhills.' },
];
---
<BaseLayout
  title="HVAC Services in Wesley Chapel & Tampa Bay | I Care Air Care"
  description="Wesley Chapel HVAC: AC repair, install, maintenance, duct cleaning, heating, thermostats, refrigeration. 4.9★ · 700+ reviews. Call (813) 395-2324."
  breadcrumbs={[{name:'Home',url:'https://www.icareaircare.com/'},{name:'Services',url:'https://www.icareaircare.com/services/'}]}
>
  <Hero
    eyebrow="Our Services · Wesley Chapel"
    title="Full-Service HVAC for Wesley Chapel & Tampa Bay"
    subtitle={`Eight core services, one licensed local team based in Wesley Chapel. From same-day AC repair to complete system replacements, air duct cleaning to commercial refrigeration — we do it all, and we do it right.`}
    image="/images/I-Care-Air-Care-HVAC-Installation-%E2%80%93-Local-Team-and-Service-Vans.webp"
    ctaLabel="Request a Quote"
    ctaHref="/contact/"
  />
  <ServiceGrid />
  <WhyChooseUs />
  <ReviewStrip />
  <AreaGrid />
  <FAQ items={faqs} />
  <FinalCTA />
  <ContactFormSection />
</BaseLayout>
