---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import FinalCTA from '../components/FinalCTA.astro';
import ContactFormSection from '../components/ContactFormSection.astro';
const team = [
  { name: 'Tim Hawk', title: 'Owner & Master HVAC Technician', img: '/images/Tim%20Hawk%20(ICAC%20Owner).webp', bio: 'Tim founded I Care Air Care in 2010 after three decades in the Tampa Bay HVAC industry. Florida-licensed master contractor, EPA Universal certified, and the person you\u2019ll often hear answer the phone.' },
  { name: 'The Install Crew', title: 'Licensed Installers', img: '/images/ICAC%20Team%282%29.webp', bio: 'Our installation team is factory-trained on every major residential brand and fully certified on the new R-454B refrigerant required for 2026 equipment.' },
  { name: 'The Service Team', title: 'Service & Maintenance Technicians', img: '/images/ICAC%20Team%283%29.webp', bio: 'EPA 608 certified, background-checked, uniformed. The crew that shows up in the marked truck for every repair and tune-up call.' },
  { name: 'Office & Dispatch', title: 'Customer Experience', img: '/images/ICAC%20Team%284%29.webp', bio: 'The voices behind the phone at (813) 395-2324. They\u2019ll confirm your appointment, answer your questions, and make sure every visit is smooth.' },
];
---
<BaseLayout
  title="Meet Our Team | I Care Air Care Wesley Chapel HVAC"
  description="Meet the licensed, background-checked HVAC technicians behind I Care Air Care in Wesley Chapel. Family-owned team with 30+ years combined experience."
  breadcrumbs={[{name:'Home',url:'https://www.icareaircare.com/'},{name:'Our Team',url:'https://www.icareaircare.com/our-team/'}]}
>
  <Hero
    eyebrow="Our Team"
    title="The People Behind I Care Air Care"
    subtitle="Licensed, background-checked, uniformed, and friendly. Every technician on our team is someone we\u2019d send to our own grandmother\u2019s house."
    image="/images/ICAC%20Team.webp"
    ctaLabel="Schedule Service"
  />
  <section class="py-16">
    <div class="container-site">
      <div class="grid md:grid-cols-2 gap-6 md:gap-8 max-w-5xl mx-auto">
        {team.map(m => (
          <div class="rounded-2xl bg-white ring-1 ring-slate-100 shadow-[var(--shadow-card)] overflow-hidden">
            <div class="aspect-[4/3] overflow-hidden bg-surface">
              <img src={m.img} alt={m.name} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-navy-700">{m.name}</h3>
              <p class="text-sm font-semibold uppercase tracking-[0.1em] text-brand-600 mt-1">{m.title}</p>
              <p class="mt-3 text-slate-600 leading-relaxed">{m.bio}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
  <WhyChooseUs />
  <FinalCTA />
  <ContactFormSection />
</BaseLayout>
