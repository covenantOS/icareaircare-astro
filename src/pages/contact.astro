---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ContactFormSection from '../components/ContactFormSection.astro';
import FinalCTA from '../components/FinalCTA.astro';
import { SITE } from '../lib/site';
const mapEmbed = 'https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d14061.8!2d-82.3727!3d28.2427!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e0!3m2!1sen!2sus!4v1713600000000';
---
<BaseLayout
  title="Contact I Care Air Care | Wesley Chapel HVAC (813) 395-2324"
  description="Call (813) 395-2324 or email tim@icareaircare.com for fast AC repair, HVAC service, and estimates across Wesley Chapel, Tampa & Tampa Bay."
  breadcrumbs={[{name:'Home',url:'https://www.icareaircare.com/'},{name:'Contact',url:'https://www.icareaircare.com/contact/'}]}
>
  <Hero
    eyebrow="Contact Us"
    title="We'd love to hear from you"
    subtitle="Call, email, or fill out the form. Same-day replies during business hours and priority scheduling for urgent no-cool issues when available."
    image="/images/Tim%20Hawk%20(ICAC%20Owner).webp"
    ctaLabel="Call Now"
    ctaHref={SITE.phoneHref}
  />

  <section class="py-16">
    <div class="container-site max-w-5xl grid md:grid-cols-3 gap-6">
      <div class="rounded-2xl bg-white ring-1 ring-slate-200 shadow-sm p-6">
        <div class="inline-flex w-12 h-12 items-center justify-center rounded-lg bg-brand-500 text-white mb-4">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.21 11.36 11.36 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.58 1 1 0 01-.21 1.11l-2.2 2.1z"/></svg>
        </div>
        <h3 class="font-bold text-navy-700 text-lg">Call or text</h3>
        <p class="mt-2 text-slate-600 text-sm">Same-day scheduling during business hours, with urgent no-cool calls prioritized when availability allows.</p>
        <a href={SITE.phoneHref} class="mt-3 inline-block text-accent-500 font-bold text-xl hover:text-accent-600">{SITE.phone}</a>
      </div>
      <div class="rounded-2xl bg-white ring-1 ring-slate-200 shadow-sm p-6">
        <div class="inline-flex w-12 h-12 items-center justify-center rounded-lg bg-brand-500 text-white mb-4">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
        </div>
        <h3 class="font-bold text-navy-700 text-lg">Email</h3>
        <p class="mt-2 text-slate-600 text-sm">For quotes, questions, or non-urgent scheduling.</p>
        <a href={`mailto:${SITE.email}`} class="mt-3 inline-block text-brand-600 font-semibold hover:text-brand-700">{SITE.email}</a>
      </div>
      <div class="rounded-2xl bg-white ring-1 ring-slate-200 shadow-sm p-6">
        <div class="inline-flex w-12 h-12 items-center justify-center rounded-lg bg-brand-500 text-white mb-4">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a7 7 0 00-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 00-7-7zm0 10a3 3 0 110-6 3 3 0 010 6z"/></svg>
        </div>
        <h3 class="font-bold text-navy-700 text-lg">Visit us</h3>
        <p class="mt-2 text-slate-600 text-sm">{SITE.address.street}<br/>{SITE.address.city}, {SITE.address.region} {SITE.address.postalCode}</p>
        <p class="mt-3 text-slate-600 text-sm">
          <strong class="text-navy-700">Hours:</strong><br/>
          Mon–Fri: 8 AM – 6 PM<br/>
          Sat: 10 AM – 4 PM
        </p>
      </div>
    </div>
    <div class="container-site max-w-5xl mt-8">
      <div class="rounded-2xl overflow-hidden shadow-[var(--shadow-soft)] ring-1 ring-slate-200 h-[360px]">
        <iframe src={mapEmbed} width="100%" height="100%" style="border:0" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="I Care Air Care location"></iframe>
      </div>
    </div>
  </section>

  <ContactFormSection />
  <FinalCTA />
</BaseLayout>
