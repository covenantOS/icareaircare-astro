---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FinalCTA from '../components/FinalCTA.astro';
import ContactFormSection from '../components/ContactFormSection.astro';
import Schema from '../components/Schema.astro';
import { BLOG_POSTS, type BlogPost } from '../lib/blog';
import { SITE } from '../lib/site';

export function getStaticPaths() {
  return BLOG_POSTS.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: BlogPost };
const url = `${SITE.url}/${post.slug}/`;
const breadcrumbs = [
  { name: 'Home', url: `${SITE.url}/` },
  { name: 'Blog', url: `${SITE.url}/blogs/` },
  { name: post.title, url },
];
// Related posts: same tag first, fill with most recent if needed, exclude current
const sameTagPosts = BLOG_POSTS.filter(p => p.slug !== post.slug && p.tag === post.tag).slice(0, 4);
const fillerPosts = BLOG_POSTS.filter(p => p.slug !== post.slug && p.tag !== post.tag).slice(0, 4 - sameTagPosts.length);
const relatedPosts = [...sameTagPosts, ...fillerPosts].slice(0, 4);
const articleSchema = {
  '@type': 'Article',
  headline: post.title,
  description: post.description,
  image: `${SITE.url}${post.image}`,
  datePublished: new Date(post.date).toISOString(),
  dateModified: new Date(post.date).toISOString(),
  author: { '@id': `${SITE.url}/#tim-hawk` },
  reviewedBy: { '@id': `${SITE.url}/#tim-hawk` },
  publisher: { '@id': `${SITE.url}/#business` },
  mainEntityOfPage: url,
};

// HowTo schema for fix-it / troubleshooting posts. The checklist becomes HowTo steps.
const isHowTo =
  /ac-not-cooling|warm-air|filter-change|how-to-lower|fix-it-fast|emergency-ac-repair/.test(post.slug) &&
  post.checklist && post.checklist.length > 0;
const howToData = isHowTo ? {
  name: post.title,
  description: post.description,
  image: `${SITE.url}${post.image}`,
  totalTime: 'PT30M',
} : null;
---
<BaseLayout title={`${post.title} | I Care Air Care`} description={post.description} breadcrumbs={breadcrumbs}>
  <Hero
    eyebrow={`${post.tag} · ${post.location}`}
    title={post.title}
    subtitle={post.description}
    image={post.image}
    imageAlt={post.imageAlt || `${post.title} — I Care Air Care Wesley Chapel, FL`}
    ctaLabel={`Schedule ${post.primaryService.label}`}
    ctaHref={post.primaryService.href}
  />

  <section class="py-14 md:py-20 bg-white">
    <div class="container-site grid lg:grid-cols-12 gap-10 items-start">
      <article class="lg:col-span-8 prose-icac">
        <div class="not-prose flex flex-wrap items-center gap-3 text-sm text-slate-500 mb-6">
          <span class="inline-flex rounded-md bg-brand-50 text-brand-700 text-xs font-semibold px-2.5 py-1">{post.tag}</span>
          <span>By <strong class="text-navy-700">{SITE.owner}</strong>, Licensed HVAC Contractor · {SITE.license}</span>
          <span>•</span>
          <span>{post.date}</span>
          <span>•</span>
          <span>{post.read} read</span>
        </div>

        <h2>Quick Answer</h2>
        <p>{post.description}</p>

        <div class="not-prose my-8 rounded-xl bg-surface ring-1 ring-slate-200 p-5">
          <h3 class="text-lg font-bold text-navy-700">Start here before you book service</h3>
          <ul class="mt-4 grid gap-3 text-[15px] text-slate-700">
            {post.checklist.map((item) => (
              <li class="flex gap-3">
                <span class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-600 text-white text-xs">✓</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Mobile-only CTA after checklist -->
        <div class="not-prose my-6 lg:hidden rounded-xl bg-brand-500 text-white p-4 flex items-center justify-between gap-4">
          <p class="text-sm font-semibold text-blue-50">Sounds like you need a tech?</p>
          <a href="tel:+18133952324" class="shrink-0 rounded-md bg-accent-500 hover:bg-accent-600 text-white font-bold px-4 py-2.5 text-sm">(813) 395-2324</a>
        </div>

        {post.body
          ? <Fragment set:html={post.body} />
          : (
            <>
              <h2>What this usually means in {post.location}</h2>
              <p>Florida HVAC problems tend to stack together: long runtime, humidity, clogged drains, dusty returns, and outdoor condenser heat all show up at the same time. That is why the best first step is a measured diagnosis instead of guessing from one symptom.</p>
              <p>If the issue connects to cooling performance, airflow, maintenance, or replacement planning, the service path usually starts with <a href={post.primaryService.href}>{post.primaryService.label}</a>. From there, a technician can separate the simple fixes from the repairs that need parts, gauges, electrical testing, or a written replacement proposal.</p>
              <h2>When to call I Care Air Care</h2>
              <p>Call when the system is not keeping up, the air feels warm, water is near the air handler, the outdoor unit is not running, the breaker trips repeatedly, or the repair decision is no longer obvious. We will explain the next step, give you the earliest available appointment window, and quote work before it begins.</p>
            </>
          )
        }

        <!-- Author bio -->
        <div class="not-prose mt-10 rounded-xl bg-surface ring-1 ring-slate-200 p-5 flex items-start gap-4">
          <img src="/images/Tim%20Hawk%20(ICAC%20Owner).webp" alt="Tim Hawk, Owner of I Care Air Care" class="w-14 h-14 rounded-full ring-2 ring-brand-200 object-cover shrink-0" width="56" height="56" loading="lazy" />
          <div>
            <div class="font-bold text-navy-700">{SITE.owner}</div>
            <div class="text-xs text-brand-600 font-semibold uppercase tracking-wide">Owner &amp; Master HVAC Technician · Florida License {SITE.license}</div>
            <p class="mt-2 text-[14px] text-slate-600 leading-relaxed">Tim founded I Care Air Care in 2010 after 30+ years in the Tampa Bay HVAC trade. EPA Universal certified. The source for all technical guidance published on this site.</p>
          </div>
        </div>

        <h2>Related local help</h2>
        <p>These pages connect this guide to the services and local areas homeowners usually need next:</p>
        <ul>
          {[post.primaryService, ...post.related].map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </article>

      <aside class="lg:col-span-4 space-y-5">

        <!-- 1. Call / book CTA -->
        <div class="rounded-xl bg-brand-500 text-white p-6 shadow-[var(--shadow-soft)]">
          <h3 class="text-white text-xl font-bold">Need help with this?</h3>
          <p class="mt-3 text-blue-50 text-sm leading-relaxed">Talk with the Wesley Chapel team and get the right next step for your home.</p>
          <a href={SITE.phoneHref} class="mt-5 inline-flex w-full justify-center rounded-md bg-accent-500 hover:bg-accent-600 text-white font-bold px-4 py-3">{SITE.phone}</a>
          <a href={SITE.bookUrl} class="mt-2 inline-flex w-full justify-center rounded-md bg-white/10 border border-white/30 hover:bg-white/20 text-white font-semibold px-4 py-3">Book Online</a>
        </div>

        <!-- 2. Author / E-E-A-T card -->
        <div class="rounded-xl bg-white ring-1 ring-slate-200 p-5 shadow-[var(--shadow-card)]">
          <div class="flex items-center gap-3">
            <img src="/images/Tim%20Hawk%20(ICAC%20Owner).webp" alt="Tim Hawk, Owner" class="w-12 h-12 rounded-full ring-2 ring-brand-200 object-cover object-top shrink-0" width="48" height="48" loading="lazy" />
            <div>
              <div class="font-bold text-navy-700 text-sm">{SITE.owner}</div>
              <div class="text-[11px] text-brand-600 font-semibold uppercase tracking-wide">Owner · Master Tech</div>
            </div>
          </div>
          <p class="mt-3 text-[13px] text-slate-600 leading-relaxed">Florida HVAC License <strong class="text-navy-700">{SITE.license}</strong> · EPA Universal certified · 16+ years serving Wesley Chapel.</p>
          <a href="/about-us/" class="mt-3 inline-block text-brand-600 text-[13px] font-semibold hover:text-brand-700">Meet the team →</a>
        </div>

        <!-- 3. Popular next steps -->
        <div class="rounded-xl bg-surface ring-1 ring-slate-200 p-6">
          <h3 class="text-lg font-bold text-navy-700">Popular next steps</h3>
          <ul class="mt-3 space-y-2 text-[15px]">
            {post.related.map((link) => (
              <li><a class="text-brand-600 hover:text-brand-700 underline underline-offset-2" href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>

        <!-- 4. Reviews CTA -->
        <div class="rounded-xl bg-white ring-1 ring-slate-200 p-5 shadow-[var(--shadow-card)]">
          <div class="flex items-center gap-3">
            <div class="text-3xl font-extrabold text-navy-700 leading-none">{SITE.rating.value.toFixed(1)}</div>
            <div>
              <div class="text-accent-500 text-sm leading-none">★★★★★</div>
              <div class="text-[11px] text-slate-500 mt-1">{SITE.rating.count}+ Google reviews</div>
            </div>
          </div>
          <p class="mt-3 text-[13px] text-slate-600 leading-relaxed">Homeowners across Wesley Chapel, Tampa, Land O' Lakes & Pasco trust our work.</p>
          <a href="/reviews/" class="mt-3 inline-block text-brand-600 text-[13px] font-semibold hover:text-brand-700">Read reviews →</a>
        </div>

        <!-- 5. More posts -->
        <div class="rounded-xl bg-white ring-1 ring-slate-200 p-5 shadow-[var(--shadow-card)]">
          <h3 class="text-sm font-bold text-navy-700 uppercase tracking-wide">More from the library</h3>
          <ul class="mt-3 space-y-3">
            {relatedPosts.map((p) => (
              <li>
                <a href={`/${p.slug}/`} class="group flex gap-3">
                  <div class="w-14 h-14 rounded-md overflow-hidden bg-slate-100 shrink-0">
                    <img src={p.image} alt="" class="w-full h-full object-cover" width="56" height="56" loading="lazy" />
                  </div>
                  <div class="min-w-0">
                    <div class="text-[13.5px] font-semibold text-navy-700 group-hover:text-brand-600 leading-snug line-clamp-2">{p.title}</div>
                    <div class="text-[11px] text-slate-500 mt-0.5">{p.read} read</div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
          <a href="/blogs/" class="mt-4 inline-block text-brand-600 text-[13px] font-semibold hover:text-brand-700">All HVAC articles →</a>
        </div>

        <!-- 6. Service areas -->
        <div class="rounded-xl bg-surface ring-1 ring-slate-200 p-6">
          <h3 class="text-sm font-bold text-navy-700 uppercase tracking-wide">Service areas</h3>
          <ul class="mt-3 grid grid-cols-2 gap-x-3 gap-y-1 text-[13.5px]">
            {SITE.serviceAreas.slice(0, 8).map((a) => (
              <li><a class="text-brand-600 hover:text-brand-700" href={`/service-areas/${a.slug}/`}>{a.name}</a></li>
            ))}
          </ul>
          <a href="/service-areas/" class="mt-3 inline-block text-brand-600 text-[13px] font-semibold hover:text-brand-700">All areas →</a>
        </div>

        <!-- 7. License / trust strip -->
        <div class="rounded-xl bg-navy-700 text-white p-5">
          <div class="text-[11px] uppercase tracking-[0.14em] text-blue-200 font-bold">Licensed &amp; Insured</div>
          <div class="mt-2 font-bold">Florida CAC {SITE.license.replace('CAC','')}</div>
          <div class="mt-1 text-[12.5px] text-blue-100">Bonded · EPA 608 · 1-year repair warranty</div>
          <div class="mt-3 text-[12px] text-blue-200">{SITE.address.street}, {SITE.address.city}, {SITE.address.region} {SITE.address.postalCode}</div>
        </div>

      </aside>
    </div>
  </section>

  <FinalCTA />
  <ContactFormSection />
  <Schema type="Article" data={articleSchema} />
  {isHowTo && <Schema type="HowTo" data={howToData} steps={post.checklist} />}
</BaseLayout>
