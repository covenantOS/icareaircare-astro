---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AreaGrid from '../../components/AreaGrid.astro';
import CTABand from '../../components/CTABand.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import ContactFormSection from '../../components/ContactFormSection.astro';
import { SITE } from '../../lib/site';
---
<BaseLayout
  title="HVAC Service Areas | Wesley Chapel & Tampa Bay | I Care Air Care"
  description="I Care Air Care serves all of Pasco, Hillsborough & Polk counties — including Wesley Chapel, New Tampa, Land O' Lakes, Lutz, Odessa, Zephyrhills & more. Call (813) 395-2324."
  breadcrumbs={[{name:'Home',url:'https://www.icareaircare.com/'},{name:'Service Areas',url:'https://www.icareaircare.com/service-areas/'}]}
>
  <section class="bg-brand-800 text-white py-14 md:py-20">
    <div class="container-site max-w-4xl">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-blue-200">Where we work</p>
      <h1 class="mt-2 text-4xl md:text-5xl font-bold text-white">HVAC Service Areas Across Tampa Bay</h1>
      <p class="mt-4 text-lg text-blue-100 max-w-2xl leading-relaxed">Based at 27022 Foamflower Blvd in Wesley Chapel, our licensed team dispatches to all of Pasco, Hillsborough, and Polk counties — nine dedicated service communities and growing. Same-day service available when the schedule allows.</p>
      <div class="mt-6 flex flex-wrap gap-3 text-sm">
        <span class="inline-flex items-center gap-1.5 bg-white/10 border border-white/20 rounded-full px-4 py-1.5 text-white"><span class="text-accent-400">✓</span> Florida License CAC1822037</span>
        <span class="inline-flex items-center gap-1.5 bg-white/10 border border-white/20 rounded-full px-4 py-1.5 text-white"><span class="text-accent-400">✓</span> 4.9★ · 700+ Google Reviews</span>
        <span class="inline-flex items-center gap-1.5 bg-white/10 border border-white/20 rounded-full px-4 py-1.5 text-white"><span class="text-accent-400">✓</span> 16+ Years Serving Tampa Bay</span>
      </div>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="container-site max-w-4xl prose-icac">
      <h2>Three-county coverage, one licensed local team</h2>
      <p>I Care Air Care covers the full Tampa Bay tri-county area from a single Wesley Chapel headquarters. That means every technician knows the roads, the neighborhoods, and the HVAC equipment common to each community. <a href="/service-areas/pasco-county-ac-repair/">Pasco County</a> homes, <a href="/service-areas/hillsborough-county-hvac-company/">Hillsborough County</a> neighborhoods, and <a href="/service-areas/polk-county-residential-ac-repair/">Polk County</a> communities all get the same licensed, flat-rate service — with the same 1-year repair warranty and same same-day scheduling approach.</p>
      <p>Not sure you're in range? Call <a href={SITE.phoneHref}>{SITE.phone}</a> and ask. If we can't reach you, we'll tell you who can.</p>
    </div>
  </section>

  <AreaGrid />

  <section class="py-14 md:py-18 bg-surface">
    <div class="container-site max-w-4xl">
      <h2 class="text-2xl md:text-3xl font-bold text-navy-700">Which area is closest to you?</h2>
      <p class="mt-3 text-slate-600 leading-relaxed">Each page below includes hyper-local detail — neighborhoods, ZIP codes, local landmarks, climate notes, and honest timing info from the actual drive time out of Wesley Chapel. Click your community for the full picture.</p>
      <div class="mt-8 grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SITE.serviceAreas.map(a => (
          <a href={`/service-areas/${a.slug}/`} class="group rounded-xl bg-white ring-1 ring-slate-200 hover:ring-brand-300 hover:shadow-[var(--shadow-card)] p-5 transition">
            <div class="flex items-center gap-2 text-brand-600">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a7 7 0 00-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 00-7-7z"/></svg>
              <span class="text-[11px] uppercase tracking-[0.14em] font-bold">Service area</span>
            </div>
            <div class="mt-2 font-bold text-navy-700 group-hover:text-brand-700">{a.name}</div>
            <div class="mt-3 text-sm text-accent-500 font-semibold">View page →</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABand />
  <FinalCTA />
  <ContactFormSection />
</BaseLayout>
