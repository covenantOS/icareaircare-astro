---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../lib/site';
---
<BaseLayout title="Page Not Found | I Care Air Care" description="The page you requested could not be found." noindex>
  <section class="py-28 text-center">
    <div class="container-site max-w-xl">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-brand-600">404</p>
      <h1 class="mt-3 text-4xl font-bold text-navy-700">We can't find that page.</h1>
      <p class="mt-4 text-slate-600 text-lg">Try one of these links, or call us directly.</p>
      <a href={SITE.phoneHref} class="mt-6 inline-flex items-center gap-2 rounded-full bg-accent-500 hover:bg-accent-600 text-white px-6 py-3.5 font-bold text-lg shadow-sm transition">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.21 11.36 11.36 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.58 1 1 0 01-.21 1.11l-2.2 2.1z"/></svg>
        Call {SITE.phone}
      </a>
      <div class="mt-8 flex flex-wrap justify-center gap-3 text-sm">
        <a href="/" class="rounded-full border border-slate-200 bg-white hover:bg-surface px-4 py-2 text-navy-700 font-semibold transition">Home</a>
        <a href="/services/" class="rounded-full border border-slate-200 bg-white hover:bg-surface px-4 py-2 text-navy-700 font-semibold transition">Services</a>
        <a href="/service-areas/" class="rounded-full border border-slate-200 bg-white hover:bg-surface px-4 py-2 text-navy-700 font-semibold transition">Service Areas</a>
        <a href="/about-us/" class="rounded-full border border-slate-200 bg-white hover:bg-surface px-4 py-2 text-navy-700 font-semibold transition">About Us</a>
        <a href="/contact/" class="rounded-full border border-slate-200 bg-white hover:bg-surface px-4 py-2 text-navy-700 font-semibold transition">Contact</a>
        <a href="/reviews/" class="rounded-full border border-slate-200 bg-white hover:bg-surface px-4 py-2 text-navy-700 font-semibold transition">Reviews</a>
      </div>
    </div>
  </section>
</BaseLayout>