---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import AreaGrid from '../components/AreaGrid.astro';
import BlogStrip from '../components/BlogStrip.astro';
import FinalCTA from '../components/FinalCTA.astro';
import { SITE } from '../lib/site';
---
<BaseLayout
  title="Page Not Found | I Care Air Care"
  description="The page you requested has moved or no longer exists. Find HVAC services, service areas, or call (813) 395-2324 for immediate help."
  noindex
>
  <!-- Apology + immediate help -->
  <section class="py-16 md:py-24 bg-gradient-to-br from-brand-50 via-white to-surface relative overflow-hidden">
    <!-- Background pattern -->
    <div class="absolute inset-0 opacity-[0.04] pointer-events-none" aria-hidden="true">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs><pattern id="grid" width="48" height="48" patternUnits="userSpaceOnUse"><path d="M0 0h48v48H0z" fill="none" stroke="currentColor" stroke-width="1"/></pattern></defs>
        <rect width="100%" height="100%" fill="url(#grid)" />
      </svg>
    </div>
    <div class="container-site relative">
      <div class="max-w-2xl mx-auto text-center">
        <p class="text-xs font-bold uppercase tracking-[0.18em] text-brand-700">404 · Page moved or removed</p>
        <h1 class="mt-3 text-4xl md:text-5xl font-bold text-navy-700">We couldn't find that page.</h1>
        <p class="mt-5 text-slate-600 text-lg leading-relaxed">
          We rebuilt our website in April 2026 and a few old links didn't make the trip. Most of what you were looking for still lives somewhere on this site — pick a quick link below, or call us and we'll point you to it.
        </p>

        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href={SITE.phoneHref} class="btn-primary btn-lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.21 11.36 11.36 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.58 1 1 0 01-.21 1.11l-2.2 2.1z"/></svg>
            Call {SITE.phone}
          </a>
          <a href={SITE.bookUrl} target="_blank" rel="noopener" class="btn-ghost btn-lg">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Book Online
          </a>
        </div>

        <!-- Inline Google site-search -->
        <form action="https://www.google.com/search" method="get" class="mt-10 max-w-md mx-auto flex items-stretch rounded-full overflow-hidden ring-1 ring-slate-200 bg-white shadow-sm focus-within:ring-2 focus-within:ring-brand-500 transition">
          <input type="hidden" name="q" value="" id="search-q-hidden" />
          <input
            type="text"
            id="search-q"
            placeholder="Search the site (e.g. duct cleaning, Wesley Chapel)"
            class="flex-1 bg-transparent px-5 py-3 text-sm focus:outline-none"
            aria-label="Search I Care Air Care"
          />
          <button type="submit" class="bg-accent-500 hover:bg-accent-600 text-white font-semibold px-5 text-sm transition">Search</button>
        </form>
        <noscript><p class="mt-3 text-xs text-slate-500">JavaScript is required for site search. <a href="/blogs/" class="underline">Browse the blog</a> instead.</p></noscript>

        <!-- Quick chip links -->
        <div class="mt-8 flex flex-wrap justify-center gap-2 text-sm">
          <a href="/" class="rounded-full border border-slate-200 bg-white hover:bg-surface px-4 py-2 text-navy-700 font-semibold transition">Home</a>
          <a href="/services/" class="rounded-full border border-slate-200 bg-white hover:bg-surface px-4 py-2 text-navy-700 font-semibold transition">All Services</a>
          <a href="/service-areas/" class="rounded-full border border-slate-200 bg-white hover:bg-surface px-4 py-2 text-navy-700 font-semibold transition">Service Areas</a>
          <a href="/blogs/" class="rounded-full border border-slate-200 bg-white hover:bg-surface px-4 py-2 text-navy-700 font-semibold transition">Blog</a>
          <a href="/about-us/" class="rounded-full border border-slate-200 bg-white hover:bg-surface px-4 py-2 text-navy-700 font-semibold transition">About</a>
          <a href="/contact/" class="rounded-full border border-slate-200 bg-white hover:bg-surface px-4 py-2 text-navy-700 font-semibold transition">Contact</a>
          <a href="/reviews/" class="rounded-full border border-slate-200 bg-white hover:bg-surface px-4 py-2 text-navy-700 font-semibold transition">Reviews</a>
          <a href="/financing/" class="rounded-full border border-slate-200 bg-white hover:bg-surface px-4 py-2 text-navy-700 font-semibold transition">Financing</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Top services -->
  <ServiceGrid />

  <!-- Service areas + map -->
  <AreaGrid />

  <!-- Recent blog posts -->
  <BlogStrip />

  <!-- Final call/book CTA -->
  <FinalCTA />

  <!-- Search form wiring: prepend "site:icareaircare.com" so Google scopes results -->
  <script is:inline>
    (function () {
      var form = document.querySelector('form[action="https://www.google.com/search"]');
      if (!form) return;
      var visible = form.querySelector('#search-q');
      var hidden = form.querySelector('#search-q-hidden');
      form.addEventListener('submit', function (e) {
        var v = (visible && visible.value || '').trim();
        if (!v) { e.preventDefault(); return; }
        hidden.value = 'site:icareaircare.com ' + v;
      });
    })();
  </script>
</BaseLayout>
