    // ─── MANUAL REVIEW ATTRIBUTION ─────────────────────────────────
    let raStatus = 'unattributed';
    let raTechsCache = [];
    async function loadReviewAttribution() {
      const list = document.getElementById('ra-list');
      const counts = document.getElementById('ra-counts');
      try {
        const r = await api(`/api/reviews/manual?status=${encodeURIComponent(raStatus)}&limit=50`);
        raTechsCache = r.techs || [];
        const c = r.counts || {};
        counts.textContent = `${fmtI(c.attributed)} of ${fmtI(c.total)} attributed (${c.total ? Math.round(c.attributed*100/c.total) : 0}%). ${fmtI(c.manual)} set manually.`;
        const reviews = r.reviews || [];
        if (!reviews.length) {
          list.innerHTML = `<div class="text-slate-400 text-sm py-4 text-center">No reviews in this view.</div>`;
          return;
        }
        const techOptions = raTechsCache.map(t => `<option value="${esc(t.hcp_id)}">${esc(t.name)}</option>`).join('');
        list.innerHTML = reviews.map(rev => {
          const stars = '★'.repeat(rev.rating || 0) + '☆'.repeat(5 - (rev.rating || 0));
          const text = (rev.text || '').slice(0, 240).replace(/\n/g, ' ');
          const currentTech = rev.attributed_tech_hcp_id || '';
          const methodChip = rev.attribution_method
            ? `<span class="chip ${rev.attribution_method === 'manual' ? 'chip-info' : 'chip-warn'}" style="font-size:9px">${esc(rev.attribution_method)}</span>`
            : '';
          return `<div class="card-quiet" data-review-id="${esc(rev.review_id)}">
            <div class="flex flex-wrap items-baseline gap-2 mb-1">
              <span class="font-semibold text-sm">${esc(rev.reviewer_name || 'Anonymous')}</span>
              <span class="text-amber-500 text-sm">${stars}</span>
              <span class="text-[10px] text-slate-500">${rev.posted_at ? new Date(rev.posted_at).toLocaleDateString() : ''}</span>
              ${methodChip}
            </div>
            ${text ? `<p class="text-sm text-slate-700 mb-2">${esc(text)}${(rev.text || '').length > 240 ? '…' : ''}</p>` : ''}
            <div class="flex items-center gap-2 flex-wrap">
              <label class="text-[11px] text-slate-500 font-semibold">Attribute to:</label>
              <select class="ra-select px-2 py-1 border border-line rounded text-xs" data-review-id="${esc(rev.review_id)}">
                <option value="">- Unattributed -</option>
                ${techOptions.replace(`value="${esc(currentTech)}"`, `value="${esc(currentTech)}" selected`)}
              </select>
              ${rev.attributed_tech_name ? `<span class="text-[11px] text-slate-500">currently: <strong>${esc(rev.attributed_tech_name)}</strong></span>` : ''}
            </div>
          </div>`;
        }).join('');
        list.querySelectorAll('.ra-select').forEach(sel => {
          sel.addEventListener('change', async () => {
            const review_id = sel.getAttribute('data-review-id');
            const tech_hcp_id = sel.value || null;
            try {
              await api('/api/reviews/manual', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ review_id, tech_hcp_id }),
              });
              toast(tech_hcp_id ? 'Attribution saved' : 'Attribution cleared', 'ok');
              // Refresh leaderboard so per-tech review counts update
              await loadAll();
              // Refresh this panel's counts
              loadReviewAttribution();
            } catch (e) {
              toast('Save failed: ' + (e.message || e), 'error');
            }
          });
        });
      } catch (e) {
        list.innerHTML = `<div class="text-red-600 text-sm py-3">Failed to load: ${esc(e.message || String(e))}</div>`;
      }
    }
    function initReviewAttribution() {
      const wrap = document.querySelector('#sec-review-attr');
      if (!wrap) return;
      wrap.querySelectorAll('[data-ra-status]').forEach(b => {
        b.addEventListener('click', () => {
          wrap.querySelectorAll('[data-ra-status]').forEach(x => x.setAttribute('aria-pressed', 'false'));
          b.setAttribute('aria-pressed', 'true');
          raStatus = b.getAttribute('data-ra-status');
          loadReviewAttribution();
        });
      });
      loadReviewAttribution();
    }

    // ─── HOURS CSV UPLOAD (Tim's Path A) ────────────────────────────
    async function uploadHoursCsv(file) {
      const result = document.getElementById('hours-result');
      const summary = document.getElementById('hours-summary');
      result.hidden = false;
      result.innerHTML = `<div class="card-quiet text-slate-600">⏳ Uploading <strong>${esc(file.name)}</strong>…</div>`;
      // Fetch directly (not via api()) so we can read the friendly error
      // message in the JSON body on a 400 instead of api() swallowing it.
      try {
        const form = new FormData();
        form.append('file', file);
        const res = await fetch(withAuth('/api/admin/timesheets-upload'), { method: 'POST', body: form, credentials: 'include' });
        const r = await res.json().catch(() => ({}));
        if (!res.ok) {
          // LOUD red error banner with the server's specific guidance.
          result.innerHTML = `<div class="card-quiet" style="border-left:4px solid #dc2626; background:#fef2f2">
            <div class="font-bold text-red-700">⚠ Upload didn't work</div>
            <div class="text-sm text-slate-700 mt-1">${esc(r.error || ('HTTP ' + res.status))}</div>
            ${r.header_seen && r.header_seen.length ? `<div class="text-[11px] text-slate-500 mt-2">Columns I saw: ${esc(r.header_seen.join(' · '))}</div>` : ''}
          </div>`;
          toast('Upload failed - see the red box for what to fix', 'error');
          return;
        }
        const range = r.date_range ? `${r.date_range.from} → ${r.date_range.to}` : '-';
        const unmatchedNote = r.sample_unmatched && r.sample_unmatched.length
          ? `<div class="text-[12px] text-amber-700 mt-2">⚠ ${fmtI(r.unmatched_rows)} rows couldn't be matched to a tech - names not found in HCP: <strong>${esc(r.sample_unmatched.join(', '))}</strong>. Fix the spelling in the CSV or check the employee exists in Housecall Pro, then re-upload.</div>`
          : '';
        const mapping = r.column_mapping || {};
        const mappedCols = Object.entries(mapping).filter(([, v]) => v !== null).map(([k]) => k.replace(/_/g, ' ')).join(', ');
        // LOUD green success banner.
        result.innerHTML = `<div class="card-quiet" style="border-left:4px solid #15803d; background:#f0fdf4">
          <div class="font-bold text-emerald-700 text-base">✓ Uploaded - hours are now on the leaderboard</div>
          <div class="text-sm text-slate-700 mt-1"><strong>${fmtI(r.matched_rows)}</strong> of ${fmtI(r.total_rows)} rows matched to a tech${r.unmatched_rows ? ` · ${fmtI(r.unmatched_rows)} unmatched` : ''}</div>
          <div class="text-[12px] text-slate-500 mt-1">Date range: <strong>${range}</strong> · columns read: ${esc(mappedCols || '-')}</div>
          ${unmatchedNote}
          <div class="text-[11px] text-slate-500 mt-2">Scroll up to the tech leaderboard - the <strong>Hours</strong> and <strong>$/Hr</strong> columns now show real numbers for this date range.</div>
        </div>`;
        toast(`Hours uploaded: ${r.matched_rows} matched`, 'ok');
        await loadAll();
        loadHoursRecent();
      } catch (e) {
        result.innerHTML = `<div class="card-quiet" style="border-left:4px solid #dc2626; background:#fef2f2"><div class="font-bold text-red-700">⚠ Upload failed</div><div class="text-sm text-slate-700 mt-1">${esc(e.message || String(e))}</div></div>`;
        toast('Upload failed', 'error');
      }
    }
    async function deleteHoursBatch(batchId, label) {
      if (!confirm(`Remove this upload (${label})? The hours for that date range will be cleared.`)) return;
      try {
        await api(`/api/admin/timesheets-upload?batch_id=${encodeURIComponent(batchId)}`, { method: 'DELETE' });
        toast('Upload removed', 'ok');
        await loadAll();
        loadHoursRecent();
      } catch (e) { toast(e.message || 'Delete failed', 'error'); }
    }
    async function loadHoursRecent() {
      try {
        const r = await api('/api/admin/timesheets-upload');
        const wrap = document.getElementById('hours-recent');
        const summary = document.getElementById('hours-summary');
        const runs = r.runs || [];
        if (!runs.length) { wrap.innerHTML = '<div class="text-slate-400 italic">No uploads yet.</div>'; if (summary) summary.textContent = 'No CSV uploaded yet.'; return; }
        const latest = runs[0];
        summary.innerHTML = `<div>Last upload: <span class="num">${fmtI(latest.matched_rows)}</span> rows · ${latest.date_min || '?'} → ${latest.date_max || '?'} <span class="text-slate-400">(${fmtRel(latest.uploaded_at)})</span></div>`;
        wrap.innerHTML = `<table class="kpi-table"><thead><tr><th>When</th><th>File</th><th class="text-right">Matched</th><th class="text-right">Unmatched</th><th>Date range</th><th></th></tr></thead><tbody>
          ${runs.map(u => `<tr>
            <td>${fmtRel(u.uploaded_at)}</td>
            <td class="truncate">${esc(u.filename || '-')}</td>
            <td class="text-right num">${fmtI(u.matched_rows)}</td>
            <td class="text-right num">${fmtI(u.unmatched_rows)}</td>
            <td>${u.date_min || '?'} → ${u.date_max || '?'}</td>
            <td class="text-right"><button class="btn-ghost-admin text-[11px] py-0.5 px-1.5" data-del-batch="${esc(u.batch_id)}" data-del-label="${esc((u.filename||'upload') + ' ' + (u.date_min||''))}">Remove</button></td>
          </tr>`).join('')}
        </tbody></table>`;
        wrap.querySelectorAll('[data-del-batch]').forEach(b => {
          b.addEventListener('click', () => deleteHoursBatch(b.getAttribute('data-del-batch'), b.getAttribute('data-del-label')));
        });
      } catch (e) { /* silent - section is optional */ }
    }
    function initHoursUpload() {
      const dz = document.getElementById('hours-dropzone');
      const input = document.getElementById('hours-file-input');
      if (!dz || !input) return;
      dz.addEventListener('click', () => input.click());
      input.addEventListener('change', () => {
        if (input.files && input.files[0]) uploadHoursCsv(input.files[0]);
      });
      dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('bg-brand-50'); });
      dz.addEventListener('dragleave', () => dz.classList.remove('bg-brand-50'));
      dz.addEventListener('drop', e => {
        e.preventDefault();
        dz.classList.remove('bg-brand-50');
        const f = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
        if (f) uploadHoursCsv(f);
      });
      loadHoursRecent();
    }

    // ─── SCROLL-SPY NAV ─────────────────────────────────────────────
    // Highlights the matching nav-pill as the user scrolls through sections.
    function initSectionNav() {
      const links = Array.from(document.querySelectorAll('a[data-nav]'));
      if (!links.length) return;
      const sectionIds = [...new Set(links.map(a => a.getAttribute('data-nav')))];
      const sections = sectionIds.map(id => document.getElementById(id)).filter(Boolean);
      if (!sections.length) return;

      const setActive = (id) => {
        links.forEach(a => a.classList.toggle('is-active', a.getAttribute('data-nav') === id));
      };

      const io = new IntersectionObserver((entries) => {
        // Pick the section closest to the top with at least some intersection
        const visible = entries.filter(e => e.isIntersecting).sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible[0]) setActive(visible[0].target.id);
      }, { rootMargin: '-90px 0px -55% 0px', threshold: [0, 0.2] });
      sections.forEach(s => io.observe(s));

      // Smooth scroll on click + offset for sticky header
      links.forEach(a => {
        a.addEventListener('click', (e) => {
          const id = a.getAttribute('data-nav');
          const el = document.getElementById(id);
          if (!el) return;
          e.preventDefault();
          const top = el.getBoundingClientRect().top + window.scrollY - 80;
          window.scrollTo({ top, behavior: 'smooth' });
          history.replaceState(null, '', '#' + id);
        });
      });
    }

    // ─── PHASE 4 - AI CHAT (ASK THE DASHBOARD) ──────────────────────
    // Floating chat panel. Calls /api/ai/chat with the conversation; the
    // server pre-loads HCP/D1 context (techs, goals, current window) and
    // hands it to MiniMax along with the question. Tool-use over D1 happens
    // server-side so the browser never sees raw rows.
    const chatHistory = [];
    function chatToggle(open) {
      const panel = document.getElementById('chat-panel');
      if (open === undefined) open = !panel.classList.contains('is-open');
      panel.classList.toggle('is-open', open);
      if (open) setTimeout(() => document.getElementById('chat-input').focus(), 50);
    }
    function chatAppend(role, text, opts) {
      const wrap = document.getElementById('chat-messages');
      const div = document.createElement('div');
      div.className = 'chat-msg ' + (role === 'user' ? 'chat-user' : 'chat-bot');
      if (role === 'assistant') {
        div.innerHTML = `<div class="font-semibold text-navy-700 text-xs mb-1">Dashboard AI</div><div>${(opts && opts.html) ? text : esc(text).replace(/\n/g, '<br>')}</div>`;
      } else {
        div.textContent = text;
      }
      wrap.appendChild(div);
      wrap.scrollTop = wrap.scrollHeight;
      return div;
    }
    function chatThinking() {
      const wrap = document.getElementById('chat-messages');
      const div = document.createElement('div');
      div.className = 'chat-msg chat-bot chat-pending';
      div.innerHTML = `<div class="chat-thinking"><span></span><span></span><span></span></div>`;
      wrap.appendChild(div);
      wrap.scrollTop = wrap.scrollHeight;
      return div;
    }
    async function chatSend(question) {
      if (!question || !question.trim()) return;
      chatAppend('user', question);
      chatHistory.push({ role: 'user', content: question });
      const pending = chatThinking();
      try {
        const w = computeWindow(currentRange);
        const r = await api(`/api/ai/chat`, {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            messages: chatHistory.slice(-8),
            window: w,
            range_days: currentRange,
          }),
        });
        pending.remove();
        const answer = r.answer || r.text || 'No response.';
        chatHistory.push({ role: 'assistant', content: answer });
        // Render markdown-ish output (bold + bullets only)
        chatAppend('assistant', mdToHtml(answer), { html: true });
        // Show data sources used in subline
        if (r.tools_used && r.tools_used.length) {
          document.getElementById('chat-sub').textContent = 'Sources: ' + r.tools_used.join(', ');
        }
      } catch (e) {
        pending.remove();
        chatAppend('assistant', `Sorry - chat failed: ${e.message || e}`);
      }
    }

    function initChat() {
      document.getElementById('chat-fab').addEventListener('click', () => chatToggle(true));
      document.getElementById('chat-open-btn').addEventListener('click', () => chatToggle(true));
      document.getElementById('chat-close-btn').addEventListener('click', () => chatToggle(false));
      document.getElementById('chat-form').addEventListener('submit', (e) => {
        e.preventDefault();
        const inp = document.getElementById('chat-input');
        const q = inp.value.trim();
        if (!q) return;
        inp.value = '';
        chatSend(q);
      });
      document.querySelectorAll('.chat-suggest').forEach(b => {
        b.addEventListener('click', () => chatSend(b.getAttribute('data-q')));
      });
      // ESC to close
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && document.getElementById('chat-panel').classList.contains('is-open')) chatToggle(false);
      });
    }

    // Boot. Picks up auth from (1) ?key= URL param (auto-stored to sessionStorage),
    // (2) sessionStorage PIN, (3) CF Access cookie.
    (async () => {
      const urlKey = new URL(location.href).searchParams.get('key');
      if (urlKey) setKey(urlKey);

      const startDashboard = async () => {
        show('dash');
        await loadConfig();
        await loadAll();
        loadAI(false);
        loadReviews(false);
        initSectionNav();
        initChat();
        initHoursUpload();
        initReviewAttribution();
      };

      if (getKey()) {
        try { await api('/api/kpis/summary'); await startDashboard(); return; } catch {}
      }
      try {
        const r = await fetch('/api/kpis/summary', { credentials: 'include' });
        if (r.ok) { await startDashboard(); return; }
      } catch {}
      show('login');
    })();
  </script>
</AdminLayout>
