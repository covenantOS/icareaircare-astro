      service:  { revenue_per_day:0.15, avg_ticket:0.10, close_rate:0.30, membership_conversion:0.15, callback_rate_inverted:0.10, review_rate:0.05, utilization:0.10, volume:0.05 },
      install:  { revenue_per_day:0.35, avg_ticket:0.25, close_rate:0.15, membership_conversion:0.05, callback_rate_inverted:0.05, review_rate:0.05, utilization:0.05, volume:0.05 },
      quality:  { revenue_per_day:0.10, avg_ticket:0.10, close_rate:0.20, membership_conversion:0.10, callback_rate_inverted:0.20, review_rate:0.15, utilization:0.10, volume:0.05 },
    };
    const WEIGHT_LABELS = {
      revenue_per_day: { name: 'Revenue / day', why: 'Higher = rewards techs who bring in more $ per work day.' },
      avg_ticket: { name: 'Average ticket', why: 'Higher = rewards techs who close bigger jobs (good for install / sales).' },
      close_rate: { name: 'Close rate', why: 'Higher = rewards techs who actually convert work, not just spin wheels.' },
      membership_conversion: { name: 'Memberships sold', why: 'Higher = rewards techs who pitch and sell care plans.' },
      callback_rate_inverted: { name: 'Low callbacks', why: 'Higher = rewards techs whose work HOLDS - quality signal.' },
      review_rate: { name: 'Reviews generated', why: 'Higher = rewards techs whose customers actually leave Google reviews. Currently lower-weighted because attribution is imperfect.' },
      utilization: { name: 'Billable hours %', why: 'Higher = rewards efficient techs (less drive, more on-site). Pending Timesheets ingest.' },
      volume: { name: 'Job volume', why: 'Higher = rewards techs who push more jobs. Keep low or quality drops.' },
    };
    let lastTechsForPreview = [];

    function readSlidersAsWeights() {
      const w = {};
      document.querySelectorAll('input[data-w-input]').forEach(inp => {
        w[inp.getAttribute('data-w-input')] = (parseFloat(inp.value) || 0) / 100;
      });
      return w;
    }
    function renderWeightSliders(weights) {
      const html = Object.entries(weights).map(([k, v]) => {
        const lbl = WEIGHT_LABELS[k] || { name: k, why: '' };
        return `<div>
          <div class="flex justify-between text-sm">
            <span title="${esc(lbl.why)}" style="cursor:help">${esc(lbl.name)} <span class="text-slate-400 text-xs">ⓘ</span></span>
            <span class="num font-semibold"><span data-w-display="${k}">${(v*100).toFixed(0)}</span>%</span>
          </div>
          <input type="range" min="0" max="50" step="1" value="${(v*100).toFixed(0)}" data-w-input="${k}" class="w-full" />
          <div class="text-[10px] text-slate-500 mt-0.5">${esc(lbl.why)}</div>
        </div>`;
      }).join('');
      document.getElementById('weight-sliders').innerHTML = html;
      document.querySelectorAll('input[data-w-input]').forEach(inp => {
        inp.addEventListener('input', () => {
          const k = inp.getAttribute('data-w-input');
          document.querySelector(`[data-w-display="${k}"]`).textContent = inp.value;
          updateLivePreview();
        });
      });
    }
    function updateLivePreview() {
      // Mirror the leaderboard's scoring exactly so the same tech shows the
      // same grade in both places. That means: filter to field techs (>=5 jobs,
      // not owner), build a peer-percentile distribution, score against it.
      // Anything other than parity here will confuse Tim ("Erick is a B on one
      // screen and an F on another?") so this MUST stay in sync with
      // renderTechs above. If you change scoring there, update here too.
      if (!lastTechsForPreview.length) {
        document.getElementById('settings-preview').innerHTML = '<div class="text-slate-400 italic">Click "Sync now" first to load tech data.</div>';
        return;
      }
      const w = readSlidersAsWeights();
      const measured = {
        revenue_per_day: true, avg_ticket: true, close_rate: true,
        membership_conversion: false, callback_rate_inverted: true,
        review_rate: true, utilization: false, volume: true,
      };
      let mw = 0; for (const k of Object.keys(w)) if (measured[k]) mw += w[k];
      if (mw === 0) mw = 1;
      const days = currentRange;
      const inputs = (t) => ({
        revenue_per_day: t.revenue / days, avg_ticket: t.avg_ticket, close_rate: t.close_rate_pct,
        membership_conversion: 0, callback_rate_inverted: -t.callback_rate_pct,
        review_rate: t.review_rate_pct || 0, utilization: 0, volume: t.jobs / days,
      });
      const percentile = (values, value) => {
        if (values.length <= 1) return 50;
        const below = values.filter(v => v < value).length;
        const equal = values.filter(v => v === value).length;
        return Math.round(((below + 0.5 * equal) / values.length) * 100);
      };

      // Field-tech peer group - same filter the leaderboard uses (MIN_JOBS=5, not owner).
      const MIN_JOBS = 5;
      const field = lastTechsForPreview.filter(t => !t.is_owner && t.jobs >= MIN_JOBS);
      if (!field.length) {
        document.getElementById('settings-preview').innerHTML = '<div class="text-slate-400 italic">Not enough field-tech data to grade.</div>';
        return;
      }
      const fieldInputs = field.map(inputs);
      const dists = {};
      for (const k of Object.keys(measured)) if (measured[k]) dists[k] = fieldInputs.map(i => i[k] || 0);
      const grade = n => n>=80?'A':n>=60?'B':n>=40?'C':n>=20?'D':'F';  // matches new Will-tuned scale
      const scored = field.map(t => {
        const inp = inputs(t);
        let total = 0;
        for (const k of Object.keys(w)) {
          if (!measured[k]) continue;
          const pct = percentile(dists[k] || [], inp[k] || 0);
          total += pct * (w[k] / mw);
        }
        return { name: t.tech_name, score: Math.round(total * 10) / 10, grade: grade(total) };
      }).sort((a, b) => b.score - a.score);

      document.getElementById('settings-preview').innerHTML = scored.slice(0, 6).map(s => {
        const c = { A:'#15803d', B:'#10b981', C:'#b45309', D:'#dc2626', F:'#991b1b' }[s.grade] || '#64748b';
        return `<div class="flex items-center justify-between gap-2">
          <span class="truncate flex-1">${esc(s.name)}</span>
          <span style="display:inline-block;width:18px;height:18px;border-radius:4px;background:${c};color:#fff;font-weight:700;text-align:center;font-size:10px;line-height:18px">${s.grade}</span>
          <span class="num text-slate-600 text-xs w-7 text-right">${s.score.toFixed(0)}</span>
        </div>`;
      }).join('');
    }
    function applyPreset(presetName) {
      const w = PRESETS[presetName];
      if (!w) return;
      renderWeightSliders(w);
      updateLivePreview();
      toast(`Preset applied: ${presetName}`, 'ok');
    }

    function openSettings() {
      const d = document.getElementById('settings-drawer'); d.classList.remove('hidden');
      const t = (configCache && configCache.thresholds) || {};
      document.getElementById('set-sold-tu').value  = (t.sold && t.sold.tune_up) || 110;
      document.getElementById('set-min-tu').value   = (t.minTicket && t.minTicket.tune_up) || 175;
      document.getElementById('set-min-diag').value = (t.minTicket && t.minTicket.diagnostic) || 275;

      const w = (configCache && configCache.weights) || PRESETS.balanced;
      renderWeightSliders(w);

      // Goals: read from configCache (or defaults)
      const goals = (configCache && configCache.goals) || { revenue_monthly: 15000, close_rate: 55, avg_ticket: 400, callback_rate: 3, review_rate: 15 };
      document.getElementById('g-rev').value = goals.revenue_monthly;
      document.getElementById('g-close').value = goals.close_rate;
      document.getElementById('g-ticket').value = goals.avg_ticket;
      document.getElementById('g-cb').value = goals.callback_rate;
      document.getElementById('g-rev-rate').value = goals.review_rate;
      updateGoalDisplays();

      updateLivePreview();
    }
    function updateGoalDisplays() {
      document.getElementById('g-rev-disp').textContent = '$' + parseInt(document.getElementById('g-rev').value).toLocaleString();
      document.getElementById('g-close-disp').textContent = document.getElementById('g-close').value + '%';
      document.getElementById('g-ticket-disp').textContent = '$' + parseInt(document.getElementById('g-ticket').value).toLocaleString();
      document.getElementById('g-cb-disp').textContent = document.getElementById('g-cb').value + '%';
      document.getElementById('g-rev-rate-disp').textContent = document.getElementById('g-rev-rate').value;
    }
    function closeSettings() { document.getElementById('settings-drawer').classList.add('hidden'); }

    async function saveSettings() {
      const sold = Number(document.getElementById('set-sold-tu').value);
      const minTu = Number(document.getElementById('set-min-tu').value);
      const minDi = Number(document.getElementById('set-min-diag').value);
      const weights = {};
      let total = 0;
      document.querySelectorAll('input[data-w-input]').forEach(inp => {
        const k = inp.getAttribute('data-w-input');
        weights[k] = Number(inp.value) / 100;
        total += weights[k];
      });
      // normalize to sum=1
      if (total > 0) for (const k of Object.keys(weights)) weights[k] = weights[k] / total;

      const goals = {
        revenue_monthly: Number(document.getElementById('g-rev').value),
        close_rate: Number(document.getElementById('g-close').value),
        avg_ticket: Number(document.getElementById('g-ticket').value),
        callback_rate: Number(document.getElementById('g-cb').value),
        review_rate: Number(document.getElementById('g-rev-rate').value),
      };

      try {
        await api('/api/kpis/config', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            thresholds: {
              sold: { default: sold, tune_up: sold, diagnostic: sold, estimate: sold },
              minTicket: { default: minTu, tune_up: minTu, diagnostic: minDi, estimate: minTu },
            },
            weights,
            goals,
          }),
        });
        toast('Settings saved · refreshing', 'ok');
        await loadConfig();
        await loadAll();
        closeSettings();
      } catch (e) { toast(e.message || 'Save failed', 'error'); }
    }

    // ─── EVENT WIRING ───────────────────────────────────────────────
    // Date-range tab handler - clears any active preset / custom window
    // when a rolling range is picked, and vice-versa for the preset tabs.
    function clearAllRangeButtonsPressed() {
      document.querySelectorAll('.tab[data-range], .tab[data-preset], #custom-range-btn')
        .forEach(x => x.setAttribute('aria-pressed', 'false'));
    }
    function setActiveRangeButton(el) {
      clearAllRangeButtonsPressed();
      el.setAttribute('aria-pressed', 'true');
    }
    document.querySelectorAll('.tab[data-range]').forEach(b => {
      b.addEventListener('click', () => {
        setActiveRangeButton(b);
        currentRange = parseInt(b.dataset.range, 10);
        customWindow = null;
        document.getElementById('custom-range-popover').classList.add('hidden');
        loadAll();
      });
    });
    document.querySelectorAll('.tab[data-preset]').forEach(b => {
      b.addEventListener('click', () => {
        const p = buildPreset(b.dataset.preset);
        if (!p) return;
        setActiveRangeButton(b);
        customWindow = p;
        // Approximate currentRange so per-day metrics stay sane.
        currentRange = Math.max(1, Math.round((Date.parse(p.to) - Date.parse(p.from)) / 86400000));
        document.getElementById('custom-range-popover').classList.add('hidden');
        loadAll();
      });
    });
    document.getElementById('custom-range-btn').addEventListener('click', () => {
      const pop = document.getElementById('custom-range-popover');
      pop.classList.toggle('hidden');
      if (!pop.classList.contains('hidden')) {
        // Seed inputs with the current window if not already filled.
        const w = computeWindow(currentRange);
        if (!document.getElementById('cr-from').value) document.getElementById('cr-from').value = ymd(new Date(w.from));
        if (!document.getElementById('cr-to').value)   document.getElementById('cr-to').value   = ymd(new Date(w.to));
      }
    });
    document.getElementById('cr-cancel').addEventListener('click', () => {
      document.getElementById('custom-range-popover').classList.add('hidden');
    });
    document.getElementById('cr-apply').addEventListener('click', () => {
      const fromStr = document.getElementById('cr-from').value;
      const toStr   = document.getElementById('cr-to').value;
      if (!fromStr || !toStr) { toast('Pick both From and To dates', 'error'); return; }
      const from = startOfLocalDay(fromStr);
      const to   = endOfLocalDay(toStr);
      if (to < from) { toast('"To" must be on or after "From"', 'error'); return; }
      customWindow = { from: from.toISOString(), to: to.toISOString(), label: `${fromStr} → ${toStr}` };
      currentRange = Math.max(1, Math.round((to.getTime() - from.getTime()) / 86400000));
      setActiveRangeButton(document.getElementById('custom-range-btn'));
      document.getElementById('custom-range-popover').classList.add('hidden');
      loadAll();
    });
