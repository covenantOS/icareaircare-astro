---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---
<AdminLayout title="KPI Dashboard">
  <!-- LOGIN GATE -->
  <div id="login-gate" hidden>
    <div class="card login-card">
      <h2 class="text-xl font-bold mb-1">Sign in</h2>
      <p class="text-sm text-slate-600 mb-5">Enter your PIN to continue. Cloudflare Access (one-time email PIN) can replace this for production.</p>
      <form id="login-form" class="space-y-3">
        <input id="login-key" type="password" inputmode="numeric" placeholder="PIN" autocomplete="current-password" required />
        <button type="submit" class="btn-admin w-full justify-center">Continue</button>
      </form>
      <p id="login-error" class="text-red-600 text-sm mt-3" hidden></p>
    </div>
  </div>

  <!-- DASHBOARD -->
  <div id="dashboard" hidden>
    <header class="bg-white border-b border-line">
      <div class="container-site py-3 sm:py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
          <h1 class="text-lg sm:text-2xl font-bold text-navy-700">I Care Air Care · KPI Dashboard</h1>
          <div id="sync-status" class="text-xs text-slate-500 mt-1">Loading sync status…</div>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <button id="settings-btn" class="btn-ghost-admin" type="button" aria-label="Settings">⚙ Settings</button>
          <button id="sync-btn" class="btn-admin" type="button">Sync now</button>
          <button id="logout-btn" class="btn-ghost-admin" type="button">Sign out</button>
        </div>
      </div>
    </header>

    <main class="container-site py-4 sm:py-6 space-y-5">

      <!-- AI INSIGHTS — structured visual rendering -->
      <section id="ai-insights" class="card relative overflow-hidden fade-up" style="background:linear-gradient(135deg, #fff 0%, #f0f7fa 100%); --i:0">
        <div class="absolute top-0 right-0 w-40 h-40 -mt-12 -mr-12 rounded-full pulse-soft" style="background:radial-gradient(circle, rgba(232,138,56,0.16), transparent 70%)"></div>
        <div class="flex items-start justify-between gap-3 relative">
          <div class="flex items-center gap-3 min-w-0">
            <span class="section-icon bg-accent-500 text-white text-sm font-bold flex-shrink-0">AI</span>
            <div class="min-w-0">
              <h2 class="text-lg font-bold text-navy-700">This week, in plain English</h2>
              <div id="ai-headline-summary" class="text-sm text-slate-700 mt-0.5 truncate">—</div>
            </div>
          </div>
          <div class="flex items-center gap-2 flex-shrink-0">
            <span id="ai-meta" class="text-xs text-slate-500 hidden sm:inline">—</span>
            <button id="ai-refresh" class="btn-ghost-admin text-xs py-1 px-2" type="button" aria-label="Refresh AI insights">↻</button>
          </div>
        </div>

        <div id="ai-loading" class="mt-3">
          <div class="skeleton h-4 w-3/4 mb-2"></div>
          <div class="skeleton h-4 w-full mb-2"></div>
          <div class="skeleton h-4 w-5/6 mb-2"></div>
          <div class="skeleton h-4 w-2/3"></div>
        </div>

        <div id="ai-structured" hidden class="mt-4 space-y-4 relative">
          <!-- Headlines as 3-5 mini cards -->
          <div id="ai-headlines" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2"></div>

          <!-- Two-column: What's working / Needs attention -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <div>
              <h3 class="text-xs font-bold uppercase tracking-wide text-emerald-700 mb-2 flex items-center gap-1">
                <span class="section-icon bg-emerald-100 text-emerald-700 w-5 h-5 text-xs">✓</span>
                What's working
              </h3>
              <ul id="ai-working" class="space-y-1.5 text-sm text-slate-800"></ul>
            </div>
            <div>
              <h3 class="text-xs font-bold uppercase tracking-wide text-amber-700 mb-2 flex items-center gap-1">
                <span class="section-icon bg-amber-100 text-amber-700 w-5 h-5 text-xs">!</span>
                Needs attention
              </h3>
              <ul id="ai-attention" class="space-y-1.5 text-sm text-slate-800"></ul>
            </div>
          </div>

          <!-- Data-quality notes — only shown if AI flagged any -->
          <div id="ai-data-quality-wrap" hidden>
            <h3 class="text-xs font-bold uppercase tracking-wide text-brand-800 mb-2 flex items-center gap-1">
              <span class="section-icon bg-brand-50 text-brand-800 w-5 h-5 text-xs">ⓘ</span>
              Data hygiene in Housecall Pro
            </h3>
            <ul id="ai-data-quality" class="space-y-1.5 text-sm text-slate-800"></ul>
          </div>

          <!-- Actions — numbered chips -->
          <div>
            <h3 class="text-xs font-bold uppercase tracking-wide text-navy-700 mb-2 flex items-center gap-1">
              <span class="section-icon bg-navy-700 text-white w-5 h-5 text-xs">▶</span>
              Recommended actions this week
            </h3>
            <ol id="ai-actions" class="space-y-2"></ol>
          </div>
        </div>

        <!-- Markdown fallback (only shown if briefing JSON failed to parse) -->
        <div id="ai-fallback-md" hidden class="mt-3 prose-icac max-w-none text-sm text-slate-800"></div>
      </section>

      <!-- DATE RANGE TABS -->
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="flex flex-wrap gap-2" role="tablist" aria-label="Date range">
          <button class="tab" data-range="7"  type="button" aria-pressed="false">7 days</button>
          <button class="tab" data-range="30" type="button" aria-pressed="true">30 days</button>
          <button class="tab" data-range="90" type="button" aria-pressed="false">90 days</button>
        </div>
        <div class="text-xs text-slate-500" id="window-display"></div>
      </div>

      <!-- HEADLINE KPI CARDS WITH SPARKLINES + BENCHMARKS -->
      <section class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
        <article class="card hover-lift fade-up" style="--i:1; border-left:3px solid var(--color-brand-500)">
          <div class="flex items-center justify-between"><div class="stat-label">Call Volume</div><div id="kv-bench" class="text-[10px]"></div></div>
          <div id="kpi-volume" class="stat-value" data-count="0">—</div>
          <div id="kpi-volume-sub" class="stat-sub">tune-ups · diagnostics · estimates</div>
          <div id="kpi-volume-spark" class="mt-2 h-10 -mx-1"></div>
        </article>
        <article class="card hover-lift fade-up" style="--i:2; border-left:3px solid #10b981">
          <div class="flex items-center justify-between"><div class="stat-label">Close Rate</div><div id="cr-bench" class="text-[10px]"></div></div>
          <div id="kpi-close" class="stat-value" data-count="0">—</div>
          <div id="kpi-close-sub" class="stat-sub">overall (sold / completed)</div>
          <div id="kpi-close-spark" class="mt-2 h-10 -mx-1"></div>
        </article>
        <article class="card hover-lift fade-up" style="--i:3; border-left:3px solid var(--color-accent-500)">
          <div class="flex items-center justify-between"><div class="stat-label">Avg Ticket</div><div id="at-bench" class="text-[10px]"></div></div>
          <div id="kpi-ticket" class="stat-value" data-count="0">—</div>
          <div id="kpi-ticket-sub" class="stat-sub">discounts applied</div>
          <div id="kpi-ticket-spark" class="mt-2 h-10 -mx-1"></div>
        </article>
        <article class="card hover-lift fade-up" style="--i:4; border-left:3px solid var(--color-navy-700)">
          <div class="flex items-center justify-between"><div class="stat-label">Revenue</div><div id="rev-bench" class="text-[10px]"></div></div>
          <div id="kpi-revenue" class="stat-value" data-count="0">—</div>
          <div id="kpi-revenue-sub" class="stat-sub">total invoiced</div>
          <div id="kpi-revenue-spark" class="mt-2 h-10 -mx-1"></div>
        </article>
      </section>

      <!-- BY CALL TYPE -->
      <section class="card">
        <div class="flex items-center justify-between flex-wrap gap-2 mb-3">
          <h2 class="text-lg font-bold text-navy-700">By call type</h2>
          <span class="text-xs text-slate-500">sold ≥ <span id="thr-sold-tu">$110</span> · min TU <span id="thr-min-tu">$175</span> / Diag <span id="thr-min-diag">$275</span></span>
        </div>
        <div class="overflow-x-auto -mx-5 sm:mx-0">
          <table class="kpi-table">
            <thead>
              <tr>
                <th>Type</th>
                <th class="text-right">Calls</th>
                <th class="text-right">Closed</th>
                <th class="text-right">Close %</th>
                <th class="text-right">Avg Ticket</th>
                <th class="text-right">Revenue</th>
              </tr>
            </thead>
            <tbody id="by-type-rows">
              <tr><td colspan="6" class="text-center text-slate-400 py-6">Loading…</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- TECH LEADERBOARD -->
      <section class="card">
        <div class="flex items-center justify-between flex-wrap gap-2 mb-3">
          <h2 class="text-lg font-bold text-navy-700">Tech leaderboard</h2>
          <span class="text-xs text-slate-500">Tap a row for detail · A-F grade via Formula A</span>
        </div>
        <div class="overflow-x-auto -mx-5 sm:mx-0">
          <table class="kpi-table">
            <thead>
              <tr>
                <th>Tech</th>
                <th class="text-center">Score</th>
                <th class="text-right">Jobs</th>
                <th class="text-right hidden sm:table-cell" title="Tune-ups · Diagnostics · Estimates">TU · Dx · Est</th>
                <th class="text-right">Close %</th>
                <th class="text-right hidden sm:table-cell">Avg Ticket</th>
                <th class="text-right">Revenue</th>
                <th class="text-right hidden lg:table-cell" title="Google reviews attributed to tech">⭐ Reviews</th>
                <th class="text-right hidden lg:table-cell">Callbacks</th>
              </tr>
            </thead>
            <tbody id="tech-rows">
              <tr><td colspan="8" class="text-center text-slate-400 py-6">Loading…</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- SEGMENTS (3-col on desktop, stack on mobile) -->
      <section class="grid grid-cols-1 lg:grid-cols-3 gap-3 sm:gap-4">
        <article class="card">
          <div class="flex items-center justify-between mb-2">
            <h3 class="font-bold text-navy-700">Dormant 12+ months</h3>
            <span id="seg-dormant-count" class="pill pill-warn">—</span>
          </div>
          <p class="text-xs text-slate-500 mb-3">Customers who haven't booked in 1+ year (still inside HCP's 3-yr cap). Sorted by lifetime value.</p>
          <div id="seg-dormant" class="space-y-1 text-sm"></div>
          <div class="flex gap-2 mt-3">
            <button class="btn-ghost-admin text-xs flex-1" data-action="copy-emails" data-segment="dormant_12mo">Copy emails</button>
            <button class="btn-admin text-xs flex-1" data-action="open-segment" data-segment="dormant_12mo">View all →</button>
          </div>
        </article>
        <article class="card">
          <div class="flex items-center justify-between mb-2">
            <h3 class="font-bold text-navy-700">Members renewing soon</h3>
            <span id="seg-renew-count" class="pill pill-info">—</span>
          </div>
          <p class="text-xs text-slate-500 mb-3">Care-plan members whose last service was 11-13 months ago — reach out before they lapse.</p>
          <div id="seg-renew" class="space-y-1 text-sm"></div>
          <div class="flex gap-2 mt-3">
            <button class="btn-ghost-admin text-xs flex-1" data-action="copy-emails" data-segment="members_renewing">Copy emails</button>
            <button class="btn-admin text-xs flex-1" data-action="open-segment" data-segment="members_renewing">View all →</button>
          </div>
        </article>
        <article class="card">
          <div class="flex items-center justify-between mb-2">
            <h3 class="font-bold text-navy-700">VIPs (top lifetime value)</h3>
            <span class="pill pill-info">Top 50</span>
          </div>
          <p class="text-xs text-slate-500 mb-3">Highest lifetime spend. Treat with care — these underwrite the business.</p>
          <div id="seg-vip" class="space-y-1 text-sm"></div>
          <div class="flex gap-2 mt-3">
            <button class="btn-admin text-xs flex-1 ml-auto" data-action="open-segment" data-segment="top_ltv">View all →</button>
          </div>
        </article>
      </section>

      <!-- GOOGLE REVIEWS -->
      <section class="grid grid-cols-1 lg:grid-cols-3 gap-3 sm:gap-4">
        <article class="card lg:col-span-1">
          <div class="flex items-center justify-between mb-2">
            <h2 class="text-lg font-bold text-navy-700">Google Reviews</h2>
            <button id="reviews-refresh" class="btn-ghost-admin text-xs py-1 px-2">↻</button>
          </div>
          <div class="flex items-baseline gap-3 mb-1">
            <div class="stat-value" id="rev-avg">—</div>
            <div class="text-2xl text-amber-500" id="rev-stars">★★★★★</div>
          </div>
          <div class="stat-sub" id="rev-count">— reviews · — 4★+ · — response rate</div>
          <div id="rev-dist" class="mt-3 space-y-1 text-xs"></div>
          <div class="text-[10px] text-slate-400 mt-3" id="rev-meta">—</div>
        </article>
        <article class="card lg:col-span-2">
          <div class="flex items-center justify-between mb-2">
            <h2 class="text-lg font-bold text-navy-700">Recent reviews</h2>
            <span class="text-xs text-slate-500">Tap-and-hold the response area to copy</span>
          </div>
          <div id="rev-recent" class="space-y-3"><div class="text-slate-400 text-sm py-2">Click ↻ to load reviews from Google.</div></div>
        </article>
      </section>

      <!-- CUSTOMER MIX + CALLBACKS -->
      <section class="grid grid-cols-1 md:grid-cols-2 gap-3 sm:gap-4">
        <article class="card">
          <h2 class="text-lg font-bold text-navy-700 mb-3">Customer mix</h2>
          <div class="space-y-3">
            <div>
              <div class="flex justify-between text-sm mb-1"><span>New customers</span><span id="cust-new" class="num font-semibold">—</span></div>
              <div class="progress"><span id="cust-new-bar" style="width:0%"></span></div>
            </div>
            <div>
              <div class="flex justify-between text-sm mb-1"><span>Existing customers</span><span id="cust-existing" class="num font-semibold">—</span></div>
              <div class="progress"><span id="cust-existing-bar" style="width:0%"></span></div>
            </div>
            <div>
              <div class="flex justify-between text-sm mb-1"><span>Care-plan members</span><span id="cust-member" class="num font-semibold">—</span></div>
              <div class="progress"><span id="cust-member-bar" style="width:0%"></span></div>
            </div>
          </div>
        </article>
        <article class="card">
          <div class="flex items-center justify-between mb-3"><h2 class="text-lg font-bold text-navy-700">Callbacks</h2><span id="cb-bench" class="text-[10px]"></span></div>
          <div class="flex items-baseline gap-3 mb-2">
            <div class="stat-value" id="cb-total">—</div>
            <div class="stat-sub">callbacks · <span id="cb-rate">—</span> rate</div>
          </div>
          <p class="text-xs text-slate-500 mb-3">Industry: under 3% target, top performers under 2%.</p>
          <div class="overflow-x-auto -mx-5 sm:mx-0">
            <table class="kpi-table">
              <thead><tr><th>Tech</th><th class="text-right">Jobs</th><th class="text-right">Callbacks</th><th class="text-right">Rate</th></tr></thead>
              <tbody id="cb-rows"><tr><td colspan="4" class="text-center text-slate-400 py-4">—</td></tr></tbody>
            </table>
          </div>
        </article>
      </section>

      <!-- FOOTNOTES -->
      <section class="card-quiet text-xs text-slate-500 leading-relaxed">
        <p class="mb-1"><strong>Source:</strong> Housecall Pro API. Tap "Sync now" to pull latest. Membership detection: HCP job tags ("Care plan member - YES").</p>
        <p class="mb-1"><strong>Score:</strong> Formula A — 25% rev/day + 15% ticket + 15% close + 10% memberships + 10% callbacks(inv) + 10% reviews + 10% utilization + 5% volume. Tunable in Settings.</p>
        <p class="mb-1"><strong>Phase 2:</strong> Hours/utilization (Timesheets CSV ingest) · Reviews per tech (Google Business Profile API) · Real-time webhooks.</p>
        <p><strong>Industry context:</strong> Top-quartile residential HVAC tech does $2,400+/day, 75-85% close rate, $450+ avg ticket. Sources: ServiceTitan, BaaDigi, MarginPlug 2026.</p>
      </section>

    </main>
  </div>

  <!-- SETTINGS DRAWER -->
  <div id="settings-drawer" class="fixed inset-0 z-40 hidden" aria-modal="true">
    <div id="settings-backdrop" class="absolute inset-0 bg-black/40"></div>
    <div class="absolute right-0 top-0 bottom-0 w-full sm:max-w-md bg-white shadow-xl overflow-y-auto">
      <div class="p-5 border-b border-line flex items-center justify-between">
        <h2 class="text-lg font-bold text-navy-700">Settings</h2>
        <button id="settings-close" class="btn-ghost-admin">✕</button>
      </div>
      <div class="p-5 space-y-6">
        <div>
          <h3 class="font-semibold text-navy-700 mb-2">Thresholds</h3>
          <p class="text-xs text-slate-500 mb-3">Tim's stated values. Below sold threshold = "didn't close". Below min ticket = highlighted in tables.</p>
          <div class="space-y-3">
            <label class="block text-sm">Tune-up sold threshold ($)
              <input id="set-sold-tu" type="number" class="block w-full mt-1 px-3 py-2 border border-line rounded" />
            </label>
            <label class="block text-sm">Tune-up minimum ticket ($)
              <input id="set-min-tu" type="number" class="block w-full mt-1 px-3 py-2 border border-line rounded" />
            </label>
            <label class="block text-sm">Diagnostic minimum ticket ($)
              <input id="set-min-diag" type="number" class="block w-full mt-1 px-3 py-2 border border-line rounded" />
            </label>
          </div>
        </div>
        <div>
          <h3 class="font-semibold text-navy-700 mb-2">Score weights</h3>
          <p class="text-xs text-slate-500 mb-3">Must sum to 1.00. Auto-normalized on save.</p>
          <div id="weight-sliders" class="space-y-3"></div>
        </div>
        <div class="flex gap-2 pt-2">
          <button id="settings-save" class="btn-admin flex-1">Save & re-score</button>
          <button id="settings-reset" class="btn-ghost-admin">Reset to defaults</button>
        </div>
      </div>
    </div>
  </div>

  <div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50" hidden>
    <div id="toast-body" class="bg-navy-700 text-white text-sm px-4 py-2 rounded-lg shadow-soft"></div>
  </div>

  <script is:inline>
    // ─────────────────────────────────────────────────────────────────
    // I Care Air Care KPI Dashboard — Phase 2
    // ─────────────────────────────────────────────────────────────────
    const STORAGE_KEY = 'icac_admin_key';
    let currentRange = 30;
    let configCache = null;

    function getKey() { return sessionStorage.getItem(STORAGE_KEY) || ''; }
    function setKey(k) { sessionStorage.setItem(STORAGE_KEY, k); }
    function clearKey() { sessionStorage.removeItem(STORAGE_KEY); }
    function withAuth(url) {
      const k = getKey(); if (!k) return url;
      const u = new URL(url, location.origin); u.searchParams.set('key', k); return u.toString();
    }
    async function api(path, init) {
      const res = await fetch(withAuth(path), { credentials: 'include', ...init });
      if (res.status === 401) { clearKey(); show('login'); throw new Error('Auth required'); }
      if (!res.ok) { const t = await res.text().catch(() => ''); throw new Error(`API ${path}: ${res.status} ${t.slice(0, 200)}`); }
      return res.json();
    }
    function show(which) {
      document.getElementById('login-gate').hidden = which !== 'login';
      document.getElementById('dashboard').hidden = which !== 'dash';
    }
    function fmt$(n)  { if (n == null || isNaN(n)) return '—'; return '$' + Number(n).toLocaleString('en-US', { maximumFractionDigits: 0 }); }
    function fmt$d(n) { if (n == null || isNaN(n)) return '—'; return '$' + Number(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }
    function fmtP(n)  { if (n == null || isNaN(n)) return '—'; return Number(n).toFixed(1) + '%'; }
    function fmtI(n)  { if (n == null || isNaN(n)) return '—'; return Number(n).toLocaleString('en-US'); }
    function esc(s)   { return String(s ?? '').replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c])); }
    function toast(msg, kind) {
      const t = document.getElementById('toast'), b = document.getElementById('toast-body');
      b.textContent = msg;
      b.className = 'text-sm px-4 py-2 rounded-lg shadow-soft ' +
        (kind === 'error' ? 'bg-red-600 text-white' : kind === 'ok' ? 'bg-emerald-600 text-white' : 'bg-navy-700 text-white');
      t.hidden = false; clearTimeout(toast._t); toast._t = setTimeout(() => t.hidden = true, 4000);
    }

    // Industry benchmarks. Sources are listed and shown on hover so it's
    // clear what each comparison is against. We only call something
    // "below avg" when we have apples-to-apples per-tech data — never
    // for shop-wide totals.
    const BENCHMARKS = {
      avg_ticket:        { p:250, a:450, t:600, dir:'up',
        src:'FieldPulse / MarginPlug 2026 — residential service, $450-600 typical, $600+ premium.' },
      close_rate:        { p:35, a:55, t:75, dir:'up',
        src:'Industry composite — Mercurio "90s percentile" target; 50-75% typical for residential service techs.' },
      close_rate_tune_up:{ p:30, a:50, t:75, dir:'up',
        src:'HVACR Business — 10% to repair + 70% to membership combined ≈ 50% avg, 75%+ top.' },
      close_rate_diag:   { p:50, a:67, t:85, dir:'up',
        src:'BaaDigi / Mercurio — diagnostic close: 60-75% avg, 80%+ top.' },
      callback_rate:     { p:5, a:3, t:2, dir:'down',
        src:'Contracting Business / Mar-Hy — under 3% acceptable, under 2% top performer.' },
      jobs_per_day:      { p:3, a:4, t:6, dir:'up',
        src:'ServiceTitan / Oxmaint — 3-5 jobs/day standard, 5-8 top performers.' },
      revenue_per_day:   { p:1200, a:2000, t:2400, dir:'up',
        src:'BaaDigi / MarginPlug 2026 — per-tech-per-day, top-quartile $2,400+ (residential service).' },
    };
    function bench(metric, value) {
      const b = BENCHMARKS[metric]; if (!b || value == null) return null;
      const tier = b.dir === 'up'
        ? (value >= b.t ? 'top' : value >= b.a ? 'avg' : 'poor')
        : (value <= b.t ? 'top' : value <= b.a ? 'avg' : 'poor');
      const color = { top:'#15803d', avg:'#b45309', poor:'#b91c1c' }[tier];
      const label = { top:'Top quartile', avg:'Industry avg', poor:'Below avg' }[tier];
      return { tier, color, label, src: b.src };
    }
    function benchPill(metric, value) {
      const b = bench(metric, value); if (!b) return '';
      return `<span title="${esc(b.src)}" style="display:inline-flex;align-items:center;gap:4px;font-weight:600;color:${b.color};cursor:help"><span style="width:7px;height:7px;border-radius:999px;background:${b.color}"></span>${b.label}</span>`;
    }

    function spark(values, opts = {}) {
      if (!values || values.length === 0) return '';
      const w = opts.w || 240, h = opts.h || 40;
      const max = Math.max(1, ...values);
      const min = Math.min(0, ...values);
      const range = max - min || 1;
      const stepX = w / Math.max(1, values.length - 1);
      const pts = values.map((v, i) => `${(i * stepX).toFixed(1)},${(h - ((v - min) / range) * h).toFixed(1)}`);
      return `<svg viewBox="0 0 ${w} ${h}" width="100%" height="${h}" preserveAspectRatio="none">
        <polyline fill="${opts.fill || 'rgba(93,165,184,0.12)'}" stroke="none" points="0,${h} ${pts.join(' ')} ${w},${h}" />
        <polyline fill="none" stroke="${opts.stroke || '#5da5b8'}" stroke-width="2" points="${pts.join(' ')}" />
      </svg>`;
    }

    function gradeColor(g) { return ({ A:'#15803d', B:'#10b981', C:'#b45309', D:'#dc2626', F:'#991b1b' }[g] || '#64748b'); }

    function computeWindow(days) {
      const to = new Date();
      const from = new Date(to.getTime() - days * 86400000);
      return { from: from.toISOString(), to: to.toISOString() };
    }

    function setSkeletons() {
      ['kpi-volume','kpi-close','kpi-ticket','kpi-revenue'].forEach(id => {
        document.getElementById(id).innerHTML = '<span class="skeleton inline-block h-9 w-24"></span>';
      });
    }

    // Count-up animation for KPI numbers. Honors prefers-reduced-motion.
    const PRM = matchMedia('(prefers-reduced-motion: reduce)').matches;
    function countUp(el, target, formatter, durationMs) {
      const dur = PRM ? 0 : (durationMs || 700);
      const start = parseFloat(el.dataset.count || '0') || 0;
      const t0 = performance.now();
      function step(now) {
        const k = Math.min(1, (now - t0) / dur);
        const eased = 1 - Math.pow(1 - k, 3);
        const v = start + (target - start) * eased;
        el.textContent = formatter(v);
        if (k < 1) requestAnimationFrame(step);
        else { el.dataset.count = String(target); el.textContent = formatter(target); }
      }
      if (dur === 0) { el.dataset.count = String(target); el.textContent = formatter(target); return; }
      requestAnimationFrame(step);
    }

    async function loadConfig() {
      try {
        configCache = await api('/api/kpis/config');
        const t = configCache.thresholds || {};
        document.getElementById('thr-sold-tu').textContent = '$' + ((t.sold && t.sold.tune_up) || 110);
        document.getElementById('thr-min-tu').textContent  = '$' + ((t.minTicket && t.minTicket.tune_up) || 175);
        document.getElementById('thr-min-diag').textContent= '$' + ((t.minTicket && t.minTicket.diagnostic) || 275);
      } catch (e) { /* ignore */ }
    }

    async function loadAll() {
      setSkeletons();
      const w = computeWindow(currentRange);
      try {
        const [summary, byTech, trend, segDormant, segRenew, segVip] = await Promise.all([
          api(`/api/kpis/summary?from=${encodeURIComponent(w.from)}&to=${encodeURIComponent(w.to)}`),
          api(`/api/kpis/by-tech?from=${encodeURIComponent(w.from)}&to=${encodeURIComponent(w.to)}`),
          api(`/api/kpis/trends?weeks=12`),
          api(`/api/kpis/segments?name=dormant_12mo&limit=5`),
          api(`/api/kpis/segments?name=members_renewing&limit=5`),
          api(`/api/kpis/segments?name=top_ltv&limit=5`),
        ]);
        renderSummary(summary, trend);
        renderTechs(byTech);
        renderSegments(segDormant, segRenew, segVip);
      } catch (e) {
        toast(e.message || 'Load failed', 'error');
      }
    }

    function renderSummary(data, trend) {
      const s = data.summary;
      const days = currentRange;
      const techCount = Math.max(1, (data.summary.revenue.by_tech || []).length);

      countUp(document.getElementById('kpi-volume'), s.call_volume.total, (v) => fmtI(Math.round(v)));
      document.getElementById('kpi-volume-sub').textContent =
        `${s.call_volume.tune_up} TU · ${s.call_volume.diagnostic} Dx · ${s.call_volume.estimate} Est`;
      // Per-tech jobs/day — only count field techs that actually closed jobs in window.
      const activeTechCount = ((data.summary.revenue.by_tech || []).filter(t => t.jobs > 0)).length || 1;
      const jpd = s.call_volume.total / days / activeTechCount;
      document.getElementById('kv-bench').innerHTML = benchPill('jobs_per_day', jpd) +
        `<span class="text-[10px] text-slate-500 ml-1">${jpd.toFixed(1)}/tech/day</span>`;

      countUp(document.getElementById('kpi-close'), s.close_rate.overall_pct, (v) => v.toFixed(1) + '%');
      document.getElementById('kpi-close-sub').textContent =
        `${s.totals.sold_jobs} sold of ${s.totals.completed_jobs}`;
      document.getElementById('cr-bench').innerHTML = benchPill('close_rate', s.close_rate.overall_pct);

      countUp(document.getElementById('kpi-ticket'), s.average_ticket.overall, (v) => fmt$(v));
      document.getElementById('at-bench').innerHTML = benchPill('avg_ticket', s.average_ticket.overall);

      countUp(document.getElementById('kpi-revenue'), s.revenue.total, (v) => fmt$(v), 900);
      // Don't dot-rate shop-wide revenue against a per-tech industry benchmark
      // — apples to oranges. Show the period total, the period rate, and
      // who topped the leaderboard. Per-tech benchmarks live in the tech detail page.
      const topTech = (data.summary.revenue.by_tech || [])[0];
      document.getElementById('kpi-revenue-sub').textContent =
        topTech ? `Top: ${topTech.tech_name} · ${fmt$(topTech.revenue)}` : `${fmt$(s.revenue.total)} total`;
      document.getElementById('rev-bench').innerHTML = '';

      // Sparklines from 12-week trend
      const t = trend.points || [];
      document.getElementById('kpi-volume-spark').innerHTML  = spark(t.map(p => p.jobs),       { stroke:'#5da5b8' });
      document.getElementById('kpi-close-spark').innerHTML   = spark(t.map(p => p.close_rate_pct),{ stroke:'#10b981', fill:'rgba(16,185,129,0.10)' });
      document.getElementById('kpi-ticket-spark').innerHTML  = spark(t.map(p => p.avg_ticket), { stroke:'#e88a38', fill:'rgba(232,138,56,0.10)' });
      document.getElementById('kpi-revenue-spark').innerHTML = spark(t.map(p => p.revenue),    { stroke:'#1a2e45', fill:'rgba(26,46,69,0.10)' });

      // By call type
      const types = ['tune_up','diagnostic','estimate','install','iaq','other'];
      const labels = { tune_up:'Tune-up', diagnostic:'Diagnostic', estimate:'Estimate', install:'Install', iaq:'IAQ', other:'Other' };
      const rows = [];
      for (const tp of types) {
        const cv = s.call_volume[tp] || 0;
        if (!cv) continue;
        const cr = s.close_rate.by_type[tp] || { closed:0, total:0, pct:0 };
        const at = s.average_ticket.by_type[tp] || 0;
        const rev = s.revenue.by_type[tp] || 0;
        rows.push(`<tr>
          <td><strong>${labels[tp]}</strong></td>
          <td class="text-right num">${fmtI(cv)}</td>
          <td class="text-right num">${fmtI(cr.closed)}</td>
          <td class="text-right num">${fmtP(cr.pct)}</td>
          <td class="text-right num">${fmt$(at)}</td>
          <td class="text-right num">${fmt$(rev)}</td>
        </tr>`);
      }
      document.getElementById('by-type-rows').innerHTML = rows.length ? rows.join('') :
        `<tr><td colspan="6" class="text-center text-slate-400 py-6">No completed jobs in this window.</td></tr>`;

      // Customer mix
      const ct = s.customer_type;
      const ctMax = Math.max(ct.new_customers, ct.existing_customers, ct.member_customers, 1);
      document.getElementById('cust-new').textContent = fmtI(ct.new_customers);
      document.getElementById('cust-existing').textContent = fmtI(ct.existing_customers);
      document.getElementById('cust-member').textContent = fmtI(ct.member_customers);
      document.getElementById('cust-new-bar').style.width = (ct.new_customers / ctMax * 100) + '%';
      document.getElementById('cust-existing-bar').style.width = (ct.existing_customers / ctMax * 100) + '%';
      document.getElementById('cust-member-bar').style.width = (ct.member_customers / ctMax * 100) + '%';

      // Callbacks
      const cb = s.callbacks;
      document.getElementById('cb-total').textContent = fmtI(cb.total);
      document.getElementById('cb-rate').textContent = fmtP(cb.rate_pct);
      document.getElementById('cb-bench').innerHTML = cb.total > 0 ? benchPill('callback_rate', cb.rate_pct) : '';
      const cbRows = (cb.by_tech || []).filter(r => r.callbacks > 0).slice(0, 8);
      document.getElementById('cb-rows').innerHTML = cbRows.length
        ? cbRows.map(r => `<tr><td>${esc(r.tech_name)}</td><td class="text-right num">${fmtI(r.total_jobs)}</td><td class="text-right num">${fmtI(r.callbacks)}</td><td class="text-right num">${fmtP(r.rate_pct)}</td></tr>`).join('')
        : `<tr><td colspan="4" class="text-center text-slate-400 py-4">No callbacks in this window 🎉</td></tr>`;

      // Sync status
      if (data.last_sync) {
        const ls = data.last_sync;
        const finished = ls.finished_at || ls.started_at;
        const successPill = ls.success === 1 ? 'pill pill-ok' : 'pill pill-err';
        const successText = ls.success === 1 ? 'Synced' : 'Failed';
        document.getElementById('sync-status').innerHTML =
          `<span class="${successPill}">${successText}</span> Last sync ${fmtRel(finished)} · ${fmtI(ls.jobs_synced)} jobs · ${fmtI(ls.customers_synced)} customers`;
      } else {
        document.getElementById('sync-status').innerHTML = `<span class="pill pill-warn">No sync yet</span> Click "Sync now"`;
      }
      document.getElementById('window-display').textContent =
        `${new Date(s.window.from).toLocaleDateString()} → ${new Date(s.window.to).toLocaleDateString()}`;
    }

    function fmtRel(iso) {
      if (!iso) return 'never';
      const d = new Date(iso); const diff = (Date.now() - d.getTime()) / 1000;
      if (diff < 60) return Math.round(diff) + 's ago';
      if (diff < 3600) return Math.round(diff / 60) + 'm ago';
      if (diff < 86400) return Math.round(diff / 3600) + 'h ago';
      return Math.round(diff / 86400) + 'd ago';
    }

    function renderTechs(data) {
      const all = (data.techs || []).filter(t => t.jobs > 0);
      if (!all.length) {
        document.getElementById('tech-rows').innerHTML =
          `<tr><td colspan="8" class="text-center text-slate-400 py-6">No tech data.</td></tr>`;
        return;
      }

      // Three groups:
      //   field   — actual field techs eligible for ranking (5+ jobs, not owner/CSR)
      //   low     — field techs with under 5 jobs (data too thin to rank fairly)
      //   non_field — owner / office / CSR / dispatch (handle different jobs;
      //               not a fair comparison — shown in a separate band)
      const MIN_JOBS = 5;
      const field = all.filter(t => !t.is_owner && t.jobs >= MIN_JOBS);
      const low   = all.filter(t => !t.is_owner && t.jobs < MIN_JOBS);
      const nonField = all.filter(t => t.is_owner);

      // Shop-relative percentile ranking — for each metric, where does this
      // tech sit in the field-tech distribution? 100 = best in shop, 0 = worst.
      // Way more meaningful for Tim than "how do we compare to industry top
      // quartile" since his tune-up techs aren't expected to do install-tech
      // numbers, but they SHOULD be measured against each other.
      // Defaults retuned 2026-05-08: close rate up (strongest signal), revenue
      // down slightly (was over-rewarding install-only techs), reviews down
      // (text-match attribution still imperfect).
      const w = (configCache && configCache.weights) || {
        revenue_per_day:0.20, avg_ticket:0.15, close_rate:0.25, membership_conversion:0.10,
        callback_rate_inverted:0.10, review_rate:0.05, utilization:0.10, volume:0.05
      };
      // Components measurable right now. review_rate flipped to true now
      // that we attribute Google reviews to techs via reviewer-name → HCP-customer
      // → most-recent-job → primary_tech matching.
      const measured = {
        revenue_per_day: true, avg_ticket: true, close_rate: true,
        membership_conversion: false, callback_rate_inverted: true,
        review_rate: true, utilization: false, volume: true,
      };
      let measuredWeight = 0;
      for (const k of Object.keys(w)) if (measured[k]) measuredWeight += w[k];
      if (measuredWeight === 0) measuredWeight = 1;

      const days = currentRange;
      function inputs(t) {
        return {
          revenue_per_day: t.revenue / days,
          avg_ticket: t.avg_ticket,
          close_rate: t.close_rate_pct,
          membership_conversion: 0,
          // Callbacks: we INVERT — fewer callbacks = higher percentile
          callback_rate_inverted: -t.callback_rate_pct,
          review_rate: t.review_rate_pct || 0,
          utilization: 0,
          volume: t.jobs / days,
        };
      }
      function percentile(values, value) {
        if (values.length <= 1) return 50;
        const below = values.filter(v => v < value).length;
        const equal = values.filter(v => v === value).length;
        return Math.round(((below + 0.5 * equal) / values.length) * 100);
      }

      // Build per-metric distributions across field techs only — that's the
      // peer group. Non-field roles get scored with the same anchors but
      // displayed in a separate band.
      const dists = {};
      const fieldInputs = field.map(inputs);
      for (const k of Object.keys(measured)) {
        if (!measured[k]) continue;
        dists[k] = fieldInputs.map(i => i[k] || 0);
      }

      const grade = (n) => n>=90?'A':n>=80?'B':n>=70?'C':n>=60?'D':'F';

      function scoreTech(t, isPeer) {
        const inp = inputs(t);
        let total = 0;
        const breakdown = {};
        for (const k of Object.keys(w)) {
          if (!measured[k]) continue;
          const v = inp[k] || 0;
          // Peer comparison uses the field-tech distribution.
          // For non-peers (owner, low-volume), show a single neutral 50 unless
          // we have a meaningful comparison group.
          const pct = isPeer ? percentile(dists[k] || [], v) : 50;
          breakdown[k] = pct;
          total += pct * (w[k] / measuredWeight);
        }
        return { score: Math.round(total * 10) / 10, breakdown };
      }

      function row(t, opts) {
        const peer = opts && opts.isPeer !== undefined ? opts.isPeer : true;
        const sc = scoreTech(t, peer);
        const g = grade(sc.score);
        const color = gradeColor(g);
        const name = t.is_owner
          ? `<strong>${esc(t.tech_name)}</strong> <span class="pill pill-info" style="font-size:9px">${esc(t.role || 'OWNER')}</span>`
          : `<strong>${esc(t.tech_name)}</strong>${t.role ? ` <span class="text-[10px] text-slate-500">${esc(t.role)}</span>` : ''}`;
        const gradeCell = peer
          ? `<span style="display:inline-flex;align-items:center;gap:6px"><span style="display:inline-block;width:28px;height:28px;border-radius:8px;background:${color};color:#fff;font-weight:700;font-size:13px;line-height:28px;text-align:center">${g}</span><span class="num text-xs text-slate-500">${sc.score.toFixed(0)}</span></span>`
          : `<span class="text-xs text-slate-400">—</span>`;
        return `<tr class="hover-lift" style="cursor:pointer" data-tech-id="${esc(t.tech_id)}">
          <td>${name}</td>
          <td class="text-center">${gradeCell}</td>
          <td class="text-right num">${fmtI(t.jobs)}</td>
          <td class="text-right num hidden sm:table-cell">${t.tune_ups} · ${t.diagnostics} · ${t.estimates}</td>
          <td class="text-right num">${fmtP(t.close_rate_pct)}</td>
          <td class="text-right num hidden sm:table-cell">${fmt$(t.avg_ticket)}</td>
          <td class="text-right num"><strong>${fmt$(t.revenue)}</strong></td>
          <td class="text-right num hidden lg:table-cell">${t.reviews_generated || 0} (${fmtP(t.review_rate_pct || 0)})</td>
          <td class="text-right num hidden lg:table-cell">${t.callbacks} (${fmtP(t.callback_rate_pct)})</td>
        </tr>`;
      }

      const sections = [];
      if (field.length) {
        // Sort by score desc within the peer group
        const fieldRows = field
          .map(t => ({ t, score: scoreTech(t, true).score }))
          .sort((a, b) => b.score - a.score)
          .map(x => row(x.t, { isPeer: true }))
          .join('');
        sections.push(fieldRows);
      }
      if (nonField.length) {
        sections.push(`<tr><td colspan="8" class="text-xs text-slate-500 bg-slate-50 py-1"><strong>Owner / Office</strong> — different role, not ranked alongside field techs</td></tr>`);
        sections.push(nonField.map(t => row(t, { isPeer: false })).join(''));
      }
      if (low.length) {
        sections.push(`<tr><td colspan="8" class="text-xs text-slate-500 bg-slate-50 py-1"><strong>Low volume (under ${MIN_JOBS} jobs)</strong> — data too thin to grade fairly</td></tr>`);
        sections.push(low.map(t => row(t, { isPeer: false })).join(''));
      }

      const tbody = document.getElementById('tech-rows');
      tbody.innerHTML = sections.join('');
      tbody.querySelectorAll('tr[data-tech-id]').forEach(tr => {
        tr.addEventListener('click', () => {
          const id = tr.getAttribute('data-tech-id');
          // Pass the current date range so the detail page shows the same
          // window and computes the same score as the leaderboard.
          location.href = `/admin/dashboard/tech/?id=${encodeURIComponent(id)}&days=${currentRange}`;
        });
      });
    }

    function renderSegments(dormant, renew, vip) {
      const fmtRow = r => `<div class="flex items-center justify-between gap-2 py-1 border-b border-line last:border-0">
        <div class="min-w-0 flex-1"><div class="font-semibold truncate">${esc(r.name)}</div><div class="text-xs text-slate-500 truncate">${esc(r.email || r.phone || '')}</div></div>
        <div class="text-right flex-shrink-0"><div class="font-semibold num">${fmt$(r.lifetime_value)}</div><div class="text-xs text-slate-500">${r.days_since_last_job != null ? r.days_since_last_job + 'd ago' : '—'}</div></div>
      </div>`;
      document.getElementById('seg-dormant').innerHTML = (dormant.rows || []).slice(0,5).map(fmtRow).join('') || '<div class="text-slate-400 text-sm py-2">No dormant customers in pool 🎉</div>';
      document.getElementById('seg-dormant-count').textContent = `${dormant.count}`;
      document.getElementById('seg-renew').innerHTML   = (renew.rows || []).slice(0,5).map(fmtRow).join('')   || '<div class="text-slate-400 text-sm py-2">None renewing in window.</div>';
      document.getElementById('seg-renew-count').textContent = `${renew.count}`;
      document.getElementById('seg-vip').innerHTML     = (vip.rows || []).slice(0,5).map(fmtRow).join('')     || '<div class="text-slate-400 text-sm py-2">—</div>';
    }

    async function loadReviews(forceRefresh) {
      const refreshBtn = document.getElementById('reviews-refresh');
      try {
        if (forceRefresh) {
          refreshBtn.disabled = true; refreshBtn.textContent = '⟳';
          toast('Pulling latest Google reviews via DataForSEO…');
          await api(`/api/reviews/sync`, { method: 'POST' });
        }
        const r = await api('/api/reviews/summary');
        const s = r.snapshot;
        if (!s) {
          document.getElementById('rev-avg').textContent = '—';
          document.getElementById('rev-count').textContent = 'No reviews fetched yet — tap ↻';
          document.getElementById('rev-recent').innerHTML = '<div class="text-slate-400 text-sm py-2">Click ↻ above to pull from Google.</div>';
          return;
        }
        const avg = s.rating_avg ? s.rating_avg.toFixed(1) : '—';
        document.getElementById('rev-avg').textContent = avg;
        // Stars: filled portion based on avg
        const filled = Math.round((s.rating_avg || 0) * 2) / 2;
        document.getElementById('rev-stars').textContent = '★★★★★'.slice(0, Math.floor(filled)) + (filled % 1 ? '☆' : '') + '☆☆☆☆☆'.slice(0, 5 - Math.ceil(filled));
        const fivePlus = (s.count_5 || 0) + (s.count_4 || 0);
        document.getElementById('rev-count').textContent =
          `${fmtI(s.rating_count)} reviews · ${fmtI(fivePlus)} are 4★+ · ${fmtP(s.response_rate_pct || 0)} response rate`;
        // Distribution bars
        const total = (s.count_5 || 0) + (s.count_4 || 0) + (s.count_3 || 0) + (s.count_2 || 0) + (s.count_1 || 0) || 1;
        const buckets = [{n:5,c:s.count_5},{n:4,c:s.count_4},{n:3,c:s.count_3},{n:2,c:s.count_2},{n:1,c:s.count_1}];
        document.getElementById('rev-dist').innerHTML = buckets.map(b => `
          <div class="flex items-center gap-2">
            <span class="w-6 text-slate-600">${b.n}★</span>
            <div class="progress flex-1"><span style="width:${((b.c||0)/total*100).toFixed(0)}%; background:${b.n>=4?'#15803d':b.n>=3?'#b45309':'#b91c1c'}"></span></div>
            <span class="num text-slate-500 w-10 text-right">${fmtI(b.c||0)}</span>
          </div>`).join('');
        document.getElementById('rev-meta').textContent =
          `Synced ${fmtRel(s.fetched_at)} · ${s.business_name} · DataForSEO via Google`;

        const recent = r.recent || [];
        const stars = (n) => n ? '★'.repeat(n) + '☆'.repeat(5 - n) : '—';
        document.getElementById('rev-recent').innerHTML = recent.length ? recent.map(rev => `
          <div class="border-l-2 ${rev.rating >= 4 ? 'border-emerald-500' : rev.rating >= 3 ? 'border-amber-500' : 'border-red-500'} pl-3 py-1">
            <div class="flex flex-wrap justify-between items-baseline gap-2">
              <div class="font-semibold text-sm">${esc(rev.reviewer_name || 'Anonymous')}</div>
              <div class="text-amber-500 text-sm">${stars(rev.rating)}</div>
              <div class="text-xs text-slate-500">${rev.posted_at ? new Date(rev.posted_at).toLocaleDateString() : ''}</div>
            </div>
            ${rev.text ? `<p class="text-sm text-slate-700 mt-1 line-clamp-3">${esc(rev.text)}</p>` : ''}
            ${rev.response_text
              ? `<div class="mt-2 text-xs bg-brand-50 p-2 rounded"><strong>Owner reply:</strong> ${esc(rev.response_text.slice(0, 200))}${rev.response_text.length > 200 ? '…' : ''}</div>`
              : `<div class="mt-1 text-xs text-amber-700">No owner reply yet</div>`}
          </div>
        `).join('') : '<div class="text-slate-400 text-sm py-2">No reviews loaded.</div>';

      } catch (e) {
        toast(e.message || 'Reviews load failed', 'error');
      } finally {
        refreshBtn.disabled = false; refreshBtn.textContent = '↻';
      }
    }

    async function loadAI(forceRefresh) {
      try {
        const url = forceRefresh ? `/api/ai/insights?days=${currentRange}&refresh=1` : `/api/ai/insights?days=${currentRange}`;
        const r = await api(url);
        document.getElementById('ai-loading').hidden = true;
        document.getElementById('ai-meta').textContent =
          (r.cached ? '· cached' : '· fresh') +
          (r.tokens && r.tokens.out ? ` · ${r.tokens.out} out` : '');

        const b = r.briefing;
        if (b && typeof b === 'object') {
          // Structured rendering
          document.getElementById('ai-fallback-md').hidden = true;
          document.getElementById('ai-structured').hidden = false;

          document.getElementById('ai-headline-summary').textContent = b.headline_summary || '';

          // Headlines as mini cards
          const toneClass = (t) => t === 'good' ? 'tone-good' : t === 'warn' ? 'tone-warn' : t === 'bad' ? 'tone-bad' : 'tone-neutral';
          document.getElementById('ai-headlines').innerHTML = (b.headlines || []).map((h, i) => `
            <div class="card-quiet ${toneClass(h.tone)} fade-up" style="--i:${i}">
              <div class="text-[10px] font-bold uppercase tracking-wide text-slate-600">${esc(h.label || '')}</div>
              <div class="text-base font-bold text-navy-700 mt-0.5">${esc(h.value || '')}</div>
              ${h.context ? `<div class="text-xs text-slate-600 mt-1">${esc(h.context)}</div>` : ''}
            </div>`).join('') || '<div class="text-slate-400 text-sm">No headlines.</div>';

          const renderItem = (item, kind) => {
            const techBadge = item.tech ? `<span class="chip chip-info">${esc(item.tech)}</span>` : '';
            const sevBadge = item.severity
              ? `<span class="chip ${item.severity === 'high' ? 'chip-bad' : item.severity === 'med' ? 'chip-warn' : 'chip-info'}">${esc(item.severity)}</span>`
              : '';
            return `<li class="flex gap-2">
              <span class="text-${kind === 'good' ? 'emerald' : 'amber'}-600 mt-0.5 flex-shrink-0">${kind === 'good' ? '✓' : '⚠'}</span>
              <div class="min-w-0 flex-1">
                <div class="font-semibold text-navy-700">${esc(item.title || '')} ${sevBadge} ${techBadge}</div>
                <div class="text-slate-700 text-[13px] mt-0.5">${esc(item.detail || '')}</div>
              </div>
            </li>`;
          };
          document.getElementById('ai-working').innerHTML =
            (b.whats_working || []).map(it => renderItem(it, 'good')).join('') ||
            '<li class="text-slate-400 italic">No standout positives flagged.</li>';
          document.getElementById('ai-attention').innerHTML =
            (b.needs_attention || []).map(it => renderItem(it, 'warn')).join('') ||
            '<li class="text-slate-400 italic">Nothing flagged this week.</li>';

          // Data-quality notes (only shown if AI included any)
          const dq = b.data_quality_notes || [];
          document.getElementById('ai-data-quality-wrap').hidden = dq.length === 0;
          document.getElementById('ai-data-quality').innerHTML = dq.map(it => `
            <li class="flex gap-2">
              <span class="text-brand-700 mt-0.5 flex-shrink-0">ⓘ</span>
              <div class="min-w-0 flex-1">
                <div class="font-semibold text-navy-700">${esc(it.title || '')}</div>
                <div class="text-slate-700 text-[13px] mt-0.5">${esc(it.detail || '')}</div>
                ${it.fix ? `<div class="mt-1 text-[12px] bg-brand-50 px-2 py-1 rounded inline-block"><strong>HCP fix:</strong> ${esc(it.fix)}</div>` : ''}
              </div>
            </li>`).join('');

          // Actions
          document.getElementById('ai-actions').innerHTML =
            (b.actions || []).sort((a, b2) => (a.priority || 99) - (b2.priority || 99)).map((a, i) => `
              <li class="flex gap-3 hover-lift card-quiet fade-up" style="--i:${i}">
                <span class="section-icon bg-accent-500 text-white text-sm font-bold flex-shrink-0">${a.priority || (i + 1)}</span>
                <div class="min-w-0 flex-1">
                  <div class="font-semibold text-navy-700">${esc(a.title || '')}</div>
                  <div class="text-slate-700 text-[13px] mt-0.5">${esc(a.detail || '')}</div>
                  ${a.value_estimate ? `<div class="mt-1"><span class="chip chip-good">${esc(a.value_estimate)}</span></div>` : ''}
                </div>
              </li>`).join('') ||
            '<li class="text-slate-400 italic">No actions this week.</li>';
        } else {
          // Markdown fallback
          document.getElementById('ai-structured').hidden = true;
          document.getElementById('ai-fallback-md').hidden = false;
          document.getElementById('ai-fallback-md').innerHTML = mdToHtml(r.markdown || '_No insight available._');
        }
      } catch (e) {
        document.getElementById('ai-loading').hidden = true;
        document.getElementById('ai-fallback-md').hidden = false;
        document.getElementById('ai-fallback-md').innerHTML = `<p class="text-amber-700">AI insights unavailable: ${esc(e.message || '')}</p>`;
      }
    }

    // Tiny markdown → HTML (headers, bullets, ordered lists, bold, italic).
    // Just enough for MiniMax's structured response.
    function mdToHtml(md) {
      const lines = md.split(/\r?\n/);
      let out = ''; let inUl = false; let inOl = false;
      const closeLists = () => { if (inUl) { out += '</ul>'; inUl = false; } if (inOl) { out += '</ol>'; inOl = false; } };
      for (let line of lines) {
        let m;
        if (/^\s*$/.test(line)) { closeLists(); continue; }
        if ((m = line.match(/^##\s+(.*)$/))) { closeLists(); out += `<h3 class="text-base font-bold text-navy-700 mt-3 mb-1">${esc(m[1])}</h3>`; continue; }
        if ((m = line.match(/^#\s+(.*)$/))) { closeLists(); out += `<h2 class="text-lg font-bold text-navy-700 mt-3 mb-2">${esc(m[1])}</h2>`; continue; }
        if ((m = line.match(/^\s*[-*]\s+(.*)$/))) {
          if (!inUl) { closeLists(); out += '<ul class="list-disc pl-5 space-y-1">'; inUl = true; }
          out += `<li>${formatInline(m[1])}</li>`; continue;
        }
        if ((m = line.match(/^\s*\d+\.\s+(.*)$/))) {
          if (!inOl) { closeLists(); out += '<ol class="list-decimal pl-5 space-y-1">'; inOl = true; }
          out += `<li>${formatInline(m[1])}</li>`; continue;
        }
        closeLists();
        out += `<p>${formatInline(line)}</p>`;
      }
      closeLists();
      return out;
    }
    function formatInline(s) {
      return esc(s)
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.+?)\*/g, '<em>$1</em>')
        .replace(/`(.+?)`/g, '<code>$1</code>');
    }

    async function runSync() {
      const btn = document.getElementById('sync-btn');
      btn.disabled = true;
      const phases = [
        { name: 'employees', label: 'Pulling techs',     body: { endpoints: ['employees'] } },
        { name: 'customers', label: 'Pulling customers', body: { endpoints: ['customers'] } },
        { name: 'jobs',      label: 'Pulling jobs',      body: { endpoints: ['jobs'], daysBack: 90 } },
      ];
      let tt=0, tc=0, tj=0; const errs = [];
      try {
        for (const p of phases) {
          btn.textContent = p.label + '…';
          toast(p.label + ' from Housecall Pro…');
          const r = await api('/api/sync/run', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(p.body),
          });
          tt += r.techs_synced || 0; tc += r.customers_synced || 0; tj += r.jobs_synced || 0;
          if (r.errors && r.errors.length) errs.push(...r.errors);
        }
        toast(errs.length
          ? `Synced w/ warnings: ${tj} jobs · ${tc} customers · ${tt} techs · ${errs.length} error(s)`
          : `Synced ${tj} jobs · ${tc} customers · ${tt} techs`,
          errs.length ? 'error' : 'ok');
        await Promise.all([loadAll(), loadAI(true)]);
      } catch (e) { toast(e.message || 'Sync failed', 'error'); }
      finally { btn.disabled = false; btn.textContent = 'Sync now'; }
    }

    // ─── SETTINGS DRAWER ────────────────────────────────────────────
    function openSettings() {
      const d = document.getElementById('settings-drawer'); d.classList.remove('hidden');
      const t = (configCache && configCache.thresholds) || {};
      document.getElementById('set-sold-tu').value  = (t.sold && t.sold.tune_up) || 110;
      document.getElementById('set-min-tu').value   = (t.minTicket && t.minTicket.tune_up) || 175;
      document.getElementById('set-min-diag').value = (t.minTicket && t.minTicket.diagnostic) || 275;

      const w = (configCache && configCache.weights) || {};
      const labels = { revenue_per_day:'Revenue/day', avg_ticket:'Avg ticket', close_rate:'Close rate', membership_conversion:'Memberships', callback_rate_inverted:'Callbacks (inverted)', review_rate:'Review rate', utilization:'Utilization', volume:'Volume' };
      document.getElementById('weight-sliders').innerHTML = Object.entries(w).map(([k, v]) => `
        <div>
          <div class="flex justify-between text-sm"><span>${labels[k]}</span><span class="num font-semibold"><span data-w-display="${k}">${(v*100).toFixed(0)}</span>%</span></div>
          <input type="range" min="0" max="50" step="1" value="${(v*100).toFixed(0)}" data-w-input="${k}" class="w-full" />
        </div>`).join('');
      document.querySelectorAll('input[data-w-input]').forEach(inp => {
        inp.addEventListener('input', () => {
          const k = inp.getAttribute('data-w-input');
          document.querySelector(`[data-w-display="${k}"]`).textContent = inp.value;
        });
      });
    }
    function closeSettings() { document.getElementById('settings-drawer').classList.add('hidden'); }

    async function saveSettings() {
      const sold = Number(document.getElementById('set-sold-tu').value);
      const minTu = Number(document.getElementById('set-min-tu').value);
      const minDi = Number(document.getElementById('set-min-diag').value);
      const weights = {};
      let total = 0;
      document.querySelectorAll('input[data-w-input]').forEach(inp => {
        const k = inp.getAttribute('data-w-input');
        weights[k] = Number(inp.value) / 100;
        total += weights[k];
      });
      // normalize to sum=1
      if (total > 0) for (const k of Object.keys(weights)) weights[k] = weights[k] / total;
      try {
        await api('/api/kpis/config', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            thresholds: {
              sold: { default: sold, tune_up: sold, diagnostic: sold, estimate: sold },
              minTicket: { default: minTu, tune_up: minTu, diagnostic: minDi, estimate: minTu },
            },
            weights,
          }),
        });
        toast('Settings saved · re-syncing', 'ok');
        await loadConfig();
        await loadAll();
        closeSettings();
      } catch (e) { toast(e.message || 'Save failed', 'error'); }
    }

    // ─── EVENT WIRING ───────────────────────────────────────────────
    document.querySelectorAll('.tab[data-range]').forEach(b => {
      b.addEventListener('click', () => {
        document.querySelectorAll('.tab[data-range]').forEach(x => x.setAttribute('aria-pressed', 'false'));
        b.setAttribute('aria-pressed', 'true');
        currentRange = parseInt(b.dataset.range, 10);
        loadAll();
      });
    });
    document.getElementById('sync-btn').addEventListener('click', runSync);
    document.getElementById('logout-btn').addEventListener('click', () => { clearKey(); show('login'); });
    document.getElementById('ai-refresh').addEventListener('click', () => loadAI(true));
    document.getElementById('reviews-refresh').addEventListener('click', () => loadReviews(true));
    document.getElementById('settings-btn').addEventListener('click', openSettings);
    document.getElementById('settings-close').addEventListener('click', closeSettings);
    document.getElementById('settings-backdrop').addEventListener('click', closeSettings);
    document.getElementById('settings-save').addEventListener('click', saveSettings);
    document.getElementById('settings-reset').addEventListener('click', async () => {
      if (!confirm('Reset thresholds and weights to defaults?')) return;
      try {
        await api('/api/kpis/config', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ thresholds: null, weights: null, targets: null }),
        });
      } catch {}
      await loadConfig(); openSettings();
    });

    document.querySelectorAll('[data-action="open-segment"]').forEach(b => {
      b.addEventListener('click', () => {
        const seg = b.getAttribute('data-segment');
        location.href = `/admin/dashboard/segments/?name=${encodeURIComponent(seg)}`;
      });
    });
    document.querySelectorAll('[data-action="copy-emails"]').forEach(b => {
      b.addEventListener('click', async () => {
        const seg = b.getAttribute('data-segment');
        try {
          const r = await api(`/api/kpis/segments?name=${encodeURIComponent(seg)}&limit=500`);
          const emails = (r.rows || []).map(x => x.email).filter(Boolean).join(', ');
          await navigator.clipboard.writeText(emails);
          toast(`Copied ${(emails.match(/,/g) || []).length + 1} emails — paste into HCP Marketing Center`, 'ok');
        } catch (e) { toast(e.message || 'Copy failed', 'error'); }
      });
    });

    document.getElementById('login-form').addEventListener('submit', async (ev) => {
      ev.preventDefault();
      const k = document.getElementById('login-key').value.trim();
      if (!k) return;
      setKey(k);
      try {
        await api('/api/kpis/summary');
        document.getElementById('login-error').hidden = true;
        show('dash');
        await loadConfig();
        await loadAll();
        loadAI(false);
        loadReviews(false);
      } catch (e) {
        document.getElementById('login-error').hidden = false;
        document.getElementById('login-error').textContent = 'Wrong PIN.';
        clearKey();
      }
    });

    // Boot. Picks up auth from (1) ?key= URL param (auto-stored to sessionStorage),
    // (2) sessionStorage PIN, (3) CF Access cookie.
    (async () => {
      const urlKey = new URL(location.href).searchParams.get('key');
      if (urlKey) setKey(urlKey);

      const startDashboard = async () => {
        show('dash');
        await loadConfig();
        await loadAll();
        loadAI(false);
        loadReviews(false);
      };

      if (getKey()) {
        try { await api('/api/kpis/summary'); await startDashboard(); return; } catch {}
      }
      try {
        const r = await fetch('/api/kpis/summary', { credentials: 'include' });
        if (r.ok) { await startDashboard(); return; }
      } catch {}
      show('login');
    })();
  </script>
</AdminLayout>
