  <div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50" hidden>
    <div id="toast-body" class="bg-navy-700 text-white text-sm px-4 py-2 rounded-lg shadow-soft"></div>
  </div>

  <script is:inline>
    // ─────────────────────────────────────────────────────────────────
    // I Care Air Care KPI Dashboard - Phase 2
    // ─────────────────────────────────────────────────────────────────
    const STORAGE_KEY = 'icac_admin_key';
    let currentRange = 30;
    let customWindow = null;   // {from, to, label} - when set, overrides currentRange-based rolling window
    let configCache = null;

    function getKey() { return sessionStorage.getItem(STORAGE_KEY) || ''; }
    function setKey(k) { sessionStorage.setItem(STORAGE_KEY, k); }
    function clearKey() { sessionStorage.removeItem(STORAGE_KEY); }
    function withAuth(url) {
      const k = getKey(); if (!k) return url;
      const u = new URL(url, location.origin); u.searchParams.set('key', k); return u.toString();
    }
    async function api(path, init) {
      const res = await fetch(withAuth(path), { credentials: 'include', ...init });
      if (res.status === 401) { clearKey(); show('login'); throw new Error('Auth required'); }
      if (!res.ok) { const t = await res.text().catch(() => ''); throw new Error(`API ${path}: ${res.status} ${t.slice(0, 200)}`); }
      return res.json();
    }
    function show(which) {
      document.getElementById('login-gate').hidden = which !== 'login';
      document.getElementById('dashboard').hidden = which !== 'dash';
    }
    function fmt$(n)  { if (n == null || isNaN(n)) return '-'; return '$' + Number(n).toLocaleString('en-US', { maximumFractionDigits: 0 }); }
    function fmt$d(n) { if (n == null || isNaN(n)) return '-'; return '$' + Number(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }
    function fmtP(n)  { if (n == null || isNaN(n)) return '-'; return Number(n).toFixed(1) + '%'; }
    function fmtI(n)  { if (n == null || isNaN(n)) return '-'; return Number(n).toLocaleString('en-US'); }
    function esc(s)   { return String(s ?? '').replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c])); }
    function toast(msg, kind) {
      const t = document.getElementById('toast'), b = document.getElementById('toast-body');
      b.textContent = msg;
      b.className = 'text-sm px-4 py-2 rounded-lg shadow-soft ' +
        (kind === 'error' ? 'bg-red-600 text-white' : kind === 'ok' ? 'bg-emerald-600 text-white' : 'bg-navy-700 text-white');
      t.hidden = false; clearTimeout(toast._t); toast._t = setTimeout(() => t.hidden = true, 4000);
    }

    // Industry benchmarks. Sources are listed and shown on hover so it's
    // clear what each comparison is against. We only call something
    // "below avg" when we have apples-to-apples per-tech data - never
    // for shop-wide totals.
    const BENCHMARKS = {
      avg_ticket:        { p:250, a:450, t:600, dir:'up',
        src:'FieldPulse / MarginPlug 2026 - residential service, $450-600 typical, $600+ premium.' },
      close_rate:        { p:35, a:55, t:75, dir:'up',
        src:'Industry composite - Mercurio "90s percentile" target; 50-75% typical for residential service techs.' },
      close_rate_tune_up:{ p:30, a:50, t:75, dir:'up',
        src:'HVACR Business - 10% to repair + 70% to membership combined ≈ 50% avg, 75%+ top.' },
      close_rate_diag:   { p:50, a:67, t:85, dir:'up',
        src:'BaaDigi / Mercurio - diagnostic close: 60-75% avg, 80%+ top.' },
      callback_rate:     { p:5, a:3, t:2, dir:'down',
        src:'Contracting Business / Mar-Hy - under 3% acceptable, under 2% top performer.' },
      jobs_per_day:      { p:3, a:4, t:6, dir:'up',
        src:'ServiceTitan / Oxmaint - 3-5 jobs/day standard, 5-8 top performers.' },
      revenue_per_day:   { p:1200, a:2000, t:2400, dir:'up',
        src:'BaaDigi / MarginPlug 2026 - per-tech-per-day, top-quartile $2,400+ (residential service).' },
    };
    function bench(metric, value) {
      const b = BENCHMARKS[metric]; if (!b || value == null) return null;
      const tier = b.dir === 'up'
        ? (value >= b.t ? 'top' : value >= b.a ? 'avg' : 'poor')
        : (value <= b.t ? 'top' : value <= b.a ? 'avg' : 'poor');
      const color = { top:'#15803d', avg:'#b45309', poor:'#b91c1c' }[tier];
      const label = { top:'Top quartile', avg:'Industry avg', poor:'Below avg' }[tier];
      return { tier, color, label, src: b.src };
    }
    function benchPill(metric, value) {
      const b = bench(metric, value); if (!b) return '';
      return `<span title="${esc(b.src)}" style="display:inline-flex;align-items:center;gap:4px;font-weight:600;color:${b.color};cursor:help"><span style="width:7px;height:7px;border-radius:999px;background:${b.color}"></span>${b.label}</span>`;
    }

    function spark(values, opts = {}) {
      if (!values || values.length === 0) return '';
      const w = opts.w || 240, h = opts.h || 40;
      const max = Math.max(1, ...values);
      const min = Math.min(0, ...values);
      const range = max - min || 1;
      const stepX = w / Math.max(1, values.length - 1);
      const pts = values.map((v, i) => `${(i * stepX).toFixed(1)},${(h - ((v - min) / range) * h).toFixed(1)}`);
      return `<svg viewBox="0 0 ${w} ${h}" width="100%" height="${h}" preserveAspectRatio="none">
        <polyline fill="${opts.fill || 'rgba(93,165,184,0.12)'}" stroke="none" points="0,${h} ${pts.join(' ')} ${w},${h}" />
        <polyline fill="none" stroke="${opts.stroke || '#5da5b8'}" stroke-width="2" points="${pts.join(' ')}" />
      </svg>`;
    }

    function gradeColor(g) { return ({ A:'#15803d', B:'#10b981', C:'#b45309', D:'#dc2626', F:'#991b1b' }[g] || '#64748b'); }

    function computeWindow(days) {
      // If a custom window is active, use it (overrides rolling days).
      if (customWindow && customWindow.from && customWindow.to) {
        return { from: customWindow.from, to: customWindow.to };
      }
      const to = new Date();
      const from = new Date(to.getTime() - days * 86400000);
      return { from: from.toISOString(), to: to.toISOString() };
    }

    // Window display in the header reflects the active selection.
    function currentWindowLabel() {
      if (customWindow && customWindow.label) return customWindow.label;
      return `Last ${currentRange} days`;
    }

    // Convert a Date to YYYY-MM-DD in LOCAL time (for input[type=date]).
    function ymd(d) {
      const y = d.getFullYear(), m = String(d.getMonth() + 1).padStart(2,'0'), day = String(d.getDate()).padStart(2,'0');
      return `${y}-${m}-${day}`;
    }
    // Parse YYYY-MM-DD as local midnight start/end (so user-entered dates feel natural).
    function startOfLocalDay(s) { const [y,m,d] = s.split('-').map(Number); return new Date(y, m-1, d, 0, 0, 0, 0); }
    function endOfLocalDay(s)   { const [y,m,d] = s.split('-').map(Number); return new Date(y, m-1, d, 23, 59, 59, 999); }

    // Build presets relative to "now" - Sun-Sat last week, current month, prior month.
    function buildPreset(name) {
      const now = new Date();
      if (name === 'last_week') {
        // Last completed Sun-Sat week. JS Sunday = 0.
        const day = now.getDay();
        const lastSat = new Date(now); lastSat.setDate(now.getDate() - day - 1); lastSat.setHours(23,59,59,999);
        const lastSun = new Date(lastSat); lastSun.setDate(lastSat.getDate() - 6); lastSun.setHours(0,0,0,0);
        return { from: lastSun.toISOString(), to: lastSat.toISOString(), label: `Last week · ${ymd(lastSun)} → ${ymd(lastSat)}` };
      }
      if (name === 'this_month') {
        const first = new Date(now.getFullYear(), now.getMonth(), 1, 0,0,0,0);
        return { from: first.toISOString(), to: now.toISOString(), label: `${first.toLocaleString('en-US',{month:'long'})} ${first.getFullYear()} (month-to-date)` };
      }
      if (name === 'last_month') {
        const firstThis = new Date(now.getFullYear(), now.getMonth(), 1, 0,0,0,0);
        const lastPrev = new Date(firstThis.getTime() - 1);                     // last ms of prior month
        const firstPrev = new Date(lastPrev.getFullYear(), lastPrev.getMonth(), 1, 0,0,0,0);
        return { from: firstPrev.toISOString(), to: lastPrev.toISOString(), label: `${firstPrev.toLocaleString('en-US',{month:'long'})} ${firstPrev.getFullYear()}` };
      }
      return null;
    }

    function setSkeletons() {
      ['kpi-volume','kpi-close','kpi-ticket','kpi-revenue'].forEach(id => {
        document.getElementById(id).innerHTML = '<span class="skeleton inline-block h-9 w-24"></span>';
      });
    }

    // Count-up animation for KPI numbers. Honors prefers-reduced-motion.
    const PRM = matchMedia('(prefers-reduced-motion: reduce)').matches;
    function countUp(el, target, formatter, durationMs) {
      const dur = PRM ? 0 : (durationMs || 700);
      const start = parseFloat(el.dataset.count || '0') || 0;
      const t0 = performance.now();
      function step(now) {
        const k = Math.min(1, (now - t0) / dur);
        const eased = 1 - Math.pow(1 - k, 3);
        const v = start + (target - start) * eased;
        el.textContent = formatter(v);
        if (k < 1) requestAnimationFrame(step);
        else { el.dataset.count = String(target); el.textContent = formatter(target); }
      }
      if (dur === 0) { el.dataset.count = String(target); el.textContent = formatter(target); return; }
      requestAnimationFrame(step);
    }

    async function loadConfig() {
      try {
        configCache = await api('/api/kpis/config');
        const t = configCache.thresholds || {};
        document.getElementById('thr-sold-tu').textContent = '$' + ((t.sold && t.sold.tune_up) || 110);
        document.getElementById('thr-min-tu').textContent  = '$' + ((t.minTicket && t.minTicket.tune_up) || 175);
        document.getElementById('thr-min-diag').textContent= '$' + ((t.minTicket && t.minTicket.diagnostic) || 275);
      } catch (e) { /* ignore */ }
    }

    async function loadAll() {
      setSkeletons();
      const w = computeWindow(currentRange);
      try {
        const [summary, byTech, trend, segDormant, segRenew, segVip] = await Promise.all([
          api(`/api/kpis/summary?from=${encodeURIComponent(w.from)}&to=${encodeURIComponent(w.to)}`),
          api(`/api/kpis/by-tech?from=${encodeURIComponent(w.from)}&to=${encodeURIComponent(w.to)}`),
          api(`/api/kpis/trends?weeks=12`),
          api(`/api/kpis/segments?name=dormant_12mo&limit=5`),
          api(`/api/kpis/segments?name=members_renewing&limit=5`),
          api(`/api/kpis/segments?name=top_ltv&limit=5`),
        ]);
        renderSummary(summary, trend);
        renderTechs(byTech);
        renderGoals(byTech);
        renderSegments(segDormant, segRenew, segVip);
        // Pre-warm AI coaching cache for all field techs in the background
        // so clicking into a tech detail page is instant (cache TTL 6h).
        // Will reported tech-detail AI taking ~2min on cold load - this
        // bakes the bread before he asks for the sandwich.
        prewarmAICoaching(byTech);
      } catch (e) {
        toast(e.message || 'Load failed', 'error');
      }
    }

    // Background AI cache pre-warming. We fire requests in series (one at a
    // time) so we don't slam MiniMax with 6 parallel reasoning calls.
    // Each request is fire-and-forget - failures are silent. KV caches for
    // 6 hours, so subsequent clicks into tech detail pages return instantly.
    let _prewarmInFlight = false;
    async function prewarmAICoaching(byTech) {
      if (_prewarmInFlight) return;
      _prewarmInFlight = true;
      try {
        const looksLikeRawId = name => !name || /^pro_[a-f0-9]{20,}$/i.test(String(name).trim());
        const candidates = ((byTech && byTech.techs) || [])
          .filter(t => t.jobs >= 5 && !looksLikeRawId(t.tech_name) && (t.role_band === 'service' || t.role_band === 'install'))
          .sort((a, b) => (b.revenue || 0) - (a.revenue || 0))
          .slice(0, 8);  // Top-8 by revenue covers Tim's likely click targets
        for (const t of candidates) {
          try {
            // Don't use api() - we don't want errors here to throw or kick to login.
            // Just GET and rely on the server-side KV cache write as the side effect.
            await fetch(withAuth(`/api/ai/tech-coaching?id=${encodeURIComponent(t.tech_id)}&days=${currentRange}`), { credentials: 'include' });
          } catch { /* silent - best-effort */ }
        }
      } finally {
        _prewarmInFlight = false;
      }
    }

    function renderSummary(data, trend) {
      const s = data.summary;
      const days = currentRange;
      const techCount = Math.max(1, (data.summary.revenue.by_tech || []).length);

      countUp(document.getElementById('kpi-volume'), s.call_volume.total, (v) => fmtI(Math.round(v)));
      document.getElementById('kpi-volume-sub').textContent =
        `${s.call_volume.tune_up} TU · ${s.call_volume.diagnostic} Dx · ${s.call_volume.estimate} Est`;
      // Per-tech jobs/day - only count field techs that actually closed jobs in window.
      const activeTechCount = ((data.summary.revenue.by_tech || []).filter(t => t.jobs > 0)).length || 1;
      const jpd = s.call_volume.total / days / activeTechCount;
      document.getElementById('kv-bench').innerHTML = benchPill('jobs_per_day', jpd) +
        `<span class="text-[10px] text-slate-500 ml-1">${jpd.toFixed(1)}/tech/day</span>`;

      countUp(document.getElementById('kpi-close'), s.close_rate.overall_pct, (v) => v.toFixed(1) + '%');
      document.getElementById('kpi-close-sub').textContent =
        `${s.totals.sold_jobs} sold of ${s.totals.completed_jobs}`;
      document.getElementById('cr-bench').innerHTML = benchPill('close_rate', s.close_rate.overall_pct);

      countUp(document.getElementById('kpi-ticket'), s.average_ticket.overall, (v) => fmt$(v));
      document.getElementById('at-bench').innerHTML = benchPill('avg_ticket', s.average_ticket.overall);

      countUp(document.getElementById('kpi-revenue'), s.revenue.total, (v) => fmt$(v), 900);
      // Don't dot-rate shop-wide revenue against a per-tech industry benchmark
      // - apples to oranges. Show the period total, the period rate, and
      // who topped the leaderboard. Per-tech benchmarks live in the tech detail page.
      const topTech = (data.summary.revenue.by_tech || [])[0];
      document.getElementById('kpi-revenue-sub').textContent =
        topTech ? `Top: ${topTech.tech_name} · ${fmt$(topTech.revenue)}` : `${fmt$(s.revenue.total)} total`;
      document.getElementById('rev-bench').innerHTML = '';

      // Sparklines from 12-week trend
      const t = trend.points || [];
      document.getElementById('kpi-volume-spark').innerHTML  = spark(t.map(p => p.jobs),       { stroke:'#5da5b8' });
      document.getElementById('kpi-close-spark').innerHTML   = spark(t.map(p => p.close_rate_pct),{ stroke:'#10b981', fill:'rgba(16,185,129,0.10)' });
      document.getElementById('kpi-ticket-spark').innerHTML  = spark(t.map(p => p.avg_ticket), { stroke:'#e88a38', fill:'rgba(232,138,56,0.10)' });
      document.getElementById('kpi-revenue-spark').innerHTML = spark(t.map(p => p.revenue),    { stroke:'#1a2e45', fill:'rgba(26,46,69,0.10)' });

      // By call type
      const types = ['tune_up','diagnostic','estimate','install','iaq','admin','other'];
      const labels = { tune_up:'Tune-up', diagnostic:'Diagnostic', estimate:'Estimate', install:'Install', iaq:'IAQ / duct', admin:'Admin (permits, pickups)', other:'Other' };
      const rows = [];
      for (const tp of types) {
        const cv = s.call_volume[tp] || 0;
        if (!cv) continue;
        const cr = s.close_rate.by_type[tp] || { closed:0, total:0, pct:0 };
        const at = s.average_ticket.by_type[tp] || 0;
        const rev = s.revenue.by_type[tp] || 0;
        rows.push(`<tr>
          <td><strong>${labels[tp]}</strong></td>
          <td class="text-right num">${fmtI(cv)}</td>
          <td class="text-right num">${fmtI(cr.closed)}</td>
          <td class="text-right num">${fmtP(cr.pct)}</td>
          <td class="text-right num">${fmt$(at)}</td>
          <td class="text-right num">${fmt$(rev)}</td>
        </tr>`);
      }
      document.getElementById('by-type-rows').innerHTML = rows.length ? rows.join('') :
        `<tr><td colspan="6" class="text-center text-slate-400 py-6">No completed jobs in this window.</td></tr>`;

      // Customer mix
      const ct = s.customer_type;
      const ctMax = Math.max(ct.new_customers, ct.existing_customers, ct.member_customers, 1);
      document.getElementById('cust-new').textContent = fmtI(ct.new_customers);
      document.getElementById('cust-existing').textContent = fmtI(ct.existing_customers);
      document.getElementById('cust-member').textContent = fmtI(ct.member_customers);
      document.getElementById('cust-new-bar').style.width = (ct.new_customers / ctMax * 100) + '%';
      document.getElementById('cust-existing-bar').style.width = (ct.existing_customers / ctMax * 100) + '%';
      document.getElementById('cust-member-bar').style.width = (ct.member_customers / ctMax * 100) + '%';

      // Callbacks
      const cb = s.callbacks;
      document.getElementById('cb-total').textContent = fmtI(cb.total);
      document.getElementById('cb-rate').textContent = fmtP(cb.rate_pct);
      document.getElementById('cb-bench').innerHTML = cb.total > 0 ? benchPill('callback_rate', cb.rate_pct) : '';
      const cbRows = (cb.by_tech || []).filter(r => r.callbacks > 0).slice(0, 8);
      document.getElementById('cb-rows').innerHTML = cbRows.length
        ? cbRows.map(r => `<tr><td>${esc(r.tech_name)}</td><td class="text-right num">${fmtI(r.total_jobs)}</td><td class="text-right num">${fmtI(r.callbacks)}</td><td class="text-right num">${fmtP(r.rate_pct)}</td></tr>`).join('')
        : `<tr><td colspan="4" class="text-center text-slate-400 py-4">No callbacks in this window 🎉</td></tr>`;

      // Sync status. Four states:
      //   success === 1                        → "Synced"
      //   finished_at && success !=1           → "Failed"
      //   started, no finished_at, < 10 min    → "In progress" (still running)
      //   started, no finished_at, ≥ 10 min    → "Sync stalled" (worker died
      //                                           mid-run; data is from a prior
      //                                           successful sync. Tim should
      //                                           click Sync to retry.)
      if (data.last_sync) {
        const ls = data.last_sync;
        const finished = ls.finished_at || ls.started_at;
        const ageMin = ls.started_at ? (Date.now() - new Date(ls.started_at).getTime()) / 60000 : Infinity;
        const STALL_AFTER_MIN = 10;
        let pill, text;
        if (ls.success === 1) { pill = 'pill pill-ok'; text = 'Synced'; }
        else if (!ls.finished_at && ageMin < STALL_AFTER_MIN) { pill = 'pill pill-warn'; text = 'In progress'; }
        else if (!ls.finished_at) { pill = 'pill pill-err'; text = 'Sync stalled - click Sync to retry'; }
        else { pill = 'pill pill-err'; text = 'Failed'; }
        const counts = ls.finished_at
          ? ` · ${fmtI(ls.jobs_synced)} jobs · ${fmtI(ls.customers_synced)} customers`
          : '';
        document.getElementById('sync-status').innerHTML =
          `<span class="${pill}">${text}</span> Last sync ${fmtRel(finished)}${counts}`;
      } else {
        document.getElementById('sync-status').innerHTML = `<span class="pill pill-warn">No sync yet</span> Click "Sync now"`;
      }
      document.getElementById('window-display').textContent =
        `${new Date(s.window.from).toLocaleDateString()} → ${new Date(s.window.to).toLocaleDateString()}`;
    }

    function fmtRel(iso) {
      if (!iso) return 'never';
      const d = new Date(iso); const diff = (Date.now() - d.getTime()) / 1000;
      if (diff < 60) return Math.round(diff) + 's ago';
      if (diff < 3600) return Math.round(diff / 60) + 'm ago';
      if (diff < 86400) return Math.round(diff / 3600) + 'h ago';
      return Math.round(diff / 86400) + 'd ago';
    }

    function renderTechs(data) {
      // Filter out tech rows that have no human name (HCP records we never
      // synced - usually deleted/historical employees still attached to
      // old jobs via all_tech_hcp_ids). They render as "pro_xxxx..." and
      // confuse the leaderboard; we can't action on them anyway.
      const looksLikeRawId = name => !name || /^pro_[a-f0-9]{20,}$/i.test(String(name).trim());
      const all = (data.techs || []).filter(t => t.jobs > 0 && !looksLikeRawId(t.tech_name));
      // Stash for the settings drawer's live preview
      lastTechsForPreview = all;
      if (!all.length) {
        document.getElementById('tech-rows').innerHTML =
          `<tr><td colspan="8" class="text-center text-slate-400 py-6">No tech data.</td></tr>`;
        return;
      }

      // Tim's bands (2026-05-09): split field techs into SERVICE vs INSTALL
      // because service and install techs do fundamentally different work
      // and shouldn't be peer-ranked against each other. Helpers (Angel /
      // Paul) ride alongside install techs but are tracked separately.
      // Owner / office stay in their own band.
      //
      //   serviceTechs   - Erick, Kleber, Gerald, James (or whoever Tim labels)
      //   installTechs   - Cesar, Daniel
      //   helpers        - Angel, Paul
      //   non_field      - owner / office / CSR / dispatch
      //   low            - under 5 jobs (data too thin in any band)
      const MIN_JOBS = 5;
      const serviceTechs = all.filter(t => t.role_band === 'service' && t.jobs >= MIN_JOBS);
      const installTechs = all.filter(t => t.role_band === 'install' && t.jobs >= MIN_JOBS);
      const helpers      = all.filter(t => t.role_band === 'helper'  && t.jobs >= MIN_JOBS);
      const otherField   = all.filter(t => !['service','install','helper','owner','office'].includes(t.role_band) && t.jobs >= MIN_JOBS);
      const low      = all.filter(t => !['owner','office'].includes(t.role_band) && t.jobs < MIN_JOBS);
      const nonField = all.filter(t => t.role_band === 'owner' || t.role_band === 'office' || t.is_owner);

      // Shop-relative percentile ranking - for each metric, where does this
      // tech sit in the field-tech distribution? 100 = best in shop, 0 = worst.
      // Way more meaningful for Tim than "how do we compare to industry top
      // quartile" since his tune-up techs aren't expected to do install-tech
      // numbers, but they SHOULD be measured against each other.
      // Defaults retuned 2026-05-08: close rate up (strongest signal), revenue
      // down slightly (was over-rewarding install-only techs), reviews down
      // (text-match attribution still imperfect).
      const w = (configCache && configCache.weights) || {
        revenue_per_day:0.20, avg_ticket:0.15, close_rate:0.25, membership_conversion:0.10,
        callback_rate_inverted:0.10, review_rate:0.05, utilization:0.10, volume:0.05
      };
      // Components measurable right now. review_rate flipped to true now
      // that we attribute Google reviews to techs via reviewer-name → HCP-customer
      // → most-recent-job → primary_tech matching.
      const measured = {
        revenue_per_day: true, avg_ticket: true, close_rate: true,
        membership_conversion: false, callback_rate_inverted: true,
        review_rate: true, utilization: false, volume: true,
      };
      let measuredWeight = 0;
      for (const k of Object.keys(w)) if (measured[k]) measuredWeight += w[k];
      if (measuredWeight === 0) measuredWeight = 1;

      const days = currentRange;
      function inputs(t) {
        return {
          revenue_per_day: t.revenue / days,
          avg_ticket: t.avg_ticket,
          close_rate: t.close_rate_pct,
          membership_conversion: 0,
          // Callbacks: we INVERT - fewer callbacks = higher percentile
          callback_rate_inverted: -t.callback_rate_pct,
          review_rate: t.review_rate_pct || 0,
          utilization: 0,
          volume: t.jobs / days,
        };
      }
      function percentile(values, value) {
        if (values.length <= 1) return 50;
        const below = values.filter(v => v < value).length;
        const equal = values.filter(v => v === value).length;
        return Math.round(((below + 0.5 * equal) / values.length) * 100);
      }

      // Build per-band, per-metric distributions. Service techs compare
      // against service techs only; install techs against install techs.
      // (Tim's 2026-05-09 feedback - service and install do different
      // work, peer ranking only works within band.)
      function buildDist(group) {
        const d = {};
        const inps = group.map(inputs);
        for (const k of Object.keys(measured)) {
          if (!measured[k]) continue;
          d[k] = inps.map(i => i[k] || 0);
        }
        return d;
      }
      const distsByBand = {
        service: buildDist(serviceTechs),
        install: buildDist(installTechs),
        helper:  buildDist(helpers),
        other:   buildDist(otherField),
      };

      // Will-tuned grade scale (2026-05-15): standard school grading made
      // every tech an F because nobody hits the 60-90 normalized range on
      // a peer-relative percentile (you'd need to be the best AND beat
      // industry top-quartile). New cuts: 80=A, 60=B, 40=C, 20=D, else F.
      // A "C" now means roughly the middle of the shop AND mid-industry - 
      // which is genuinely "average," matching how people read grades.
      const grade = (n) => n>=80?'A':n>=60?'B':n>=40?'C':n>=20?'D':'F';

      function scoreTech(t, isPeer) {
        const inp = inputs(t);
        // Pick the distribution that matches this tech's band.
        const bandKey = ['service','install','helper'].includes(t.role_band) ? t.role_band : 'other';
        const dists = distsByBand[bandKey] || {};
        let total = 0;
        const breakdown = {};
        for (const k of Object.keys(w)) {
          if (!measured[k]) continue;
          const v = inp[k] || 0;
          // Peer comparison uses the within-band distribution.
          // Non-peer (owner, low-volume) gets a single neutral 50.
          const pct = isPeer ? percentile(dists[k] || [], v) : 50;
          breakdown[k] = pct;
          total += pct * (w[k] / measuredWeight);
        }
        return { score: Math.round(total * 10) / 10, breakdown };
      }

      // INDUSTRY-ANCHORED scoring (Tim feedback 2026-05-14 - show alongside peer).
      // Normalizes each metric against industry top-quartile anchors from
      // configCache.targets. Each component is 0-100, weighted, summed.
      // This is harsher than peer-relative - a 50% close rate scores lower
      // against an 85% top-quartile anchor than it does against ICAC's median.
      function scoreIndustry(t) {
        const targets = (configCache && configCache.targets) || {
          revenue_per_day:{zero:1000,hundred:2400}, avg_ticket:{zero:200,hundred:550},
          close_rate:{zero:50,hundred:90}, membership_conversion:{zero:10,hundred:35},
          callback_rate_inverted:{zero:5,hundred:0}, review_rate:{zero:5,hundred:30},
          utilization:{zero:50,hundred:75}, volume:{zero:2,hundred:5}
        };
        const inp = inputs(t);
        const norm = (val, tg) => {
          if (!tg || tg.zero === tg.hundred) return 50;
          const c = n => Math.max(0, Math.min(100, n));
          return tg.zero < tg.hundred
            ? c(((val - tg.zero) / (tg.hundred - tg.zero)) * 100)
            : c(((tg.zero - val) / (tg.zero - tg.hundred)) * 100);
        };
        let total = 0;
        for (const k of Object.keys(w)) {
          if (!measured[k]) continue;
          total += norm(inp[k] || 0, targets[k]) * (w[k] / measuredWeight);
        }
        return Math.round(total * 10) / 10;
      }

      function row(t, opts) {
        const peer = opts && opts.isPeer !== undefined ? opts.isPeer : true;
        const sc = scoreTech(t, peer);
        const g = grade(sc.score);
        const color = gradeColor(g);
        // Industry-anchored grade is always computed; the column is
        // shown/hidden by the "Show industry grade" toggle.
        const indScore = scoreIndustry(t);
        const indGrade = grade(indScore);
        const indColor = gradeColor(indGrade);
        const formerBadge = (t.is_active === false)
          ? ` <span class="pill" style="font-size:9px;background:#fee2e2;color:#991b1b" title="No longer active in Housecall Pro | drops off once they have no jobs in the window">former</span>`
          : '';
        const name = t.is_owner
          ? `<strong>${esc(t.tech_name)}</strong> <span class="pill pill-info" style="font-size:9px">${esc(t.role || 'OWNER')}</span>${formerBadge}`
          : `<strong>${esc(t.tech_name)}</strong>${t.role ? ` <span class="text-[10px] text-slate-500">${esc(t.role)}</span>` : ''}${formerBadge}`;
        const peerCell = peer
          ? `<span style="display:inline-flex;align-items:center;gap:6px"><span style="display:inline-block;width:28px;height:28px;border-radius:8px;background:${color};color:#fff;font-weight:700;font-size:13px;line-height:28px;text-align:center">${g}</span><span class="num text-xs text-slate-500">${sc.score.toFixed(0)}</span></span>`
          : `<span class="text-xs text-slate-400">-</span>`;
        const indCell = `<span style="display:inline-flex;align-items:center;gap:6px"><span style="display:inline-block;width:28px;height:28px;border-radius:8px;background:${indColor};color:#fff;font-weight:700;font-size:13px;line-height:28px;text-align:center" title="vs HVAC industry top-quartile anchors">${indGrade}</span><span class="num text-xs text-slate-500">${indScore.toFixed(0)}</span></span>`;
        // Show "X jobs" with a quiet "+Y shared" indicator when the tech
        // got credit on multi-tech jobs (where they weren't primary).
        const sharedHint = (t.shared_jobs || 0) > 0
          ? ` <span class="text-[10px] text-slate-500" title="${t.shared_jobs} of these jobs you worked alongside another tech (multi-tech credit)">+${t.shared_jobs} shared</span>`
          : '';
        return `<tr class="hover-lift" style="cursor:pointer" data-tech-id="${esc(t.tech_id)}">
          <td>${name}</td>
          <td class="text-center">${peerCell}</td>
          <td class="text-center industry-col hidden">${indCell}</td>
          <td class="text-right num">${fmtI(t.jobs)}${sharedHint}</td>
          <td class="text-right num hidden sm:table-cell">${t.tune_ups} · ${t.diagnostics} · ${t.estimates}</td>
          <td class="text-right num">${fmtP(t.close_rate_pct)}</td>
          <td class="text-right num hidden sm:table-cell">${fmt$(t.avg_ticket)}</td>
          <td class="text-right num"><strong>${fmt$(t.revenue)}</strong></td>
          <td class="text-right num hidden md:table-cell">${fmt$(t.sales_rev || 0)}</td>
          <td class="text-right num hidden md:table-cell">${fmt$(t.install_rev || 0)}</td>
          <td class="text-right num hidden lg:table-cell">${(t.hours_total || 0) > 0 ? (t.hours_total).toFixed(1) + 'h' : '<span class="text-slate-300" title="No Time Tracking CSV uploaded yet">-</span>'}</td>
          <td class="text-right num hidden lg:table-cell">${(t.rev_per_hour || 0) > 0 ? fmt$(t.rev_per_hour) : '<span class="text-slate-300">-</span>'}</td>
          <td class="text-right num hidden lg:table-cell">${t.reviews_generated || 0} (${fmtP(t.review_rate_pct || 0)})</td>
          <td class="text-right num hidden lg:table-cell">${t.callbacks} (${fmtP(t.callback_rate_pct)})</td>
        </tr>`;
      }

      const sections = [];
      const bandHeader = (label, sublabel) =>
        `<tr><td colspan="14" class="text-xs text-slate-600 bg-slate-50 py-2 px-3"><strong>${label}</strong> <span class="text-slate-400">- ${sublabel}</span></td></tr>`;
      const sortByScore = (arr) => arr.map(t => ({ t, score: scoreTech(t, true).score })).sort((a, b) => b.score - a.score).map(x => row(x.t, { isPeer: true })).join('');

      if (serviceTechs.length) {
        sections.push(bandHeader('Service techs', 'tune-ups, diagnostics, repair - graded against each other'));
        sections.push(sortByScore(serviceTechs));
      }
      if (installTechs.length) {
        sections.push(bandHeader('Install techs', 'replacements, change-outs - different work, ranked separately'));
        sections.push(sortByScore(installTechs));
      }
      if (helpers.length) {
        sections.push(bandHeader('Install helpers', 'apprentice / 2nd-tech support'));
        sections.push(helpers.map(t => row(t, { isPeer: false })).join(''));
      }
      if (otherField.length) {
        sections.push(bandHeader('Field (unlabeled)', 'set their band in Settings → Roles'));
        sections.push(otherField.map(t => row(t, { isPeer: false })).join(''));
      }
      if (nonField.length) {
        sections.push(bandHeader('Owner / Office', 'different role, not ranked alongside field techs'));
        sections.push(nonField.map(t => row(t, { isPeer: false })).join(''));
      }
      if (low.length) {
        sections.push(bandHeader(`Low volume (under ${MIN_JOBS} jobs)`, 'data too thin to grade fairly'));
        sections.push(low.map(t => row(t, { isPeer: false })).join(''));
      }

      const tbody = document.getElementById('tech-rows');
      tbody.innerHTML = sections.join('');
      tbody.querySelectorAll('tr[data-tech-id]').forEach(tr => {
        tr.addEventListener('click', () => {
          const id = tr.getAttribute('data-tech-id');
          // Pass the current date range so the detail page shows the same
          // window and computes the same score as the leaderboard.
          location.href = `/admin/dashboard/tech/?id=${encodeURIComponent(id)}&days=${currentRange}`;
        });
      });
      // Reapply industry-column visibility - every render recreates the
      // .industry-col cells with the default `hidden` class.
      const indCb = document.getElementById('show-industry');
      if (indCb && indCb.checked) {
        document.querySelectorAll('.industry-col').forEach(el => el.classList.remove('hidden'));
      }
    }

    // ─── PHASE 8 - GOAL PROGRESS ────────────────────────────────────
    // Render shop-wide rollup + per-tech progress vs the goals stored in KV.
    // Goals are monthly targets - we prorate to the active window so a 7-day
    // view shows progress to date for that 7-day slice of the month, not the
    // full monthly figure. This keeps "X is at 87% of his goal" honest.
    function renderGoals(byTech) {
      const wrapShop = document.getElementById('goals-shop');
      const wrapTech = document.getElementById('goals-tech');
      const empty    = document.getElementById('goals-empty');
      const summary  = document.getElementById('goals-summary');
      const note     = document.getElementById('goals-window-note');

      // Apply the same MIN_JOBS=5 filter the leaderboard uses. A tech with 1 job
      // is "data too thin to grade fairly" - including them here drags the shop
      // rollup averages down AND lets them appear as "Most upside" leader, which
      // is misleading (low jobs ≠ underperformer).
      const MIN_JOBS_FOR_GOALS = 5;
      const looksLikeRawId = name => !name || /^pro_[a-f0-9]{20,}$/i.test(String(name).trim());
      const techs = (byTech && byTech.techs)
        ? byTech.techs.filter(t => t.jobs >= MIN_JOBS_FOR_GOALS && !t.is_owner && !looksLikeRawId(t.tech_name))
        : [];
      if (!techs.length) { wrapShop.innerHTML = ''; wrapTech.innerHTML = ''; empty.hidden = false; summary.textContent = ''; return; }
      empty.hidden = true;

      const goals = (configCache && configCache.goals) || { revenue_monthly: 15000, close_rate: 55, avg_ticket: 400, callback_rate: 3, review_rate: 15 };
      const days = currentRange;
      // Prorate monthly revenue goal to window (30-day month basis)
      const revGoalForWindow = goals.revenue_monthly * (days / 30);
      note.textContent = `${days}-day window · revenue goal prorated from $${Math.round(goals.revenue_monthly).toLocaleString()}/mo to $${Math.round(revGoalForWindow).toLocaleString()}.`;

      // Compute progress for one tech across all 5 goals.
      // Returns array of {key, label, value, valDisplay, goal, goalDisplay, pct, tone, inverted}
      // tone: 'good' >= 100% (90% for review_rate), 'warn' >= 70%, 'bad' otherwise.
      // For inverted goals (callback_rate - lower is better), tone reverses: 'good' if at/under goal.
      function progressFor(t) {
        const out = [];
        // Revenue (window-prorated)
        const revPct = revGoalForWindow > 0 ? (t.revenue / revGoalForWindow) * 100 : 0;
        out.push({ key:'revenue', label:'Revenue', value:t.revenue, valDisplay:fmt$(t.revenue),
          goal:revGoalForWindow, goalDisplay:fmt$(revGoalForWindow), pct:revPct,
          tone: revPct >= 100 ? 'good' : revPct >= 70 ? 'warn' : 'bad', inverted:false });
        // Close rate
        const crPct = goals.close_rate > 0 ? (t.close_rate_pct / goals.close_rate) * 100 : 0;
        out.push({ key:'close', label:'Close rate', value:t.close_rate_pct, valDisplay:fmtP(t.close_rate_pct),
          goal:goals.close_rate, goalDisplay:goals.close_rate + '%', pct:crPct,
          tone: crPct >= 100 ? 'good' : crPct >= 80 ? 'warn' : 'bad', inverted:false });
        // Avg ticket
        const atPct = goals.avg_ticket > 0 ? (t.avg_ticket / goals.avg_ticket) * 100 : 0;
        out.push({ key:'ticket', label:'Avg ticket', value:t.avg_ticket, valDisplay:fmt$(t.avg_ticket),
          goal:goals.avg_ticket, goalDisplay:fmt$(goals.avg_ticket), pct:atPct,
          tone: atPct >= 100 ? 'good' : atPct >= 75 ? 'warn' : 'bad', inverted:false });
        // Callback rate (INVERTED - lower = better; pct shown as headroom)
        const cbVal = t.callback_rate_pct || 0;
        // Headroom: 100% if 0 callbacks, 0% if at/over goal cap.
        const cbPct = goals.callback_rate > 0 ? Math.max(0, 100 - (cbVal / goals.callback_rate) * 100) : 100;
        out.push({ key:'callbacks', label:'Callbacks', value:cbVal, valDisplay:fmtP(cbVal) + ' rate',
          goal:goals.callback_rate, goalDisplay:'≤' + goals.callback_rate + '%', pct:cbPct,
          tone: cbVal <= goals.callback_rate ? 'good' : cbVal <= goals.callback_rate * 1.5 ? 'warn' : 'bad', inverted:true });
        // Review rate (per 100 jobs)
        const rrVal = t.review_rate_pct || 0;
        const rrPct = goals.review_rate > 0 ? (rrVal / goals.review_rate) * 100 : 0;
        out.push({ key:'reviews', label:'Reviews', value:rrVal, valDisplay:(t.reviews_generated || 0) + ' (' + fmtP(rrVal) + ')',
          goal:goals.review_rate, goalDisplay:goals.review_rate + ' / 100 jobs', pct:rrPct,
          tone: rrPct >= 90 ? 'good' : rrPct >= 50 ? 'warn' : 'bad', inverted:false });
        return out;
      }

      function barRow(p) {
        const fillPct = Math.max(2, Math.min(100, p.pct));
        const toneClass = 'is-' + p.tone;
        return `<div class="goal-row">
          <div class="flex justify-between items-baseline gap-2 text-xs mb-1">
            <span class="font-semibold text-navy-700">${p.label}</span>
            <span class="num text-slate-700">${p.valDisplay}</span>
          </div>
          <div class="goal-bar ${toneClass}"><span class="goal-fill" style="width:${fillPct.toFixed(0)}%"></span></div>
          <div class="flex justify-between text-[10px] text-slate-500 mt-1">
            <span>${p.pct >= 100 ? '✓ ' : ''}${Math.round(p.pct)}% of goal</span>
            <span>Goal ${p.goalDisplay}</span>
          </div>
        </div>`;
      }

      // Shop rollup - average each metric across field techs, total revenue.
      const shopMetrics = {
        revenue: techs.reduce((s, t) => s + (t.revenue || 0), 0),
        close_rate: avg(techs.map(t => t.close_rate_pct)),
        avg_ticket: avg(techs.map(t => t.avg_ticket)),
        callback_rate: avg(techs.map(t => t.callback_rate_pct)),
        review_rate: avg(techs.map(t => t.review_rate_pct || 0)),
      };
      const shopGoalRev = revGoalForWindow * techs.length;
      const shopProgress = [
        { key:'revenue', label:'Total revenue', valDisplay:fmt$(shopMetrics.revenue), goalDisplay:fmt$(shopGoalRev),
          pct: shopGoalRev > 0 ? (shopMetrics.revenue / shopGoalRev) * 100 : 0,
          tone: shopMetrics.revenue >= shopGoalRev ? 'good' : shopMetrics.revenue >= shopGoalRev * 0.7 ? 'warn' : 'bad' },
        // NOTE: these are mean-of-per-tech-means (each tech weighted equally),
        // NOT revenue-weighted. That's intentional - the goal is "every tech
        // hits $400 ticket / 55% close", so a high-ticket tech shouldn't mask
        // low-ticket teammates. But this differs from the KPI tile up top
        // (which IS revenue-weighted), so the labels say "(per tech)" to make
        // the math explicit. If Tim asks "why is shop avg ticket $259 here but
        // $551 up top?", point at the label.
        { key:'close', label:'Close rate (per tech)', valDisplay:fmtP(shopMetrics.close_rate), goalDisplay:goals.close_rate + '%',
          pct: goals.close_rate > 0 ? (shopMetrics.close_rate / goals.close_rate) * 100 : 0,
          tone: shopMetrics.close_rate >= goals.close_rate ? 'good' : shopMetrics.close_rate >= goals.close_rate * 0.8 ? 'warn' : 'bad' },
        { key:'ticket', label:'Avg ticket (per tech)', valDisplay:fmt$(shopMetrics.avg_ticket), goalDisplay:fmt$(goals.avg_ticket),
          pct: goals.avg_ticket > 0 ? (shopMetrics.avg_ticket / goals.avg_ticket) * 100 : 0,
          tone: shopMetrics.avg_ticket >= goals.avg_ticket ? 'good' : shopMetrics.avg_ticket >= goals.avg_ticket * 0.75 ? 'warn' : 'bad' },
        { key:'callbacks', label:'Callback rate', valDisplay:fmtP(shopMetrics.callback_rate), goalDisplay:'≤' + goals.callback_rate + '%',
          pct: goals.callback_rate > 0 ? Math.max(0, 100 - (shopMetrics.callback_rate / goals.callback_rate) * 100) : 100,
          tone: shopMetrics.callback_rate <= goals.callback_rate ? 'good' : shopMetrics.callback_rate <= goals.callback_rate * 1.5 ? 'warn' : 'bad' },
        { key:'reviews', label:'Reviews / 100 jobs', valDisplay:fmtP(shopMetrics.review_rate), goalDisplay:goals.review_rate + ' / 100',
          pct: goals.review_rate > 0 ? (shopMetrics.review_rate / goals.review_rate) * 100 : 0,
          tone: shopMetrics.review_rate >= goals.review_rate ? 'good' : shopMetrics.review_rate >= goals.review_rate * 0.5 ? 'warn' : 'bad' },
      ];
      wrapShop.innerHTML = `<div class="goal-card goal-card-shop fade-up" style="--i:0">
        <div class="flex items-center justify-between mb-2 gap-2 flex-wrap">
          <div class="flex items-center gap-2">
            <span class="section-icon bg-accent-500 text-white w-7 h-7 text-sm">🏆</span>
            <div>
              <div class="font-bold text-navy-700">Shop rollup · ${techs.length} field techs</div>
              <div class="text-[11px] text-slate-500">Total + averages across the team this window</div>
            </div>
          </div>
          <div class="text-xs text-slate-600">
            <span class="num font-semibold">${shopProgress.filter(p => p.tone === 'good').length}</span>/${shopProgress.length} goals on track
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-5 gap-3">
          ${shopProgress.map(p => `
            <div>
              <div class="text-[10px] uppercase tracking-wide text-slate-500 font-bold">${p.label}</div>
              <div class="num font-bold text-base text-navy-700 mt-0.5">${p.valDisplay}</div>
              <div class="goal-bar is-${p.tone} mt-1"><span class="goal-fill" style="width:${Math.max(2, Math.min(100, p.pct)).toFixed(0)}%"></span></div>
              <div class="text-[10px] text-slate-500 mt-1">Goal ${p.goalDisplay} · ${Math.round(p.pct)}%</div>
            </div>`).join('')}
        </div>
      </div>`;

      // Per-tech cards - sorted by overall goal-progress score (avg pct across goals).
      const scored = techs.map(t => {
        const ps = progressFor(t);
        const avgPct = ps.reduce((s, p) => s + p.pct, 0) / ps.length;
        return { t, ps, avgPct };
      }).sort((a, b) => b.avgPct - a.avgPct);

      wrapTech.innerHTML = scored.map((s, i) => {
        const onTrack = s.ps.filter(p => p.tone === 'good').length;
        const dotColor = s.avgPct >= 90 ? '#15803d' : s.avgPct >= 70 ? '#b45309' : '#b91c1c';
        return `<article class="goal-card hover-lift fade-up" style="--i:${i+1}; cursor:pointer" data-tech-id="${esc(s.t.tech_id)}">
          <div class="flex items-center justify-between gap-2 mb-2">
            <div class="flex items-center gap-2 min-w-0">
              <span style="display:inline-block;width:10px;height:10px;border-radius:999px;background:${dotColor}"></span>
              <div class="min-w-0">
                <div class="font-bold text-navy-700 truncate">${esc(s.t.tech_name)}</div>
                <div class="text-[10px] text-slate-500">${s.t.jobs} jobs · ${fmt$(s.t.revenue)} window revenue</div>
              </div>
            </div>
            <div class="text-right flex-shrink-0">
              <div class="num text-base font-bold" style="color:${dotColor}">${Math.round(s.avgPct)}%</div>
              <div class="text-[10px] text-slate-500">${onTrack}/${s.ps.length} on track</div>
            </div>
          </div>
          ${s.ps.map(barRow).join('')}
        </article>`;
      }).join('');

      // Wire click → tech detail
      wrapTech.querySelectorAll('article[data-tech-id]').forEach(a => {
        a.addEventListener('click', () => {
          const id = a.getAttribute('data-tech-id');
          location.href = `/admin/dashboard/tech/?id=${encodeURIComponent(id)}&days=${currentRange}`;
        });
      });

      // Top-right summary
      const topAvg = scored[0];
      const bottom = scored[scored.length - 1];
      summary.innerHTML = `<div>Leader: <strong>${esc(topAvg.t.tech_name)}</strong> (${Math.round(topAvg.avgPct)}%)</div>
        <div class="text-slate-400">Most upside: <strong>${esc(bottom.t.tech_name)}</strong> (${Math.round(bottom.avgPct)}%)</div>`;
    }
    function avg(arr) {
      const filtered = arr.filter(v => typeof v === 'number' && !isNaN(v));
      if (!filtered.length) return 0;
      return filtered.reduce((s, v) => s + v, 0) / filtered.length;
    }

    function renderSegments(dormant, renew, vip) {
      // HCP customers without a real display_name fall back to phone in the API.
      // Showing "6263250860" as both the name AND contact looks broken to Tim
      // (who is reading it as "we don't know who this person is"). Detect raw
      // phone-shaped names and substitute a placeholder; the phone is still
