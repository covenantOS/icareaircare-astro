---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---
<AdminLayout title="Tech detail">
  <style is:global>
    /* Print / PDF — 1-page tech scorecard (Tim asked 2026-05-21).
       Hide nav/controls, tighten spacing, force light bg, avoid card breaks. */
    @media print {
      .no-print { display: none !important; }
      body { background: #fff !important; }
      .admin-shell > footer { display: none !important; }
      main { padding: 0 !important; }
      main.container-site, .container-site { max-width: 100% !important; padding: 0 !important; }
      .card, .card-quiet { box-shadow: none !important; border: 1px solid #ccc !important; break-inside: avoid; page-break-inside: avoid; margin-bottom: 8px !important; }
      section { break-inside: avoid; }
      .stat-value { font-size: 1.6rem !important; }
      /* Expand any collapsed AI sections / skeletons so the print is complete */
      .skeleton { display: none !important; }
      @page { margin: 0.5in; size: letter portrait; }
      /* Print header band */
      #th-print-header { display: block !important; }
    }
    #th-print-header { display: none; }
  </style>
  <div id="login-gate" hidden>
    <div class="card login-card">
      <h2 class="text-xl font-bold mb-1">Sign in</h2>
      <p class="text-sm text-slate-600 mb-5">Enter your PIN to continue.</p>
      <form id="login-form" class="space-y-3">
        <input id="login-key" type="password" inputmode="numeric" placeholder="PIN" autocomplete="current-password" required />
        <button type="submit" class="btn-admin w-full justify-center">Continue</button>
      </form>
      <p id="login-error" class="text-red-600 text-sm mt-3" hidden></p>
    </div>
  </div>

  <div id="dashboard" hidden>
    <header class="bg-white border-b border-line">
      <div class="container-site py-3 sm:py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
          <a href="/admin/dashboard/" class="text-sm text-brand-700 hover:underline">← All techs</a>
          <h1 id="th-name" class="text-xl sm:text-2xl font-bold text-navy-700">Tech detail</h1>
          <div id="th-role" class="text-xs text-slate-500 mt-1"></div>
        </div>
        <div class="flex items-center gap-2 flex-wrap no-print">
          <select id="th-window" class="tab" aria-label="Window">
            <option value="7">Last 7 days</option>
            <option value="30" selected>Last 30 days</option>
            <option value="90">Last 90 days</option>
            <option value="365">Last 365 days</option>
            <option value="this_month">This month</option>
            <option value="last_month">Last month</option>
            <option value="custom">Custom range…</option>
          </select>
          <button id="th-print" class="btn-ghost-admin text-xs py-1.5 px-2.5" type="button" title="Print or save this scorecard as a 1-page PDF">🖨 Print / PDF</button>
        </div>
      </div>
      <!-- Custom range popover -->
      <div id="th-custom-range" class="hidden container-site pb-3 no-print">
        <div class="card flex items-end gap-3 flex-wrap" style="max-width:520px">
          <label class="text-xs font-semibold flex-1 min-w-[130px]">From<input id="th-cr-from" type="date" class="w-full mt-1 px-3 py-2 border border-line rounded text-sm" /></label>
          <label class="text-xs font-semibold flex-1 min-w-[130px]">To<input id="th-cr-to" type="date" class="w-full mt-1 px-3 py-2 border border-line rounded text-sm" /></label>
          <button id="th-cr-apply" type="button" class="btn-admin text-sm">Apply</button>
        </div>
      </div>
    </header>

    <main class="container-site py-4 sm:py-6 space-y-5">
      <!-- Print-only header band -->
      <div id="th-print-header" style="margin-bottom:12px; border-bottom:2px solid #1a2e45; padding-bottom:6px">
        <div style="font-size:1.25rem; font-weight:700; color:#1a2e45">I Care Air Care — Tech Scorecard</div>
        <div style="font-size:0.8rem; color:#555"><span id="th-print-name">—</span> · <span id="th-print-window">—</span> · printed <span id="th-print-date">—</span></div>
      </div>
      <section class="card">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <div class="stat-label">Performance Score</div>
            <div class="flex items-baseline gap-3">
              <div id="th-score" class="stat-value">—</div>
              <div id="th-grade" class="text-3xl font-bold">—</div>
            </div>
            <div id="th-grade-sub" class="stat-sub">Formula A</div>
          </div>
          <div id="th-score-bars" class="grid grid-cols-2 sm:grid-cols-4 gap-3 flex-1 min-w-0"></div>
        </div>
      </section>

      <section class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
        <article class="card">
          <div class="stat-label">Jobs</div>
          <div id="th-jobs" class="stat-value">—</div>
          <div id="th-jobs-sub" class="stat-sub"></div>
        </article>
        <article class="card">
          <div class="stat-label">Close rate</div>
          <div id="th-close" class="stat-value">—</div>
          <div id="th-close-sub" class="stat-sub"></div>
        </article>
        <article class="card">
          <div class="stat-label">Avg ticket</div>
          <div id="th-ticket" class="stat-value">—</div>
          <div id="th-ticket-sub" class="stat-sub"></div>
        </article>
        <article class="card">
          <div class="stat-label">Revenue</div>
          <div id="th-revenue" class="stat-value">—</div>
          <div id="th-revenue-sub" class="stat-sub"></div>
        </article>
      </section>

      <section class="card">
        <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
          <h2 class="text-lg font-bold text-navy-700">12-week trend</h2>
          <span class="text-xs text-slate-500">Revenue &amp; close rate</span>
        </div>
        <div id="th-trend" class="space-y-3">
          <div class="text-slate-400 text-sm py-4">Loading…</div>
        </div>
      </section>

      <section class="card overflow-x-auto">
        <h2 class="text-lg font-bold text-navy-700 mb-3">Top 5 jobs by ticket</h2>
        <table class="kpi-table">
          <thead><tr><th>Customer</th><th>Type</th><th class="hidden sm:table-cell">Completed</th><th class="text-right">Ticket</th></tr></thead>
          <tbody id="th-top-rows"><tr><td colspan="4" class="text-slate-400 text-sm py-4">—</td></tr></tbody>
        </table>
      </section>

      <section class="card">
        <h2 class="text-lg font-bold text-navy-700 mb-3">Vs. shop average</h2>
        <div id="th-peer" class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm"></div>
      </section>

      <!-- AI COACHING — per-tech briefing -->
      <section id="th-ai" class="card relative overflow-hidden" style="background:linear-gradient(135deg, #fff 0%, #f0f7fa 100%);">
        <div class="absolute top-0 right-0 w-32 h-32 -mt-8 -mr-8 rounded-full pulse-soft" style="background:radial-gradient(circle, rgba(232,138,56,0.14), transparent 70%)"></div>
        <div class="flex items-start justify-between gap-3 relative">
          <div class="flex items-center gap-3 min-w-0">
            <span class="section-icon bg-accent-500 text-white text-sm font-bold flex-shrink-0">AI</span>
            <div class="min-w-0">
              <h2 class="text-lg font-bold text-navy-700">Coaching briefing</h2>
              <div id="th-ai-headline" class="text-sm text-slate-700 mt-0.5">—</div>
            </div>
          </div>
          <button id="th-ai-refresh" class="btn-ghost-admin text-xs py-1 px-2" type="button" aria-label="Refresh">↻</button>
        </div>

        <div id="th-ai-loading" class="mt-3">
          <div class="skeleton h-4 w-3/4 mb-2"></div>
          <div class="skeleton h-4 w-full mb-2"></div>
          <div class="skeleton h-4 w-5/6"></div>
        </div>

        <div id="th-ai-body" hidden class="mt-4 space-y-4 relative">
          <div id="th-ai-score-reading" class="text-sm text-navy-700 italic"></div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <div>
              <h3 class="text-xs font-bold uppercase tracking-wide text-emerald-700 mb-2">✓ Strengths</h3>
              <ul id="th-ai-strengths" class="space-y-2 text-sm"></ul>
            </div>
            <div>
              <h3 class="text-xs font-bold uppercase tracking-wide text-amber-700 mb-2">⚠ Concerns</h3>
              <ul id="th-ai-concerns" class="space-y-2 text-sm"></ul>
            </div>
          </div>

          <div id="th-ai-reviews-wrap" hidden>
            <h3 class="text-xs font-bold uppercase tracking-wide text-brand-800 mb-2">⭐ What customers are saying about this tech</h3>
            <ul id="th-ai-reviews" class="space-y-2 text-sm"></ul>
          </div>

          <div>
            <h3 class="text-xs font-bold uppercase tracking-wide text-navy-700 mb-2">▶ Coaching actions for Tim</h3>
            <ol id="th-ai-actions" class="space-y-2"></ol>
          </div>

          <div>
            <h3 class="text-xs font-bold uppercase tracking-wide text-slate-600 mb-2">Vs. shop peers</h3>
            <div id="th-ai-compare" class="grid grid-cols-1 sm:grid-cols-2 gap-2"></div>
          </div>
        </div>

        <div id="th-ai-error" hidden class="mt-3 text-sm text-amber-700"></div>
      </section>

      <!-- (Quick rule-based prompts removed 2026-05-15 per Will — too crude
           alongside the AI briefing; the briefing covers the same ground better.) -->
    </main>
  </div>

  <div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50" hidden>
    <div id="toast-body" class="bg-navy-700 text-white text-sm px-4 py-2 rounded-lg shadow-soft"></div>
  </div>

  <script is:inline>
    const STORAGE_KEY = 'icac_admin_key';
    const techId = new URL(location.href).searchParams.get('id') || '';
    // If the URL passes ?days= (set by the leaderboard click), use it as the
    // initial window value so the score on this page matches what the user
    // saw on the dashboard when they clicked the row.
    const urlDays = new URL(location.href).searchParams.get('days');
    if (urlDays) {
      const sel = document.getElementById('th-window');
      if (sel && [...sel.options].some(o => o.value === urlDays)) sel.value = urlDays;
    }
    // Also persist URL ?key= → sessionStorage on first visit.
    const urlKey = new URL(location.href).searchParams.get('key');
    if (urlKey) sessionStorage.setItem(STORAGE_KEY, urlKey);

    function getKey() { return sessionStorage.getItem(STORAGE_KEY) || ''; }
    function setKey(k) { sessionStorage.setItem(STORAGE_KEY, k); }
    function clearKey() { sessionStorage.removeItem(STORAGE_KEY); }
    function withAuth(url) { const k = getKey(); if (!k) return url; const u = new URL(url, location.origin); u.searchParams.set('key', k); return u.toString(); }
    async function api(path, init) {
      const res = await fetch(withAuth(path), { credentials: 'include', ...init });
      if (res.status === 401) { clearKey(); show('login'); throw new Error('Auth required'); }
      if (!res.ok) throw new Error(`API ${path} ${res.status}`);
      return res.json();
    }
    function show(which) {
      document.getElementById('login-gate').hidden = which !== 'login';
      document.getElementById('dashboard').hidden = which !== 'dash';
    }
    function fmt$(n) { if (n == null || isNaN(n)) return '—'; return '$' + Number(n).toLocaleString('en-US', { maximumFractionDigits: 0 }); }
    function fmtP(n) { if (n == null || isNaN(n)) return '—'; return Number(n).toFixed(1) + '%'; }
    function esc(s) { return String(s ?? '').replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c])); }
    function toast(msg, kind) { const t=document.getElementById('toast'),b=document.getElementById('toast-body'); b.textContent=msg; b.className='text-sm px-4 py-2 rounded-lg shadow-soft '+(kind==='error'?'bg-red-600 text-white':'bg-navy-700 text-white'); t.hidden=false; setTimeout(()=>t.hidden=true,3500); }

    function bench(metric, value) {
      const B = {
        revenue_per_tech_per_day: { p:1200, a:2000, t:2400, dir:'up' },
        avg_ticket: { p:250, a:450, t:600, dir:'up' },
        callback_rate: { p:5, a:3, t:2, dir:'down' },
      };
      const b = B[metric]; if (!b || value == null) return null;
      const tier = b.dir === 'up'
        ? (value >= b.t ? 'top' : value >= b.a ? 'avg' : 'poor')
        : (value <= b.t ? 'top' : value <= b.a ? 'avg' : 'poor');
      const color = { top:'#15803d', avg:'#b45309', poor:'#b91c1c' }[tier];
      const label = { top:'Top quartile', avg:'Industry avg', poor:'Below avg' }[tier];
      return { color, label };
    }
    function dot(metric, value) {
      const b = bench(metric, value); if (!b) return '';
      return `<span style="display:inline-flex;align-items:center;gap:4px;font-weight:600;color:${b.color}"><span style="width:7px;height:7px;border-radius:999px;background:${b.color}"></span>${b.label}</span>`;
    }
    function spark(values, opts = {}) {
      if (!values || values.length === 0) return '';
      const w = opts.w || 320, h = opts.h || 56;
      const max = Math.max(1, ...values);
      const min = Math.min(0, ...values);
      const range = max - min || 1;
      const stepX = w / Math.max(1, values.length - 1);
      const pts = values.map((v, i) => `${(i * stepX).toFixed(1)},${(h - ((v - min) / range) * h).toFixed(1)}`);
      return `<svg viewBox="0 0 ${w} ${h}" width="100%" height="${h}" preserveAspectRatio="none">
        <polyline fill="${opts.fill || 'rgba(93,165,184,0.12)'}" stroke="none" points="0,${h} ${pts.join(' ')} ${w},${h}" />
        <polyline fill="none" stroke="${opts.stroke || '#5da5b8'}" stroke-width="2" points="${pts.join(' ')}" />
      </svg>`;
    }
    const gradeColor = g => ({ A:'#15803d', B:'#10b981', C:'#b45309', D:'#dc2626', F:'#991b1b' }[g] || '#64748b');

    async function loadAICoaching(days, forceRefresh) {
      const loading = document.getElementById('th-ai-loading');
      const body = document.getElementById('th-ai-body');
      const errBox = document.getElementById('th-ai-error');
      loading.hidden = false; body.hidden = true; errBox.hidden = true;
      try {
        const url = `/api/ai/tech-coaching?id=${encodeURIComponent(techId)}&days=${days}${forceRefresh ? '&refresh=1' : ''}`;
        const r = await api(url);
        loading.hidden = true;
        const b = r.briefing;
        if (!b) { errBox.hidden = false; errBox.textContent = 'AI returned no briefing.'; return; }

        document.getElementById('th-ai-headline').textContent = b.headline || '';
        document.getElementById('th-ai-score-reading').textContent = b.score_reading || '';

        const renderItem = (it, kind) => {
          const sev = it.severity ? `<span class="chip ${it.severity === 'high' ? 'chip-bad' : it.severity === 'med' ? 'chip-warn' : 'chip-info'}">${esc(it.severity)}</span>` : '';
          return `<li class="card-quiet ${kind === 'good' ? 'tone-good' : 'tone-warn'}">
            <div class="font-semibold text-navy-700 text-sm">${esc(it.title || '')} ${sev}</div>
            <div class="text-slate-700 text-[13px] mt-1">${esc(it.detail || '')}</div>
            ${it.evidence ? `<div class="text-[11px] text-slate-500 mt-1 italic">${esc(it.evidence)}</div>` : ''}
          </li>`;
        };
        document.getElementById('th-ai-strengths').innerHTML =
          (b.strengths || []).map(it => renderItem(it, 'good')).join('') || '<li class="text-slate-400 italic">No strengths called out.</li>';
        document.getElementById('th-ai-concerns').innerHTML =
          (b.concerns || []).map(it => renderItem(it, 'warn')).join('') || '<li class="text-slate-400 italic">No concerns flagged 🎉</li>';

        // Review signals
        const rs = b.review_signals || [];
        document.getElementById('th-ai-reviews-wrap').hidden = rs.length === 0;
        document.getElementById('th-ai-reviews').innerHTML = rs.map(r => {
          const tone = r.tone === 'good' ? 'tone-good' : r.tone === 'warn' ? 'tone-warn' : 'tone-neutral';
          return `<li class="card-quiet ${tone}">
            <div class="font-semibold text-navy-700 text-sm">${esc(r.reviewer || 'Anonymous')}</div>
            <div class="text-slate-700 text-[13px] mt-1">${esc(r.takeaway || '')}</div>
          </li>`;
        }).join('');

        // Actions
        document.getElementById('th-ai-actions').innerHTML =
          (b.coaching_actions || []).sort((a, x) => (a.priority || 99) - (x.priority || 99)).map((a, i) => `
            <li class="flex gap-3 hover-lift card-quiet">
              <span class="section-icon bg-accent-500 text-white text-sm font-bold flex-shrink-0">${a.priority || (i + 1)}</span>
              <div class="min-w-0 flex-1">
                <div class="font-semibold text-navy-700">${esc(a.title || '')}</div>
                <div class="text-slate-700 text-[13px] mt-0.5">${esc(a.detail || '')}</div>
                ${a.value_estimate ? `<div class="mt-1"><span class="chip chip-good">${esc(a.value_estimate)}</span></div>` : ''}
              </div>
            </li>`).join('') || '<li class="text-slate-400 italic">No actions this week.</li>';

        // Compare to peers
        document.getElementById('th-ai-compare').innerHTML =
          (b.compare_to_peers || []).map(c => {
            const tone = c.tone === 'good' ? 'tone-good' : c.tone === 'warn' ? 'tone-warn' : 'tone-neutral';
            return `<div class="card-quiet ${tone}">
              <div class="text-[10px] font-bold uppercase tracking-wide text-slate-600">${esc(c.metric || '')}</div>
              <div class="flex items-baseline gap-2 mt-1">
                <span class="text-base font-bold text-navy-700">${esc(c.tech_value || '')}</span>
                <span class="text-xs text-slate-500">vs peer ${esc(c.peer_median || '—')}</span>
              </div>
              ${c.gap ? `<div class="text-[11px] mt-1">${esc(c.gap)}</div>` : ''}
            </div>`;
          }).join('') || '<div class="text-slate-400 text-sm italic">No comparison data.</div>';

        body.hidden = false;
      } catch (e) {
        loading.hidden = true;
        errBox.hidden = false;
        errBox.textContent = 'AI coaching unavailable: ' + (e.message || '');
      }
    }

    // Resolve the window selector to either a rolling `days` value or an
    // explicit from/to range (presets + custom). Returns a query-string
    // fragment + a human label.
    function resolveWindow() {
      const sel = document.getElementById('th-window').value;
      const ymd = d => `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
      const now = new Date();
      if (sel === 'this_month') {
        const first = new Date(now.getFullYear(), now.getMonth(), 1);
        return { qs: `from=${first.toISOString()}&to=${now.toISOString()}`, label: `${first.toLocaleString('en-US',{month:'long'})} (month-to-date)`, days: Math.max(1, Math.round((now-first)/86400000)) };
      }
      if (sel === 'last_month') {
        const firstThis = new Date(now.getFullYear(), now.getMonth(), 1);
        const lastPrev = new Date(firstThis.getTime() - 1);
        const firstPrev = new Date(lastPrev.getFullYear(), lastPrev.getMonth(), 1);
        return { qs: `from=${firstPrev.toISOString()}&to=${lastPrev.toISOString()}`, label: `${firstPrev.toLocaleString('en-US',{month:'long'})} ${firstPrev.getFullYear()}`, days: Math.max(1, Math.round((lastPrev-firstPrev)/86400000)) };
      }
      if (sel === 'custom') {
        const f = document.getElementById('th-cr-from').value, t = document.getElementById('th-cr-to').value;
        if (f && t) {
          const fd = new Date(f + 'T00:00:00'), td = new Date(t + 'T23:59:59');
          return { qs: `from=${fd.toISOString()}&to=${td.toISOString()}`, label: `${f} → ${t}`, days: Math.max(1, Math.round((td-fd)/86400000)) };
        }
        return { qs: `days=30`, label: '30 day window', days: 30 };
      }
      const days = parseInt(sel, 10) || 30;
      return { qs: `days=${days}`, label: `${days} day window`, days };
    }

    async function load() {
      if (!techId) { toast('Missing ?id=', 'error'); return; }
      const win = resolveWindow();
      const days = win.days;
      try {
        const data = await api(`/api/kpis/tech-detail?id=${encodeURIComponent(techId)}&${win.qs}`);
        const s = data.summary, sc = data.score, peer = data.peer_comparison;

        document.getElementById('th-name').textContent = s.tech_name;
        document.getElementById('th-role').textContent = s.role || '';
        // Print header fields
        document.getElementById('th-print-name').textContent = s.tech_name;
        document.getElementById('th-print-window').textContent = win.label;
        document.getElementById('th-print-date').textContent = new Date().toLocaleDateString();
        document.getElementById('th-score').textContent = sc.total.toFixed(1);
        document.getElementById('th-grade').textContent = sc.grade;
        document.getElementById('th-grade').style.color = gradeColor(sc.grade);
        document.getElementById('th-grade-sub').textContent = `Formula A · ${win.label}`;

        const labels = { revenue_per_day:'Rev/day', avg_ticket:'Ticket', close_rate:'Close', membership_conversion:'Members', callback_rate_inverted:'Callbacks', review_rate:'Reviews', utilization:'Utilization', volume:'Volume' };
        document.getElementById('th-score-bars').innerHTML = Object.entries(sc.components).map(([k, v]) => `
          <div>
            <div class="text-xs text-slate-600 flex justify-between"><span>${labels[k] || k}</span><span class="font-semibold text-navy-700">${v.normalized.toFixed(0)}</span></div>
            <div class="progress mt-1"><span style="width:${Math.max(2, v.normalized).toFixed(0)}%; background:${gradeColor(sc.grade)}"></span></div>
          </div>`).join('');

        document.getElementById('th-jobs').textContent = s.jobs;
        document.getElementById('th-jobs-sub').textContent = `${s.tune_ups} TU · ${s.diagnostics} Dx · ${s.estimates} Est · ${s.jobs_per_day}/day`;
        document.getElementById('th-close').textContent = fmtP(s.close_rate_pct);
        document.getElementById('th-close-sub').textContent = `${s.closed_jobs} sold of ${s.jobs}`;
        document.getElementById('th-ticket').textContent = fmt$(s.avg_ticket);
        document.getElementById('th-ticket-sub').innerHTML = dot('avg_ticket', s.avg_ticket);
        document.getElementById('th-revenue').textContent = fmt$(s.revenue);
        document.getElementById('th-revenue-sub').innerHTML = `${fmt$(s.revenue_per_day)}/day · ${dot('revenue_per_tech_per_day', s.revenue_per_day)}`;

        const t = data.trend;
        const revVals = t.map(p => p.revenue);
        const closeVals = t.map(p => p.close_rate_pct);
        document.getElementById('th-trend').innerHTML = `
          <div>
            <div class="flex justify-between text-xs text-slate-500 mb-1"><span>Revenue per week</span><span>Latest ${fmt$(revVals[revVals.length-1])} · max ${fmt$(Math.max(...revVals))}</span></div>
            ${spark(revVals, { stroke:'#e88a38', fill:'rgba(232,138,56,0.10)' })}
          </div>
          <div>
            <div class="flex justify-between text-xs text-slate-500 mb-1"><span>Close rate per week</span><span>${(closeVals[closeVals.length-1] || 0).toFixed(1)}% latest</span></div>
            ${spark(closeVals, { stroke:'#5da5b8' })}
          </div>`;

        const tj = data.top_jobs || [];
        document.getElementById('th-top-rows').innerHTML = tj.length
          ? tj.map(j => `<tr><td><strong>${esc(j.customer_name || 'Unknown customer')}</strong><div class="font-mono text-[10px] text-slate-400">${esc(j.job_id.slice(-8))}</div></td><td>${esc(j.job_type)}</td><td class="hidden sm:table-cell text-xs text-slate-500">${j.completed_at ? new Date(j.completed_at).toLocaleDateString() : '—'}</td><td class="text-right num"><strong>${fmt$(j.ticket)}</strong></td></tr>`).join('')
          : `<tr><td colspan="4" class="text-slate-400 text-sm py-4">No invoiced jobs in window.</td></tr>`;

        const cmp = (a, b) => a > b ? 'text-emerald-700' : a < b ? 'text-amber-700' : 'text-slate-600';
        document.getElementById('th-peer').innerHTML = `
          <div><div class="stat-label">Revenue</div><div class="flex items-baseline gap-2"><div class="text-xl font-bold ${cmp(s.revenue, peer.shop_avg_revenue)}">${fmt$(s.revenue)}</div><div class="text-sm text-slate-500">vs ${fmt$(peer.shop_avg_revenue)}</div></div></div>
          <div><div class="stat-label">Close rate</div><div class="flex items-baseline gap-2"><div class="text-xl font-bold ${cmp(s.close_rate_pct, peer.shop_avg_close_rate_pct)}">${fmtP(s.close_rate_pct)}</div><div class="text-sm text-slate-500">vs ${fmtP(peer.shop_avg_close_rate_pct)}</div></div></div>
          <div><div class="stat-label">Avg ticket</div><div class="flex items-baseline gap-2"><div class="text-xl font-bold ${cmp(s.avg_ticket, peer.shop_avg_ticket)}">${fmt$(s.avg_ticket)}</div><div class="text-sm text-slate-500">vs ${fmt$(peer.shop_avg_ticket)}</div></div></div>`;

        // Rule-based prompts removed — AI panel handles all coaching guidance.
        loadAICoaching(days, false);
      } catch (e) { toast(e.message || 'Load failed', 'error'); }
    }

    document.getElementById('th-window').addEventListener('change', () => {
      const isCustom = document.getElementById('th-window').value === 'custom';
      document.getElementById('th-custom-range').classList.toggle('hidden', !isCustom);
      if (!isCustom) load();   // presets/rolling apply immediately; custom waits for Apply
    });
    document.getElementById('th-cr-apply').addEventListener('click', load);
    document.getElementById('th-ai-refresh').addEventListener('click', () => {
      loadAICoaching(resolveWindow().days, true);
    });
    // Print / PDF — browser's native print dialog with a print stylesheet.
    document.getElementById('th-print').addEventListener('click', () => window.print());
    document.getElementById('login-form').addEventListener('submit', async (ev) => {
      ev.preventDefault();
      const k = document.getElementById('login-key').value.trim();
      if (!k) return; setKey(k);
      try { await api('/api/kpis/summary'); show('dash'); await load(); }
      catch { document.getElementById('login-error').hidden = false; document.getElementById('login-error').textContent = 'Wrong PIN.'; clearKey(); }
    });
    (async () => {
      if (getKey()) {
        try { await api('/api/kpis/summary'); show('dash'); await load(); return; } catch {}
      }
      try {
        const r = await fetch('/api/kpis/summary', { credentials: 'include' });
        if (r.ok) { show('dash'); await load(); return; }
      } catch {}
      show('login');
    })();
  </script>
</AdminLayout>
