---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ReviewStrip from '../components/ReviewStrip.astro';
import FinalCTA from '../components/FinalCTA.astro';
import ContactFormSection from '../components/ContactFormSection.astro';
import { SITE } from '../lib/site';
---
<BaseLayout
  title="Reviews | I Care Air Care Wesley Chapel HVAC 4.9★"
  description="Read 700+ five-star Google reviews from Wesley Chapel, Tampa, Land O' Lakes & Pasco County homeowners who trust I Care Air Care for AC repair and HVAC service."
  breadcrumbs={[{name:'Home',url:'https://www.icareaircare.com/'},{name:'Reviews',url:'https://www.icareaircare.com/reviews/'}]}
>
  <Hero
    eyebrow={`${SITE.rating.value}★ &middot; ${SITE.rating.count}+ Reviews`}
    title="What Wesley Chapel Homeowners Say About Us"
    subtitle={`700+ five-star Google reviews and counting. See why Wesley Chapel, Tampa, Land O' Lakes and Pasco County homeowners choose I Care Air Care.`}
    image="/images/ICAC%20Team.webp"
    ctaLabel="Leave a Review"
    ctaHref={SITE.socials.google}
  />
  <ReviewStrip />
  <section class="py-16">
    <div class="container-site max-w-4xl text-center prose-icac">
      <h2>700+ five-star reviews</h2>
      <p>Our Google Business Profile is the best place to read current customer feedback from Wesley Chapel, Land O' Lakes, Tampa, and the surrounding service area. Review themes are consistent: clear communication, practical repair advice, clean work, and written pricing before work begins.</p>
    </div>

    <!-- Read + leave a review on Google or Yelp -->
    <div class="container-site max-w-3xl mt-8 not-prose">
      <div class="grid sm:grid-cols-2 gap-4">
        <a
          href={SITE.socials.google}
          target="_blank"
          rel="noopener"
          class="group rounded-2xl bg-white ring-1 ring-slate-200 hover:ring-brand-300 hover:shadow-[var(--shadow-card)] p-6 flex flex-col items-center text-center transition"
          aria-label="Read or write a Google review"
        >
          <div class="flex items-center gap-2">
            <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="#4285F4" d="M21.35 11.1h-9.17v2.73h6.51c-.33 3.81-3.5 5.44-6.5 5.44C8.36 19.27 5 16.25 5 12c0-4.1 3.2-7.27 7.2-7.27 3.09 0 4.9 1.97 4.9 1.97L19 4.72S16.56 2 12.1 2C6.42 2 2.03 6.8 2.03 12c0 5.05 4.13 10 10.22 10 5.35 0 9.25-3.67 9.25-9.09 0-1.15-.15-1.81-.15-1.81z"/>
            </svg>
            <span class="text-accent-500 text-lg leading-none">★★★★★</span>
          </div>
          <div class="mt-3 font-bold text-navy-700 text-lg">Read &amp; review on Google</div>
          <div class="mt-1 text-sm text-slate-600">{SITE.rating.value} stars · {SITE.rating.count}+ Google reviews. Click "Write a review" once the page loads.</div>
          <span class="mt-4 text-sm font-semibold text-brand-700 group-hover:text-brand-800">Open Google Business Profile →</span>
        </a>
        <a
          href={SITE.socials.yelp}
          target="_blank"
          rel="noopener"
          class="group rounded-2xl bg-white ring-1 ring-slate-200 hover:ring-red-300 hover:shadow-[var(--shadow-card)] p-6 flex flex-col items-center text-center transition"
          aria-label="Read or write a Yelp review"
        >
          <div class="flex items-center gap-2">
            <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="#D32323" d="M20.16 12.594l-1.49.234c-.93.146-1.91.292-2.4.36-1.32.18-2.04-1.36-1.27-2.43.29-.41.65-.78 1.02-1.16l1.51-1.55c.31-.32.62-.65.93-.97.21-.22.39-.5.31-.83-.07-.31-.34-.5-.6-.66-1.46-.86-3.2-1.36-4.88-1.42-.34-.01-.7.05-.93.31-.16.18-.23.43-.27.66l-.13.79-.32 1.99c-.09.59-.18 1.18-.27 1.77-.1.66-.17 1.31.55 1.71.55.31 1.27.16 1.77-.16l3.94-2.49c.45-.28.9-.57 1.36-.85.4-.25.85-.55.74-1.07-.07-.36-.42-.55-.74-.65zm-9.51-1.99c.7-.36.59-1.32.41-1.97-.6-2.12-1.83-3.96-3.43-5.4-.21-.18-.44-.39-.74-.4-.36-.01-.66.21-.92.45-.59.55-1.03 1.27-1.39 2-.42.86-.76 1.79-.82 2.76-.04.59.05 1.27.55 1.66.34.27.78.34 1.21.41 1.36.21 2.74.27 4.13.34.36.02.69.02 1-.05zm-1.07 7.36c-.13-.71-.83-1.18-1.46-1.41-.99-.36-2.08-.5-3.13-.42-.5.04-1.02.16-1.36.55-.34.41-.34 1-.27 1.5.16 1.16.65 2.27 1.39 3.21.27.34.62.69 1.07.69.39 0 .69-.27.95-.55l1.54-1.66c.31-.34.62-.69.85-1.07.21-.32.31-.59.43-.84zm.69 1.38l1.83-2.43c.4-.55 1.16-.99 1.84-.55.34.22.55.59.65.99.27.99.39 2 .27 3.02-.04.36-.13.74-.4 1-.27.27-.65.39-1.02.45-1.18.21-2.43.04-3.51-.42-.42-.18-.99-.5-.85-1.09.04-.18.16-.34.31-.5.31-.32.62-.65.88-.97zm6.54-3.15c-.36-.07-.69-.18-1.05-.27-.43-.13-.86-.27-1.27-.42-.4-.13-1.02-.39-1.39 0-.36.39-.18 1.02 0 1.46.27.69.69 1.32 1.16 1.91.27.34.59.69 1.02.83.45.16.97.07 1.36-.18.45-.27.78-.69 1.07-1.13.39-.59.69-1.27.65-2-.04-.13-.13-.21-.27-.27-.5-.18-.83.04-1.27.07z"/>
            </svg>
            <span class="text-red-600 text-lg leading-none">★★★★★</span>
          </div>
          <div class="mt-3 font-bold text-navy-700 text-lg">Read &amp; review on Yelp</div>
          <div class="mt-1 text-sm text-slate-600">Rate us on Yelp — Tampa Bay homeowners use Yelp to find local HVAC.</div>
          <span class="mt-4 text-sm font-semibold text-red-600 group-hover:text-red-700">Open Yelp listing →</span>
        </a>
      </div>
    </div>

    <div class="container-site max-w-2xl mt-10">
      <div class="rounded-2xl bg-brand-600 text-white p-8 text-center shadow-[var(--shadow-soft)]">
        <p class="text-xl font-bold">Ready to experience 5-star service yourself?</p>
        <p class="mt-2 text-blue-100 text-sm">Call or book online — same-day scheduling often available across Wesley Chapel & Tampa Bay.</p>
        <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center">
          <a href={SITE.phoneHref} class="inline-flex items-center justify-center gap-2 rounded-md bg-accent-500 hover:bg-accent-600 text-white font-bold px-6 py-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.21 11.36 11.36 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.57 3.58 1 1 0 01-.21 1.11l-2.2 2.1z"/></svg>
            {SITE.phone}
          </a>
          <a href={SITE.bookUrl} target="_blank" rel="noopener" class="inline-flex items-center justify-center rounded-md bg-white/15 border border-white/30 hover:bg-white/25 text-white font-semibold px-6 py-3">Book Online</a>
        </div>
      </div>
    </div>
  </section>
  <FinalCTA />
  <ContactFormSection />
</BaseLayout>
