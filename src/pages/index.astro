---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import AreaGrid from '../components/AreaGrid.astro';
import IntroBand from '../components/IntroBand.astro';
import BrandBand from '../components/BrandBand.astro';
import ThreeStep from '../components/ThreeStep.astro';
import ReviewStrip from '../components/ReviewStrip.astro';
import BlogStrip from '../components/BlogStrip.astro';
import FAQ from '../components/FAQ.astro';
import ContactFormSection from '../components/ContactFormSection.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Schema from '../components/Schema.astro';

const faqs = [
  { q: 'How do I schedule a consultation?', a: "You can book <strong>AC repair</strong> or any HVAC service online or call us directly. We confirm your appointment fast — same-day availability is often possible across Wesley Chapel, Land O' Lakes and Pasco County." },
  { q: 'How do I choose the best HVAC contractor in Wesley Chapel?', a: 'Look for a Florida-licensed contractor (ours is CAC1822037), 5-star Google reviews, upfront written estimates, and warranty-backed work. I Care Air Care hits all four with 700+ Wesley Chapel-area reviews and a 1-year repair warranty.' },
  { q: 'What areas do you serve?', a: "We're based in <strong>Wesley Chapel</strong> and serve New Tampa, Land O' Lakes, Lutz, Odessa, Zephyrhills, and all of Pasco, Hillsborough and Polk counties. <a class=\"underline\" href=\"/service-areas/\">See the full service-area map</a>." },
  { q: 'Do you offer emergency repair services in Wesley Chapel?', a: 'Yes — we prioritize <a class="underline" href="/services/emergency-ac-repair-tampa/">urgent AC repair</a> from our Wesley Chapel base when cooling is not working. Call for the earliest available appointment and a realistic ETA.' },
  { q: 'How quickly can you come out for service?', a: "Most Wesley Chapel, Land O' Lakes, and New Tampa service calls are handled same-day when route availability allows. Call (813) 395-2324 and we'll give you the earliest available arrival window." },
  { q: 'How much does HVAC repair cost in Wesley Chapel?', a: 'Typical AC repair runs $150–$600 depending on the part. Diagnostic visits are quoted upfront — no surprise fees. Complex issues like compressor replacement or refrigerant leaks are priced separately with written estimates.' },
  { q: 'Are you licensed and insured?', a: 'Yes. I Care Air Care is licensed (Florida CAC1822037), bonded and insured, with trained technicians in marked service vehicles.' },
  { q: 'When should I call an AC contractor for repair?', a: 'Call when you notice warm air, weak airflow, strange noises, water leaks, ice on the coil, or rising energy bills. Early diagnosis usually prevents a larger repair.' },
  { q: 'Do you provide financing or special offers?', a: 'We offer flexible financing through Synchrony for qualified Wesley Chapel homeowners — see our <a class="underline" href="/financing/">financing page</a> for current terms and monthly-payment estimates.' },
  { q: 'What is included in an AC tune-up in Wesley Chapel?', a: 'Our <a class="underline" href="/services/ac-maintenance-tampa/">21-point AC tune-up</a> includes coil cleaning, refrigerant check, electrical inspection, thermostat calibration, blower motor test, condensate drain flush, and a full written system report.' },
  { q: 'What does an AC contractor in Wesley Chapel do?', a: 'We diagnose and repair air conditioning systems, install new high-efficiency equipment, clean air ducts, maintain existing systems, and service commercial refrigeration — all from one licensed local team headquartered on Foamflower Blvd.' },
  { q: 'Do you offer refrigeration repair for businesses?', a: 'Yes. We service walk-in coolers, reach-in freezers, and light-commercial refrigeration for restaurants and small businesses across Wesley Chapel and the greater Tampa Bay area.' },
];
---
<BaseLayout
  title="Wesley Chapel HVAC Contractor | AC Repair & Installation | I Care Air Care"
  description="Wesley Chapel's 5-star HVAC contractor. 4.9★ · 700+ Google reviews · 16+ years. Serving Wesley Chapel, New Tampa, Land O' Lakes, Lutz & all Tampa Bay. Call (813) 395-2324."
>
  <link rel="preload" as="image" href="/images/ICAC%20Team%281%29.webp" slot="head" />
  <Hero
    variant="home"
    showForm={true}
    eyebrow="16+ Years of Service"
    title={`Wesley Chapel's Most-Reviewed<br/>HVAC Contractor`}
    subtitle={`Trusted local <span class="text-accent-400 font-semibold">AC repair</span> experts serving <span class="text-accent-400 font-semibold">Wesley Chapel</span>, New Tampa, Land O' Lakes &amp; all of Tampa Bay for 16+ years with fast, reliable <span class="text-accent-400 font-semibold">HVAC service</span> plus heating, cooling &amp; <span class="text-accent-400 font-semibold">air duct cleaning</span>.`}
    image="/images/ICAC%20Team%281%29.webp"
  />

  <!-- Local team + vans band (crisp, natural aspect, no upscaling) -->
  <section class="relative bg-white">
    <div class="container-site py-12 md:py-16 grid lg:grid-cols-12 gap-10 items-center">
      <div class="lg:col-span-7">
        <div class="relative rounded-2xl overflow-hidden ring-1 ring-slate-200 shadow-[var(--shadow-card)] bg-slate-100 aspect-[1024/604] max-w-[1024px]">
          <img
            src="/images/I-Care-Air-Care-HVAC-Installation-%E2%80%93-Local-Team-and-Service-AC.webp"
            alt="I Care Air Care local Wesley Chapel team with service vehicles"
            class="w-full h-full object-cover"
            width="1024"
            height="604"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
      <div class="lg:col-span-5">
        <span class="inline-flex items-center rounded-full bg-brand-50 text-brand-700 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em]">Your local team</span>
        <h2 class="mt-3 text-3xl md:text-4xl title-accent">Wesley Chapel neighbors, dispatching from Foamflower Blvd.</h2>
        <p class="mt-4 text-slate-600 leading-relaxed">Every truck you see in a Wesley Chapel driveway is our crew driving minutes from home. Owner Tim Hawk and a local team of trained HVAC technicians bring personal attention to repair, maintenance, and replacement calls. <strong>4.9★ · 700+</strong> Google reviews, Florida license <strong>CAC1822037</strong>, 16+ years serving Pasco, Hillsborough &amp; Polk counties.</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/about-us/" class="btn-primary">Meet the team</a>
          <a href="tel:+18133952324" class="btn-outline" style="color:var(--color-navy-700);border-color:var(--color-navy-300);">(813) 395-2324</a>
        </div>
      </div>
    </div>
  </section>

  <BrandBand />
  <ServiceGrid />
  <IntroBand />
  <AreaGrid />
  <WhyChooseUs />
  <ReviewStrip />
  <ThreeStep />
  <FinalCTA />
  <BlogStrip />
  <FAQ title="Frequently Asked Questions" items={faqs.slice(0, 5)} columns={1} variant="white" />
  <ContactFormSection />

  <Schema type="FAQPage" faqs={faqs.map(f => ({ q: f.q, a: f.a.replace(/<[^>]*>/g,'') }))} />
</BaseLayout>
