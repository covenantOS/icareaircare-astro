---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import ReviewStrip from '../components/ReviewStrip.astro';
import FinalCTA from '../components/FinalCTA.astro';
import ContactFormSection from '../components/ContactFormSection.astro';
import { SITE } from '../lib/site';

const team = [
  {
    name: 'Tim Hawk',
    title: 'Owner & Master HVAC Technician',
    img: '/images/Tim%20Hawk%20(ICAC%20Owner).webp',
    imgClass: 'object-contain object-top',
    bio: 'Tim founded I Care Air Care in 2010 after more than three decades in the Tampa Bay HVAC trade. Florida-licensed master contractor (CAC1816515), EPA Universal certified, and the voice most Wesley Chapel homeowners hear when they call (813) 395-2324.',
    creds: ['Florida HVAC License CAC1816515', 'EPA Section 608 Universal', '30+ years in the trade'],
  },
  {
    name: 'The Install Crew',
    title: 'HVAC Installation Team',
    img: '/images/I-Care-Air-Care-HVAC-Installation-%E2%80%93-Local-Team-and-Service-AC.webp',
    imgClass: 'object-cover',
    bio: 'The installation team handles replacements, changeouts, ductwork checks, thermostat setup, warranty registration, and county permit coordination across Pasco, Hillsborough, and Polk.',
    creds: ['Manual-J load calculations', 'County permit coordination', 'Warranty registration', 'System commissioning'],
  },
  {
    name: 'The Service Team',
    title: 'Repair & Maintenance Technicians',
    img: '/images/ICAC%20Team%283%29.webp',
    imgClass: 'object-cover',
    bio: 'Uniformed repair and maintenance technicians who show up in marked white-and-blue trucks for diagnostics, tune-ups, drain clearing, capacitor replacements, blower repairs, and heat pump service.',
    creds: ['EPA 608 certified', 'Marked service trucks', 'Repair diagnostics', 'Maintenance plans'],
  },
  {
    name: 'Office & Dispatch',
    title: 'Customer Experience',
    img: '/images/ICAC%20Team%284%29.webp',
    imgClass: 'object-cover',
    bio: "The voices behind the phone. They confirm your appointment, text you the technician's name and photo before arrival, and follow up after the visit so nothing falls through the cracks.",
    creds: ['Appointment confirmations', 'Technician updates', 'Same-day scheduling when available', 'Follow-up support'],
  },
];

const milestones = [
  { year: '2010', title: 'Founded in Wesley Chapel', body: 'Tim parks the first van at Foamflower Blvd. with a simple pledge — no commission-driven upsells, ever.' },
  { year: '2014', title: '100th five-star review', body: 'Service area grows from Wesley Chapel to all of Pasco County. First full-time install crew joins.' },
  { year: '2018', title: 'Hillsborough + Polk expansion', body: 'Licensed and insured service expands across Pasco, Hillsborough, and Polk counties.' },
  { year: '2022', title: '500+ reviews · 4.9★ sustained', body: 'Named one of the top-reviewed HVAC companies in the Tampa Bay region.' },
  { year: '2025', title: 'Low-GWP refrigerant era', body: 'Install processes are updated for the newer R-454B and R-32 equipment now entering Florida homes.' },
  { year: '2026', title: 'Still family-run', body: 'Same owner, same Wesley Chapel address, same promise. Growing only as fast as we can keep the service personal.' },
];

const values = [
  { icon: 'honesty', title: 'Honesty beats upselling', body: "We'll tell you when a $20 capacitor is all you need — even when a full replacement would pay our mortgage that month." },
  { icon: 'quote', title: 'Flat-rate, written quotes', body: 'You see the number before work starts. Always. No diagnostic-fee bait and switch.' },
  { icon: 'shield', title: 'Licensed and trained', body: "Florida CAC1816515. We send technicians we would be comfortable sending to our own family's home." },
  { icon: 'warranty', title: 'Warranty-backed work', body: "1-year parts-and-labor warranty on every repair — stacked on top of the manufacturer's coverage." },
  { icon: 'phone', title: 'Clear communication', body: 'Call (813) 395-2324 and our local team will help you choose the next step, whether that is scheduling, troubleshooting, or a written estimate.' },
  { icon: 'heart', title: 'Built for our neighbors', body: "Based at 27022 Foamflower Blvd. Wesley Chapel is home — you're not a ticket number, you're down the street." },
];

const icon = (k: string) => ({
  honesty:  '<path d="M12 2L4 6v6c0 5 3.4 9.6 8 10 4.6-.4 8-5 8-10V6l-8-4zm-1 14l-4-4 1.4-1.4L11 13.2l5.6-5.6L18 9l-7 7z"/>',
  quote:    '<path d="M3 5h18v14H3z" fill="none"/><path d="M4 6h16v12H4zM6 9h12v1.5H6zM6 12h12v1.5H6zM6 15h8v1.5H6z"/>',
  shield:   '<path d="M12 2l8 3v6c0 5-3.4 9.6-8 11-4.6-1.4-8-6-8-11V5l8-3z"/>',
  warranty: '<path d="M12 2l2.4 4.8L20 8l-4 3.9.9 5.5L12 14.8 7.1 17.4 8 11.9 4 8l5.6-1.2z"/>',
  phone:    '<path d="M6.6 10.8a15 15 0 006.6 6.6l2.2-2.2a1 1 0 011.1-.2 11 11 0 003.6.6 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11 11 0 00.6 3.6 1 1 0 01-.2 1.1l-2.3 2.1z"/>',
  heart:    '<path d="M12 21s-7-4.3-9.2-9.2C1.1 8.2 3.2 5 6.5 5c1.8 0 3.5.9 4.5 2.3C12 5.9 13.7 5 15.5 5 18.8 5 20.9 8.2 19.2 11.8 17 16.7 12 21 12 21z"/>',
}[k] || '');
---
<BaseLayout
  title="About I Care Air Care | Wesley Chapel HVAC"
  description="Meet the licensed, family-run team behind I Care Air Care in Wesley Chapel. 16+ years, 700+ five-star reviews, Florida CAC1816515."
  breadcrumbs={[{name:'Home',url:'https://www.icareaircare.com/'},{name:'About Us',url:'https://www.icareaircare.com/about-us/'}]}
>
  <Hero
    eyebrow="Our Story · Our Team"
    title="Family-run HVAC, built on Foamflower Blvd."
    subtitle={`Sixteen years, 700+ five-star reviews, and a single promise: treat every Wesley Chapel neighbor the way we'd want our own family treated.`}
    image="/images/ICAC%20Team.webp"
    imageAlt="I Care Air Care family team and service vans in Wesley Chapel, FL"
    ctaLabel="Meet The Team"
    ctaHref="#team"
  />

  <!-- Intro band -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container-site grid lg:grid-cols-12 gap-10 items-start">
      <div class="lg:col-span-7 prose-icac">
        <span class="inline-flex items-center rounded-full bg-brand-50 text-brand-700 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em]">Our Story</span>
        <h2 class="mt-3">Why we started I Care Air Care</h2>
        <p>Tim Hawk had been turning wrenches on Tampa Bay HVAC systems for more than three decades before he opened I Care Air Care in <strong>2010</strong>. The last straw was watching one too many big-brand contractors push commission-driven sales on elderly homeowners who just needed a $40 capacitor. He walked out, parked his own truck in a Wesley Chapel driveway, and wrote down a single pledge: <strong>treat every customer the way you'd want your own family treated.</strong></p>
        <p>Sixteen years later, that pledge still runs the company. We've grown from one truck in a Wesley Chapel garage to a fully licensed (Florida <strong>CAC1816515</strong>), bonded and insured HVAC contractor with <strong>hundreds of five-star Google reviews</strong> and a service radius that covers Pasco, Hillsborough and Polk counties — but we've kept the family feel, the Foamflower Blvd. headquarters, and the local phone line.</p>
        <p>We're not trying to be the biggest HVAC company in Tampa Bay. We're trying to be the one your neighbors actually recommend — by name, at the mailbox, unprompted.</p>
      </div>
      <aside class="lg:col-span-5">
        <div class="rounded-2xl bg-gradient-to-br from-brand-600 to-brand-800 text-white p-6 md:p-7 shadow-[var(--shadow-soft)]">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-full bg-white/15 ring-1 ring-white/30 flex items-center justify-center">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" class="text-accent-400"><path d="M12 2l2.4 7.4H22l-6 4.4 2.3 7.4L12 16.9l-6.3 4.3L8 13.8 2 9.4h7.6z"/></svg>
            </div>
            <div>
              <div class="text-[11px] uppercase tracking-[0.16em] text-blue-100">Verified on Google</div>
              <div class="text-xl font-bold">4.9 / 5 · {SITE.rating.count}+ reviews</div>
            </div>
          </div>
          <dl class="mt-6 grid grid-cols-2 gap-4 text-sm">
            <div><dt class="text-blue-100 uppercase tracking-wider text-[11px]">Years in business</dt><dd class="text-2xl font-bold mt-1">16+</dd></div>
            <div><dt class="text-blue-100 uppercase tracking-wider text-[11px]">FL license</dt><dd class="text-base font-bold mt-1">CAC1816515</dd></div>
            <div><dt class="text-blue-100 uppercase tracking-wider text-[11px]">Counties served</dt><dd class="text-2xl font-bold mt-1">3</dd></div>
            <div><dt class="text-blue-100 uppercase tracking-wider text-[11px]">Repair warranty</dt><dd class="text-base font-bold mt-1">1 year parts + labor</dd></div>
          </dl>
          <div class="mt-6 pt-6 border-t border-white/20 flex items-center gap-3">
            <img src="/images/Tim%20Hawk%20(ICAC%20Owner).webp" alt="Tim Hawk, Owner of I Care Air Care" class="w-14 h-14 rounded-full ring-2 ring-white/40 object-cover" width="56" height="56" loading="lazy" />
            <div>
              <div class="font-bold">Tim Hawk — Owner</div>
              <div class="text-blue-100 text-sm">"When you call, you're calling my local team."</div>
            </div>
          </div>
        </div>
        <div class="mt-4 rounded-xl bg-surface ring-1 ring-slate-200 p-5 text-sm">
          <div class="flex items-start gap-3">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-brand-700 mt-0.5 shrink-0"><path d="M12 2a7 7 0 00-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 00-7-7zm0 10a3 3 0 110-6 3 3 0 010 6z"/></svg>
            <div>
              <div class="font-bold text-navy-700">Headquartered in Wesley Chapel</div>
              <div class="text-slate-600 mt-1">27022 Foamflower Blvd, Wesley Chapel, FL 33544</div>
              <a href="https://maps.app.goo.gl/2iCjuu1yf3GAbvSS8" target="_blank" rel="noopener" class="mt-2 inline-flex items-center gap-1 text-brand-700 font-semibold">Get directions →</a>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <!-- Values -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="container-site">
      <div class="max-w-3xl">
        <span class="inline-flex items-center rounded-full bg-white text-brand-700 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em] ring-1 ring-slate-200">What we believe</span>
        <h2 class="mt-3 text-3xl md:text-4xl">The six promises every technician makes</h2>
        <p class="mt-3 text-slate-600 text-[17px]">The promises that keep every service call grounded and accountable.</p>
      </div>
      <div class="mt-10 grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {values.map(v => (
          <div class="rounded-2xl bg-white ring-1 ring-slate-200 p-6 shadow-[var(--shadow-card)] hover:shadow-[var(--shadow-soft)] transition">
            <div class="w-12 h-12 rounded-xl bg-brand-50 text-brand-700 flex items-center justify-center">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" set:html={icon(v.icon)} />
            </div>
            <h3 class="mt-4 text-lg font-bold text-navy-700">{v.title}</h3>
            <p class="mt-2 text-slate-600 text-[15px] leading-relaxed">{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container-site">
      <div class="max-w-3xl">
        <span class="inline-flex items-center rounded-full bg-accent-50 text-accent-600 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em]">Our journey</span>
        <h2 class="mt-3 text-3xl md:text-4xl">From one Wesley Chapel driveway to three counties</h2>
        <p class="mt-3 text-slate-600 text-[17px]">Sixteen years. Same owner. Same address. Same pledge.</p>
      </div>
      <div class="mt-12 relative">
        <div class="absolute left-4 md:left-1/2 md:-translate-x-1/2 top-0 bottom-0 w-0.5 bg-gradient-to-b from-brand-500 via-brand-400 to-accent-400"></div>
        <ol class="space-y-10">
          {milestones.map((m, i) => (
            <li class={`relative md:grid md:grid-cols-2 md:gap-10 ${i % 2 === 0 ? '' : 'md:[&>div:first-child]:order-2'}`}>
              <div class="pl-12 md:pl-0 md:pr-10 md:text-right">
                <div class="hidden md:inline-flex absolute left-1/2 -translate-x-1/2 w-10 h-10 rounded-full bg-white ring-4 ring-brand-500 text-brand-700 font-bold items-center justify-center text-xs">{m.year.slice(-2)}</div>
                <div class="md:hidden absolute left-0 top-1 w-9 h-9 rounded-full bg-white ring-4 ring-brand-500 text-brand-700 font-bold flex items-center justify-center text-xs">{m.year.slice(-2)}</div>
                <div class="text-brand-700 font-bold tracking-wider text-sm">{m.year}</div>
                <h3 class="mt-1 text-xl font-bold text-navy-700">{m.title}</h3>
                <p class="mt-2 text-slate-600 text-[15px] leading-relaxed">{m.body}</p>
              </div>
              <div></div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- Team section -->
  <section id="team" class="py-16 md:py-20 bg-gradient-to-b from-surface to-white scroll-mt-24">
    <div class="container-site">
      <div class="max-w-3xl">
        <span class="inline-flex items-center rounded-full bg-brand-50 text-brand-700 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em]">Our Team</span>
        <h2 class="mt-3 text-3xl md:text-4xl">The people behind your service call</h2>
        <p class="mt-3 text-slate-600 text-[17px]">Licensed. Uniformed. Friendly. Every technician on our team is someone we'd want helping our own family.</p>
      </div>
      <div class="mt-12 grid md:grid-cols-2 gap-6 lg:gap-8">
        {team.map(m => (
          <div class="group rounded-2xl bg-white ring-1 ring-slate-200 shadow-[var(--shadow-card)] overflow-hidden hover:shadow-[var(--shadow-soft)] transition">
            <div class="relative aspect-[5/3] overflow-hidden bg-slate-100">
              <img src={m.img} alt={`${m.name} — ${m.title} at I Care Air Care`} class={`w-full h-full ${m.imgClass || 'object-cover'} group-hover:scale-[1.02] transition duration-500`} width="800" height="480" loading="lazy" decoding="async" />
              <div class="absolute inset-0 bg-gradient-to-t from-navy-900/70 via-navy-900/10 to-transparent"></div>
              <div class="absolute bottom-4 left-5 right-5 text-white">
                <div class="text-[11px] uppercase tracking-[0.14em] text-accent-300">{m.title}</div>
                <div class="text-2xl font-bold mt-0.5">{m.name}</div>
              </div>
            </div>
            <div class="p-6">
              <p class="text-slate-600 leading-relaxed text-[15px]">{m.bio}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {m.creds.map(c => (
                  <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-50 text-brand-700 px-3 py-1 text-xs font-semibold">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg>
                    {c}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Credentials strip -->
      <div class="mt-12 rounded-2xl bg-navy-700 text-white p-6 md:p-8 shadow-[var(--shadow-soft)]">
        <div class="grid md:grid-cols-4 gap-6 items-center">
          <div class="md:col-span-1">
            <div class="text-[11px] uppercase tracking-[0.14em] text-blue-200">Credentials</div>
            <h3 class="mt-1 text-white text-xl font-bold">Credentialed for Florida homes and light commercial work</h3>
          </div>
          <ul class="md:col-span-3 grid sm:grid-cols-2 gap-x-6 gap-y-2 text-sm">
            <li class="flex items-center gap-2"><span class="text-accent-400">✓</span> <a href={SITE.licenseVerificationUrl} target="_blank" rel="noopener" class="text-white hover:text-accent-300 underline-offset-2 hover:underline">Florida HVAC License CAC1816515 <span class="text-accent-300 text-xs">(verify on FL DBPR ↗)</span></a></li>
            <li class="flex items-center gap-2"><span class="text-accent-400">✓</span> Fully bonded and insured</li>
            <li class="flex items-center gap-2"><span class="text-accent-400">✓</span> EPA 608 Universal certified</li>
            <li class="flex items-center gap-2"><span class="text-accent-400">✓</span> Current low-GWP refrigerant installation practices</li>
            <li class="flex items-center gap-2"><span class="text-accent-400">✓</span> Major residential HVAC brands serviced</li>
            <li class="flex items-center gap-2"><span class="text-accent-400">✓</span> Heat pump, straight-cool, and mini-split support</li>
            <li class="flex items-center gap-2"><span class="text-accent-400">✓</span> Pasco / Hillsborough / Polk county permits</li>
            <li class="flex items-center gap-2"><span class="text-accent-400">✓</span> Marked trucks and uniformed field staff</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Verified third-party profiles. The same URLs surface as schema.org sameAs
       in <head>, but rendering them visibly does two things: gives Wesley Chapel
       homeowners a one-click path to verify Tim's company across every platform
       they actually check, and reinforces the schema with a real visible link
       signal Google reads as additional corroboration. -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="container-site">
      <div class="max-w-3xl">
        <span class="inline-flex items-center rounded-full bg-white text-brand-800 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em] ring-1 ring-slate-200">Verified across the platforms you check</span>
        <h2 class="mt-3 text-3xl md:text-4xl">Don't take our word for it — verify us anywhere</h2>
        <p class="mt-3 text-slate-600 text-[17px]">Click any badge to read reviews, confirm the license, or check Tim's professional history directly with the source. Every link is a real third-party profile, not a marketing claim.</p>
      </div>
      <div class="mt-10 grid grid-cols-2 md:grid-cols-3 gap-4">
        <a href="https://maps.app.goo.gl/2iCjuu1yf3GAbvSS8" target="_blank" rel="noopener" class="group rounded-2xl bg-white ring-1 ring-slate-200 hover:ring-brand-400 hover:shadow-[var(--shadow-card)] p-5 transition flex items-center gap-4">
          <span class="shrink-0 w-12 h-12 rounded-xl bg-white ring-1 ring-slate-100 flex items-center justify-center">
            <svg width="28" height="28" viewBox="0 0 48 48" aria-hidden="true">
              <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
              <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
              <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
              <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
            </svg>
          </span>
          <div class="min-w-0">
            <div class="text-[11px] uppercase tracking-[0.14em] text-slate-500">Google Business</div>
            <div class="font-bold text-navy-700 group-hover:text-brand-700 truncate">{SITE.rating.value}★ · {SITE.rating.count}+ reviews</div>
            <div class="text-[12px] text-accent-600 font-semibold mt-0.5">Read on Google →</div>
          </div>
        </a>

        <a href={SITE.licenseVerificationUrl} target="_blank" rel="noopener" class="group rounded-2xl bg-white ring-1 ring-slate-200 hover:ring-brand-400 hover:shadow-[var(--shadow-card)] p-5 transition flex items-center gap-4">
          <span class="shrink-0 w-12 h-12 rounded-xl bg-brand-50 text-brand-700 flex items-center justify-center">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l8 3v6c0 5-3.4 9.6-8 11-4.6-1.4-8-6-8-11V5l8-3zm-1 13l5-5-1.4-1.4L11 12.2l-2.6-2.6L7 11l4 4z"/></svg>
          </span>
          <div class="min-w-0">
            <div class="text-[11px] uppercase tracking-[0.14em] text-slate-500">Florida DBPR</div>
            <div class="font-bold text-navy-700 group-hover:text-brand-700 truncate">License {SITE.license}</div>
            <div class="text-[12px] text-accent-600 font-semibold mt-0.5">Verify on DBPR →</div>
          </div>
        </a>

        <a href="https://www.bbb.org/us/fl/wesley-chapel/profile/air-conditioning-contractor/i-care-air-care-llc-0653-90109276" target="_blank" rel="noopener" class="group rounded-2xl bg-white ring-1 ring-slate-200 hover:ring-brand-400 hover:shadow-[var(--shadow-card)] p-5 transition flex items-center gap-4">
          <span class="shrink-0 w-12 h-12 rounded-xl bg-[#005a87] text-white flex items-center justify-center font-bold text-lg tracking-tight" aria-hidden="true">BBB</span>
          <div class="min-w-0">
            <div class="text-[11px] uppercase tracking-[0.14em] text-slate-500">Better Business Bureau</div>
            <div class="font-bold text-navy-700 group-hover:text-brand-700 truncate">Wesley Chapel profile</div>
            <div class="text-[12px] text-accent-600 font-semibold mt-0.5">View BBB profile →</div>
          </div>
        </a>

        <a href="https://icareaircare.rheempropartner.com/" target="_blank" rel="noopener" class="group rounded-2xl bg-white ring-1 ring-slate-200 hover:ring-brand-400 hover:shadow-[var(--shadow-card)] p-5 transition flex items-center gap-4">
          <span class="shrink-0 w-12 h-12 rounded-xl bg-[#cf112d] text-white flex items-center justify-center font-bold text-[13px] tracking-tight" aria-hidden="true">RHEEM</span>
          <div class="min-w-0">
            <div class="text-[11px] uppercase tracking-[0.14em] text-slate-500">Manufacturer partner</div>
            <div class="font-bold text-navy-700 group-hover:text-brand-700 truncate">Rheem Pro Partner</div>
            <div class="text-[12px] text-accent-600 font-semibold mt-0.5">View partner page →</div>
          </div>
        </a>

